@model IEnumerable<ContratosYReembolsos.Models.Branch>

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark">Convenios con Agencias</h2>
        <p class="text-muted">Seleccione la filial para administrar los contratos con funerarias externas</p>
    </div>

    <div class="row g-4 justify-content-center">
        @foreach (var branch in Model)
        {
            <div class="col-md-4">
                <a href="@Url.Action("Index", new { selectedBranchId = branch.Id })"
                   class="card border-0 shadow-sm rounded-4 h-100 text-decoration-none hover-card p-4 text-center">
                    <div class="icon-box bg-success-subtle text-success rounded-circle mx-auto mb-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-handshake fa-2x"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">@branch.Name</h5>
                    <span class="badge bg-light text-success border rounded-pill">
                        @(branch.Agencies?.Count ?? 0) Convenios
                    </span>
                </a>
            </div>
        }
    </div>
</div>