@using Microsoft.AspNetCore.Identity
@inject UserManager<ContratosYReembolsos.Models.ApplicationUser> UserManager

@{
    string currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";

    // Obtenemos los datos del usuario logueado
    var user = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName ?? "Usuario";
    var roles = await UserManager.GetRolesAsync(user!);
    var roleDisplay = roles.FirstOrDefault() ?? "Sin Rol";
}

<aside class="sidebar" id="mainSidebar">
    <div class="sidebar-header mb-4">
        <div class="logo-box">
            <i class="fa-solid fa-shield-halved text-primary"></i>
        </div>
        <div class="sidebar-text ms-2">
            <h6 class="fw-bold mb-0">FONAFUN</h6>
            <small class="text-muted" style="font-size: 10px;">Gestión de Servicios</small>
        </div>
    </div>

    <nav class="nav flex-column flex-grow-1">
        <a href="@Url.Action("Index", "Home")"
           class="nav-link @(currentController == "Home" ? "active" : "")">
            <i class="fa-solid fa-house-chimney"></i>
            <span class="sidebar-text ms-2">Dashboard</span>
        </a>

        <a href="@Url.Action("Index", "Contract")"
           class="nav-link @(currentController == "Contract" ? "active" : "")">
            <i class="fa-solid fa-file-contract"></i>
            <span class="sidebar-text ms-2">Contratos</span>
        </a>

        <a href="@Url.Action("Index", "Coffin")"
           class="nav-link @(currentController == "Coffin" ? "active" : "")">
            <i class="fa-solid fa-box"></i>
            <span class="sidebar-text ms-2">Ataúdes</span>
        </a>

        <a href="@Url.Action("Index", "Transport")"
           class="nav-link @(currentController == "Transport" ? "active" : "")">
            <i class="fa-solid fa-car-side"></i>
            <span class="sidebar-text ms-2">Movilidad</span>
        </a>

        <div class="nav-item">
            <a href="@Url.Action("Index", "Cemetery")"
               class="nav-link @(currentController == "Cemetery" && currentAction != "Templates" ? "active" : "")">
                <i class="fa-solid fa-monument"></i>
                <span class="sidebar-text ms-2">Sepulturas</span>
            </a>

            <div class="ps-3 mt-1">
                <a href="@Url.Action("Templates", "Cemetery")"
                   class="nav-link py-1 @(currentAction == "Templates" ? "active text-primary fw-bold" : "text-muted")"
                   style="font-size: 12px; background: transparent !important; box-shadow: none !important;">
                    <i class="fa-solid fa-gears me-2" style="font-size: 10px;"></i>
                    <span class="sidebar-text">Modelos Técnicos</span>
                </a>
            </div>
        </div>

        <a href="@Url.Action("Index", "Branch")"
           class="nav-link @(currentController == "Branch" ? "active" : "")">
            <i class="fa-solid fa-building-user"></i>
            <span class="sidebar-text ms-2">Filiales</span>
        </a>
    </nav>

    @* --- SECCIÓN DE PERFIL REAL --- *@
    <div class="user-profile border-top pt-3 mt-auto">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <div class="avatar bg-light text-primary rounded-circle me-2"
                     style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-user-tie"></i>
                </div>
                <div class="sidebar-text">
                    <p class="mb-0 fw-bold small">@fullName</p>
                    <small class="text-muted" style="font-size: 10px;">@roleDisplay</small>
                </div>
            </div>

            @* Logout con Formulario por seguridad *@
            <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                <button type="submit" class="btn btn-link text-muted p-0 sidebar-text" title="Cerrar Sesión">
                    <i class="fa-solid fa-right-from-bracket"></i>
                </button>
            </form>
        </div>
    </div>
</aside>