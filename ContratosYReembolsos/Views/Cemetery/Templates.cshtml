@using ContratosYReembolsos.Models.Entities.Cemeteries
@using Microsoft.AspNetCore.Authorization
@model IEnumerable<IntermentStructureTemplate>
@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Modelos Técnicos";
    var canCreate = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Modelos.Crear")).Succeeded;
    var canEdit = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Modelos.Editar")).Succeeded;
    var canDelete = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Modelos.Eliminar")).Succeeded;
}

@Html.AntiForgeryToken()
<div class="container-fluid py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0 text-dark">Modelos de Estructura</h4>
            <p class="text-muted small mb-0">Parámetros técnicos para la construcción automatizada de nichos y columbarios.</p>
        </div>
        @if (canCreate)
        {
            <button class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" onclick="openTemplateModal(0)">
                <i class="fa-solid fa-plus-circle me-2"></i> Nuevo Modelo Técnico
            </button>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-muted small text-uppercase fw-bold">
                        <th class="ps-4 py-3">Nombre del Modelo</th>
                        <th class="text-center">Tipo</th>
                        <th class="text-center">Dimensiones (F x P)</th>
                        <th class="text-center">Columnas</th>
                        <th class="text-center">Precio Base</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.Name</div>
                                <small class="text-muted x-small">ID: #@item.Id</small>
                            </td>
                            <td class="text-center">
                                <span class="badge @(item.Type == "PABELLON" ? "bg-primary-subtle text-primary" : "bg-info-subtle text-info") rounded-pill px-3">
                                    @item.Type
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <span class="badge bg-light text-dark border fw-normal">@item.RowsCount Filas</span>
                                    <span class="badge bg-light text-dark border fw-normal">@item.TotalFloors Pisos</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="fw-bold">@(item.IsDoubleFace ? item.ColsPerFace * 2 : item.ColsPerFace)</span>
                                <small class="text-muted">@(item.IsDoubleFace ? "(Doble Cara)" : "(Simple)")</small>
                            </td>
                            <td class="text-center fw-bold text-success">
                                S/ @item.DefaultPrice.ToString("N2")
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    @if (canEdit)
                                    {
                                        <button class="btn btn-sm btn-outline-primary rounded-circle me-1" onclick="openTemplateModal(@item.Id)">
                                            <i class="fa-solid fa-pen"></i>
                                        </button>
                                    }
                                    @if (canDelete)
                                    {
                                        <button class="btn btn-sm btn-outline-danger rounded-circle" onclick="confirmDeleteTemplate(@item.Id)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        const urlGetTemplateForm = '@Url.Action("GetTemplateForm", "Cemetery")';

        async function openTemplateModal(id) {
            try {
                const response = await fetch(`${urlGetTemplateForm}?id=${id}`);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;
                new bootstrap.Modal(container.querySelector('.modal')).show();
            } catch (e) {
                Swal.fire('Error', 'No se pudo cargar el formulario.', 'error');
            }
        }

        async function submitTemplateForm(formId, modalId) {
            const form = document.getElementById(formId);
            const formData = new FormData(form);
            try {
                const response = await fetch(form.action, { method: 'POST', body: formData });
                const result = await response.json();
                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById(modalId)).hide();
                    Swal.fire('Éxito', result.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Atención', result.message, 'warning');
                }
            } catch (e) {
                Swal.fire('Error', 'Error en el servidor.', 'error');
            }
        }

                // Reemplaza la función confirmDeleteTemplate en tu bloque de scripts
        async function confirmDeleteTemplate(id) {
            const result = await Swal.fire({
                title: '¿Está seguro?',
                text: "Esta acción eliminará el modelo técnico permanentemente.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true
            });

            if (result.isConfirmed) {
                // Mostrar cargando
                Swal.fire({
                    title: 'Eliminando...',
                    didOpen: () => { Swal.showLoading() },
                    allowOutsideClick: false
                });

                try {
                    const response = await fetch(`@Url.Action("DeleteTemplate", "Cemetery")?id=${id}`, {
                        method: 'POST',
                        headers: {
                            // Si usas AntiForgeryToken global, añádelo aquí
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        }
                    });

                    const res = await response.json();

                    if (res.success) {
                        Swal.fire('¡Eliminado!', res.message, 'success').then(() => location.reload());
                    } else {
                        Swal.fire('Atención', res.message, 'error');
                    }
                } catch (error) {
                    Swal.fire('Error', 'No se pudo procesar la eliminación en el servidor.', 'error');
                }
            }
        }
    </script>
}