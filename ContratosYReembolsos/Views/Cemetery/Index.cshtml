@using ContratosYReembolsos.Models.Entities.Cemeteries
@using Microsoft.AspNetCore.Authorization
@model IEnumerable<Cemetery>
@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Sedes de Cementerios";
    var canViewStructures = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Estructuras.Ver")).Succeeded;

    // Separación de la lógica de negocio directamente en la vista
    var internalCemeteries = Model.Where(c => c.IsInternal).OrderBy(c => c.Name);
    var externalCemeteries = Model.Where(c => !c.IsInternal).OrderBy(c => c.Name);
}

<div class="container-fluid py-4 animate__animated animate__fadeIn">
    @* --- 1. NAVEGACIÓN PARA ADMIN --- *@
    @if (ViewBag.IsAdmin == true)
    {
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb bg-white p-2 rounded-3 shadow-sm border px-3">
                <li class="breadcrumb-item">
                    <a asp-action="Index" asp-route-selectedBranchId="" class="text-decoration-none">
                        <i class="fa-solid fa-map me-1 text-muted"></i>Filiales
                    </a>
                </li>
                <li class="breadcrumb-item active fw-bold text-primary">@ViewBag.BranchName</li>
            </ol>
        </nav>
    }

    @* --- 2. ENCABEZADO --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0 text-dark">
                <i class="fa-solid fa-church me-2 text-primary"></i>
                Sedes en @(ViewBag.BranchName ?? "Mi Filial")
            </h4>
            <p class="text-muted small mb-0">Gestión de inventario propio y convenios externos.</p>
        </div>

        @if ((await AuthorizationService.AuthorizeAsync(User, "Permissions.Cementerios.Crear")).Succeeded)
        {
            <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm"
                    onclick="openCreateCemeteryModal()">
                <i class="fa-solid fa-plus me-2"></i>Nueva Sede
            </button>
        }
    </div>

    @* --- 3. TABLA: SEDES PROPIAS (GESTIONABLES) --- *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
        <div class="card-header bg-white py-3 border-0">
            <h6 class="fw-bold text-primary mb-0">
                <i class="fa-solid fa-building-shield me-2"></i>Sedes Propias (Internas)
            </h6>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Nombre de la Sede</th>
                        <th>RUC</th>
                        <th>Contacto</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Estructuras</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!internalCemeteries.Any())
                    {
                        <tr><td colspan="6" class="text-center py-4 text-muted">No hay sedes internas registradas.</td></tr>
                    }
                    @foreach (var cem in internalCemeteries)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@cem.Name</div>
                                <small class="text-muted">@cem.Address</small>
                            </td>
                            <td><span class="badge bg-light text-dark border">@cem.RUC</span></td>
                            <td><small>@cem.Phone</small></td>
                            <td class="text-center">
                                @if (cem.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted rounded-pill px-3">Inactivo</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="fw-bold text-primary">@(cem.Structures?.Count ?? 0)</div>
                            </td>
                            <td class="text-end pe-4">
                                @if (canViewStructures)
                                {
                                    <a href="@Url.Action("SelectionMenu", new { id = cem.Id })"
                                       class="btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm">
                                        Gestionar <i class="fa-solid fa-chevron-right ms-1"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* --- 4. TABLA: SEDES EXTERNAS (CONVENIOS) --- *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden border-start border-info border-4">
        <div class="card-header bg-white py-3 border-0">
            <h6 class="fw-bold text-info mb-0">
                <i class="fa-solid fa-handshake me-2"></i>Sedes Externas (Terceros)
            </h6>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Nombre de la Sede</th>
                        <th>RUC</th>
                        <th>Contacto</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end pe-4">Info</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!externalCemeteries.Any())
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">No hay sedes externas registradas.</td></tr>
                    }
                    @foreach (var cem in externalCemeteries)
                    {
                        <tr class="opacity-75">
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@cem.Name</div>
                                <small class="text-muted text-truncate d-block" style="max-width: 250px;">@cem.Address</small>
                            </td>
                            <td><span class="badge bg-light text-dark border">@cem.RUC</span></td>
                            <td><small>@cem.Phone</small></td>
                            <td class="text-center">
                                @if (cem.IsActive)
                                {
                                    <span class="badge bg-info-subtle text-info rounded-pill px-3">En Convenio</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted rounded-pill px-3">Finalizado</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <span class="badge bg-light text-muted rounded-pill py-2">Solo lectura</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="modalCemeteryContainer"></div>

@section Scripts {
    <script>
        const currentBranchId = @(ViewBag.SelectedBranchId ?? 0);
        const getCreateCemeteryUrl = '@Url.Action("GetCreateCemetery", "Cemetery")';

        async function openCreateCemeteryModal() {
            try {
                const response = await fetch(`${getCreateCemeteryUrl}?branchId=${currentBranchId}`);
                const html = await response.text();
                document.getElementById('modalCemeteryContainer').innerHTML = html;
                new bootstrap.Modal(document.getElementById('modalCreateCemetery')).show();
            } catch (e) {
                Swal.fire('Error', 'No se pudo cargar el formulario.', 'error');
            }
        }

        async function submitCemeteryForm() {
            const form = document.getElementById('formCreateCemetery');
            if (!form.checkValidity()) { form.reportValidity(); return; }

            const formData = new FormData(form);
            const response = await fetch(form.action, { method: 'POST', body: formData });
            const result = await response.json();

            if (result.success) {
                Swal.fire('Éxito', result.message, 'success').then(() => location.reload());
            } else {
                Swal.fire('Atención', result.message, 'warning');
            }
        }
    </script>
}

<style>
    .table thead th {
        font-weight: 700;
        font-size: 0.75rem;
    }

    .card-header {
        border-bottom: 1px solid rgba(0,0,0,0.05) !important;
    }

    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-2px);
        }
</style>