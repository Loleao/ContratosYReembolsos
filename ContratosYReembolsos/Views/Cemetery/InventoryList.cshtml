@using ContratosYReembolsos.Models.Entities.Cemeteries
@model IEnumerable<IntermentStructure>
@{
    string currentType = ViewBag.CurrentType ?? "PABELLON";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h4 class="fw-bold mb-0">Gestión de @(currentType)</h4>
        </div>
        <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm"
                onclick="openBuildStructureModal(@ViewBag.CemeteryId, '@ViewBag.CurrentType')">
            <i class="fa-solid fa-plus me-2"></i>Nueva Estructura
        </button>
    </div>

    <div class="row g-4">
        <div class="row g-4">
            @foreach (var structure in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 border-start border-4 border-primary">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold text-dark mb-1">@structure.Name</h5>
                                    <span class="badge bg-light text-primary border border-primary-subtle small text-uppercase" style="font-size: 10px;">
                                        <i class="fa-solid fa-location-dot me-1"></i> Sede @structure.CemeteryId
                                    </span>
                                </div>
                                <div class="bg-primary-subtle p-2 rounded-3">
                                    <i class="fa-solid fa-building-columns text-primary"></i>
                                </div>
                            </div>

                            <div class="row g-0 py-3 border-top border-bottom my-3">
                                <div class="col-6 border-end text-center">
                                    <small class="text-muted d-block small text-uppercase">Total</small>
                                    <span class="fw-bold">@structure.Spaces.Count()</span>
                                </div>
                                <div class="col-6 text-center">
                                    <small class="text-muted d-block small text-uppercase">Libres</small>
                                    <span class="fw-bold text-success">@structure.Spaces.Count(s => s.Status == IntermentStatus.Disponible)</span>
                                </div>
                            </div>

                            <div class="mb-4">
                                @{
                                    var ocupados = structure.Spaces.Count(s => s.Status == IntermentStatus.Ocupado);
                                    var total = structure.Spaces.Count();
                                    var porcentaje = total > 0 ? (ocupados * 100) / total : 0;
                                }
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted fw-bold">Ocupación</span>
                                    <span class="fw-bold">@porcentaje%</span>
                                </div>
                                <div class="progress rounded-pill" style="height: 8px; background-color: #e9ecef;">
                                    <div class="progress-bar bg-primary shadow-sm" role="progressbar"
                                         style="width: @porcentaje%" aria-valuenow="@porcentaje"
                                         aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>

                            <a href="@Url.Action("Details", "Cemetery", new { id = structure.Id })"
                               class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm">
                                Gestionar Espacios <i class="fa-solid fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        const urlGetBuildStructure = '@Url.Action("GetBuildStructure", "Cemetery")';

        async function openBuildStructureModal(id, type) {
            try {
                // Enviamos AMBOS parámetros en la URL
                const response = await fetch(`${urlGetBuildStructure}?id=${id}&type=${type}`);

                if (!response.ok) throw new Error("Error en el servidor");

                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;

                const modalElement = container.querySelector('.modal');
                new bootstrap.Modal(modalElement).show();
            } catch (error) {
                console.error(error);
                Swal.fire('Error', 'No se pudo cargar el constructor de estructuras.', 'error');
            }
        }

        async function submitBuildForm(formId, modalId) {
            const form = document.getElementById(formId);
            const formData = new FormData(form);

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();

                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById(modalId)).hide();
                    Swal.fire('¡Construido!', result.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Error en la comunicación con el servidor.', 'error');
            }
        }
    </script>
}