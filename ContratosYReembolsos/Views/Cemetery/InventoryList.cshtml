@using ContratosYReembolsos.Models.Entities.Cemeteries
@using Microsoft.AspNetCore.Authorization
@model IEnumerable<IntermentStructure>
@inject IAuthorizationService AuthorizationService

@{
    string currentType = ViewBag.CurrentType ?? "PABELLON";
    ViewData["Title"] = "Gestión de " + currentType;

    // Evaluamos permisos de seguridad
    var canCreateStructure = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Estructuras.Crear")).Succeeded;
    var canViewSpaces = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Espacios.Ver")).Succeeded;
}

<div class="container-fluid py-4 animate__animated animate__fadeIn">
    @* --- ENCABEZADO --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Cementerios</a></li>
                    <li class="breadcrumb-item"><a asp-action="SelectionMenu" asp-route-id="@ViewBag.CemeteryId" class="text-decoration-none">@ViewBag.CemeteryName</a></li>
                    <li class="breadcrumb-item active text-primary fw-bold">@currentType</li>
                </ol>
            </nav>
            <h4 class="fw-bold mb-0 text-dark">Control de @(currentType)S</h4>
        </div>

        @* Validación de permiso para crear estructuras *@
        @if (canCreateStructure)
        {
            <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm"
                    onclick="openBuildStructureModal(@ViewBag.CemeteryId, '@ViewBag.CurrentType')">
                <i class="fa-solid fa-plus me-2"></i>Nueva Estructura
            </button>
        }
    </div>

    @* --- TABLA DE INVENTARIO --- *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase fw-bold">
                            <th class="ps-4 py-3">Nombre / Identificación</th>
                            <th class="text-center">Capacidad Total</th>
                            <th class="text-center">Disponibles</th>
                            <th class="text-center" style="width: 250px;">Ocupación</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <i class="fa-solid fa-layer-group fa-3x text-muted opacity-25 mb-3"></i>
                                    <p class="text-muted">No se encontraron estructuras registradas.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var structure in Model)
                            {
                                var total = structure.Spaces?.Count() ?? 0;
                                var disponibles = structure.Spaces?.Count(s => s.Status == IntermentStatus.Disponible) ?? 0;
                                var ocupados = total - disponibles;
                                var porcentaje = total > 0 ? (ocupados * 100) / total : 0;

                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3">
                                                <i class="fa-solid fa-building-columns"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@structure.Name</div>
                                                <small class="text-muted small">ID: #@structure.Id</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center fw-bold text-dark">@total</td>
                                    <td class="text-center text-success fw-bold">@disponibles</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-between x-small mb-1">
                                            <span class="text-muted">@porcentaje% Ocupado</span>
                                            <span class="text-dark fw-bold">@ocupados/@total</span>
                                        </div>
                                        <div class="progress rounded-pill" style="height: 6px;">
                                            <div class="progress-bar @(porcentaje > 90 ? "bg-danger" : "bg-primary")"
                                                 role="progressbar" style="width: @porcentaje%"></div>
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        @* Validación de permiso para ver espacios *@
                                        @if (canViewSpaces)
                                        {
                                            <a href="@Url.Action("Details", "Cemetery", new { id = structure.Id })"
                                               class="btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm">
                                                Gestionar <i class="fa-solid fa-arrow-right ms-1" style="font-size: 0.7rem;"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted border rounded-pill px-3 py-2">
                                                <i class="fa-solid fa-lock me-1"></i> Sin acceso
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        const urlGetBuildStructure = '@Url.Action("GetBuildStructure", "Cemetery")';

        async function openBuildStructureModal(id, type) {
            try {
                const response = await fetch(`${urlGetBuildStructure}?id=${id}&type=${type}`);
                if (!response.ok) throw new Error("Error en el servidor");

                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;

                const modalElement = container.querySelector('.modal');
                new bootstrap.Modal(modalElement).show();
            } catch (error) {
                console.error(error);
                Swal.fire('Error', 'No se pudo cargar el constructor.', 'error');
            }
        }

        async function submitBuildForm(formId, modalId) {
            const form = document.getElementById(formId);
            const formData = new FormData(form);

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();

                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById(modalId)).hide();
                    Swal.fire('¡Éxito!', result.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Error en la comunicación con el servidor.', 'error');
            }
        }
    </script>
}

<style>
    .x-small {
        font-size: 0.7rem;
    }

    .table thead th {
        font-weight: 700;
        font-size: 0.75rem;
    }

    .progress {
        background-color: #f0f2f5;
    }
</style>