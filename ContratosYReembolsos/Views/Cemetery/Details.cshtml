@using ContratosYReembolsos.Models.Entities.Cemeteries
@using Microsoft.AspNetCore.Authorization
@model IntermentStructure
@inject IAuthorizationService AuthorizationService

@{
    var template = Model.Template;
    int colsPerFace = template?.ColsPerFace ?? 25;
    bool isDouble = template?.IsDoubleFace ?? false;
    bool isTierra = Model.Type == "TUMBA" || Model.Type == "MAUSOLEO";

    // Evaluación de permisos
    var canCreateSpaces = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Espacios.Crear")).Succeeded;
    var canDeleteSpaces = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Espacios.Eliminar")).Succeeded;
}

<div class="container-fluid py-4 animate__animated animate__fadeIn">
    @* --- CABECERA DE ESTRUCTURA --- *@
    <div class="card border-0 shadow-sm rounded-4 mb-4 border-start border-4 @(isTierra ? "border-success" : "border-primary")">
        <div class="card-body p-4 d-flex justify-content-between align-items-center">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1 x-small text-uppercase fw-bold">
                        <li class="breadcrumb-item">
                            <a href="@Url.Action("InventoryList", "Cemetery", new { id = Model.CemeteryId, type = Model.Type })" class="text-decoration-none">@Model.Type</a>
                        </li>
                        <li class="breadcrumb-item active">Mapa de Espacios</li>
                    </ol>
                </nav>
                <h4 class="fw-bold mb-0 text-dark">
                    <i class="fa-solid @(isTierra ? "fa-seedling text-success" : "fa-building-columns text-primary") me-2"></i>@Model.Name
                </h4>
            </div>

            <div class="text-end d-flex gap-2">
                @* LÓGICA SOLO PARA TIERRA: Agregar filas y Borrar espacios *@
                @if (isTierra)
                {
                    @if (canCreateSpaces)
                    {
                        <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm" onclick="openMassiveTumbasModal(@Model.Id)">
                            <i class="fa-solid fa-layer-group me-2"></i> Generar Fila Completa
                        </button>
                    }

                    @if (canDeleteSpaces)
                    {
                        <button id="btnToggleEdit" class="btn btn-outline-danger rounded-pill px-3 fw-bold" onclick="toggleEditMode()">
                            <i class="fa-solid fa-pen-to-square me-1"></i> Modo Edición
                        </button>
                    }
                }

                <div class="badge bg-dark text-white rounded-pill px-3 py-2 d-flex align-items-center">
                    <i class="fa-solid fa-calculator me-2"></i>Capacidad Actual: @Model.Spaces.Count()
                </div>
            </div>
        </div>
    </div>

    @* --- RENDERIZADO DE MAPA --- *@
    @if (isTierra)
    {
        @* (El código del mapa de tierra se mantiene igual pero ahora los botones de borrado 
            están protegidos por la lógica de arriba) *@
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
            <div class="card-header bg-dark text-white py-3">
                <h6 class="fw-bold mb-0 text-uppercase small"><i class="fa-solid fa-map me-2 text-success"></i>Distribución en Terreno</h6>
            </div>
            <div class="card-body p-4 bg-light-subtle">
                <div class="p-3 bg-white rounded-4 shadow-sm overflow-auto custom-scroll">
                    <div class="d-flex flex-column gap-2" style="min-width: max-content;">
                        @foreach (var row in Model.Spaces.GroupBy(s => s.RowLetter).OrderBy(g => g.Key))
                        {
                            <div class="d-flex align-items-center">
                                <div class="fw-bold text-muted border-end pe-3 me-2 text-center" style="width: 45px; font-size: 14px;">@row.Key</div>
                                <div class="d-flex flex-nowrap gap-1">
                                    @foreach (var tumba in row.OrderBy(s => s.ColumnNumber))
                                    {
                                        <div class="position-relative d-inline-block">
                                            <div class="space-item @GetSpaceClass(tumba.Status)"
                                                 data-bs-toggle="tooltip" title="Tumba @tumba.Code"
                                                 onclick="verDetalleNicho(@tumba.Id, '@tumba.Code', '@Model.Name', '@tumba.Status')">
                                                @tumba.ColumnNumber
                                            </div>
                                            @if (canDeleteSpaces && tumba.Status == IntermentStatus.Disponible)
                                            {
                                                <button class="delete-overlay d-none" onclick="confirmDeleteSpace(@tumba.Id, '@tumba.Code')">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @* MAPA DE PABELLONES: Aquí no hay modo edición ni borrado manual por tumba *@
        @foreach (var floor in Model.Spaces.GroupBy(s => s.FloorNumber).OrderByDescending(g => g.Key))
        {
            <div class="card border-0 shadow-sm rounded-4 mb-5 overflow-hidden">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="fw-bold mb-0 text-uppercase small"><i class="fa-solid fa-stairs me-2"></i>Nivel @floor.Key</h6>
                </div>
                <div class="card-body p-4 bg-light-subtle">
                    <div class="d-flex flex-column gap-4">
                        @* CARA A *@
                        <div class="p-3 bg-white rounded-4 shadow-sm">
                            <span class="fw-bold text-primary small d-block mb-3 border-bottom pb-2 text-uppercase">Lado Frontal / Cara A</span>
                            <div class="overflow-auto custom-scroll">
                                <div class="d-flex flex-column gap-2" style="min-width: max-content;">
                                    @foreach (var row in floor.Where(s => s.ColumnNumber <= colsPerFace).GroupBy(s => s.RowLetter).OrderBy(g => g.Key))
                                    {
                                        <div class="d-flex align-items-center">
                                            <div class="fw-bold text-muted border-end pe-3 me-2 text-center" style="width: 45px; font-size: 14px;">@row.Key</div>
                                            <div class="d-flex flex-nowrap gap-1">
                                                @foreach (var nicho in row.OrderBy(s => s.ColumnNumber))
                                                {
                                                    <div class="space-item @GetSpaceClass(nicho.Status)"
                                                         data-bs-toggle="tooltip" title="Nicho @nicho.Code"
                                                         onclick="verDetalleNicho(@nicho.Id, '@nicho.Code', '@Model.Name', '@nicho.Status')">
                                                        @nicho.ColumnNumber
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        @if (isDouble)
                        {
                            @* CARA B *@
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <span class="fw-bold text-info small d-block mb-3 border-bottom pb-2 text-uppercase">Lado Posterior / Cara B</span>
                                <div class="overflow-auto custom-scroll">
                                    <div class="d-flex flex-column gap-2" style="min-width: max-content;">
                                        @foreach (var row in floor.Where(s => s.ColumnNumber > colsPerFace).GroupBy(s => s.RowLetter).OrderBy(g => g.Key))
                                        {
                                            <div class="d-flex align-items-center">
                                                <div class="fw-bold text-muted border-end pe-3 me-2 text-center" style="width: 45px; font-size: 14px;">@row.Key</div>
                                                <div class="d-flex flex-nowrap gap-1">
                                                    @foreach (var nicho in row.OrderBy(s => s.ColumnNumber))
                                                    {
                                                        <div class="space-item @GetSpaceClass(nicho.Status)"
                                                             data-bs-toggle="tooltip" title="Nicho @nicho.Code"
                                                             onclick="verDetalleNicho(@nicho.Id, '@nicho.Code', '@Model.Name', '@nicho.Status')">
                                                            @nicho.ColumnNumber
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        let editModeActive = false;
        let isSelectingDestiny = false;
        let originSpaceId = 0;
        let destinationSpaceId = 0;

        const urlGetMassiveTumbas = '@Url.Action("GetAddMassiveGraves", "Cemetery")';

        // Inicializar tooltips
        $(function () {
            $('[data-bs-toggle="tooltip"]').tooltip();
        });

        async function openMassiveTumbasModal(id) {
            try {
                const response = await fetch(`${urlGetMassiveTumbas}?structureId=${id}`);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;
                new bootstrap.Modal(container.querySelector('.modal')).show();
            } catch (error) {
                Swal.fire('Error', 'No se pudo cargar el generador.', 'error');
            }
        }

        // --- FUNCIÓN FALTANTE QUE SOLUCIONA EL ERROR ---
        function validateAndSubmit() {
            const finalInput = document.getElementById('finalRowLetter');
            const isNewTab = document.getElementById('new-tab')?.classList.contains('active');

            if (isNewTab) {
                // Si existe el campo de texto para nueva fila
                const inputNueva = document.getElementById('inputNuevaFila');
                if(inputNueva) finalInput.value = inputNueva.value.trim().toUpperCase();
            } else {
                // Si existe el select para fila existente
                const selectExt = document.getElementById('selectExistente');
                if(selectExt) finalInput.value = selectExt.value;
            }

            if (!finalInput.value) {
                Swal.fire('Atención', 'Debe indicar una letra para la fila.', 'warning');
                return;
            }

            submitMassiveForm();
        }

        async function submitMassiveForm() {
            const form = document.getElementById('formMassiveTumbas');
            if(!form) return;

            const formData = new FormData(form);

            // Mostrar loading
            Swal.fire({
                title: 'Generando espacios...',
                didOpen: () => { Swal.showLoading() },
                allowOutsideClick: false
            });

            try {
                const response = await fetch(form.action, { method: 'POST', body: formData });
                const result = await response.json();

                if (result.success) {
                    Swal.fire('¡Éxito!', result.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Atención', result.message, 'warning');
                }
            } catch (error) {
                Swal.fire('Error', 'Fallo de servidor.', 'error');
            }
        }

        function toggleEditMode() {
            editModeActive = !editModeActive;
            const btn = document.getElementById('btnToggleEdit');
            const deleteButtons = document.querySelectorAll('.delete-overlay');

            if (editModeActive) {
                btn.classList.replace('btn-outline-danger', 'btn-danger');
                btn.innerHTML = '<i class="fa-solid fa-check me-1"></i> Finalizar Edición';
                deleteButtons.forEach(b => b.classList.remove('d-none'));
            } else {
                btn.classList.replace('btn-danger', 'btn-outline-danger');
                btn.innerHTML = '<i class="fa-solid fa-pen-to-square me-1"></i> Modo Edición';
                deleteButtons.forEach(b => b.classList.add('d-none'));
            }
        }

        async function confirmDeleteSpace(id, code) {
            event.stopPropagation();
            const result = await Swal.fire({
                title: '¿Eliminar espacio?',
                text: `Se borrará la ubicación ${code}. Esta acción no se puede deshacer.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, borrar',
                cancelButtonText: 'Cancelar'
            });

            if (result.isConfirmed) {
                const response = await fetch(`@Url.Action("DeleteSpace", "Cemetery")?id=${id}`, { method: 'POST' });
                const res = await response.json();
                if (res.success) location.reload();
                else Swal.fire('Error', res.message, 'error');
            }
        }

        function verDetalleNicho(id, code, structureName, status) {
            if (isSelectingDestiny) {
                // Lógica de traslado...
            } else {
                console.log("Detalle de espacio:", id, status);
            }
        }
    </script>
}

@functions {
    public string GetSpaceClass(IntermentStatus status)
    {
        return status switch
        {
            IntermentStatus.Disponible => "bg-success text-white",
            IntermentStatus.Ocupado => "bg-danger text-white",
            IntermentStatus.Reservado => "bg-warning text-dark",
            IntermentStatus.Mantenimiento => "bg-secondary text-white",
            IntermentStatus.Bloqueado => "bg-dark text-white",
            _ => "bg-secondary text-white"
        };
    }
}

<style>
    .space-item {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        font-weight: 800;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid rgba(0,0,0,0.1);
        user-select: none;
    }

        .space-item:hover {
            transform: scale(1.15);
            z-index: 5;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

    .delete-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 32px;
        height: 32px;
        background-color: rgba(220, 53, 69, 0.9);
        color: white;
        border: none;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        cursor: pointer;
        z-index: 10;
    }

    .custom-scroll::-webkit-scrollbar {
        height: 8px;
    }

    .custom-scroll::-webkit-scrollbar-thumb {
        background: #cbd5e0;
        border-radius: 4px;
    }

    .pulse-destiny {
        animation: pulse-green 1.5s infinite;
        border: 2px solid white !important;
    }

    @@keyframes pulse-green {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
            box-shadow: 0 0 10px #198754;
        }

        100% {
            transform: scale(1);
        }
    }
</style>