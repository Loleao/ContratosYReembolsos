@using ContratosYReembolsos.Models.Entities.Cemeteries
@model IntermentStructure
@{
    var template = Model.Template;
    int colsPerFace = template?.ColsPerFace ?? 25;
    bool isDouble = template?.IsDoubleFace ?? false;
    bool isTierra = Model.Type == "TUMBA" || Model.Type == "MAUSOLEO";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4 mb-4 border-start border-4 @(isTierra ? "border-success" : "border-primary")">
        <div class="card-body p-4 d-flex justify-content-between align-items-center">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1 x-small text-uppercase fw-bold">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Cemetery", new { type = Model.Type })">@Model.Type</a></li>
                        <li class="breadcrumb-item active">Gestión Visual de Espacios</li>
                    </ol>
                </nav>
                <h4 class="fw-bold mb-0 text-dark">
                    <i class="fa-solid @(isTierra ? "fa-seedling text-success" : "fa-building-columns text-primary") me-2"></i>@Model.Name
                </h4>
            </div>
            <div class="text-end d-flex gap-2">
                @if (isTierra)
                {
                    <button class="btn btn-outline-success rounded-pill px-3 fw-bold btn-sm" onclick="openAddTumbaModal(@Model.Id)">
                        <i class="fa-solid fa-plus me-1"></i> Individual
                    </button>
                    <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm" onclick="openMassiveTumbasModal(@Model.Id)">
                        <i class="fa-solid fa-layer-group me-2"></i> Generar Fila Completa
                    </button>
                }
                else
                {
                    <div class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                        <i class="fa-solid fa-layer-group me-2"></i>Capacidad: @Model.Spaces.Count()
                    </div>
                }
            </div>
        </div>
    </div>

    @if (isTierra)
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
            <div class="card-header bg-dark text-white py-3">
                <h6 class="fw-bold mb-0 text-uppercase small"><i class="fa-solid fa-map me-2"></i>Mapa de Ocupación (Suelo)</h6>
                <button id="btnToggleEdit" class="btn btn-outline-light btn-sm rounded-pill px-3 fw-bold" onclick="toggleEditMode()">
                    <i class="fa-solid fa-pen-to-square me-1"></i> Modo Edición
                </button>
            </div>
            <div class="card-body p-4 bg-light-subtle">
                <div class="p-3 bg-white rounded-4 shadow-sm">
                    <span class="fw-bold text-success small d-block mb-3 border-bottom pb-2 text-uppercase">Distribución por Filas / Sectores</span>

                    <div class="overflow-auto custom-scroll pb-2">
                        @* Agrupamos por Fila, asumiendo que en tierra siempre es Nivel 1 *@
                        <div class="d-flex flex-column gap-2" style="min-width: max-content;">
                            @foreach (var row in Model.Spaces.GroupBy(s => s.RowLetter).OrderBy(g => g.Key))
                            {
                                <div class="d-flex align-items-center">
                                    @* Letra de la Fila (A, B, C...) - Mismo estilo que Pabellón *@
                                    <div class="fw-bold text-muted border-end pe-3 me-2 text-center" style="width: 45px; font-size: 14px;">@row.Key</div>

                                    @* Contenedor de Tumbas - Mismo estilo flex apretado *@
                                    <div class="d-flex flex-nowrap gap-1">
                                        @foreach (var tumba in row.OrderBy(s => s.ColumnNumber))
                                        {
                                            <div class="position-relative d-inline-block me-1 mb-1">
                                                <div class="space-item @GetSpaceClass(tumba.Status)"
                                                     data-bs-toggle="tooltip" title="Tumba @tumba.Code"
                                                     onclick="verDetalleNicho(@tumba.Id)">
                                                    @tumba.ColumnNumber
                                                </div>

                                                @if (tumba.Status == IntermentStatus.Disponible)
                                                {
                                                    @* El botón ahora tiene la clase 'delete-overlay' que controlaremos con JS *@
                                                    <button class="delete-overlay d-none" onclick="confirmDeleteSpace(@tumba.Id, '@tumba.Code')">
                                                        <i class="fa-solid fa-trash-can"></i>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @foreach (var floor in Model.Spaces.GroupBy(s => s.FloorNumber).OrderByDescending(g => g.Key))
        {
            <div class="card border-0 shadow-sm rounded-4 mb-5 overflow-hidden">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="fw-bold mb-0 text-uppercase small"><i class="fa-solid fa-stairs me-2"></i>Nivel @floor.Key</h6>
                </div>
                <div class="card-body p-4 bg-light-subtle">
                    <div class="d-flex flex-column gap-4">

                        <div class="p-3 bg-white rounded-4 shadow-sm">
                            <span class="fw-bold text-primary small d-block mb-3 border-bottom pb-2 text-uppercase">Lado Frontal / Cara A</span>
                            <div class="overflow-auto custom-scroll pb-2">
                                <div class="d-flex flex-column gap-2" style="min-width: max-content;">
                                    @foreach (var row in floor.Where(s => s.ColumnNumber <= colsPerFace).GroupBy(s => s.RowLetter).OrderBy(g => g.Key))
                                    {
                                        <div class="d-flex align-items-center">
                                            <div class="fw-bold text-muted border-end pe-3 me-2 text-center" style="width: 45px; font-size: 14px;">@row.Key</div>
                                            <div class="d-flex flex-nowrap gap-1">
                                                @foreach (var nicho in row.OrderBy(s => s.ColumnNumber))
                                                {
                                                    <div class="space-item @GetSpaceClass(nicho.Status)"
                                                         data-bs-toggle="tooltip" title="Nicho @nicho.Code"
                                                         onclick="verDetalleNicho(@nicho.Id)">
                                                        @nicho.ColumnNumber
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        @if (isDouble)
                        {
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <span class="fw-bold text-info small d-block mb-3 border-bottom pb-2 text-uppercase">Lado Posterior / Cara B</span>
                                <div class="overflow-auto custom-scroll pb-2">
                                    <div class="d-flex flex-column gap-2" style="min-width: max-content;">
                                        @foreach (var row in floor.Where(s => s.ColumnNumber > colsPerFace).GroupBy(s => s.RowLetter).OrderBy(g => g.Key))
                                        {
                                            <div class="d-flex align-items-center">
                                                <div class="fw-bold text-muted border-end pe-3 me-2 text-center" style="width: 45px; font-size: 14px;">@row.Key</div>
                                                <div class="d-flex flex-nowrap gap-1">
                                                    @foreach (var nicho in row.OrderBy(s => s.ColumnNumber))
                                                    {
                                                        <div class="space-item @GetSpaceClass(nicho.Status)"
                                                             data-bs-toggle="tooltip" title="Nicho @nicho.Code"
                                                             onclick="verDetalleNicho(@nicho.Id)">
                                                            @nicho.ColumnNumber
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        let editModeActive = false;
        let isSelectingDestiny = false;
        let originSpaceId = 0;
        let destinationSpaceId = 0;

        const urlGetAddTumba = '@Url.Action("GetAddTumbaModal", "Cemetery")';
        const urlGetMassiveTumbas = '@Url.Action("GetAddMassiveGraves", "Cemetery")';

        // Inicializar tooltips de Bootstrap
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });

        async function openAddTumbaModal(id) {
            try {
                const response = await fetch(`${urlGetAddTumba}?structureId=${id}`);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;
                new bootstrap.Modal(container.querySelector('.modal')).show();
            } catch (error) {
                Swal.fire('Error', 'No se pudo cargar el formulario.', 'error');
            }
        }

        async function openMassiveTumbasModal(id) {
            try {
                const response = await fetch(`${urlGetMassiveTumbas}?structureId=${id}`);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;
                new bootstrap.Modal(container.querySelector('.modal')).show();
            } catch (error) {
                Swal.fire('Error', 'No se pudo cargar el generador masivo.', 'error');
            }
        }

        async function submitMassiveForm() {
            const form = document.getElementById('formMassiveTumbas');
            const formData = new FormData(form);
            try {
                const response = await fetch(form.action, { method: 'POST', body: formData });
                const result = await response.json();
                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('modalMassiveTumbas')).hide();
                    Swal.fire('Éxito', result.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Atención', result.message, 'warning');
                }
            } catch (error) {
                Swal.fire('Error', 'Error en el servidor.', 'error');
            }
        }

        function verDetalleNicho(id) {
            console.log("Ver detalle del espacio ID:", id);
            // Aquí llamarías a tu modal de detalles del difunto/contrato
        }

        function validateAndSubmit() {
            const finalInput = document.getElementById('finalRowLetter');
            const isNewTab = document.getElementById('new-tab').classList.contains('active');

            if (isNewTab) {
                // Si está en la pestaña "Nueva", jalamos del input de texto
                finalInput.value = document.getElementById('inputNuevaFila').value.trim().toUpperCase();
            } else {
                // Si está en "Existente", jalamos del select
                finalInput.value = document.getElementById('selectExistente').value;
            }

            if (!finalInput.value) {
                Swal.fire('Atención', 'Debe indicar una letra para la fila.', 'warning');
                return;
            }

            // Llamamos a la función global que ya tenías en Details.cshtml
            submitMassiveForm();
        }

        function toggleEditMode() {
            editModeActive = !editModeActive;
            const btn = document.getElementById('btnToggleEdit');
            const deleteButtons = document.querySelectorAll('.delete-overlay');

            if (editModeActive) {
                btn.classList.replace('btn-outline-light', 'btn-danger');
                btn.innerHTML = '<i class="fa-solid fa-check me-1"></i> Finalizar Edición';
                deleteButtons.forEach(b => b.classList.remove('d-none'));
                // Opcional: Deshabilitar tooltips para que no estorben
            } else {
                btn.classList.replace('btn-danger', 'btn-outline-light');
                btn.innerHTML = '<i class="fa-solid fa-pen-to-square me-1"></i> Modo Edición';
                deleteButtons.forEach(b => b.classList.add('d-none'));
            }
        }

        async function confirmDeleteSpace(id, code) {
            event.stopPropagation(); // Evita abrir el modal de detalles

            const result = await Swal.fire({
                title: '¿Eliminar tumba?',
                text: `Se borrará permanentemente la ubicación ${code}.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`@Url.Action("DeleteSpace", "Cemetery")/${id}`, {
                        method: 'POST'
                    });
                    const res = await response.json();
                    if (res.success) {
                        location.reload();
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                } catch (e) {
                    Swal.fire('Error', 'Fallo de conexión', 'error');
                }
            }
        }

        async function openExhumationModal(id) {
            originSpaceId = id;
            try {
                const response = await fetch(`@Url.Action("GetExhumation", "Cemetery")?spaceId=${id}`);
                const html = await response.text();
                document.getElementById('modalContainer').innerHTML = html;
                new bootstrap.Modal(document.querySelector('#modalExhumation')).show();
            } catch (e) { Swal.fire('Error', 'No se pudo cargar la orden.', 'error'); }
        }

        function selectNewSpace() {
            isSelectingDestiny = true;
            bootstrap.Modal.getInstance(document.querySelector('#modalExhumation')).hide();

            Swal.fire({
                toast: true,
                position: 'top',
                title: 'Seleccione un espacio disponible en el mapa',
                icon: 'info',
                showConfirmButton: false,
                timer: 5000
            });

            document.querySelectorAll('.bg-success').forEach(el => el.classList.add('pulse-destiny'));
        }

        function verDetalleNicho(id, code, structureName, status) {
            if (isSelectingDestiny) {
                if (status !== 'Disponible') {
                    Swal.fire('Error', 'Debe seleccionar un espacio libre.', 'warning');
                    return;
                }

                destinationSpaceId = id;
                isSelectingDestiny = false;

                // Removemos el efecto visual
                document.querySelectorAll('.pulse-destiny').forEach(el => el.classList.remove('pulse-destiny'));

                // Reabrimos el modal y llenamos los datos del destino
                const modal = new bootstrap.Modal(document.querySelector('#modalExhumation'));
                modal.show();

                document.getElementById('noDestiny').classList.add('d-none');
                document.getElementById('destinationSelected').classList.remove('d-none');
                document.getElementById('destCode').innerText = code;
                document.getElementById('destStructure').innerText = structureName;
                document.getElementById('btnConfirmTransfer').disabled = false;
            } else {
                // Lógica normal de ver detalles...
                if (status === 'Ocupado') openExhumationModal(id);
            }
        }
    </script>
}

@functions {
    // Función unificada para las clases de color
    public string GetSpaceClass(string status)
    {
        return status switch
        {
            IntermentStatus.Disponible => "bg-success text-white",
            IntermentStatus.Ocupado => "bg-danger text-white",
            IntermentStatus.Reservado => "bg-warning text-dark",
            _ => "bg-secondary text-white"
        };
    }
}

<style>
    .space-item {
        width: 34px;
        height: 34px;
        min-width: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 800;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(0,0,0,0.05);
        flex-shrink: 0;
    }

        .space-item:hover {
            transform: scale(1.2);
            z-index: 10;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

    /* Scroll Personalizado Estilo FONAFUN */
    .custom-scroll::-webkit-scrollbar {
        height: 6px;
    }

    .custom-scroll::-webkit-scrollbar-thumb {
        background: #cbd5e0;
        border-radius: 10px;
    }

        .custom-scroll::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

    .x-small {
        font-size: 11px;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
    }

    .delete-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 34px; 
        height: 34px;
        background-color: rgba(220, 53, 69, 0.9);
        color: white;
        border: none;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        cursor: pointer;
        z-index: 10;
        animation: fadeIn 0.2s;
    }

        .delete-overlay:hover {
            background-color: #dc3545;
            transform: scale(1.1);
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .pulse-destiny {
        animation: pulse-green 1.5s infinite;
        border: 2px solid white !important;
        box-shadow: 0 0 15px rgba(25, 135, 84, 0.7);
    }

    @@keyframes pulse-green {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.15);
            filter: brightness(1.2);
        }

        100% {
            transform: scale(1);
        }
    }
</style>