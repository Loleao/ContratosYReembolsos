@using ContratosYReembolsos.Models.Entities.Cemeteries
@model Cemetery

<div class="modal fade" id="modalCreateCemetery" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white p-4">
                <h5 class="modal-title fw-bold" id="modalLabel">
                    <i class="fa-solid fa-church me-2"></i>Nueva Sede en @ViewBag.BranchName
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form id="formCreateCemetery" asp-action="Create" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" asp-for="BranchId" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Nombre de la Sede</label>
                        <input asp-for="Name" class="form-control rounded-3" placeholder="Ej: Cementerio General San José" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="RUC" class="form-label fw-bold">RUC</label>
                            <input asp-for="RUC" class="form-control rounded-3" placeholder="10XXXXXXXXX" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label fw-bold">Teléfono</label>
                            <input asp-for="Phone" class="form-control rounded-3" placeholder="01-XXXXXX" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-bold">Dirección Física</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fa-solid fa-map-pin"></i></span>
                            <input asp-for="Address" class="form-control rounded-end-3" placeholder="Av. Principal 123..." />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold">Correo de Contacto</label>
                        <input asp-for="Email" type="email" class="form-control rounded-3" placeholder="sede@fonafun.com" />
                    </div>
                </div>

                <div class="modal-footer bg-light p-3 border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" onclick="submitCemeteryForm()">
                        Registrar Sede <i class="fa-solid fa-save ms-1"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>