@model IntermentStructureTemplate

<div class="modal fade" id="modalTemplate" tabindex="-1">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-gears me-2"></i>Configurar Plantilla Técnica</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="formCreateTemplate" asp-action="SaveTemplate" method="post">
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-bold text-muted text-uppercase small">Nombre del Modelo</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fa-solid fa-font text-primary"></i></span>
                                <input asp-for="Name" class="form-control border-2 shadow-sm" placeholder="Ej: Pabellón Estándar 6 Filas" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-primary small">TIPO DE ESTRUCTURA</label>
                            <select asp-for="Type" class="form-select border-2 shadow-sm">
                                <option value="PABELLON">Pabellón (Nichos)</option>
                                <option value="COLUMBARIO">Columbario (Urnas)</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-primary small">PRECIO BASE (S/.)</label>
                            <div class="input-group">
                                <span class="input-group-text">S/</span>
                                <input asp-for="DefaultPrice" type="number" step="0.01" class="form-control border-2 shadow-sm" required>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold small">FILAS</label>
                            <input asp-for="RowsCount" type="number" class="form-control text-center fw-bold border-2" min="1">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold small">PISOS</label>
                            <input asp-for="TotalFloors" type="number" class="form-control text-center fw-bold border-2" min="1">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold small">COLS x CARA</label>
                            <input asp-for="ColsPerFace" type="number" class="form-control text-center fw-bold border-2" value="25">
                        </div>

                        <div class="col-12 mt-3">
                            <div class="form-check form-switch card p-2 ps-5 border-2 shadow-sm">
                                <input asp-for="IsDoubleFace" class="form-check-input" type="checkbox" id="checkFace" checked>
                                <label class="form-check-label fw-bold small" for="checkFace">¿Es de Doble Cara? (1-25 y 26-50)</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light rounded-bottom-4">
                    <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary rounded-pill px-5 fw-bold shadow" onclick="submitTemplateForm('formCreateTemplate', 'modalTemplate')">
                        Guardar Plantilla <i class="fa-solid fa-floppy-disk ms-2"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>