@using ContratosYReembolsos.Models.Entities.Branches
@model IEnumerable<IGrouping<string, Branch>>

@{
    ViewData["Title"] = "Gestión de Camposantos - Selección";
}

<style>
    .icon-shape-cemetery {
        width: 40px;
        height: 40px;
        background: #e7f1ff;
        color: #0d6efd;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .branch-card-horizontal {
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        border: 1px solid #e2e8f0;
        border-radius: 15px;
        background: white;
    }

        .branch-card-horizontal:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
            border-color: #0d6efd;
        }

    .search-pill {
        background: #f1f4f8;
        border-radius: 50px;
        padding: 10px 25px;
        border: 1px solid transparent;
        width: 100%;
        transition: 0.3s;
    }

        .search-pill:focus {
            outline: none;
            background: white;
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
        }
</style>

<div class="container py-4 animate__animated animate__fadeIn">
    <div class="text-center mb-5">
        <div class="bg-primary bg-opacity-10 text-primary d-inline-block p-3 rounded-circle mb-3">
            <i class="fa-solid fa-location-dot fa-3x"></i>
        </div>
        <h2 class="fw-bold text-dark">Gestión de Camposantos</h2>
        <p class="text-muted mx-auto" style="max-width: 600px;">
            Seleccione una filial para administrar las sedes de cementerios, pabellones y la disponibilidad de nichos institucionales.
        </p>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-md-8">
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="top: 17px; left: 25px;"></i>
                <input type="text" id="cemeteryBranchSearch" class="search-pill ps-5 shadow-sm"
                       placeholder="Buscar filial por nombre, código o departamento...">
            </div>
        </div>
    </div>

    <div class="accordion border-0 shadow-none" id="accordionCemeteries">
        @foreach (var group in Model.OrderBy(g => g.Key))
        {
            <div class="accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden region-group">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-bold py-3 px-4 bg-white text-dark" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapse-@group.Key.Replace(" ", "")">
                        <div class="d-flex align-items-center w-100">
                            <i class="fa-solid fa-map-location-dot me-3 text-primary fs-5"></i>
                            <span>@group.Key.ToUpper()</span>
                            <span class="badge bg-light text-primary border ms-auto me-3 rounded-pill fw-bold">@group.Count() Filiales</span>
                        </div>
                    </button>
                </h2>
                <div id="collapse-@group.Key.Replace(" ", "")" class="accordion-collapse collapse" data-bs-parent="#accordionCemeteries">
                    <div class="accordion-body p-4 bg-light bg-opacity-50">
                        <div class="row g-3">
                            @foreach (var branch in group.OrderBy(b => b.Name))
                            {
                                <div class="col-xl-4 col-md-6 branch-item" data-search="@branch.Name @branch.Code @group.Key">
                                    <div class="card branch-card-horizontal shadow-sm h-100">
                                        <div class="card-body p-3">
                                            <div class="d-flex align-items-start mb-3">
                                                <div class="icon-shape-cemetery me-3 flex-shrink-0">
                                                    <i class="fa-solid fa-monument fs-4"></i>
                                                </div>
                                                <div class="overflow-hidden">
                                                    <div class="d-flex align-items-center gap-2 mb-1">
                                                        <span class="badge bg-dark text-white" style="font-size: 0.65rem;">@branch.Code</span>
                                                        <span class="badge bg-primary-subtle text-primary x-small px-2 border border-primary-subtle">
                                                            @(branch.Cemeteries?.Count ?? 0) Sedes
                                                        </span>
                                                    </div>
                                                    <h6 class="fw-bold text-dark mb-1 text-truncate">@branch.Name</h6>
                                                    <small class="text-muted text-truncate d-block" style="font-size: 0.75rem;">
                                                        <i class="fa-solid fa-location-arrow me-1 text-danger opacity-75"></i>
                                                        @branch.Address
                                                    </small>
                                                </div>
                                            </div>
                                            <div class="d-grid">
                                                <a href="@Url.Action("Index", "Cemetery", new { selectedBranchId = branch.Id })"
                                                   class="btn btn-sm btn-outline-primary rounded-pill fw-bold py-2 border-2 shadow-sm">
                                                    Administrar Sedes <i class="fa-solid fa-chevron-right ms-1"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div id="emptySearch" class="text-center py-5 d-none animate__animated animate__fadeIn">
        <i class="fa-solid fa-map-location fa-3x text-muted opacity-25 mb-3"></i>
        <h5 class="fw-bold text-dark">No se encontraron filiales</h5>
        <p class="text-muted">Intente con otro nombre de filial o región.</p>
    </div>
</div>

@section Scripts {
    <script>
        // --- MOTOR DE BÚSQUEDA INTELIGENTE ---
        $('#cemeteryBranchSearch').on('input', function() {
            let term = $(this).val().toLowerCase().trim();
            let totalMatch = 0;

            $('.region-group').each(function() {
                let $region = $(this);
                let regionMatch = false;

                $region.find('.branch-item').each(function() {
                    if ($(this).data('search').toLowerCase().includes(term)) {
                        $(this).show();
                        regionMatch = true;
                        totalMatch++;
                    } else {
                        $(this).hide();
                    }
                });

                if (regionMatch) {
                    $region.show();
                    if (term.length > 1) {
                        $region.find('.accordion-collapse').addClass('show');
                        $region.find('.accordion-button').removeClass('collapsed');
                    }
                } else {
                    $region.hide();
                }
            });

            if (totalMatch === 0 && term.length > 0) $('#emptySearch').removeClass('d-none');
            else $('#emptySearch').addClass('d-none');
        });
    </script>
}