<div class="container py-4">
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb x-small fw-bold text-uppercase">
                <li class="breadcrumb-item"><a href="@Url.Action("Index")">Inicio</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>
        <h3 class="fw-bold">@Model.Name</h3>
        <p class="text-muted">Seleccione el módulo que desea gestionar:</p>
    </div>

    <div class="row g-3">
        <div class="col-12">
            <a href="@Url.Action("InventoryList", new { id = Model.Id, type = "PABELLON" })"
               class="d-flex align-items-center p-4 bg-white border rounded-4 text-decoration-none hover-list-item shadow-sm">
                <div class="icon-box bg-primary-subtle text-primary me-4">
                    <i class="fa-solid fa-building-columns fa-lg"></i>
                </div>
                <div class="flex-grow-1">
                    <h6 class="fw-bold mb-0 text-dark">Pabellones y Nichos</h6>
                    <small class="text-muted">Gestión de estructuras verticales y niveles.</small>
                </div>
                <i class="fa-solid fa-arrow-right text-muted"></i>
            </a>
        </div>

        <div class="col-12">
            <a href="@Url.Action("InventoryList", new { id = Model.Id, type = "COLUMBARIO" })"
               class="d-flex align-items-center p-4 bg-white border rounded-4 text-decoration-none hover-list-item shadow-sm">
                <div class="icon-box bg-info-subtle text-info me-4">
                    <i class="fa-solid fa-box-archive fa-lg"></i>
                </div>
                <div class="flex-grow-1">
                    <h6 class="fw-bold mb-0 text-dark">Columbarios</h6>
                    <small class="text-muted">Gestión de espacios para urnas y cenizas.</small>
                </div>
                <i class="fa-solid fa-arrow-right text-muted"></i>
            </a>
        </div>

        <div class="col-12">
            <a href="@Url.Action("InventoryList", new { id = Model.Id, type = "TUMBA" })"
               class="d-flex align-items-center p-4 bg-white border rounded-4 text-decoration-none hover-list-item shadow-sm">
                <div class="icon-box bg-success-subtle text-success me-4">
                    <i class="fa-solid fa-seedling fa-lg"></i>
                </div>
                <div class="flex-grow-1">
                    <h6 class="fw-bold mb-0 text-dark">Tumbas y Mausoleos</h6>
                    <small class="text-muted">Gestión de parcelas en tierra y áreas verdes.</small>
                </div>
                <i class="fa-solid fa-arrow-right text-muted"></i>
            </a>
        </div>
    </div>
</div>

<style>
    .icon-box {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
    }

    .hover-list-item {
        transition: transform 0.2s, background-color 0.2s;
    }

        .hover-list-item:hover {
            background-color: #f8f9fa !important;
            transform: translateX(10px);
        }

    .x-small {
        font-size: 11px;
    }
</style>