@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 p-5">
                <div class="mb-4">
                    <i class="fa-solid fa-user-lock fa-5x text-danger opacity-25"></i>
                </div>
                <h2 class="fw-bold text-dark">Acceso Restringido</h2>
                <p class="text-muted">
                    Lo sentimos, no tienes los permisos necesarios para acceder a este módulo de <strong>FONAFUN</strong>.
                    Si crees que esto es un error, contacta con el administrador del sistema.
                </p>
                <div class="mt-4">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary rounded-pill px-5">
                        <i class="fa-solid fa-arrow-left me-2"></i> Volver al Inicio
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>