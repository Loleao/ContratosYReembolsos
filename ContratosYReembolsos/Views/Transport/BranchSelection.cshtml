@using ContratosYReembolsos.Models.Entities.Branches
@model IEnumerable<IGrouping<string, Branch>>

@{
    ViewData["Title"] = "Gestión de Movilidad - Sedes";
}

<style>
    .branch-card-transport {
        transition: all 0.3s ease;
        border: 1px solid #e2e8f0;
        border-radius: 15px;
        background: white;
    }

        .branch-card-transport:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
            border-color: #0d6efd;
        }

    .icon-box-transport {
        width: 50px;
        height: 50px;
        background: #e7f1ff;
        color: #0d6efd;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .search-pill {
        background: #f1f4f8;
        border-radius: 50px;
        padding: 12px 25px;
        border: 1px solid transparent;
        width: 100%;
        transition: 0.3s;
    }

        .search-pill:focus {
            outline: none;
            background: white;
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
        }
</style>

<div class="container py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-0">Gestión de Movilidad</h2>
            <p class="text-muted mb-0">Control de flota, conductores y despacho por sede operativa.</p>
        </div>
        <button class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm" onclick="location.href='@Url.Action("VehicleTypes", "Transport")'">
            <i class="fa-solid fa-gears me-2 text-info"></i>Configuración Maestra
        </button>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="top: 17px; left: 25px;"></i>
                <input type="text" id="transportBranchSearch" class="search-pill ps-5 shadow-sm"
                       placeholder="Buscar filial por nombre, código o región...">
            </div>
        </div>
    </div>

    <div class="accordion border-0 shadow-none" id="accordionTransport">
        @foreach (var group in Model)
        {
            <div class="accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden region-group">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-bold py-3 px-4 bg-white text-dark" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapse-@group.Key.Replace(" ", "")">
                        <div class="d-flex align-items-center w-100">
                            <i class="fa-solid fa-map-location-dot me-3 text-primary fs-5"></i>
                            <span>@group.Key.ToUpper()</span>
                            <span class="badge bg-light text-primary border ms-auto me-3 rounded-pill fw-bold">@group.Count() Sedes</span>
                        </div>
                    </button>
                </h2>
                <div id="collapse-@group.Key.Replace(" ", "")" class="accordion-collapse collapse" data-bs-parent="#accordionTransport">
                    <div class="accordion-body p-4 bg-light bg-opacity-50">
                        <div class="row g-3">
                            @foreach (var branch in group)
                            {
                                @* Nota: Ajusta los nombres de las propiedades según tus entidades *@
                                <div class="col-xl-4 col-md-6 branch-item" data-search="@branch.Name @group.Key @branch.Code">
                                    <div class="card branch-card-transport shadow-sm h-100">
                                        <div class="card-body p-3">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="icon-box-transport me-3 flex-shrink-0 shadow-sm">
                                                    <i class="fa-solid fa-truck-front fs-4"></i>
                                                </div>
                                                <div class="overflow-hidden">
                                                    <h6 class="fw-bold text-dark mb-1 text-truncate">@branch.Name</h6>
                                                    <div class="d-flex gap-2">
                                                        <span class="badge bg-white text-primary border border-primary-subtle x-small">
                                                            <i class="fa-solid fa-car me-1"></i> @(branch.Vehicles?.Count ?? 0) Unid.
                                                        </span>
                                                        @* Conteo de pendientes aproximado desde el modelo *@
                                                        <span class="badge bg-white text-danger border border-danger-subtle x-small">
                                                            <i class="fa-solid fa-clock me-1"></i> Pendientes
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="d-grid">
                                                <a href="@Url.Action("Index", "Transport", new { branchId = branch.Id })"
                                                   class="btn btn-sm btn-primary rounded-pill fw-bold py-2 shadow-sm">
                                                    Gestionar Movilidad <i class="fa-solid fa-chevron-right ms-1"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div id="emptySearch" class="text-center py-5 d-none animate__animated animate__fadeIn">
        <i class="fa-solid fa-road-circle-exclamation fa-3x text-muted opacity-25 mb-3"></i>
        <h5 class="fw-bold text-dark">Sede no encontrada</h5>
        <p class="text-muted">Intente con otro término de búsqueda.</p>
    </div>
</div>

@section Scripts {
    <script>
        // --- MOTOR DE BÚSQUEDA ---
        $('#transportBranchSearch').on('input', function() {
            let term = $(this).val().toLowerCase().trim();
            let totalMatch = 0;

            $('.region-group').each(function() {
                let $region = $(this);
                let regionMatch = false;

                $region.find('.branch-item').each(function() {
                    if ($(this).data('search').toLowerCase().includes(term)) {
                        $(this).show();
                        regionMatch = true;
                        totalMatch++;
                    } else {
                        $(this).hide();
                    }
                });

                if (regionMatch) {
                    $region.show();
                    if (term.length > 1) {
                        $region.find('.accordion-collapse').addClass('show');
                        $region.find('.accordion-button').removeClass('collapsed');
                    }
                } else {
                    $region.hide();
                }
            });

            if (totalMatch === 0 && term.length > 0) $('#emptySearch').removeClass('d-none');
            else $('#emptySearch').addClass('d-none');
        });
    </script>
}