@using ContratosYReembolsos.Models.Entities.Transport
@model IEnumerable<Vehicle>

<div class="animate__animated animate__fadeIn">
    <div class="row g-4">
        @foreach (var v in Model)
        {
            var isService = v.CurrentStatus == "EN_SERVICIO";
            var isMaint = v.CurrentStatus == "MANTENIMIENTO";

            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                    @* Barra de estado superior *@
                    <div style="height: 6px;" class="@(isService ? "bg-danger" : isMaint ? "bg-warning" : "bg-success")"></div>

                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="bg-light rounded-3 p-2">
                                <i class="fa-solid fa-car-side fa-2x text-secondary"></i>
                            </div>
                            <div class="dropdown">
                                <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-ellipsis-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <li><a class="dropdown-item small" href="#"><i class="fa-solid fa-pen-to-square me-2"></i>Editar</a></li>
                                    <li><a class="dropdown-item small text-warning" href="#"><i class="fa-solid fa-wrench me-2"></i>Mantenimiento</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item small text-danger" href="#"><i class="fa-solid fa-trash me-2"></i>Dar de baja</a></li>
                                </ul>
                            </div>
                        </div>

                        <h5 class="fw-bold mb-0">@v.Plate</h5>
                        <p class="text-muted x-small fw-bold mb-3">@v.Brand @v.Model (@v.Year)</p>

                        <div class="d-flex align-items-center mb-3">
                            <span class="badge @(isService ? "bg-danger-subtle text-danger" : isMaint ? "bg-warning-subtle text-warning" : "bg-success-subtle text-success") rounded-pill px-3 x-small">
                                <i class="fa-solid fa-circle me-1" style="font-size: 6px;"></i> @v.CurrentStatus
                            </span>
                        </div>

                        @if (isService)
                        {
                            <div class="p-2 bg-light rounded-3 border">
                                <div class="x-small text-muted fw-bold">EN RUTA DESDE:</div>
                                <div class="small fw-bold">10:30 AM</div> @* Dato dinámico del ServiceLog *@
                            </div>
                        }
                        else
                        {
                            <p class="text-muted x-small mb-0"><i class="fa-solid fa-location-dot me-1"></i> Ubicado en: @ViewBag.SubsidiaryName</p>
                        }
                    </div>
                </div>
            </div>
        }

        @* Card para agregar nuevo vehículo *@
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 border-2 border-dashed d-flex align-items-center justify-content-center py-5 bg-light"
                 style="cursor: pointer; border: 2px dashed #dee2e6 !important;" onclick="openCreateVehicle()">
                <div class="text-center">
                    <i class="fa-solid fa-plus-circle fa-3x text-muted opacity-50 mb-2"></i>
                    <p class="fw-bold text-muted mb-0">Agregar Vehículo</p>
                </div>
            </div>
        </div>
    </div>
</div>