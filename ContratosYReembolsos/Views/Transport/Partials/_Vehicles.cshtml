@using ContratosYReembolsos.Models.Entities.Transport
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@model IEnumerable<Vehicle>

@{
    // Evaluación de políticas de seguridad para la flota
    var canCreate = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Vehiculos.Crear")).Succeeded;
    var canEdit = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Vehiculos.Editar")).Succeeded;
    var canDelete = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Vehiculos.Eliminar")).Succeeded;
}

<div class="animate__animated animate__fadeIn">
    <div class="row g-4">
        @foreach (var v in Model)
        {
            var isService = v.CurrentStatus == "EN_SERVICIO";
            var isMaint = v.CurrentStatus == "MANTENIMIENTO";

            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                    @* Barra de estado superior dinámica *@
                    <div style="height: 6px;" class="@(isService ? "bg-danger" : isMaint ? "bg-warning" : "bg-success")"></div>

                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="bg-light rounded-3 p-2 text-primary">
                                <i class="fa-solid fa-car-side fa-2x opacity-75"></i>
                            </div>

                            @* Acciones protegidas por permisos *@
                            @if (canEdit || canDelete)
                            {
                                <div class="dropdown">
                                    <button class="btn btn-link text-muted p-0 shadow-none" data-bs-toggle="dropdown">
                                        <i class="fa-solid fa-ellipsis-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                        @if (canEdit)
                                        {
                                            <li><a class="dropdown-item small" href="javascript:void(0)" onclick="editVehicle(@v.Id)"><i class="fa-solid fa-pen-to-square me-2 text-primary"></i>Editar</a></li>
                                            <li><a class="dropdown-item small text-warning" href="javascript:void(0)" onclick="setMaintenance(@v.Id)"><i class="fa-solid fa-wrench me-2"></i>Mantenimiento</a></li>
                                        }
                                        @if (canDelete)
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item small text-danger" href="javascript:void(0)" onclick="deleteVehicle(@v.Id)"><i class="fa-solid fa-trash me-2"></i>Dar de baja</a></li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>

                        <h5 class="fw-bold mb-0">@v.Plate</h5>
                        <p class="text-muted x-small fw-bold mb-3">@v.Brand @v.Model (@v.Year)</p>

                        <div class="d-flex align-items-center mb-3">
                            <span class="badge @(isService ? "bg-danger-subtle text-danger" : isMaint ? "bg-warning-subtle text-warning" : "bg-success-subtle text-success") rounded-pill px-3 x-small">
                                <i class="fa-solid fa-circle me-1" style="font-size: 6px;"></i> @v.CurrentStatus
                            </span>
                        </div>

                        @if (isService)
                        {
                            <div class="p-2 bg-light rounded-3 border">
                                <div class="x-small text-muted fw-bold">ESTADO OPERATIVO:</div>
                                <div class="small fw-bold text-danger"><i class="fa-solid fa-route me-1"></i> Unidad en Servicio</div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted x-small mb-0"><i class="fa-solid fa-location-dot me-1"></i> Ubicado en: @ViewBag.BranchName</p>
                        }
                    </div>
                </div>
            </div>
        }

        @* Card para agregar nuevo vehículo (Solo visible con permiso) *@
        @if (canCreate)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 border-2 border-dashed d-flex align-items-center justify-content-center py-5 bg-light hover-lift"
                     style="cursor: pointer; border: 2px dashed #dee2e6 !important;" onclick="openCreateVehicle()">
                    <div class="text-center">
                        <i class="fa-solid fa-plus-circle fa-3x text-primary opacity-50 mb-2"></i>
                        <p class="fw-bold text-muted mb-0">Agregar Vehículo</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .x-small {
        font-size: 0.7rem;
    }

    .hover-lift {
        transition: transform 0.2s;
    }

        .hover-lift:hover {
            transform: translateY(-5px);
        }

    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .bg-danger-subtle {
        background-color: #f8d7da !important;
    }

    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }
</style>