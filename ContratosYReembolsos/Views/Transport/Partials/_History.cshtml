@model IEnumerable<ContratosYReembolsos.Models.VehicleService>

<div class="animate__animated animate__fadeIn">
    <ul class="nav nav-pills mb-4 bg-white p-2 rounded-pill shadow-sm border d-inline-flex" id="historyTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active rounded-pill px-4 fw-bold" id="en-ruta-tab" data-bs-toggle="pill" data-bs-target="#en-ruta" type="button">
                <i class="fa-solid fa-truck-fast text-primary me-2"></i>En Curso
                <span class="badge bg-primary ms-2">@Model.Count(s => s.TripStatus == "EN_RUTA")</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill px-4 fw-bold text-muted" id="finalizados-tab" data-bs-toggle="pill" data-bs-target="#finalizados" type="button">
                <i class="fa-solid fa-clock-rotate-left me-2"></i>Finalizados
                <span class="badge bg-light text-dark border ms-2">@Model.Count(s => s.TripStatus == "FINALIZADO")</span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="historyTabsContent">
        <div class="tab-pane fade show active" id="en-ruta" role="tabpanel">
            @{
                renderServiceList(Model.Where(s => s.TripStatus == "EN_RUTA"), true);
            }
        </div>

        <div class="tab-pane fade" id="finalizados" role="tabpanel">
            @{ 
                renderServiceList(Model.Where(s => s.TripStatus == "FINALIZADO"), false); 
            }
        </div>
    </div>
</div>

@{
    void renderServiceList(IEnumerable<ContratosYReembolsos.Models.VehicleService> services, bool isActive)
    {
        if (!services.Any())
        {
            <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-dashed">
                <i class="fa-solid fa-folder-open fa-3x text-light mb-3"></i>
                <p class="text-muted">No hay registros para mostrar en esta categoría.</p>
            </div>
        }
        else
        {
            var grouped = services.GroupBy(s => s.DepartureTime.Date);
            foreach (var group in grouped)
            {
                <div class="mb-4">
                    <div class="d-flex align-items-center mb-3">
                        <span class="x-small fw-bold text-muted text-uppercase tracking-wider">
                            <i class="fa-solid fa-calendar me-1"></i> @group.Key.ToString("dd MMMM, yyyy")
                        </span>
                        <div class="flex-grow-1 ms-3 border-bottom opacity-10"></div>
                    </div>

                    <div class="row g-3">
                        @foreach (var item in group)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="card border-0 shadow-sm rounded-4 h-100 @(isActive ? "border-start border-4 border-primary" : "")">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span class="x-small fw-bold text-primary">#@item.Contract?.ContractNumber</span>
                                            <span class="x-small text-muted fw-bold">@item.DepartureTime.ToString("HH:mm")</span>
                                        </div>

                                        <div class="fw-bold text-primary">
                                            <span class="x-small fw-bold text-primary">Tipo: @item.ServiceType</span>
                                        </div>

                                        <h6 class="fw-bold mb-1 text-uppercase" style="font-size: 0.85rem;">@item.Contract?.DeceasedName</h6>
                                        <p class="x-small text-muted mb-3"><i class="fa-solid fa-location-dot me-1"></i>@item.Contract?.IntermentSpace.Structure.Cemetery.Name</p>

                                        <div class="p-2 bg-light rounded-3 mb-3 small border-0">
                                            <div class="d-flex align-items-center mb-1">
                                                <i class="fa-solid fa-van-shuttle text-secondary me-2" style="width: 15px;"></i>
                                                <span>@item.Vehicle?.Plate</span>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <i class="fa-solid fa-user-circle text-secondary me-2" style="width: 15px;"></i>
                                                <span class="text-truncate">@item.Driver?.FullName</span>
                                            </div>
                                        </div>

                                        @if (isActive)
                                        {
                                            <button class="btn btn-success btn-sm w-100 rounded-pill fw-bold shadow-sm" onclick="prepareReturn(@item.VehicleId)">
                                                Confirmar Retorno <i class="fa-solid fa-check-circle ms-1"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <div class="d-flex justify-content-between align-items-center x-small pt-2 border-top">
                                                <span class="text-muted italic">Finalizó: @item.ReturnTime?.ToString("HH:mm")</span>
                                                <span class="text-success fw-bold"><i class="fa-solid fa-circle-check me-1"></i>Completado</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    }
}