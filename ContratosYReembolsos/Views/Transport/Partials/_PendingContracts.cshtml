@using ContratosYReembolsos.Models.ViewModels.Transport
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@model IEnumerable<PendingContractViewModel>

@{
    // Evaluamos el permiso de asignación una sola vez
    var canAssign = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Movilidad.Asignar")).Succeeded;
}

<div class="list-group animate__animated animate__fadeIn">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-circle-check fa-3x text-success opacity-25 mb-3"></i>
            <h6 class="text-muted fw-bold">No hay despachos pendientes</h6>
            <p class="small text-muted">Todos los servicios de movilidad han sido atendidos.</p>
        </div>
    }
    else
    {
        @foreach (var contrato in Model)
        {
            <div class="list-group-item mb-3 border-start border-4 border-primary shadow-sm rounded-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-1 text-primary fw-bold">@contrato.ContractNumber</h5>
                    <span class="badge bg-info text-dark rounded-pill px-3">
                        <i class="fa-regular fa-calendar me-1"></i> @contrato.BurialDate.ToShortDateString()
                        <i class="fa-regular fa-clock ms-2 me-1"></i> @contrato.BurialTime.ToString(@"hh\:mm")
                    </span>
                </div>
                <p class="mb-2 text-muted small">Difunto: <strong>@contrato.DeceasedName</strong></p>

                <div class="mt-2 border-top pt-2">
                    <h6 class="small fw-bold text-uppercase text-secondary mb-2" style="font-size: 10px;">Vehículos por Despachar:</h6>

                    @foreach (var detail in contrato.PendingDetails)
                    {
                        <div class="d-flex justify-content-between align-items-center p-2 bg-light rounded mb-2 border">
                            <div class="small">
                                <i class="@detail.VehicleType.Icon text-primary me-2"></i>
                                <span class="fw-bold">@detail.VehicleType.Name</span>
                            </div>

                            @if (canAssign)
                            {
                                <button class="btn btn-sm btn-primary rounded-pill px-3 fw-bold"
                                        onclick="openDispatchModal(@contrato.Id, @detail.Id)">
                                    <i class="fa-solid fa-truck-fast me-1"></i> Despachar
                                </button>
                            }
                            else
                            {
                                <span class="badge bg-white text-muted border rounded-pill px-3 py-2 small">
                                    <i class="fa-solid fa-lock me-1"></i> Solo lectura
                                </span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>