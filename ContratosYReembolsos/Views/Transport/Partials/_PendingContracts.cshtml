@model IEnumerable<ContratosYReembolsos.Models.Contract>

<div class="animate__animated animate__fadeIn">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-dark text-white">
                <tr class="small text-uppercase">
                    <th class="ps-4 py-3">Contrato / Fallecido</th>
                    <th>Velatorio / Destino</th>
                    <th>Fecha Sepelio</th>
                    <th class="text-center">Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-primary">#@c.ContractNumber</div>
                            <div class="small fw-bold text-uppercase">@c.DeceasedName</div>
                            <div class="x-small text-muted">Solicitante: @c.SolicitorName</div>
                        </td>
                        <td>
                            <div class="small"><i class="fa-solid fa-house-chimney-window me-1 text-muted"></i> @c.WakeName</div>
                            <div class="small fw-bold"><i class="fa-solid fa-monument me-1 text-muted"></i> @c.CemeteryName</div>
                        </td>
                        <td>
                            <div class="small fw-bold">@c.BurialDate.ToShortDateString()</div>
                            <div class="x-small text-muted">Hora: @c.BurialTime</div>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-primary btn-sm rounded-pill px-4 fw-bold shadow-sm"
                                    onclick="openDispatchModal(@c.Id)">
                                <i class="fa-solid fa-truck-arrow-right me-1"></i> Despachar
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-circle-check fa-3x mb-3 opacity-25"></i>
                            <p>No hay contratos pendientes de movilidad.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>