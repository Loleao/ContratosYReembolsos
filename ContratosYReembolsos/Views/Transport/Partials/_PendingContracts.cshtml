@using ContratosYReembolsos.Models.ValueObjects
@model IEnumerable<ContratosYReembolsos.Models.Contract>

<table class="table align-middle">
    <thead>
        <tr class="x-small text-muted">
            <th>CONTRATO / FALLECIDO</th>
            <th>SERVICIOS REQUERIDOS</th>
            <th class="text-center">GESTIÓN</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>
                    <div class="fw-bold">#@c.ContractNumber</div>
                    <div class="small text-uppercase">@c.DeceasedName</div>
                </td>
                <td>
                    @foreach (var m in c.MovilityDetails)
                    {
                        <span class="badge @(m.IsDispatched ? "bg-success-subtle text-success" : "bg-warning-subtle text-dark") border x-small">
                            <i class="fa-solid @TipoMovilidad.GetIcon(m.ServiceType) me-1"></i>
                            @m.ServiceType
                        </span>
                    }
                </td>
                <td class="text-center">
                    <button class="btn btn-primary btn-sm rounded-pill fw-bold" onclick="openDispatchModal(@c.Id)">
                        Despachar Unidad
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>