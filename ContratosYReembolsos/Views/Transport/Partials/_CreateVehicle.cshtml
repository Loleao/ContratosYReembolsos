@using ContratosYReembolsos.Models.Entities.Transport
@model Vehicle

<div class="modal fade" id="createVehicleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            @* Encabezado con degradado suave *@
            <div class="modal-header border-0 bg-light rounded-top-4 pb-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary text-white rounded-3 p-2 me-3 shadow-sm">
                        <i class="fa-solid fa-car-side fa-lg"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">Registrar Unidad</h5>
                        <small class="text-muted">Gestión de activos de movilidad</small>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form id="formVehicle" onsubmit="saveResource('@Url.Action("CreateVehicle", "Transport")', new FormData(this), 'getVehiclesModal'); return false;">
                <div class="modal-body p-4">
                    @* Campo oculto para el ID de la Filial *@
                    <input type="hidden" name="BranchId" value="@ViewBag.BranchId" />

                    <div class="row g-3">
                        @* Sección: Ubicación (No editable) *@
                        <div class="col-12 mb-2">
                            <label class="form-label small fw-bold text-muted text-uppercase">Filial Asignada</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-primary-subtle text-primary">
                                    <i class="fa-solid fa-location-dot"></i>
                                </span>
                                <input type="text" class="form-control border-0 bg-primary-subtle fw-bold text-primary"
                                       value="@ViewBag.BranchName" readonly>
                            </div>
                        </div>

                        @* Sección: Tipo de Vehículo *@
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted text-uppercase">Categoría / Tipo</label>
                            <select name="VehicleTypeId" class="form-select border-2 rounded-3 shadow-sm" required>
                                <option value="" disabled selected>Seleccione el tipo...</option>
                                @foreach (var type in ViewBag.VehicleTypes)
                                {
                                    <option value="@type.Id">@type.Name</option>
                                }
                            </select>
                        </div>

                        @* Datos Técnicos *@
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Placa</label>
                            <input type="text" name="Plate" class="form-control border-2 rounded-3"
                                   placeholder="Ej: F1X-999" required style="text-transform: uppercase;">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Año Fab.</label>
                            <input type="number" name="Year" class="form-control border-2 rounded-3"
                                   value="@DateTime.Now.Year" min="1990" max="@(DateTime.Now.Year + 1)">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Marca</label>
                            <input type="text" name="Brand" class="form-control border-2 rounded-3"
                                   placeholder="Ej: Mercedes-Benz" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Modelo</label>
                            <input type="text" name="Model" class="form-control border-2 rounded-3"
                                   placeholder="Ej: Sprinter 515" required>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 bg-light p-3 rounded-bottom-4">
                    <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow">
                        <i class="fa-solid fa-save me-2"></i>Guardar Unidad
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .bg-primary-subtle {
        background-color: rgba(13, 110, 253, 0.1) !important;
    }

    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
</style>