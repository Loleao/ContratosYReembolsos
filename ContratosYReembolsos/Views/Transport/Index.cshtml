<style>
    .bg-primary-subtle {
        background-color: rgba(13, 110, 253, 0.1) !important;
    }

    .border-primary-subtle {
        border-color: rgba(13, 110, 253, 0.2) !important;
    }
    /* Estilo para que el botón de cambiar sede resalte al pasar el mouse */
    a.text-primary:hover {
        color: #004a99 !important;
        text-decoration: underline !important;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <h4 class="fw-bold mb-0">Gestión Operativa de Movilidad</h4>
                @* Badge de la Filial Actual *@
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3">
                    <i class="fa-solid fa-location-dot me-1"></i> @ViewBag.BranchName
                </span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <p class="text-muted small mb-0">Despacho de servicios y control de recursos.</p>
                @* Botón para volver al selector solo si es Admin *@
                @if (ViewBag.IsAdmin == true)
                {
                    <a href="@Url.Action("Index", "Transport", new { branchId = (int?)null })" class="text-decoration-none small fw-bold text-primary">
                        <i class="fa-solid fa-rotate me-1"></i> Cambiar sede
                    </a>
                }
            </div>
        </div>

        <div class="bg-white p-1 rounded-pill shadow-sm border d-flex">
            <button id="btnContracts" class="btn btn-primary rounded-pill px-4 fw-bold" onclick="switchTransportView('getPendingContractsModal')">
                <i class="fa-solid fa-file-signature me-2"></i>Contratos <span class="badge bg-white text-primary ms-1">@ViewBag.PendingCount</span>
            </button>
            <button id="btnHistory" class="btn btn-light rounded-pill px-4 fw-bold text-muted" onclick="switchTransportView('getHistoryModal')">
                <i class="fa-solid fa-clock-rotate-left me-2"></i>Historial
            </button>
            <button id="btnVehicles" class="btn btn-light rounded-pill px-4 fw-bold text-muted" onclick="switchTransportView('getVehiclesModal')">
                <i class="fa-solid fa-car-rear me-2"></i>Vehículos
            </button>
            <button id="btnDrivers" class="btn btn-light rounded-pill px-4 fw-bold text-muted" onclick="switchTransportView('getDriversModal')">
                <i class="fa-solid fa-id-card me-2"></i>Conductores
            </button>
        </div>
    </div>

    <div id="transportViewContainer" class="position-relative" style="min-height: 500px;">
    </div>

    <div id="modalContainer"></div>
</div>

@section Scripts {
    <script>
        const currentBranchId = @(ViewBag.SelectedBranchId ?? 0);
        const transportUrls = {
            getPendingContractsModal: '@Url.Action("GetPendingContracts")',
            getVehiclesModal: '@Url.Action("GetVehicles")',
            getDriversModal: '@Url.Action("GetDrivers")',
            getHistoryModal: '@Url.Action("GetHistory")'
        };

        document.addEventListener("DOMContentLoaded", () => switchTransportView('getPendingContractsModal'));

        async function switchTransportView(view) {
            const container = document.getElementById('transportViewContainer');
            const baseUrl = transportUrls[view];

            if (!baseUrl) return;

            container.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>';

            try {
                // AGREGAMOS el branchId a la URL de la petición
                const response = await fetch(`${baseUrl}?branchId=${currentBranchId}`);
                const html = await response.text();
                container.innerHTML = html;

                updateButtonStyles(view);
            } catch (error) {
                container.innerHTML = '<div class="alert alert-danger">Error al cargar la información.</div>';
            }
        }

        function updateButtonStyles(activeView) {
            const buttons = {
                'contracts': document.getElementById('btnContracts'),
                'vehicles': document.getElementById('btnVehicles'),
                'drivers': document.getElementById('btnDrivers')
            };

            Object.keys(buttons).forEach(key => {
                const btn = buttons[key];
                if (key === activeView) {
                    btn.className = "btn btn-primary rounded-pill px-4 fw-bold shadow-sm";
                } else {
                    btn.className = "btn btn-light rounded-pill px-4 fw-bold text-muted";
                }
            });
        }

        async function openDispatchModal(contractId, detailId) {
            // IMPORTANTE: Enviamos ambos parámetros en la URL
            const url = `@Url.Action("GetDispatchVehicle", "Transport")?contractId=${contractId}&detailId=${detailId}`;

            try {
                const response = await fetch(url);

                // Si el controlador devuelve un error (BadRequest, NotFound, etc.)
                if (!response.ok) {
                    const errorMsg = await response.text();
                    throw new Error(errorMsg || 'Error en el servidor');
                }

                const html = await response.text();

                let modalContainer = document.getElementById('modalContainer');
                if (!modalContainer) {
                    modalContainer = document.createElement('div');
                    modalContainer.id = 'modalContainer';
                    document.body.appendChild(modalContainer);
                }

                modalContainer.innerHTML = html;

                // Asegúrate de que el ID del modal en el PartialView sea 'dispatchModal'
                const modalElement = document.getElementById('dispatchModal');
                if (modalElement) {
                    const myModal = new bootstrap.Modal(modalElement);
                    myModal.show();
                } else {
                    console.error("No se encontró el elemento 'dispatchModal' en el HTML cargado.");
                }

            } catch (error) {
                console.error("Error al cargar modal:", error);
                Swal.fire('Error', error.message || 'No se pudo cargar el formulario de despacho.', 'error');
            }
        }

        $(document).on('submit', '#formDispatchVehicle', async function (e) {
            e.preventDefault(); // <--- CRITICO: Evita que la página se recargue

            const $form = $(this);
            const $btn = $form.find('button[type="submit"]');

            // Bloqueo visual del botón
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Despachando...');

            // Recolectamos los datos (usa los atributos 'name' del form)
            const formData = new FormData(this);

            try {
                const response = await fetch('@Url.Action("StartTrip", "Transport")', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    // 1. Cerrar el modal
                    const modalElement = document.getElementById('dispatchModal');
                    const modalInstance = bootstrap.Modal.getInstance(modalElement);
                    if (modalInstance) modalInstance.hide();

                    // 2. Alerta de éxito
                    Swal.fire({
                        icon: 'success',
                        title: '¡Unidad en Ruta!',
                        text: result.message,
                        timer: 2000,
                        showConfirmButton: false
                    });

                    // 3. Refrescar la vista de contratos pendientes
                    switchTransportView('getPendingContractsModal');
                } else {
                    Swal.fire('Error', result.message, 'error');
                    $btn.prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-2"></i>Registrar Salida');
                }
            } catch (error) {
                console.error(error);
                Swal.fire('Error', 'No se pudo procesar el despacho.', 'error');
                $btn.prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-2"></i>Registrar Salida');
            }
        });

        async function prepareReturn(vehicleId) {
            const { value: observations } = await Swal.fire({
                title: '¿Confirmar Retorno de Unidad?',
                text: "El vehículo y el chofer volverán a estar disponibles para otros contratos.",
                input: 'text',
                inputPlaceholder: 'Observaciones del viaje (ej: Tanque medio lleno)',
                showCancelButton: true,
                confirmButtonText: 'Registrar Entrada',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#198754',
                inputAttributes: {
                    'aria-label': 'Observaciones'
                }
            });

            // Si el usuario no canceló el SweetAlert
            if (observations !== undefined) {
                try {
                    const formData = new FormData();
                    formData.append('vehicleId', vehicleId);
                    formData.append('observations', observations || "Sin observaciones");

                    const response = await fetch('@Url.Action("EndTrip", "Transport")', {
                        method: 'POST',
                        body: formData
                    });

                    const result = await response.json();

                    if (result.success) {
                        Swal.fire({
                            title: '¡Servicio Finalizado!',
                            text: result.message,
                            icon: 'success',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            // Refrescamos la vista actual (ya sea Seguimiento o Vehículos)
                            // Esta es la clave para que pase de "En Curso" a "Finalizado"
                            if (document.getElementById('en-ruta-tab')) {
                                switchTransportView('getHistoryModal');
                            } else {
                                switchTransportView('getVehiclesModal');
                            }
                        });
                    } else {
                        Swal.fire('Error', result.message, 'error');
                    }
                } catch (error) {
                    Swal.fire('Error', 'No se pudo conectar con el servidor.', 'error');
                }
            }
        }

        async function openCreateVehicle() {
            if (typeof currentBranchId === 'undefined' || currentBranchId === 0) {
                Swal.fire('Error', 'No se ha detectado una filial activa.', 'error');
                return;
            }

            const url = `@Url.Action("GetCreateVehicle", "Transport")?branchId=${currentBranchId}`;

            try {
                const response = await fetch(url);

                if (!response.ok) {
                    throw new Error("No se pudo obtener el formulario.");
                }

                const html = await response.text();

                // 3. Insertamos el HTML en el contenedor
                const modalContainer = document.getElementById('modalContainer');
                modalContainer.innerHTML = html;

                // 4. Inicializamos el modal SOLO si el elemento existe en el HTML cargado
                const modalElement = document.getElementById('createVehicleModal');
                if (modalElement) {
                    const myModal = new bootstrap.Modal(modalElement);
                    myModal.show();
                } else {
                    console.error("El elemento 'createVehicleModal' no se encontró en la respuesta.");
                }

            } catch (error) {
                console.error(error);
                Swal.fire('Error', 'No se pudo cargar el formulario de creación.', 'error');
            }
        }

        async function openCreateDriver() {
            // 1. Verificar si tenemos la variable global de la filial actual
            if (typeof currentBranchId === 'undefined' || currentBranchId === 0) {
                Swal.fire('Atención', 'Debe seleccionar una filial primero.', 'warning');
                return;
            }

            // 2. Construir la URL con el parámetro branchId
            // Es vital que el nombre del parámetro (branchId) coincida con el del controlador
            const url = `@Url.Action("GetCreateDriver", "Transport")?branchId=${currentBranchId}`;

            try {
                const response = await fetch(url);

                if (!response.ok) {
                    throw new Error("Error al cargar el componente");
                }

                const html = await response.text();

                // 3. Inyectar en el contenedor de modales
                const modalContainer = document.getElementById('modalContainer');
                if (modalContainer) {
                    modalContainer.innerHTML = html;

                    // 4. Mostrar el modal usando la instancia de Bootstrap
                    const modalElement = document.getElementById('createDriverModal');
                    if (modalElement) {
                        const myModal = new bootstrap.Modal(modalElement);
                        myModal.show();
                    } else {
                        console.error("No se encontró el ID 'createDriverModal' en el HTML devuelto. Revisa que el ID en la PartialView sea correcto.");
                    }
                }

            } catch (error) {
                console.error(error);
                Swal.fire('Error', 'No se pudo cargar el formulario de conductores.', 'error');
            }
        }

        async function saveResource(url, formData, viewToRefresh) {
            const response = await fetch(url, { method: 'POST', body: formData });
            const result = await response.json();
            if (result.success) {
                bootstrap.Modal.getInstance(document.querySelector('.modal')).hide();
                Swal.fire('¡Éxito!', result.message, 'success');
                switchTransportView(viewToRefresh);
            } else {
                Swal.fire('Error', result.message, 'error');
            }
        }
    </script>
}