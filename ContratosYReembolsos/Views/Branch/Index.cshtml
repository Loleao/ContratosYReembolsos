@using ContratosYReembolsos.Models.Entities.Branches
@using Microsoft.AspNetCore.Authorization
@model IEnumerable<IGrouping<string, Branch>>
@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Gestión de Filiales";
    // Evaluamos permisos una sola vez para optimizar
    var canCreate = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Filiales.Crear")).Succeeded;
    var canViewDetails = (await AuthorizationService.AuthorizeAsync(User, "Permissions.Filiales.Ver")).Succeeded;
}

<div class="container-fluid py-4 px-md-5 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0 text-dark">Gestión de Filiales</h4>
            <p class="text-muted small">Administración territorial por departamentos y sedes operativas a nivel nacional.</p>
        </div>

        @* POLÍTICA: Solo usuarios con permiso de creación ven el botón *@
        @if (canCreate)
        {
            <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" onclick="openCreateBranchModal()">
                <i class="fa-solid fa-building-circle-plus me-2"></i>Nueva Filial
            </button>
        }
    </div>

    @* --- BARRA DE BÚSQUEDA --- *@
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="card-body p-3 bg-white">
            <div class="row g-3 align-items-center">
                <div class="col-md-7">
                    <div class="input-group bg-light rounded-pill px-3">
                        <span class="input-group-text bg-transparent border-0 pe-0">
                            <i class="fa-solid fa-magnifying-glass text-muted"></i>
                        </span>
                        <input type="text" id="branchSearch" class="form-control bg-transparent border-0 py-2 shadow-none"
                               placeholder="Buscar por nombre de sede, código, departamento o distrito...">
                    </div>
                </div>
                <div class="col-md-5 text-md-end">
                    <div class="btn-group shadow-none">
                        <button class="btn btn-white border rounded-pill px-3 btn-sm fw-bold me-2" onclick="expandAll()">
                            <i class="fa-solid fa-arrows-expand me-1"></i> Expandir
                        </button>
                        <button class="btn btn-white border rounded-pill px-3 btn-sm fw-bold" onclick="collapseAll()">
                            <i class="fa-solid fa-arrows-collapse me-1"></i> Colapsar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- LISTADO ACORDEÓN POR REGIONES --- *@
    <div class="accordion border-0 shadow-none custom-regions-accordion" id="accordionRegions">
        @foreach (var group in Model.OrderBy(g => g.Key))
        {
            <div class="accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden region-group">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-bold bg-white text-dark py-3 px-4" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapse-@group.Key.Replace(" ", "")">
                        <div class="d-flex align-items-center w-100">
                            <div class="icon-shape bg-primary-subtle text-primary rounded-3 me-3">
                                <i class="fa-solid fa-map-location-dot"></i>
                            </div>
                            <span class="fs-6">@group.Key.ToUpper()</span>
                            <span class="badge bg-light text-muted border ms-auto me-3 rounded-pill fw-normal">
                                @group.Count() Sedes
                            </span>
                        </div>
                    </button>
                </h2>
                <div id="collapse-@group.Key.Replace(" ", "")" class="accordion-collapse collapse" data-bs-parent="#accordionRegions">
                    <div class="accordion-body p-4 bg-light bg-opacity-50">
                        <div class="row g-3">
                            @foreach (var branch in group.OrderBy(b => b.Name))
                            {
                                <div class="col-xl-4 col-md-6 branch-card-item"
                                     data-search="@branch.Name @branch.Code @branch.Ubigeo.Region @branch.Ubigeo.District">
                                    <div class="card border-0 shadow-sm rounded-4 hover-lift h-100">
                                        <div class="card-body p-3 d-flex flex-column">
                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <div class="bg-dark text-white rounded-3 px-2 py-1 fw-bold" style="font-size: 0.65rem;">
                                                    @branch.Code
                                                </div>
                                                <span class="badge bg-white text-primary border border-primary-subtle rounded-pill x-small px-2 py-1">
                                                    <i class="fa-solid fa-monument me-1"></i> @(branch.Cemeteries?.Count ?? 0) Cem.
                                                </span>
                                            </div>

                                            <h6 class="fw-bold text-dark mb-1 text-truncate" title="@branch.Name">@branch.Name</h6>
                                            <p class="text-muted mb-3 x-small">
                                                <i class="fa-solid fa-location-dot me-1 text-danger opacity-75"></i>
                                                @branch.Ubigeo.District, @branch.Ubigeo.Province
                                            </p>

                                            <div class="d-grid mt-auto">
                                                @* POLÍTICA: Solo habilitado si puede ver detalles *@
                                                @if (canViewDetails)
                                                {
                                                    <a href="@Url.Action("Details", "Branch", new { id = branch.Id })"
                                                       class="btn btn-sm btn-outline-primary rounded-pill fw-bold border-2 py-2">
                                                        Gestionar Filial <i class="fa-solid fa-arrow-right ms-1"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-light rounded-pill fw-bold border-2 py-2 text-muted" disabled>
                                                        <i class="fa-solid fa-lock me-1"></i> Acceso Restringido
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* --- ESTADO BÚSQUEDA VACÍA --- *@
    <div id="emptySearchState" class="text-center py-5 d-none animate__animated animate__fadeIn">
        <div class="bg-light rounded-circle p-4 d-inline-block mb-3">
            <i class="fa-solid fa-building-circle-exclamation fa-3x text-muted opacity-25"></i>
        </div>
        <h5 class="fw-bold text-dark">No se encontraron sedes</h5>
        <p class="text-muted small">Intenta con otro término de búsqueda o departamento.</p>
    </div>
</div>

<div id="modalBranchContainer"></div>

<style>
    .custom-regions-accordion .accordion-button:not(.collapsed) {
        background-color: #fff;
        color: var(--bs-primary);
        box-shadow: none;
        border-bottom: 1px solid #f1f4f8;
    }

    .custom-regions-accordion .accordion-button::after {
        background-size: 1rem;
    }

    .icon-shape {
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hover-lift {
        transition: all 0.25s ease;
    }

        .hover-lift:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.08) !important;
            border: 1px solid rgba(0, 74, 153, 0.1) !important;
        }

    .x-small {
        font-size: 0.7rem;
    }

    .bg-primary-subtle {
        background-color: #e0eefe !important;
    }

    /* Personalización del acordeón para quitar el foco azul de Bootstrap */
    .accordion-button:focus {
        box-shadow: none;
        border-color: rgba(0,0,0,.125);
    }
</style>

@section Scripts {
    <script>
        const urlGetCreateBranch = '@Url.Action("GetCreateBranch", "Branch")';

        // --- LÓGICA DE FILTRO INTELIGENTE ---
        $('#branchSearch').on('input', function() {
            let term = $(this).val().toLowerCase().trim();
            let totalVisible = 0;

            $('.region-group').each(function() {
                let $group = $(this);
                let hasMatchInGroup = false;

                $group.find('.branch-card-item').each(function() {
                    let searchData = $(this).data('search').toLowerCase();
                    if (searchData.includes(term)) {
                        $(this).show();
                        hasMatchInGroup = true;
                        totalVisible++;
                    } else {
                        $(this).hide();
                    }
                });

                if (hasMatchInGroup) {
                    $group.show();
                    // Si el usuario está escribiendo, expandimos las regiones que coinciden
                    if (term.length > 2) {
                        $group.find('.accordion-collapse').addClass('show');
                        $group.find('.accordion-button').removeClass('collapsed');
                    }
                } else {
                    $group.hide();
                }
            });

            // Manejo del Empty State
            if (totalVisible === 0) $('#emptySearchState').removeClass('d-none');
            else $('#emptySearchState').addClass('d-none');
        });

        function expandAll() {
            $('.accordion-collapse').addClass('show');
            $('.accordion-button').removeClass('collapsed');
        }

        function collapseAll() {
            $('.accordion-collapse').removeClass('show');
            $('.accordion-button').addClass('collapsed');
        }

        // --- MANTENER TUS FUNCIONES EXISTENTES ---
        async function openCreateBranchModal() {
            try {
                const response = await fetch(urlGetCreateBranch);
                const html = await response.text();
                document.getElementById('modalBranchContainer').innerHTML = html;
                new bootstrap.Modal(document.getElementById('modalCreateBranch')).show();
            } catch (error) {
                Swal.fire('Error', 'No se pudo cargar el formulario.', 'error');
            }
        }

        async function submitBranchForm() {
            const form = document.getElementById('formCreateBranch');
            if (!form.checkValidity()) { form.reportValidity(); return; }

            const formData = new FormData(form);
            try {
                const response = await fetch(form.action, { method: 'POST', body: formData });
                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '¡Logrado!',
                        text: result.message,
                        confirmButtonColor: '#198754'
                    }).then(() => location.reload());
                } else {
                    Swal.fire({
                        icon: 'warning',
                        title: 'No se pudo guardar',
                        text: result.message,
                        confirmButtonColor: '#ffc107'
                    });
                }
            } catch (error) {
                Swal.fire('Error', 'Error crítico de conexión.', 'error');
            }
        }

        async function loadProvincias() {
            const region = document.getElementById('selectRegion').value;
            const selectProv = document.getElementById('selectProvincia');
            const selectDist = document.getElementById('selectDistrito');
            selectProv.innerHTML = '<option value="">Cargando...</option>';
            selectDist.innerHTML = '<option value="">Seleccione...</option>';
            selectDist.disabled = true;
            if (!region) { selectProv.disabled = true; return; }
            const response = await fetch(`@Url.Action("GetProvincias", "Branch")?region=${region}`);
            const data = await response.json();
            selectProv.innerHTML = '<option value="">Seleccione Provincia</option>';
            data.forEach(p => selectProv.innerHTML += `<option value="${p}">${p}</option>`);
            selectProv.disabled = false;
        }

        async function loadDistritos() {
            const region = document.getElementById('selectRegion').value;
            const provincia = document.getElementById('selectProvincia').value;
            const selectDist = document.getElementById('selectDistrito');
            selectDist.innerHTML = '<option value="">Cargando...</option>';
            if (!provincia) { selectDist.disabled = true; return; }
            const response = await fetch(`@Url.Action("GetDistritos", "Branch")?region=${region}&provincia=${provincia}`);
            const data = await response.json();
            selectDist.innerHTML = '<option value="">Seleccione Distrito</option>';
            data.forEach(d => selectDist.innerHTML += `<option value="${d.id}">${d.district}</option>`);
            selectDist.disabled = false;
        }
    </script>
}