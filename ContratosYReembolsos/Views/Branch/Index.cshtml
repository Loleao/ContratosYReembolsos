@model IEnumerable<IGrouping<string, ContratosYReembolsos.Models.Branch>>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0 text-dark">Gestión de Filiales</h4>
            <p class="text-muted small">Administración por departamentos y sedes operativas</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4 fw-bold shadow" onclick="openCreateBranchModal()">
            <i class="fa-solid fa-building-circle-plus me-2"></i>Nueva Filial
        </button>
    </div>

    <div class="accordion border-0 shadow-sm rounded-4 overflow-hidden" id="accordionRegions">
        @foreach (var group in Model)
        {
            <div class="accordion-item border-0 border-bottom">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-bold bg-white text-dark py-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@group.Key.Replace(" ", "")">
                        <i class="fa-solid fa-map-location-dot me-3 text-primary"></i>
                        @group.Key.ToUpper()
                        <span class="badge bg-primary-subtle text-primary border ms-3">@group.Count() Sedes</span>
                    </button>
                </h2>
                <div id="collapse-@group.Key.Replace(" ", "")" class="accordion-collapse collapse" data-bs-parent="#accordionRegions">
                    <div class="accordion-body p-0 bg-light">
                        <div class="list-group list-group-flush">
                            @foreach (var branch in group)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center p-3 border-0 border-bottom hover-bg">
                                    <div class="ps-4">
                                        <div class="fw-bold text-dark">@branch.Name</div>
                                        <small class="text-muted">
                                            <span class="badge bg-dark text-white me-2">@branch.Code</span>
                                            <i class="fa-solid fa-location-dot me-1"></i>
                                            @branch.Ubigeo.Region / @branch.Ubigeo.Province / @branch.Ubigeo.District
                                        </small>
                                    </div>
                                    <div class="pe-3 d-flex align-items-center">
                                        <span class="badge bg-light text-muted border rounded-pill me-3">
                                            <i class="fa-solid fa-monument me-1"></i> @(branch.Cemeteries?.Count ?? 0)
                                        </span>
                                        <a href="@Url.Action("Details", "Branch", new { id = branch.Id })" class="btn btn-sm btn-white border shadow-sm rounded-pill px-3 fw-bold text-primary">
                                            Ver Detalle
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div id="modalBranchContainer"></div>

@section Scripts {
    <script>
        const urlGetCreateBranch = '@Url.Action("GetCreateBranch", "Branch")';

        async function openCreateBranchModal() {
            try {
                const response = await fetch(urlGetCreateBranch);
                const html = await response.text();
                document.getElementById('modalBranchContainer').innerHTML = html;

                // Inicializamos el modal
                new bootstrap.Modal(document.getElementById('modalCreateBranch')).show();
            } catch (error) {
                Swal.fire('Error', 'No se pudo cargar el formulario.', 'error');
            }
        }

        async function submitBranchForm() {
            const form = document.getElementById('formCreateBranch');
            if (!form.checkValidity()) { form.reportValidity(); return; }

            const formData = new FormData(form);
            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '¡Logrado!',
                        text: result.message,
                        confirmButtonColor: '#198754'
                    }).then(() => location.reload());
                } else {
                    // Aquí verás el error que definimos en el paso 1 (los errores de validación)
                    Swal.fire({
                        icon: 'warning',
                        title: 'No se pudo guardar',
                        text: result.message,
                        confirmButtonColor: '#ffc107'
                    });
                }
            } catch (error) {
                Swal.fire('Error', 'Error crítico de conexión con el servidor.', 'error');
            }
        }

        async function loadProvincias() {
            const region = document.getElementById('selectRegion').value;
            const selectProv = document.getElementById('selectProvincia');
            const selectDist = document.getElementById('selectDistrito');

            // Resetear hijos
            selectProv.innerHTML = '<option value="">Cargando...</option>';
            selectDist.innerHTML = '<option value="">Seleccione...</option>';
            selectDist.disabled = true;

            if (!region) {
                selectProv.disabled = true;
                return;
            }

            const response = await fetch(`@Url.Action("GetProvincias", "Branch")?region=${region}`);
            const data = await response.json();

            selectProv.innerHTML = '<option value="">Seleccione Provincia</option>';
            data.forEach(p => {
                selectProv.innerHTML += `<option value="${p}">${p}</option>`;
            });
            selectProv.disabled = false;
        }

        async function loadDistritos() {
            const region = document.getElementById('selectRegion').value;
            const provincia = document.getElementById('selectProvincia').value;
            const selectDist = document.getElementById('selectDistrito');

            selectDist.innerHTML = '<option value="">Cargando...</option>';

            if (!provincia) {
                selectDist.disabled = true;
                return;
            }

            const response = await fetch(`@Url.Action("GetDistritos", "Branch")?region=${region}&provincia=${provincia}`);
            const data = await response.json();

            selectDist.innerHTML = '<option value="">Seleccione Distrito</option>';
            data.forEach(d => {
                selectDist.innerHTML += `<option value="${d.id}">${d.district}</option>`;
            });
            selectDist.disabled = false;
        }
    </script>
}