@using ContratosYReembolsos.Models.Entities.FixedAssets
@model List<FixedAsset>

<div class="card border-0 shadow-sm rounded-4 animate__animated animate__fadeIn">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4" style="width: 150px;">Cód. Patrimonial</th>
                        <th>Activo / Modelo</th>
                        <th>Marca</th>
                        <th>N° Serie</th>
                        <th>Condición</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-folder-open fa-3x mb-3 opacity-20"></i>
                                <p>No hay activos registrados en esta sede.</p>
                            </td>
                        </tr>
                    }
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-primary">@a.PatrimonialCode</td>
                            <td>
                                <div class="fw-bold text-dark">@a.AssetCatalog?.Name</div>
                                <div class="x-small text-muted">@a.AssetCatalog?.Subcategory?.Name</div>
                            </td>
                            <td><span class="badge bg-light text-dark border">@a.AssetCatalog?.Brand</span></td>
                            <td class="small font-monospace">@a.SerialNumber</td>
                            <td>
                                @switch (a.Condition)
                                {
                                    case AssetCondition.New: // O el nombre que tenga tu Enum para el valor 0
                                        <span class="text-success"><i class="fa-solid fa-star me-1"></i>Nuevo</span>
                                        break;
                                    case AssetCondition.Good: // O el nombre que tenga tu Enum para el valor 2
                                        <span class="text-primary"><i class="fa-solid fa-check me-1"></i>Bueno</span>
                                        break;
                                    default:
                                        <span class="text-warning">Regular</span>
                                        break;
                                }
                            </td>
                            <td class="text-center">
                                @if (a.Status == AssetStatus.Available)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success px-3">Disponible</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-warning-subtle text-warning px-3">En Tránsito</span>
                                }
                            </td>
                            <td class="text-center pe-4">
                                <button class="btn btn-light btn-sm rounded-circle" title="Ver Detalles">
                                    <i class="fa-solid fa-eye text-primary"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>