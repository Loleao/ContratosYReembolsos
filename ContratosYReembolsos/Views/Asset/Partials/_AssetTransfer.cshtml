@using ContratosYReembolsos.Models.ViewModels.Assets
@model AssetTransferFormViewModel

<div class="modal fade" id="modalTransferContainer" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-warning text-dark border-0 py-3">
                <h5 class="modal-title fw-bold">
                    <i class="fa-solid fa-truck-fast me-2"></i>Nueva Transferencia de Activos Patrimoniales
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="formAssetTransfer">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">

                    @* --- CABECERA DE CONTROL Y SEDES --- *@
                    <div class="row g-3 mb-4 p-3 bg-light rounded-3 border">
                        <div class="col-md-3">
                            <label class="form-label x-small fw-bold text-muted text-uppercase">N° Movimiento TR</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-hashtag text-warning"></i></span>
                                <input type="text" name="InternalControlNumber" value="@ViewBag.NextTransferCode"
                                       class="form-control bg-white border-start-0 fw-bold text-dark" readonly />
                            </div>
                            <small class="x-small text-muted">Correlativo de traslado</small>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label x-small fw-bold text-primary text-uppercase">Sede Origen (Despacho)</label>
                            @if (Model.IsAdmin)
                            {
                                <select name="OriginBranchId" id="select-origin-branch" class="form-select border-2 shadow-sm" onchange="onOriginBranchChange(this.value)" required>
                                    <option value="">-- Seleccione Origen --</option>
                                    @foreach (var b in Model.AllBranches)
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="hidden" name="OriginBranchId" value="@Model.UserBranchId" id="select-origin-branch" />
                                <input type="text" class="form-control bg-white border-2 fw-bold" value="@Model.UserBranchName" readonly />
                            }
                        </div>

                        <div class="col-md-1 d-flex align-items-center justify-content-center pt-3">
                            <i class="fa-solid fa-arrow-right-long fa-xl text-muted opacity-50"></i>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label x-small fw-bold text-danger text-uppercase">Sede Destino (Recepción)</label>
                            <select name="TargetBranchId" class="form-select border-2 shadow-sm" required>
                                <option value="">-- Seleccione Destino --</option>
                                @foreach (var b in Model.AllBranches)
                                {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    @* --- TABLA DINÁMICA --- *@
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <h6 class="fw-bold text-dark mb-0">Equipos a Trasladar</h6>
                            <small class="text-muted">Solo se muestran equipos en estado 'Disponible'</small>
                        </div>
                        <button type="button" onclick="addTransferAssetRow()" class="btn btn-outline-warning btn-sm rounded-pill px-4 text-dark fw-bold" id="btn-add-row" disabled>
                            <i class="fa-solid fa-plus me-1"></i> Agregar Activo
                        </button>
                    </div>

                    <div class="table-responsive" style="min-height: 250px; overflow-x: hidden;">
                        <table class="table table-bordered align-middle" style="table-layout: fixed; width: 100%;">
                            <thead class="table-dark x-small">
                                <tr>
                                    <th style="width: 60%;">Activo (Cód. Patrimonial - Modelo - Serie)</th>
                                    <th style="width: 30%;">Estado Actual</th>
                                    <th style="width: 10%;"></th>
                                </tr>
                            </thead>
                            <tbody id="transferTableBody">
                                @* Aquí se inyectan las filas con los activos de la sede elegida *@
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <label class="form-label x-small fw-bold text-muted text-uppercase">Observaciones del Traslado</label>
                        <textarea name="Observation" class="form-control border-2" rows="2" placeholder="Motivo del traslado o detalles del transportista..."></textarea>
                    </div>
                </div>

                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-5 fw-bold shadow text-dark">
                        <i class="fa-solid fa-truck-ramp-box me-2"></i>INICIAR TRASLADO
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>