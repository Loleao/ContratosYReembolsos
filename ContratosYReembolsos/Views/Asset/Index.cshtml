@{
    ViewData["Title"] = "Activos Fijos";
}

<div class="container-fluid p-4 animate__animated animate__fadeIn">
    <div class="row g-3">
        @* Bento Card: Título y Acciones *@
        <div class="col-md-7">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-4 bg-white d-flex justify-content-between">
                <div>
                    <h3 class="fw-bold text-dark mb-1">Módulo de Activos</h3>
                    <p class="text-muted small">Gestión y control de bienes patrimoniales <span class="text-primary fw-bold">FONAFUN</span>.</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-dark rounded-pill px-4" onclick="openRegisterModal()">
                        <i class="fa-solid fa-plus me-2"></i>Nuevo Activo
                    </button>
                    <a asp-action="Catalog" class="btn btn-outline-primary rounded-pill px-4">
                        <i class="fa-solid fa-layer-group me-2"></i>Catálogo
                    </a>
                </div>
            </div>
        </div>

        @* Bento Card: Estadísticas rápidas *@
        <div class="col-md-5">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-4 bg-primary text-white">
                <h6 class="text-uppercase small fw-bold opacity-75">Resumen de Estados</h6>
                <div class="d-flex justify-content-around mt-3">
                    <div class="text-center">
                        <h4 class="fw-bold mb-0">--</h4>
                        <span class="x-small">Uso</span>
                    </div>
                    <div class="text-center">
                        <h4 class="fw-bold mb-0">--</h4>
                        <span class="x-small">Taller</span>
                    </div>
                    <div class="text-center">
                        <h4 class="fw-bold mb-0">--</h4>
                        <span class="x-small">Baja</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>