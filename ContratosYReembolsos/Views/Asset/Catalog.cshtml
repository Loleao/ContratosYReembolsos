@model List<ContratosYReembolsos.Models.Entities.FixedAssets.AssetCatalog>
@{
    ViewData["Title"] = "Catálogo de Activos";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0"><i class="fa-solid fa-layer-group me-2"></i>Modelos de Activos</h4>
        <button class="btn btn-primary rounded-pill px-4" onclick="openCreateCatalogModal()">
            <i class="fa-solid fa-plus me-1"></i> Registrar Nuevo Modelo
        </button>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive p-3">
            <table class="table table-hover align-middle" id="tableCatalog">
                <thead class="bg-light">
                    <tr class="x-small text-muted text-uppercase">
                        <th>Imagen</th>
                        <th>Nombre / Descripción</th>
                        <th>Marca / Modelo</th>
                        <th>Categoría</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="width: 80px;">
                                <div class="rounded-3 bg-light d-flex align-items-center justify-content-center" style="height: 50px;">
                                    <i class="fa-solid fa-image text-muted opacity-50"></i>
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Name</div>
                                <div class="x-small text-muted">ID: #@item.Id</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border fw-normal">@item.Brand</span>
                                <span class="text-muted small ms-1">@item.Model</span>
                            </td>
                            <td>
                                <div class="small">@item.Subcategory.Category.Name</div>
                                <div class="x-small text-muted">@item.Subcategory.Name</div>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-secondary rounded-circle" onclick="editCatalogItem(@item.Id)">
                                    <i class="fa-solid fa-pencil"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>

</script>