@model ContratosYReembolsos.Models.Entities.FixedAssets.AssetCategory
@{
    ViewData["Title"] = "Subcategorías de " + Model.Name;
}

<div class="container-fluid p-4">
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Categories" class="text-decoration-none">Categorías</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="fw-bold m-0">Subcategorías de @Model.Name</h4>
            <button class="btn btn-primary rounded-pill px-4" onclick="openCreateSubCategoryModal(@Model.Id)">
                <i class="fa-solid fa-plus me-1"></i> Nueva Subcategoría
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive p-3">
            <table class="table table-hover align-middle">
                <thead class="bg-light">
                    <tr class="x-small text-muted text-uppercase">
                        <th>Nombre de Subcategoría</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in Model.Subcategories)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@sub.Name</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="editSubCategory(@sub.Id)">
                                    <i class="fa-solid fa-pen-to-square me-1"></i> Editar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>