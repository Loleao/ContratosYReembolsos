@model List<ContratosYReembolsos.Models.Entities.Branches.Branch>
@{
    ViewData["Title"] = "Selección de Sede - Activos";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark">Gestión Patrimonial por Sede</h2>
        <p class="text-muted">Seleccione una filial para administrar sus activos físicos y asignaciones.</p>
    </div>

    <div class="row g-4 justify-content-center">
        @foreach (var branch in Model)
        {
            <div class="col-md-4 col-lg-3">
                <a href="@Url.Action("BranchInventory", "Assets", new { branchId = branch.Id })" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm rounded-4 bento-hover p-4 text-center">
                        <div class="icon-shape bg-primary-light text-primary rounded-circle mx-auto mb-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                            <i class="fa-solid fa-building-shield fa-xl"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">@branch.Name</h5>
                        <p class="x-small text-muted mb-0">Haga clic para gestionar activos</p>
                    </div>
                </a>
            </div>
        }
    </div>
</div>