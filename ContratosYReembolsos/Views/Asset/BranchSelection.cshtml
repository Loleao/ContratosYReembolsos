@using ContratosYReembolsos.Models.Entities.Branches
@model IEnumerable<IGrouping<string, Branch>>

@{
    ViewData["Title"] = "Supervisión de Activos";
}

<style>
    .select2-container--bootstrap-5 .select2-selection {
        height: 38px !important;
        display: flex !important;
        align-items: center !important;
    }

    /* Estilos para las Cards de Sedes dentro del acordeón */
    .branch-card-horizontal {
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        border: 1px solid #e2e8f0;
        border-radius: 15px;
        background: white;
    }

        .branch-card-horizontal:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
            border-color: #0d6efd;
        }

    .icon-box-asset {
        width: 50px;
        height: 50px;
        background: #e7f1ff;
        color: #0d6efd;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .search-pill {
        background: #f1f4f8;
        border-radius: 50px;
        padding: 10px 25px;
        border: 1px solid transparent;
        width: 100%;
        transition: 0.3s;
    }

        .search-pill:focus {
            outline: none;
            background: white;
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
        }
</style>

<div class="container py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Supervisión de Activos Fijos</h3>
            <p class="text-muted small mb-0">Gestión patrimonial <span class="text-primary fw-bold">FONAFUN</span>.</p>
        </div>
        <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
            <button class="btn btn-success px-4 fw-bold border-0" onclick="openAssetEntryModal()">
                <i class="fa-solid fa-plus me-2"></i>Ingreso Central
            </button>
            <button class="btn btn-warning px-4 fw-bold text-dark border-0" onclick="openAssetTransferModal()">
                <i class="fa-solid fa-truck-fast me-2"></i>Transferir Activo
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="top: 15px; left: 20px;"></i>
                <input type="text" id="assetBranchSearch" class="search-pill ps-5"
                       placeholder="Filtrar sede por nombre, región o código patrimonial...">
            </div>
        </div>
    </div>

    <div class="accordion border-0 shadow-none" id="accordionAssets">
        @foreach (var group in Model.OrderBy(g => g.Key))
        {
            <div class="accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden region-group">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-bold py-3 px-4 bg-white text-dark" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapse-@group.Key.Replace(" ", "")">
                        <div class="d-flex align-items-center w-100">
                            <i class="fa-solid fa-map-location-dot me-3 text-primary fs-5"></i>
                            <span>@group.Key.ToUpper()</span>
                            <span class="badge bg-light text-primary border ms-auto me-3 rounded-pill fw-bold">@group.Count() Filiales</span>
                        </div>
                    </button>
                </h2>
                <div id="collapse-@group.Key.Replace(" ", "")" class="accordion-collapse collapse" data-bs-parent="#accordionAssets">
                    <div class="accordion-body p-4 bg-light bg-opacity-50">
                        <div class="row g-3">
                            @foreach (var branch in group.OrderBy(b => b.Name))
                            {
                                <div class="col-xl-4 col-md-6 branch-item" data-search="@branch.Name @branch.Code @group.Key">
                                    <div class="card branch-card-horizontal shadow-sm h-100">
                                        <div class="card-body p-3">
                                            <div class="d-flex align-items-start mb-3">
                                                <div class="icon-box-asset me-3 flex-shrink-0">
                                                    <i class="fa-solid fa-hotel fs-4"></i>
                                                </div>
                                                <div class="overflow-hidden">
                                                    <div class="d-flex align-items-center gap-2 mb-1">
                                                        <span class="badge bg-dark text-white" style="font-size: 0.65rem;">@branch.Code</span>
                                                    </div>
                                                    <h6 class="fw-bold text-dark mb-1 text-truncate">@branch.Name</h6>
                                                    <small class="text-muted text-truncate d-block" style="font-size: 0.75rem;">
                                                        <i class="fa-solid fa-location-dot me-1 text-danger opacity-75"></i>
                                                        @branch.Address
                                                    </small>
                                                </div>
                                            </div>
                                            <div class="d-grid">
                                                <a asp-action="BranchAssets" asp-route-branchId="@branch.Id"
                                                   class="btn btn-sm btn-outline-primary rounded-pill fw-bold py-2 border-2">
                                                    Gestionar Sede <i class="fa-solid fa-chevron-right ms-1"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div id="emptySearch" class="text-center py-5 d-none animate__animated animate__fadeIn">
        <div class="bg-light rounded-circle p-4 d-inline-block mb-3">
            <i class="fa-solid fa-boxes-stacked fa-3x text-muted opacity-25"></i>
        </div>
        <h5 class="fw-bold text-dark">No se encontraron sedes</h5>
        <p class="text-muted">Intente con otro nombre o departamento.</p>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        // --- MOTOR DE BÚSQUEDA INTELIGENTE ---
        $('#assetBranchSearch').on('input', function() {
            let term = $(this).val().toLowerCase().trim();
            let totalMatch = 0;

            $('.region-group').each(function() {
                let $region = $(this);
                let regionMatch = false;

                $region.find('.branch-item').each(function() {
                    if ($(this).data('search').toLowerCase().includes(term)) {
                        $(this).show();
                        regionMatch = true;
                        totalMatch++;
                    } else {
                        $(this).hide();
                    }
                });

                if (regionMatch) {
                    $region.show();
                    if (term.length > 1) {
                        $region.find('.accordion-collapse').addClass('show');
                        $region.find('.accordion-button').removeClass('collapsed');
                    }
                } else {
                    $region.hide();
                }
            });

            if (totalMatch === 0 && term.length > 0) $('#emptySearch').removeClass('d-none');
            else $('#emptySearch').addClass('d-none');
        });

        function expandAll() {
            $('.accordion-collapse').addClass('show');
            $('.accordion-button').removeClass('collapsed');
        }


        // 1. VARIABLES GLOBALES
        let globalCatalogItems = [];
        let assetEntryRowIndex = 0;

        /**
         * 2. CARGA PREVIA DE DATOS
         * Carga el catálogo en formato JSON para evitar llamadas repetitivas al servidor
         * cada vez que se agrega una fila nueva.
         */
        async function preloadCatalogData() {
            try {
                const res = await fetch('@Url.Action("GetCatalogJson", "Asset")');
                globalCatalogItems = await res.json();
            } catch (e) {
                console.error("Error cargando catálogo maestro:", e);
            }
        }

        document.addEventListener("DOMContentLoaded", preloadCatalogData);

        /**
         * 3. GESTIÓN DEL MODAL
         */
        async function openAssetEntryModal() {
            // Mostrar loading de SweetAlert mientras se descarga el HTML del parcial
            Swal.fire({ title: 'Cargando formulario...', didOpen: () => { Swal.showLoading() } });

            try {
                const res = await fetch('@Url.Action("GetRegisterEntryForm", "Asset")');
                const html = await res.text();

                // Inyectar HTML y resetear el índice de filas
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;
                assetEntryRowIndex = 0;

                // Agregar la primera fila automáticamente y mostrar modal
                addNewAssetRow();

                Swal.close();
                const modal = new bootstrap.Modal(document.getElementById('modalAssetEntryContainer'));
                modal.show();
            } catch (e) {
                Swal.fire('Error', 'No se pudo cargar el formulario de ingreso', 'error');
            }
        }

        /**
         * 4. LÓGICA DE FILAS DINÁMICAS
         */
        function addNewAssetRow() {
            const idx = assetEntryRowIndex;
            const options = globalCatalogItems.map(p => `<option value="${p.id}">${p.name} (${p.brand})</option>`).join('');

            const html = `
                <tr id="row-asset-${idx}" class="animate__animated animate__fadeIn">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 38px; border: 1px solid #dee2e6;">
                                <i class="fa-solid fa-laptop text-muted"></i>
                            </div>
                            <div style="flex-grow: 1; min-width: 0;">
                                <select name="Assets[${idx}].AssetCatalogId" class="form-select select-asset-catalog" data-idx="${idx}" required>
                                    <option value="">-- Seleccione Modelo --</option>
                                    ${options}
                                </select>
                            </div>
                        </div>
                    </td>
                    <td>
                        <input type="text" name="Assets[${idx}].PatrimonialCode" id="code-${idx}"
                               class="form-control form-control-sm text-center fw-bold bg-light" readonly placeholder="Auto" />
                    </td>
                    <td>
                        <input type="text" name="Assets[${idx}].SerialNumber" class="form-control form-control-sm" placeholder="Serie factory" required />
                    </td>
                    <td>
                        <select name="Assets[${idx}].Condition" class="form-select form-select-sm border-0 bg-transparent">
                            <option value="0">Nuevo</option>
                            <option value="2">Bueno</option>
                            <option value="3">Regular</option>
                        </select>
                    </td>
                    <td class="text-center">
                        <button type="button" onclick="removeAssetRow(${idx})" class="btn btn-link text-danger p-0">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>`;

            $('#assetEntryTableBody').append(html);

            // Inicializar Select2 en la nueva fila
            $(`#row-asset-${idx} .select-asset-catalog`).select2({
                theme: 'bootstrap-5',
                dropdownParent: $('#modalAssetEntryContainer'),
                width: '100%'
            });

            assetEntryRowIndex++;
        }

        function removeAssetRow(idx) {
            $(`#row-asset-${idx}`).remove();
            // Forzamos el recalculo de los códigos visibles para mantener el orden
            $('.select-asset-catalog').trigger('change');
        }

        /**
         * 5. GENERACIÓN DE CÓDIGO PATRIMONIAL PREVENTIVO
         * Llama al servidor para previsualizar el código basado en la subcategoría del modelo elegido.
         */
        $(document).on('change', '.select-asset-catalog', async function() {
            const idx = $(this).data('idx');
            const catalogId = $(this).val();

            if (!catalogId) {
                $(`#code-${idx}`).val('');
                return;
            }

            try {
                // 1. Obtenemos el código base del servidor
                const res = await fetch(`@Url.Action("GetNextCode", "Asset")?catalogId=${catalogId}`);
                const data = await res.json();

                if (!data.code) return;

                // 2. Lógica para evitar duplicados en la vista:
                // Contamos cuántas veces aparece este mismo catalogId en filas ANTERIORES a la actual
                let countSameProduct = 0;
                $('.select-asset-catalog').each(function() {
                    const currentIdx = $(this).data('idx');
                    // Solo contamos si es el mismo producto y está en una fila distinta (o anterior)
                    if (currentIdx < idx && $(this).val() === catalogId) {
                        countSameProduct++;
                    }
                });

                // 3. Ajustamos el correlativo visualmente
                // Separamos el prefijo del número (Ej: FON-COM-2026-0005 -> 0005)
                const parts = data.code.split('-');
                const lastPart = parts.pop();
                const baseNumber = parseInt(lastPart);
                const newNumber = baseNumber + countSameProduct;

                // Formateamos con ceros a la izquierda (padding de 4)
                const formattedNumber = newNumber.toString().padStart(4, '0');

                // Reconstruimos el código: FON-COM-2026-0006...
                const finalCode = [...parts, formattedNumber].join('-');

                $(`#code-${idx}`).val(finalCode);

            } catch (e) {
                console.error("Error al generar código visual:", e);
            }
        });

        /**
         * 6. ENVÍO DEL FORMULARIO (PROCESO MASIVO)
         */
        $(document).on('submit', '#formBulkAssetEntry', async function (e) {
            e.preventDefault();

            // Verificación mínima de filas
            if ($('#assetEntryTableBody tr').length === 0) {
                Swal.fire('Atención', 'Debe agregar al menos un activo a la lista', 'warning');
                return;
            }

            const $btn = $(this).find('button[type="submit"]');
            const originalText = $btn.html();

            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Procesando...');

            try {
                const res = await fetch('@Url.Action("RegisterBulkAssets", "Asset")', {
                    method: 'POST',
                    body: new FormData(this)
                });

                const result = await res.json();

                if (result.success) {
                    Swal.fire({
                        title: '¡Ingreso Exitoso!',
                        text: result.message,
                        icon: 'success',
                        confirmButtonColor: '#198754'
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Error en el registro', result.message, 'error');
                    $btn.prop('disabled', false).html(originalText);
                }
            } catch (e) {
                Swal.fire('Error crítico', 'No se pudo conectar con el servidor', 'error');
                $btn.prop('disabled', false).html(originalText);
            }
        });



        let availableAssetsForTransfer = [];

        async function openAssetTransferModal() {
            // Feedback visual de carga
            Swal.fire({
                title: 'Preparando traslado...',
                didOpen: () => { Swal.showLoading() }
            });

            try {
                // Llamada al método que definimos en el Controller
                const res = await fetch('@Url.Action("GetAssetTransferForm", "Asset")');
                const html = await res.text();

                // Inyectar en el contenedor de la página
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;

                Swal.close();

                // Mostrar el modal XL
                const modal = new bootstrap.Modal(document.getElementById('modalTransferContainer'));
                modal.show();

            } catch (e) {
                console.error(e);
                Swal.fire('Error', 'No se pudo cargar el formulario de transferencias', 'error');
            }
        }

        async function onOriginBranchChange(branchId) {
            if (!branchId) return;
            $('#btn-add-row').prop('disabled', true);

            const res = await fetch(`@Url.Action("GetAvailableAssets", "Asset")?branchId=${branchId}`);
            availableAssetsForTransfer = await res.json();

            $('#transferTableBody').empty();
            $('#btn-add-row').prop('disabled', false);
        }

        function addTransferAssetRow() {
            const idx = Date.now();
            const options = availableAssetsForTransfer.map(a => `<option value="${a.id}" data-status="${a.status}">${a.text}</option>`).join('');

            const html = `
                <tr id="row-tr-${idx}">
                    <td>
                        <select name="SelectedAssetIds" class="form-select select-asset-transfer" required>
                            <option value="">-- Seleccione Activo --</option>
                            ${options}
                        </select>
                    </td>
                    <td><input type="text" class="form-control form-control-sm border-0 bg-light status-preview" readonly /></td>
                    <td class="text-center">
                        <button type="button" onclick="$(this).closest('tr').remove()" class="btn btn-link text-danger"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>`;

            $('#transferTableBody').append(html);
            $('.select-asset-transfer').select2({ theme: 'bootstrap-5', dropdownParent: $('#modalTransferContainer') });
        }

        $(document).on('change', '.select-asset-transfer', function() {
            const status = $(this).find(':selected').data('status');
            $(this).closest('tr').find('.status-preview').val(status);
        });

        $(document).on('submit', '#formAssetTransfer', async function (e) {
            e.preventDefault();

            const $btn = $(this).find('button[type="submit"]');
            const originalText = $btn.html();

            // Validación: Al menos un activo seleccionado
            if ($('#transferTableBody tr').length === 0) {
                Swal.fire('Atención', 'Debe agregar al menos un activo para iniciar el traslado', 'warning');
                return;
            }

            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Iniciando...');

            try {
                const formData = new FormData(this);
                const res = await fetch('@Url.Action("ProcessTransfer", "Asset")', {
                    method: 'POST',
                    body: formData
                });

                const result = await res.json();

                if (result.success) {
                    Swal.fire({
                        title: '¡Traslado Iniciado!',
                        text: `Se ha generado el código ${result.transferCode}. El activo figurará como 'Transferido' hasta su recepción.`,
                        icon: 'success'
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Error', result.message, 'error');
                    $btn.prop('disabled', false).html(originalText);
                }
            } catch (e) {
                Swal.fire('Error', 'No se pudo comunicar con el servidor', 'error');
                $btn.prop('disabled', false).html(originalText);
            }
        });
    </script>
}