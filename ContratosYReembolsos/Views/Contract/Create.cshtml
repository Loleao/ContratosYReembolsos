			// 2. LÓGICA COBRO AUTOMÁTICO (ID 11)
			const ID_VELATORIO_AUTO = 11;
			if (isInternal) {
				// Evitar duplicados y agregar
				if (!contractData.serviceItems.some(s => s.id === ID_VELATORIO_AUTO)) {
					contractData.serviceItems.push({
