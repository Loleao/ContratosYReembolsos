@{
	ViewData["Title"] = "Registro de Contratos";
	ViewData["NoPadding"] = false;
}

<style>
	:root {
		--pnp-blue: #004a99;
		--pnp-bg: #003366;
		--pnp-gray: #f1f4f8;
	}

	body {
		background-color: var(--pnp-bg);
		font-family: 'Segoe UI', sans-serif;
	}

	/* Contenedor Principal */
	.stepper-card {
		background: white;
		border-radius: 20px;
		padding: 40px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.2);
		/* max-width: 1000px;  <-- ELIMINA O COMENTA ESTA LÍNEA */
		width: 95%;
		margin: 30px auto;
		min-height: calc(100vh - 100px);
	}

	.stepper-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: relative;
		margin-bottom: 50px;
		padding: 0 40px;
	}

		.stepper-header::before {
			content: "";
			position: absolute;
			top: 25px; /* Centrado con el dot de 50px */
			left: 60px; /* Ajuste para no sobresalir al inicio */
			right: 60px; /* Ajuste para no sobresalir al final */
			height: 3px;
			background: #e2e8f0;
			z-index: 1;
		}

	/* --- ESTILO DE LOS PASOS --- */
	.step-item {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		z-index: 2;
		position: relative;
	}

		/* Quitamos el .step-item::after porque la línea general la maneja el header::before */
		.step-item::after {
			display: none;
		}

	.step-dot {
		width: 50px;
		height: 50px;
		background: white;
		border: 2px solid #e2e8f0;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		font-size: 1.2rem;
		z-index: 5;
		margin-bottom: 10px; /* Espacio con el texto inferior */
	}

	/* Efecto cuando el paso está ACTIVO */
	.step-item.active .step-dot {
		border-color: var(--pnp-blue);
		background-color: var(--pnp-blue);
		color: white;
		transform: scale(1.1);
		box-shadow: 0 0 15px rgba(0, 74, 153, 0.3);
		border-width: 4px;
	}

	/* Efecto cuando el paso está COMPLETADO */
	.step-item.completed .step-dot {
		background-color: #10b981;
		border-color: #10b981;
		color: white;
	}

	.step-label {
		font-size: 11px;
		font-weight: bold;
		color: #94a3b8;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		transition: color 0.3s;
	}

	.step-item.active .step-label {
		color: var(--pnp-blue);
	}

	#dynamic-content {
		transition: opacity 0.3s ease-in-out, transform 0.3s ease-out;
	}

	.content-fade-out {
		opacity: 0;
		transform: translateY(10px);
	}

	.content-fade-in {
		opacity: 1;
		transform: translateY(0);
	}

	.step-dot {
		width: 50px; /* Un poco más grande para los iconos */
		height: 50px;
		background: #fff;
		border: 2px solid #e2e8f0;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		font-size: 1.2rem;
		z-index: 5;
	}

	.step-item.active .step-dot {
		border-color: var(--pnp-blue);
		color: var(--pnp-blue);
		border-width: 3px;
	}

	.step-item.completed .step-dot {
		background: #28a745;
		border-color: #28a745;
		color: white;
	}

	.step-label {
		font-size: 12px;
		font-weight: bold;
		color: #999;
		text-transform: uppercase;
	}

	/* Estilo unificado de celdas (Igual a Details) */
	.space-item-modal {
		width: 34px;
		height: 34px;
		min-width: 34px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 10px;
		font-weight: 800;
		border-radius: 6px;
		cursor: pointer;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		border: 1px solid rgba(0,0,0,0.05);
		flex-shrink: 0;
		color: white;
	}

		.space-item-modal:hover {
			transform: scale(1.2);
			z-index: 10;
			box-shadow: 0 4px 10px rgba(0,0,0,0.3);
		}

	/* Colores de estado */
	.st-disponible {
		background-color: #198754 !important;
	}
	/* bg-success */
	.st-ocupado {
		background-color: #dc3545 !important;
	}
	/* bg-danger */
	.st-reservado {
		background-color: #ffc107 !important;
		color: #212529 !important;
	}
	/* bg-warning */
	.st-otro {
		background-color: #6c757d !important;
	}

	/* Contenedor de scroll para el mapa */
	.map-scroll-container {
		overflow-x: auto;
		padding-bottom: 10px;
	}

		.map-scroll-container::-webkit-scrollbar {
			height: 6px;
		}

		.map-scroll-container::-webkit-scrollbar-thumb {
			background: #cbd5e0;
			border-radius: 10px;
		}

	/* Asegura que las tarjetas de las caras ocupen todo el ancho y se vean iguales */
	/* Forzar ancho del modal para el selector de nichos */
	#ajaxTargetSearch {
		max-width: 1200px !important; /* Aumentamos el ancho significativamente */
		width: 90%;
	}

	/* Unificar el tamaño de las tarjetas de las caras */
	.card-face {
		min-height: 300px; /* Altura mínima para que sean iguales */
		display: flex;
		flex-direction: column;
	}

	.map-scroll-container {
		overflow-x: auto;
		overflow-y: hidden;
		padding: 15px 5px;
		background-color: #f8fafc; /* Un fondo muy sutil para delimitar el área */
		border-radius: 8px;
		flex-grow: 1; /* Hace que el área de scroll ocupe el resto de la tarjeta */
	}

	/* Paso 4 */

	.time-slot {
		border: 1px solid #f0f0f0 !important;
		min-width: 90px;
		transition: 0.2s;
	}

		.time-slot.available:hover {
			background-color: var(--pnp-blue) !important;
			color: white !important;
			cursor: pointer;
			transform: scale(1.05);
			z-index: 5;
			box-shadow: 0 4px 8px rgba(0,0,0,0.1);
		}

		.time-slot.occupied {
			cursor: not-allowed;
			opacity: 0.7;
		}

	.sticky-column {
		background-color: #f8f9fa !important;
		border-right: 2px solid #dee2e6 !important;
	}

	.slot.slot-green:hover {
		background-color: #218838 !important; /* Un verde más oscuro */
		cursor: pointer;
		transform: scale(1.1); /* Se agranda un poquito */
		z-index: 10;
		box-shadow: 0 4px 15px rgba(0,0,0,0.3);
		border-radius: 4px;
		transition: all 0.2s ease;
	}

	.slot.slot-red {
		cursor: not-allowed;
	}

	/* Estilo para la celda que ya está seleccionada (la estrella) */
	.slot[style*="border: 4px solid"] {
		animation: pulse-blue 2s infinite;
	}

	@@keyframes pulse-blue {
		0% {
			box-shadow: 0 0 0 0 rgba(0, 74, 153, 0.7);
		}

		70% {
			box-shadow: 0 0 0 10px rgba(0, 74, 153, 0);
		}

		100% {
			box-shadow: 0 0 0 0 rgba(0, 74, 153, 0);
		}
	}


	/* Overlay Personalizado (Tu lógica de Legajos) */
	.custom-modal-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background: rgba(15, 23, 42, 0.6);
		backdrop-filter: blur(5px);
		display: none;
		justify-content: center;
		align-items: center;
		z-index: 3000;
	}

	.swal2-container {
		z-index: 4000 !important;
	}

	#ajaxTargetSearch {
		width: 95%; /* Ocupa casi todo el ancho en móviles */
		max-width: 900px; /* Ancho cómodo para la tabla */
		background: white;
		border-radius: 20px;
		padding: 25px;
		box-shadow: 0 20px 50px rgba(0,0,0,0.3);
	}

</style>

<div class="container-fluid px-4">
	@Html.AntiForgeryToken()
	<div class="stepper-card">
		<div class="stepper-header">
			<div class="step-item active" id="nav-1">
				<div class="step-dot"><i class="fa-solid fa-user"></i></div>
				<div class="step-label">Solicitante</div>
			</div>
			<div class="step-item" id="nav-2">
				<div class="step-dot"><i class="fa-solid fa-dove"></i></div>
				<div class="step-label">Difunto</div>
			</div>
			<div class="step-item" id="nav-3">
				<div class="step-dot"><i class="fa-solid fa-truck-ramp-box"></i></div>
				<div class="step-label">Servicios</div>
			</div>
			<div class="step-item" id="nav-4">
				<div class="step-dot"><i class="fa-solid fa-file-invoice-dollar"></i></div>
				<div class="step-label">Resumen</div>
			</div>
		</div>

		<div id="dynamic-content" class="mt-4">
			<div class="text-center py-5">
				<i class="fa-solid fa-circle-notch fa-spin fa-2x text-primary"></i>
				<p class="mt-2 text-muted">Cargando formulario...</p>
			</div>
		</div>
	</div>
</div>

<div id="modalOverlaySearch" class="custom-modal-overlay" onclick="handleOverlayClick(event)">
	<div id="ajaxTargetSearch"></div>
</div>

@section Scripts {
	<script>
		const urls = {
			actualStep: 1,
			step1: '@Url.Action("GetStep1", "Contract")',
			step2: '@Url.Action("GetStep2", "Contract")',
			step3: '@Url.Action("GetStep3", "Contract")',
			step4: '@Url.Action("GetStep4", "Contract")',
			searchModal: '@Url.Action("GetSearchModal", "Contract")',
			searchAction: '@Url.Action("SearchAffiliates", "Contract")',
			searchBeneficiariesModal: '@Url.Action("GetSearchBeneficiary", "Contract")',
			searchBeneficiaries: '@Url.Action("GetBeneficiariesByAffiliate", "Contract")',
			getRegions: '@Url.Action("GetRegions", "Contract")',
			getProvinces: '@Url.Action("GetProvinces", "Contract")',
			getDistricts: '@Url.Action("GetDistricts", "Contract")',
			getBranchCapabilities: '@Url.Action("GetBranchCapabilities", "Contract")',
			getWakes: '@Url.Action("GetWakes", "Contract")',
			getCemeteryModal: '@Url.Action("GetSearchCemetery", "Contract")',
			getCemeteriesAction: '@Url.Action("GetCemeteries", "Contract")',
			getAgencyModal: '@Url.Action("GetSearchAgency", "Contract")',
			getAgenciesAction: '@Url.Action("GetAgencies", "Contract")',
			getNicheSelectorModal: '@Url.Action("GetNicheSelector", "Contract")',
			getStructures: '@Url.Action("GetStructures", "Contract")',
			getSpaceMap: '@Url.Action("GetSpaceMap", "Contract")',
			getServicesAction: '@Url.Action("GetServices", "Service")',
			getAvailableUnits: '@Url.Action("GetAvailableUnits", "Service")',
			getUnitPickerModal: '@Url.Action("GetUnitPicker", "Service")',
			getDailyAvailability: '@Url.Action("GetDailyAvailability", "Service")',
			getWeeklyAvailability: '@Url.Action("GetWeeklyAvailability", "Service")',
			getPrefix: '@Url.Action("GetBranchPrefix", "Contract")',
			saveContract: '@Url.Action("Create", "Contract")',
			downloadContract: '@Url.Action("DescargarContratoPDF", "Contract")',
		};

		let contractData = {
			branchId: 0,
			solicitor: { id: '', dni: '', name: '', cip: '', type: '' },
			affiliate: { dni: '', name: '', cip: '' },
			deceased: {
				id: '', dni: '', name: '', cip: '', deathDate: '',
				burialDate: '', burialTime: '',
				ubigeoFull: '', inei: '',
				wakeId: '', wakeName: '', customWakeAddress: '',
				cemeteryId: '', cemeteryName: '',
				intermentStructureId: null,
				intermentSpaceId: null,
				burialType: '',
				burialDetail: ''
			},
			agencyId: 0,
			stockItems: [],      // Para Ataúdes (consumibles)
			mobilityItems: [],
			serviceItems: [], // Reemplaza a assetItems
			agreementServiceItems: []     // Para Capillas, Biombos (activos fijos)
		};

		const SERVICIO_SEPULTURA_AUTO = {
			'Pabellon': 3,   // Servicio de Nicho
			'Tumba': 5,      // Servicio de Tumba
			'Columbario': 34 // Servicio de Columbario
		};

		let searchTarget = 'Solicitor';

		let branchCaps = { hasWake: false };

		async function handleStepInitialization(n) {
			console.log("Inicializando paso:", n);

			const container = document.getElementById('dynamic-content');

			switch (n) {
				case 1:
					if (typeof toggleSolicitorType === 'function') {
						toggleSolicitorType();
					}
				break;

				case 2:
					try {
						const response = await fetch(`${urls.getBranchCapabilities}?branchId=${contractData.branchId}`);
						if (response.ok) {
							const caps = await response.json(); // Cambiado de branchCaps a constante local

							const $wakeSection = $('#sectionWakePlace');
							if (caps.hasWake) {
								$wakeSection.fadeIn(300).removeClass('d-none');
								if (typeof loadWakes === 'function') loadWakes();
							} else {
								$wakeSection.hide().addClass('d-none');
								contractData.deceased.wakeId = "0";
								contractData.deceased.wakeName = "Particular / Domicilio";
							}
						}
					} catch (e) {
						console.error("Error al validar capacidades de filial:", e);
					}

					if (typeof filterDeceasedOptions === 'function') filterDeceasedOptions();
					if (typeof loadRegions === 'function') loadRegions();
				break;

				case 3:
					setTimeout(() => {
						if (typeof renderCatalog === 'function') {
							renderCatalog('Inventario');
						}
						if (typeof updateSelectionUI === 'function') {
							updateSelectionUI();
						}
					}, 150); // 150ms es suficiente para que el navegador procese el nuevo HTML
				break;

				case 4:
					if (typeof renderSummary === 'function') {
						await renderSummary();
					}
				break;
			}
		}

		async function loadStep(n) {
			const container = document.getElementById('dynamic-content');
			container.style.opacity = '0';

			setTimeout(async () => {
				try {
					const resp = await fetch(urls[`step${n}`]);
					if (!resp.ok) throw new Error("No se pudo cargar el HTML");

					const html = await resp.text();
					container.innerHTML = html;

					updateStepperHeader(n);

					// LLAMADA A LA FUNCIÓN
					handleStepInitialization(n);

					container.style.opacity = '1';
					actualStep = n;

				} catch (e) {
					console.error("Error crítico en loadStep:", e);
					container.innerHTML = `<div class="alert alert-danger">Error: ${e.message}</div>`;
					container.style.opacity = '1';
				}
			}, 200);
		}

		function updateStepperHeader(n) {
			const icons = ['fa-user', 'fa-dove', 'fa-handshake', 'fa-truck-ramp-box', 'fa-file-invoice-dollar'];
			document.querySelectorAll('.step-item').forEach((el, i) => {
				const stepNum = i + 1;
				const dot = el.querySelector('.step-dot');
				el.classList.toggle('active', stepNum === n);
				el.classList.toggle('completed', stepNum < n);
				if (dot) {
					dot.innerHTML = stepNum < n
						? '<i class="fa-solid fa-check"></i>'
						: `<i class="fa-solid ${icons[i]}"></i>`;
				}
			});
		}

		document.addEventListener('DOMContentLoaded', () => {
			const initialBranch = @(ViewBag.UserBranchId ?? 0);
			contractData.branchId = initialBranch;
			console.log("Filial cargada en contractData:", contractData.branchId);
			loadStep(1);
		});

		function openSearchAffiliate(target) {
			searchTarget = target; // Guardamos si es para 'Solicitor' o 'Deceased'

			$.ajax({
				url: urls.searchModal,
				type: 'GET',
				success: function (html) {
					$('#ajaxTargetSearch').html(html);
					$('#modalOverlaySearch').css('display', 'flex').hide().fadeIn(300);
				}
			});
		}

		function closeSearchModal() {
			$('#modalOverlaySearch').fadeOut(300);
		}

		function handleOverlayClick(e) {
			if (e.target.id === 'modalOverlaySearch') closeSearchModal();
		}

		async function executeSearch() {
			// 1. Obtenemos los filtros básicos
			const filters = {
				dni: $('#filterDni').val(),
				cip: $('#filterCip').val(),
				name: $('#filterName').val(),
			};

			const $tbody = $('#resultsTableBody');
			$tbody.html('<tr><td colspan="4" class="text-center py-4"><i class="fas fa-spinner fa-spin"></i> Filtrando beneficiarios...</td></tr>');

			try {
				// 2. Construimos la URL con el nuevo parámetro parentDni
				const query = `dni=${filters.dni}&cip=${filters.cip}&name=${encodeURIComponent(filters.name)}&parentDni=${filters.parentDni}`;
				const response = await fetch(`${urls.searchAction}?${query}`);
				const data = await response.json();

				$tbody.empty();

				if (data.length === 0) {
					$tbody.append('<tr><td colspan="4" class="text-center text-danger">No se encontraron beneficiarios asociados a este titular.</td></tr>');
					return;
				}

				// 3. Renderizamos los resultados
				data.forEach(item => {
					const tr = $(`
						<tr style="cursor:pointer" class="align-middle">
							<td><b>${item.dni}</b></td>
							<td>${item.cip || '---'}</td> <td>${item.name}</td>
							<td class="text-end"><button class="btn btn-sm btn-primary rounded-pill">Seleccionar</button></td>
						</tr>
					`);
					tr.click(() => selectAffiliate(item));
					$tbody.append(tr);
				});
			} catch (e) {
				$tbody.html('<tr><td colspan="4" class="text-center text-danger">Error al conectar con la base de datos de beneficiarios.</td></tr>');
			}
		}

		function selectAffiliate(item) {
			// Identificamos el objetivo de la búsqueda
			const isSolicitor = (searchTarget === 'Solicitor');
			const isAffiliate = (searchTarget === 'Affiliate');
			const isDeceased = (searchTarget === 'Deceased');

			// Determinamos el prefijo de los IDs de los inputs
			let targetPrefix = '';
			if (isSolicitor) targetPrefix = '#Solicitor';
			if (isAffiliate) targetPrefix = '#Affiliate';
			if (isDeceased)  targetPrefix = '#Deceased';

			const hasValidDni = item.dni && item.dni.toString().trim().length >= 8 && item.dni !== "999999999";

			// Llenado de campos en la UI
			if (hasValidDni) {
				$(`${targetPrefix}Dni`).val(item.dni).prop('readonly', true).addClass('bg-light');
			} else {
				$(`${targetPrefix}Dni`).val('').prop('readonly', false).removeClass('bg-light').focus();
				Swal.fire('Atención', 'DNI no válido en base de datos. Ingréselo manualmente.', 'warning');
			}

			$(`${targetPrefix}Name`).val(item.name).prop('readonly', true).addClass('bg-light');
			$(`${targetPrefix}Cip`).val(item.cip || '');

			// Persistencia en el objeto contractData según el target
			if (isSolicitor) {
				contractData.solicitor.id = item.id;
				contractData.solicitor.dni = item.dni;
				contractData.solicitor.cip = item.cip;
				contractData.solicitor.name = item.name;

				// REGLA DE NEGOCIO: Si es titular, sus datos de afiliado son los mismos
				if ($('#SolicitorType').val() === "Titular") {
					contractData.affiliate.dni = item.dni;
					contractData.affiliate.name = item.name;
					contractData.affiliate.cip = item.cip;
				}
			}
			else if (isAffiliate) {
				contractData.affiliate.dni = item.dni;
				contractData.affiliate.name = item.name;
				contractData.affiliate.cip = item.cip;
			}
			else if (isDeceased) {
				contractData.deceased.id = item.id;
				contractData.deceased.dni = item.dni;
				contractData.deceased.name = item.name;
			}

			closeSearchModal();
		}

		// Función auxiliar para solo números en el DNI manual
		function isNumber(evt) {
			evt = (evt) ? evt : window.event;
			var charCode = (evt.which) ? evt.which : evt.keyCode;
			if (charCode > 31 && (charCode < 48 || charCode > 57)) return false;
			return true;
		}

		function toggleSolicitorType() {
			const select = document.getElementById('SolicitorType');
			if (!select) return;

			const type = select.value;
			contractData.solicitor.type = type;

			const btnLupa = document.getElementById('btnLupaSolicitor');
			const dniField = document.getElementById('SolicitorDni');
			const nameField = document.getElementById('SolicitorName');
			const cipField = document.getElementById('SolicitorCip');
			const sectionAffiliate = document.getElementById('sectionAffiliateData');
			const helper = document.getElementById('typeHelper');

			// Reset de estados
			dniField.classList.remove('border-danger');
			$('#dniErrorMsg').addClass('d-none');

			switch (type) {
				case "Titular":
					$(sectionAffiliate).fadeOut(200); // Ocultamos sección inferior
					$(btnLupa).fadeIn(200);          // Mostramos lupa SOLICITANTE

					dniField.readOnly = true;
					nameField.readOnly = true;
					cipField.readOnly = true;
					dniField.classList.add('bg-light');
					nameField.classList.add('bg-light');

					if (helper) helper.innerHTML = '<i class="fa-solid fa-circle-info me-1"></i> El solicitante es el titular del beneficio.';
					break;

				case "Familiar":
				case "TerceroPolicial":
					$(sectionAffiliate).fadeIn(200).removeClass('d-none'); // Mostramos sección inferior
					$(btnLupa).fadeOut(200);                               // OCULTAMOS lupa SOLICITANTE

					dniField.readOnly = false;
					nameField.readOnly = false;
					cipField.readOnly = false;
					dniField.classList.remove('bg-light');
					nameField.classList.remove('bg-light');

					// Limpiamos campos para obligar a nueva entrada si cambia el tipo
					dniField.value = "";
					nameField.value = "";
					cipField.value = "";

					if (helper) {
						const icons = { "Familiar": "fa-person-rays", "TerceroPolicial": "fa-user-shield" };
						helper.innerHTML = `<i class="fa-solid ${icons[type]} me-1"></i> El solicitante es un ${type}. <b>Debe buscar al Afiliado Titular abajo.</b>`;
					}
					break;

				case "Tercero":
					$(sectionAffiliate).fadeOut(200); // Ocultamos sección inferior
					$(btnLupa).fadeOut(200);

					dniField.readOnly = false;
					nameField.readOnly = false;
					cipField.readOnly = false;
					dniField.classList.remove('bg-light');
					nameField.classList.remove('bg-light');

					// Limpiamos campos para obligar a nueva entrada si cambia el tipo
					dniField.value = "";
					nameField.value = "";
					cipField.value = "";
					
					if (helper) helper.innerHTML = '<i class="fa-solid fa-circle-info me-1"></i> El solicitante es un tercero no oficial.';

				break;
			}
		}

		function validateStep1() {
			const type = $('#SolicitorType').val();
			const sDni = $('#SolicitorDni').val();
			const sName = $('#SolicitorName').val();

			if (!sDni || sDni.length < 8) {
				Swal.fire('Atención', 'Debe ingresar el DNI del solicitante.', 'warning');
				return false;
			}

			// Si NO es titular, validar que se haya buscado al afiliado
			if (type == "Familiar") {
				const aDni = $('#AffiliateDni').val();
				if (!aDni || aDni.length < 8) {
					Swal.fire('Vínculo Obligatorio', 'Debe buscar y seleccionar un Afiliado Titular.', 'error');
					return false;
				}
			} else if (type == "TerceroPolicial") {
				const aDni = $('#AffiliateDni').val();
				if (!aDni || aDni.length < 8) {
					Swal.fire('Vínculo Obligatorio', 'Debe buscar y seleccionar un Afiliado Titular.', 'error');
					return false;
				}
			}

			// Sincronizar contractData final
			contractData.solicitor.dni = sDni;
			contractData.solicitor.name = sName;
			contractData.solicitor.type = type;
			contractData.solicitor.cip = $('#SolicitorCip').val();

			// Si es titular, duplicamos datos al objeto affiliate
			if (type === "Titular") {
				contractData.affiliate.dni = sDni;
				contractData.affiliate.name = sName;
				contractData.affiliate.cip = contractData.solicitor.cip;
			} else {
				contractData.affiliate.dni = $('#AffiliateDni').val();
				contractData.affiliate.name = $('#AffiliateName').val();
				contractData.affiliate.cip = $('#AffiliateCip').val();
			}

			return true;
		}

