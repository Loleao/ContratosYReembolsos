		async function renderCatalog(category) {
			const container = document.getElementById('catalogContainer');

			// Validación de sede
			if (!contractData.branchId || contractData.branchId === 0) {
				if (container) container.innerHTML = '<div class="alert alert-warning">Seleccione una sede primero.</div>';
				return;
			}

			let activeCategory = category;
			if (category.includes('Inventario')) activeCategory = 'Inventario';
			if (category.includes('Movilidad')) activeCategory = 'Movilidad';
			if (category.includes('Adicionales')) activeCategory = 'Adicionales';

			document.querySelectorAll('#pills-tab .nav-link').forEach(btn => {
				const btnText = btn.innerText.trim();
				btn.classList.toggle('active', btnText.includes(activeCategory));
			});

			if (container) {
				container.innerHTML = '<div class="text-center py-5 w-100"><div class="spinner-border text-primary"></div></div>';
			}

			const routes = {
				'Inventario': '@Url.Action("GetInventoryStock", "Contract")',
				'Movilidad': '@Url.Action("GetAvailableVehicleTypesByBranch", "Contract")',
				'Adicionales': '@Url.Action("GetAvailableAssets", "Contract")'
			};

			const baseUrl = routes[activeCategory];
			if (!baseUrl) {
				console.error("No se encontró una ruta para la categoría:", activeCategory);
				return;
			}

			try {
				const url = `${baseUrl}?branchId=${contractData.branchId}`;
				const response = await fetch(url);
				if (!response.ok) throw new Error("Error en servidor");
				const data = await response.json();

				if (container) {
					container.innerHTML = data.length ? '' : '<p class="text-center py-5 w-100 text-muted small">No hay elementos disponibles en esta categoría.</p>';

					// AHORA AGRUPAMOS TANTO INVENTARIO COMO ADICIONALES
					if (activeCategory === 'Inventario' || activeCategory === 'Adicionales') {
						const grouped = data.reduce((acc, item) => {
							// Si el item no tiene categoría por algún error, lo mandamos a "Otros"
							const catName = item.category || "Otros";
							acc[catName] = acc[catName] || [];
							acc[catName].push(item);
							return acc;
						}, {});

						for (const catName in grouped) {
							// Icono dinámico según la pestaña activa
							const icon = activeCategory === 'Inventario' ? 'fa-tag' : 'fa-layer-group';

							container.innerHTML += `
								<div class="col-12 mt-3 mb-2">
									<h6 class="text-uppercase fw-bold text-muted small border-bottom pb-2">
										<i class="fa-solid ${icon} me-2 text-primary"></i>${catName}
									</h6>
								</div>`;

							grouped[catName].forEach(item => {
								container.innerHTML += createProductCard(item, activeCategory);
							});
						}
					} else {
						// Movilidad se lista directo (sin grupos)
						data.forEach(item => {
							container.innerHTML += createProductCard(item, activeCategory);
						});
					}
				}
			} catch (error) {
				console.error("Error en renderCatalog:", error);
				if (container) container.innerHTML = '<div class="alert alert-danger">Error al cargar datos.</div>';
			}
		}

		function createProductCard(item, type) {
			let isSelected = false;
			if (type === 'Inventario') isSelected = contractData.stockItems.some(x => x.id === item.id);
			else if (type === 'Movilidad') isSelected = contractData.mobilityItems.includes(item.id);
			else if (type === 'Adicionales') isSelected = contractData.assetItems.some(x => x.id === item.id);

			const itemData = JSON.stringify(item).replace(/"/g, '&quot;');
			const detail = item.stock ? `Stock: ${item.stock}` : (item.patrimonialCode || 'Servicio');

			return `
				<div class="col-md-6 mb-2">
					<div class="card h-100 border-2 ${isSelected ? 'border-primary bg-primary-subtle' : 'border-light'}"
						 onclick="handleSelection('${type}', ${itemData})" style="cursor:pointer">
						<div class="card-body p-2 px-3">
							<div class="d-flex justify-content-between align-items-center">
								<div>
									<p class="fw-bold mb-0 small">${item.name}</p>
									<span class="text-muted small" style="font-size:0.7rem">${detail}</span>
								</div>
								${isSelected ? '<i class="fa-solid fa-check-circle text-primary"></i>' : ''}
							</div>
						</div>
					</div>
				</div>`;
		}

		function handleSelection(type, item) {
			if (type === 'Inventario') {
				// Buscamos si el item ya está seleccionado
				const idx = contractData.stockItems.findIndex(x => x.id === item.id);

				if (idx === -1) {
					// LÓGICA DE SELECCIÓN ÚNICA PARA ATAÚDES
					if (item.category === 'Ataudes') {
						// Filtramos la lista para ELIMINAR cualquier otro producto que sea de la categoría 'Ataúdes'
						contractData.stockItems = contractData.stockItems.filter(x => x.category !== 'Ataudes');
						console.log("Se ha reemplazado el ataúd anterior por:", item.name);
					}

					// Agregamos el nuevo item (sea ataúd o cualquier otro consumible)
					contractData.stockItems.push(item);
				} else {
					// Si ya existía y le volvieron a dar click, lo quitamos (deseleccionar)
					contractData.stockItems.splice(idx, 1);
				}
			}
			else if (type === 'Movilidad') {
				const idx = contractData.mobilityItems.indexOf(item.id);
				if (idx === -1) contractData.mobilityItems.push(item.id);
				else contractData.mobilityItems.splice(idx, 1);
			}
			else if (type === 'Adicionales') {
				const idx = contractData.assetItems.findIndex(x => x.id === item.id);
				if (idx === -1) contractData.assetItems.push(item);
				else contractData.assetItems.splice(idx, 1);
			}

			// Refrescar UI
			renderCatalog(type);
			updateSelectionUI();
		}

		function updateSelectionUI() {
			// Apuntamos al contenido interno para no borrar los contenedores fijos
			const cartContent = document.getElementById('cartContent');
			const emptyMsg = document.getElementById('emptyCartMsg');
			const totalBadge = document.getElementById('totalItemsBadge');

			if (!cartContent || !emptyMsg) return;

			// Limpiamos solo el área donde van los tickets
			cartContent.innerHTML = '';

			const hasStock = contractData.stockItems.length > 0;
			const hasAssets = contractData.assetItems.length > 0;
			const hasMobility = contractData.mobilityItems.length > 0;

			const totalCount = contractData.stockItems.length + contractData.assetItems.length + contractData.mobilityItems.length;

			// Control del mensaje "Vacío"
			emptyMsg.style.display = totalCount > 0 ? 'none' : 'block';

			// Actualizar el contador del badge
			if (totalBadge) totalBadge.innerText = totalCount;

			if (totalCount === 0) return;

			// --- GRUPO 1: INVENTARIO ---
			if (hasStock) {
				cartContent.innerHTML += `<div class="text-muted fw-bold mb-2 mt-1" style="font-size: 0.65rem; letter-spacing: 1px; text-transform: uppercase;">Bienes e Inventario</div>`;
				contractData.stockItems.forEach(item => {
					const isAtaud = item.category === 'Ataúdes' || item.name.toUpperCase().includes('ATAUD');
					const color = isAtaud ? "bg-primary" : "bg-secondary";
					const icon = isAtaud ? "fa-vault" : "fa-box";

					cartContent.innerHTML += createCartTicket(
						item.name,
						item.category,
						color,
						`handleSelection('Inventario', ${JSON.stringify(item).replace(/"/g, '&quot;')})`,
						icon
					);
				});
			}

			// --- GRUPO 2: ACTIVOS FIJOS ---
			if (hasAssets) {
				cartContent.innerHTML += `<div class="text-muted fw-bold mb-2 mt-3" style="font-size: 0.65rem; letter-spacing: 1px; text-transform: uppercase;">Equipamiento (Activos)</div>`;
				contractData.assetItems.forEach(a => {
					cartContent.innerHTML += createCartTicket(
						a.name,
						`Patrimonio: ${a.patrimonialCode}`,
						"bg-info text-dark",
						`handleSelection('Adicionales', ${JSON.stringify(a).replace(/"/g, '&quot;')})`,
						"fa-couch"
					);
				});
			}

			// --- GRUPO 3: MOVILIDAD ---
			if (hasMobility) {
				cartContent.innerHTML += `<div class="text-muted fw-bold mb-2 mt-3" style="font-size: 0.65rem; letter-spacing: 1px; text-transform: uppercase;">Logística / Transporte</div>`;
				contractData.mobilityItems.forEach(id => {
					cartContent.innerHTML += createCartTicket(
						"Servicio de Transporte",
						"Programado",
						"bg-dark",
						`handleSelection('Movilidad', {id:${id}})`,
						"fa-car-side"
					);
				});
			}
		}

		// Función auxiliar para crear un diseño tipo "Ticket" más elegante que un simple badge
		function createCartTicket(title, subtitle, colorClass, removeAction, icon) {
			const isDark = colorClass.includes('bg-primary') || colorClass.includes('bg-dark') || colorClass.includes('bg-secondary');
			const textColor = isDark ? 'text-white' : 'text-dark';

			return `
				<div class="card border-0 shadow-sm mb-2 animate__animated animate__fadeInRight" style="border-radius: 10px; overflow: hidden;">
					<div class="d-flex align-items-center ${colorClass} ${textColor} p-2">
						<div class="rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center me-2" style="width: 30px; height: 30px;">
							<i class="fa-solid ${icon} fw-bold" style="font-size: 0.8rem;"></i>
						</div>
						<div class="flex-grow-1 overflow-hidden">
							<div class="fw-bold text-truncate" style="font-size: 0.75rem; line-height: 1;">${title}</div>
							<small class="opacity-75" style="font-size: 0.65rem;">${subtitle}</small>
						</div>
						<button class="btn btn-sm ${textColor} p-0 ms-2" onclick="${removeAction}">
							<i class="fa-solid fa-circle-xmark opacity-75"></i>
						</button>
					</div>
				</div>`;
		}

		function createSelectionBadge(label, type, color, action) {
			return `<div class="d-flex justify-content-between align-items-center ${color} text-white p-2 rounded-3 mb-2 shadow-sm">
						<div style="font-size: 0.8rem;"><small class="d-block opacity-75">${type}</small><b>${label}</b></div>
						<button class="btn btn-sm text-white p-0" onclick="${action}"><i class="fa-solid fa-xmark"></i></button>
					</div>`;
		}

		function validateStep4() {
			// 1. Validar que exista al menos un ataúd (Buscamos en stockItems)
			const tieneAtaud = contractData.stockItems.some(item =>
				item.category === 'Ataúdes' || item.name.toUpperCase().includes('ATAUD')
			);

			if (!tieneAtaud) {
				Swal.fire({
					title: 'Atención',
					text: 'Es obligatorio seleccionar un ataúd para continuar con el contrato.',
					icon: 'warning',
					confirmButtonColor: '#004a99'
				});
				return false; // Detiene el avance al paso 5
			}

			// Si todo está correcto
			console.log("Validación del Paso 4 exitosa.");
			return true; // Permite avanzar al paso 5
		}

		//PASO
		//NUMERO
		//5

		async function renderStep5() {
			console.log("Generando resumen final con datos:", contractData);

			// 1. Prefijo de Contrato
			$('#resContractPreview').text("Cargando...");
			let previewPrefix = "GEN";
			try {
				const resp = await fetch(`/Contract/GetBranchPrefix?branchId=${contractData.branchId}`);
				if (resp.ok) {
					const data = await resp.json();
					previewPrefix = data.prefix || "GEN";
				}
			} catch (e) { console.warn("Fallo al obtener prefijo", e); }

			const year = new Date().getFullYear();
			$('#resContractPreview').text(`${previewPrefix}${year}-XXXXX`);

			// 2. Datos Personales (Usando tus objetos de pasos anteriores)
			$('#resSolicitorName').text(contractData.solicitor?.name || "---");
			$('#resSolicitorDni').text(`DNI: ${contractData.solicitor?.dni || "---"}`);
			$('#resDeceasedName').text(contractData.deceased?.name || "---");
			$('#resDeceasedDni').text(`DNI: ${contractData.deceased?.dni || "---"}`);

			// 3. Logística (Paso 3)
			const d = contractData.deceased;
			$('#resBurialDateTime').text(`${d?.burialDate || '---'} ${d?.burialTime || ''}`);
			$('#resWakePlace').text(d?.wakeName || "Particular / Domicilio");
			$('#resCemetery').text(d?.cemeteryName || "No seleccionado");

			if (d?.burialDetail) {
				$('#resNicheRow').removeClass('d-none').show();
				$('#resNicheDetail').text(d.burialDetail);
			} else {
				$('#resNicheRow').hide();
			}

			// 4. Detalle de Beneficios (Tabla/Lista)
			const $container = $('#resServicesTable');
			$container.empty();

			if (contractData.stockItems.length > 0) {
				$container.append(createSummarySectionHeader("Bienes e Inventario (Suministros)", "fa-box-open", "text-primary"));
				contractData.stockItems.forEach(item => {
					const isAtaud = item.category === 'Ataúdes' || item.name.toUpperCase().includes('ATAUD');
					$container.append(createSummaryRow(item.name, item.category, isAtaud ? 'primary' : 'secondary', isAtaud ? 'fa-vault' : 'fa-box', "Entregado"));
				});
			}

			// --- GRUPO 2: EQUIPAMIENTO Y ACTIVOS (PRÉSTAMOS) ---
			if (contractData.assetItems.length > 0) {
				$container.append(createSummarySectionHeader("Equipamiento en Préstamo (Activos Fijos)", "fa-couch", "text-info"));
				contractData.assetItems.forEach(item => {
					$container.append(createSummaryRow(item.name, `Código Patrimonial: ${item.patrimonialCode}`, 'info', 'fa-fingerprint', "En Préstamo"));
				});
			}

			// --- GRUPO 3: LOGÍSTICA Y MOVILIDAD ---
			if (contractData.mobilityItems.length > 0) {
				$container.append(createSummarySectionHeader("Logística de Transporte", "fa-car-side", "text-dark"));
				contractData.mobilityItems.forEach(id => {
					// Aquí puedes buscar el nombre real si lo tienes, o usar un genérico
					$container.append(createSummaryRow("Unidad de Transporte Programada", "Servicio Logístico", 'dark', 'fa-clock', "Programado"));
				});
			}

			if ($container.children().length === 0) {
				$container.append('<div class="text-center py-4 text-muted border rounded-4">No hay beneficios asignados.</div>');
			}
		}

		function createSummarySectionHeader(title, icon, textColor) {
			return `
				<div class="mt-4 mb-2 d-flex align-items-center">
					<div class="border-bottom flex-grow-1"></div>
					<span class="mx-3 fw-bold small ${textColor} text-uppercase" style="letter-spacing: 1px;">
						<i class="fa-solid ${icon} me-2"></i>${title}
					</span>
					<div class="border-bottom flex-grow-1"></div>
				</div>`;
		}

		// Función auxiliar para las filas (Ajustada para que se vea más como tabla)
		function createSummaryRow(title, subtitle, color, icon, tag) {
			return `
				<div class="d-flex justify-content-between align-items-center py-2 px-3 mb-1 bg-white border rounded-3 shadow-sm animate__animated animate__fadeInUp">
					<div class="d-flex align-items-center">
						<div class="text-${color} me-3" style="width: 25px; text-align: center;">
							<i class="fa-solid ${icon} fs-5"></i>
						</div>
						<div>
							<span class="fw-bold d-block text-dark small" style="line-height: 1.2;">${title}</span>
							<small class="text-muted" style="font-size: 0.65rem;">${subtitle}</small>
						</div>
					</div>
					<span class="badge bg-${color}-subtle text-${color} border border-${color} rounded-pill" style="font-size: 0.6rem; padding: 0.4em 0.8em;">
						${tag.toUpperCase()}
					</span>
				</div>`;
		}

		async function saveFinalContract() {
			const result = await Swal.fire({
				title: '¿Confirmar Registro?',
				text: "Se generará el contrato legal y se actualizará el inventario.",
				icon: 'question',
				showCancelButton: true,
				confirmButtonText: 'Sí, Registrar',
				cancelButtonText: 'Revisar',
				confirmButtonColor: '#004a99'
			});

			if (result.isConfirmed) {
				Swal.fire({
					title: 'Procesando...',
					allowOutsideClick: false,
					didOpen: () => { Swal.showLoading(); }
				});

				// --- MAPEO DE DATOS PARA EL VIEWMODEL ---
				// Extraemos solo los IDs porque el servidor espera List<int>
				const payload = {
					branchId: parseInt(contractData.branchId),
					agencyId: parseInt(contractData.agencyId || 0),
					solicitor: contractData.solicitor,
					deceased: contractData.deceased,
					stockItems: contractData.stockItems.map(item => item.id), // Solo IDs
					assetItems: contractData.assetItems.map(item => item.id),   // Solo IDs
					mobilityItems: contractData.mobilityItems // Ya es una lista de IDs
				};

				try {
					const response = await fetch('@Url.Action("Create", "Contract")', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() // Opcional: si usas AntiForgeryToken
						},
						body: JSON.stringify(payload)
					});

					// Si el servidor responde con error 400, 404 o 500
					if (!response.ok) {
						const errorData = await response.json();
						throw new Error(errorData.message || `Error del servidor (${response.status})`);
					}

					const data = await response.json();

					if (data.success) {
						Swal.fire('¡Éxito!', 'El contrato ha sido registrado correctamente.', 'success')
							.then(() => {
								window.location.href = '@Url.Action("Index", "Contract")';
							});
					} else {
						Swal.fire('Error', data.message || 'No se pudo registrar el contrato.', 'error');
					}
				} catch (error) {
					console.error("Error en la petición:", error);
					Swal.fire('Error', error.message || 'Ocurrió un fallo en la conexión.', 'error');
				}
			}
		}

	</script>
}