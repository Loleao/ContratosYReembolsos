@{
	ViewData["Title"] = "Registro de Contratos";
}

<style>
	:root {
		--pnp-blue: #004a99;
		--pnp-bg: #003366;
		--pnp-gray: #f1f4f8;
	}

	body {
		background-color: var(--pnp-bg);
		font-family: 'Segoe UI', sans-serif;
	}

	/* Contenedor Principal */
	.stepper-card {
		background: white;
		border-radius: 20px;
		padding: 40px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.2);
		/* max-width: 1000px;  <-- ELIMINA O COMENTA ESTA LÍNEA */
		width: 95%;
		margin: 30px auto;
		min-height: calc(100vh - 100px);
	}

	.stepper-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: relative;
		margin-bottom: 50px;
		padding: 0 40px;
	}

		.stepper-header::before {
			content: "";
			position: absolute;
			top: 25px; /* Centrado con el dot de 50px */
			left: 60px; /* Ajuste para no sobresalir al inicio */
			right: 60px; /* Ajuste para no sobresalir al final */
			height: 3px;
			background: #e2e8f0;
			z-index: 1;
		}

	/* --- ESTILO DE LOS PASOS --- */
	.step-item {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		z-index: 2;
		position: relative;
	}

		/* Quitamos el .step-item::after porque la línea general la maneja el header::before */
		.step-item::after {
			display: none;
		}

	.step-dot {
		width: 50px;
		height: 50px;
		background: white;
		border: 2px solid #e2e8f0;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		font-size: 1.2rem;
		z-index: 5;
		margin-bottom: 10px; /* Espacio con el texto inferior */
	}

	/* Efecto cuando el paso está ACTIVO */
	.step-item.active .step-dot {
		border-color: var(--pnp-blue);
		background-color: var(--pnp-blue);
		color: white;
		transform: scale(1.1);
		box-shadow: 0 0 15px rgba(0, 74, 153, 0.3);
		border-width: 4px;
	}

	/* Efecto cuando el paso está COMPLETADO */
	.step-item.completed .step-dot {
		background-color: #10b981;
		border-color: #10b981;
		color: white;
	}

	.step-label {
		font-size: 11px;
		font-weight: bold;
		color: #94a3b8;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		transition: color 0.3s;
	}

	.step-item.active .step-label {
		color: var(--pnp-blue);
	}

	#dynamic-content {
		transition: opacity 0.3s ease-in-out, transform 0.3s ease-out;
	}

	.content-fade-out {
		opacity: 0;
		transform: translateY(10px);
	}

	.content-fade-in {
		opacity: 1;
		transform: translateY(0);
	}

	.step-dot {
		width: 50px; /* Un poco más grande para los iconos */
		height: 50px;
		background: #fff;
		border: 2px solid #e2e8f0;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		font-size: 1.2rem;
		z-index: 5;
	}

	.step-item.active .step-dot {
		border-color: var(--pnp-blue);
		color: var(--pnp-blue);
		border-width: 3px;
	}

	.step-item.completed .step-dot {
		background: #28a745;
		border-color: #28a745;
		color: white;
	}

	.step-label {
		font-size: 12px;
		font-weight: bold;
		color: #999;
		text-transform: uppercase;
	}

	/* Estilo unificado de celdas (Igual a Details) */
	.space-item-modal {
		width: 34px;
		height: 34px;
		min-width: 34px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 10px;
		font-weight: 800;
		border-radius: 6px;
		cursor: pointer;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		border: 1px solid rgba(0,0,0,0.05);
		flex-shrink: 0;
		color: white;
	}

		.space-item-modal:hover {
			transform: scale(1.2);
			z-index: 10;
			box-shadow: 0 4px 10px rgba(0,0,0,0.3);
		}

	/* Colores de estado */
	.st-disponible {
		background-color: #198754 !important;
	}
	/* bg-success */
	.st-ocupado {
		background-color: #dc3545 !important;
	}
	/* bg-danger */
	.st-reservado {
		background-color: #ffc107 !important;
		color: #212529 !important;
	}
	/* bg-warning */
	.st-otro {
		background-color: #6c757d !important;
	}

	/* Contenedor de scroll para el mapa */
	.map-scroll-container {
		overflow-x: auto;
		padding-bottom: 10px;
	}

		.map-scroll-container::-webkit-scrollbar {
			height: 6px;
		}

		.map-scroll-container::-webkit-scrollbar-thumb {
			background: #cbd5e0;
			border-radius: 10px;
		}

	/* Asegura que las tarjetas de las caras ocupen todo el ancho y se vean iguales */
	/* Forzar ancho del modal para el selector de nichos */
	#ajaxTargetSearch {
		max-width: 1200px !important; /* Aumentamos el ancho significativamente */
		width: 90%;
	}

	/* Unificar el tamaño de las tarjetas de las caras */
	.card-face {
		min-height: 300px; /* Altura mínima para que sean iguales */
		display: flex;
		flex-direction: column;
	}

	.map-scroll-container {
		overflow-x: auto;
		overflow-y: hidden;
		padding: 15px 5px;
		background-color: #f8fafc; /* Un fondo muy sutil para delimitar el área */
		border-radius: 8px;
		flex-grow: 1; /* Hace que el área de scroll ocupe el resto de la tarjeta */
	}

	/* Paso 4 */

	.time-slot {
		border: 1px solid #f0f0f0 !important;
		min-width: 90px;
		transition: 0.2s;
	}

		.time-slot.available:hover {
			background-color: var(--pnp-blue) !important;
			color: white !important;
			cursor: pointer;
			transform: scale(1.05);
			z-index: 5;
			box-shadow: 0 4px 8px rgba(0,0,0,0.1);
		}

		.time-slot.occupied {
			cursor: not-allowed;
			opacity: 0.7;
		}

	.sticky-column {
		background-color: #f8f9fa !important;
		border-right: 2px solid #dee2e6 !important;
	}

	.slot.slot-green:hover {
		background-color: #218838 !important; /* Un verde más oscuro */
		cursor: pointer;
		transform: scale(1.1); /* Se agranda un poquito */
		z-index: 10;
		box-shadow: 0 4px 15px rgba(0,0,0,0.3);
		border-radius: 4px;
		transition: all 0.2s ease;
	}

	.slot.slot-red {
		cursor: not-allowed;
	}

	/* Estilo para la celda que ya está seleccionada (la estrella) */
	.slot[style*="border: 4px solid"] {
		animation: pulse-blue 2s infinite;
	}

	@@keyframes pulse-blue {
		0% {
			box-shadow: 0 0 0 0 rgba(0, 74, 153, 0.7);
		}

		70% {
			box-shadow: 0 0 0 10px rgba(0, 74, 153, 0);
		}

		100% {
			box-shadow: 0 0 0 0 rgba(0, 74, 153, 0);
		}
	}


	/* Overlay Personalizado (Tu lógica de Legajos) */
	.custom-modal-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background: rgba(15, 23, 42, 0.6);
		backdrop-filter: blur(5px);
		display: none;
		justify-content: center;
		align-items: center;
		z-index: 3000;
	}

	.swal2-container {
		z-index: 4000 !important;
	}

	#ajaxTargetSearch {
		width: 95%; /* Ocupa casi todo el ancho en móviles */
		max-width: 900px; /* Ancho cómodo para la tabla */
		background: white;
		border-radius: 20px;
		padding: 25px;
		box-shadow: 0 20px 50px rgba(0,0,0,0.3);
	}

</style>

<div class="container-fluid px-4">
	<div class="stepper-card">
		<div class="stepper-header">
			<div class="step-item active" id="nav-1">
				<div class="step-dot"><i class="fa-solid fa-user"></i></div>
				<div class="step-label">Solicitante</div>
			</div>
			<div class="step-item" id="nav-2">
				<div class="step-dot"><i class="fa-solid fa-dove"></i></div>
				<div class="step-label">Difunto</div>
			</div>
			<div class="step-item" id="nav-3">
				<div class="step-dot"><i class="fa-solid fa-handshake"></i></div>
				<div class="step-label">Agencia</div>
			</div>
			<div class="step-item" id="nav-4">
				<div class="step-dot"><i class="fa-solid fa-truck-ramp-box"></i></div>
				<div class="step-label">Servicios</div>
			</div>
			<div class="step-item" id="nav-5">
				<div class="step-dot"><i class="fa-solid fa-file-invoice-dollar"></i></div>
				<div class="step-label">Resumen</div>
			</div>
		</div>

		<div id="dynamic-content" class="mt-4">
			<div class="text-center py-5">
				<i class="fa-solid fa-circle-notch fa-spin fa-2x text-primary"></i>
				<p class="mt-2 text-muted">Cargando formulario...</p>
			</div>
		</div>
	</div>
</div>

<div id="modalOverlaySearch" class="custom-modal-overlay" onclick="handleOverlayClick(event)">
	<div id="ajaxTargetSearch"></div>
</div>

@section Scripts {
	<script>
		const urls = {
			actualStep: 1,
			step1: '@Url.Action("GetStep1", "Contract")',
			step2: '@Url.Action("GetStep2", "Contract")',
			step3: '@Url.Action("GetStep3", "Contract")',
			step4: '@Url.Action("GetStep4", "Contract")',
			step5: '@Url.Action("GetStep5", "Contract")',
			searchModal: '@Url.Action("GetSearchModal", "Contract")',
			searchAction: '@Url.Action("SearchAffiliates", "Contract")',
			searchBeneficiariesModal: '@Url.Action("GetSearchBeneficiary", "Contract")',
			searchBeneficiaries: '@Url.Action("GetBeneficiariesByAffiliate", "Contract")',
			getRegions: '@Url.Action("GetRegions", "Contract")',
			getProvinces: '@Url.Action("GetProvinces", "Contract")',
			getDistricts: '@Url.Action("GetDistricts", "Contract")',
			getBranchCapabilities: '@Url.Action("GetBranchCapabilities", "Contract")',
			getWakes: '@Url.Action("GetWakes", "Contract")',
			getCemeteryModal: '@Url.Action("GetSearchCemetery", "Contract")',
			getCemeteriesAction: '@Url.Action("GetCemeteries", "Contract")',
			getAgencyModal: '@Url.Action("GetSearchAgency", "Contract")',
			getAgenciesAction: '@Url.Action("GetAgencies", "Contract")',
			getNicheSelectorModal: '@Url.Action("GetNicheSelector", "Contract")',
			getStructures: '@Url.Action("GetStructures", "Contract")',
			getSpaceMap: '@Url.Action("GetSpaceMap", "Contract")',
			getServicesAction: '@Url.Action("GetServices", "Service")',
			getAvailableUnits: '@Url.Action("GetAvailableUnits", "Service")',
			getUnitPickerModal: '@Url.Action("GetUnitPicker", "Service")',
			getDailyAvailability: '@Url.Action("GetDailyAvailability", "Service")',
			getWeeklyAvailability: '@Url.Action("GetWeeklyAvailability", "Service")',
			getPrefix: '@Url.Action("GetPrefix", "Contract")',
			saveContract: '@Url.Action("Create", "Contract")',
			downloadContract: '@Url.Action("DescargarContratoPDF", "Contract")',
		};

		let contractData = {
			branchId: 0,
			solicitor: { id: '', dni: '', name: '', cip: '', type: '' },
			deceased: {
				id: '', dni: '', name: '', deathDate: '',
				burialDate: '', burialTime: '',
				ubigeoFull: '', inei: '',
				wakeId: '', wakeName: '',
				cemeteryId: '', cemeteryName: '',
				intermentStructureId: null,
				intermentSpaceId: null,
				burialType: '',
				burialDetail: ''
			},
			agencyId: 0,
			stockItems: [],      // Para Ataúdes (consumibles)
			assetItems: [],      // Para Capillas, Biombos (activos fijos)
			mobilityItems: [],
		};

		let searchTarget = 'Solicitor';

		let branchCaps = { hasWake: false, hasCem: false };

		async function handleStepInitialization(n) {
			console.log("Inicializando paso:", n);

			const container = document.getElementById('dynamic-content');

			switch (n) {
				case 1:
					if (typeof toggleSolicitorType === 'function') {
						toggleSolicitorType();
					}
					break;

				case 2:
					try {
						const response = await fetch(`${urls.getBranchCapabilities}?branchId=${contractData.branchId}`);
						if (response.ok) {
							branchCaps = await response.json();

							const $wakeSection = $('#sectionWakePlace');
							if (branchCaps.hasWake) {
								$wakeSection.fadeIn(300).removeClass('d-none');
								if (typeof loadWakes === 'function') loadWakes();
							} else {
								$wakeSection.hide().addClass('d-none');
								contractData.deceased.wakeId = "0";
								contractData.deceased.wakeName = "Particular / Domicilio";
							}

							$('#sectionSpecificLocation').addClass('d-none');

							if (!branchCaps.hasCem) {
								contractData.deceased.intermentSpaceId = null;
							}
						}
					} catch (e) {
						console.error("Error al validar capacidades de filial:", e);
					}

					if (typeof filterDeceasedOptions === 'function') filterDeceasedOptions();
					if (typeof loadRegions === 'function') loadRegions();
					break;

				case 3:
					if (typeof executeAgencySearch === 'function') {
						executeAgencySearch(true);
					}
					break;

					case 4:
						setTimeout(() => {
							if (typeof renderCatalog === 'function') {
								renderCatalog('Inventario');
							}
							if (typeof updateSelectionUI === 'function') {
								updateSelectionUI();
							}
						}, 150); // 150ms es suficiente para que el navegador procese el nuevo HTML
						break;

				case 5:
					if (typeof renderStep5 === 'function') {
						await renderStep5();
					}
					break;
			}
		}

		async function loadStep(n) {
			const container = document.getElementById('dynamic-content');
			container.style.opacity = '0';

			setTimeout(async () => {
				try {
					const resp = await fetch(urls[`step${n}`]);
					if (!resp.ok) throw new Error("No se pudo cargar el HTML");

					const html = await resp.text();
					container.innerHTML = html;

					updateStepperHeader(n);

					// LLAMADA A LA FUNCIÓN
					handleStepInitialization(n);

					container.style.opacity = '1';
					actualStep = n;

				} catch (e) {
					console.error("Error crítico en loadStep:", e);
					container.innerHTML = `<div class="alert alert-danger">Error: ${e.message}</div>`;
					container.style.opacity = '1';
				}
			}, 200);
		}

		function updateStepperHeader(n) {
			const icons = ['fa-user', 'fa-dove', 'fa-handshake', 'fa-truck-ramp-box', 'fa-file-invoice-dollar'];
			document.querySelectorAll('.step-item').forEach((el, i) => {
				const stepNum = i + 1;
				const dot = el.querySelector('.step-dot');
				el.classList.toggle('active', stepNum === n);
				el.classList.toggle('completed', stepNum < n);
				if (dot) {
					dot.innerHTML = stepNum < n
						? '<i class="fa-solid fa-check"></i>'
						: `<i class="fa-solid ${icons[i]}"></i>`;
				}
			});
		}

		document.addEventListener('DOMContentLoaded', () => {
			const initialBranch = @(ViewBag.UserBranchId ?? 0);
			contractData.branchId = initialBranch;
			console.log("Filial cargada en contractData:", contractData.branchId);
			loadStep(1);
		});

		function openSearchAffiliate(target) {
			searchTarget = target; // Guardamos si es para 'Solicitor' o 'Deceased'

			$.ajax({
				url: urls.searchModal,
				type: 'GET',
				success: function (html) {
					$('#ajaxTargetSearch').html(html);
					$('#modalOverlaySearch').css('display', 'flex').hide().fadeIn(300);
				}
			});
		}

		function closeSearchModal() {
			$('#modalOverlaySearch').fadeOut(300);
		}

		function handleOverlayClick(e) {
			if (e.target.id === 'modalOverlaySearch') closeSearchModal();
		}

		async function executeSearch() {
			// 1. Obtenemos los filtros básicos
			const filters = {
				dni: $('#filterDni').val(),
				cip: $('#filterCip').val(),
				name: $('#filterName').val(),
			};

			const $tbody = $('#resultsTableBody');
			$tbody.html('<tr><td colspan="4" class="text-center py-4"><i class="fas fa-spinner fa-spin"></i> Filtrando beneficiarios...</td></tr>');

			try {
				// 2. Construimos la URL con el nuevo parámetro parentDni
				const query = `dni=${filters.dni}&cip=${filters.cip}&name=${encodeURIComponent(filters.name)}&parentDni=${filters.parentDni}`;
				const response = await fetch(`${urls.searchAction}?${query}`);
				const data = await response.json();

				$tbody.empty();

				if (data.length === 0) {
					$tbody.append('<tr><td colspan="4" class="text-center text-danger">No se encontraron beneficiarios asociados a este titular.</td></tr>');
					return;
				}

				// 3. Renderizamos los resultados
				data.forEach(item => {
					const tr = $(`
						<tr style="cursor:pointer" class="align-middle">
							<td><b>${item.dni}</b></td>
							<td>${item.relationship || 'Familiar'}</td> <td>${item.name}</td>
							<td class="text-end"><button class="btn btn-sm btn-primary rounded-pill">Seleccionar</button></td>
						</tr>
					`);
					tr.click(() => selectAffiliate(item));
					$tbody.append(tr);
				});
			} catch (e) {
				$tbody.html('<tr><td colspan="4" class="text-center text-danger">Error al conectar con la base de datos de beneficiarios.</td></tr>');
			}
		}

		function selectAffiliate(item) {
			if (searchTarget === 'Solicitor') {
				contractData.solicitor.id = item.id;
				contractData.solicitor.dni = item.dni;
				contractData.solicitor.name = item.name;
				contractData.solicitor.cip = item.cip;


				$('#SolicitorDni').val(item.dni);
				$('#SolicitorName').val(item.name);
				$('#SolicitorCip').val(item.cip);
			}
			else if (searchTarget === 'Deceased') {
				$('#DeceasedDni').val(item.dni);
				$('#DeceasedName').val(item.name);
				$('#DeceasedCip').val(item.cip);
			}
			closeSearchModal();
		}

		function toggleSolicitorType() {
			const select = document.getElementById('SolicitorType');
			if (!select) return;

			const type = select.value;
			contractData.solicitor.type = type;

			const isTitular = (type === "Titular");
			const btnLupa = document.getElementById('btnLupa');
			const fields = ['SolicitorDni', 'SolicitorName', 'SolicitorCip'];

			if (btnLupa) {
				isTitular ? $(btnLupa).fadeIn(200) : $(btnLupa).fadeOut(200);
			}

			fields.forEach(id => {
				const el = document.getElementById(id);
				if (!el) return;

				if (isTitular) {
					el.readOnly = true;
					el.classList.add('bg-light');
				} else {
					el.readOnly = false;
					el.classList.remove('bg-light');
				}
			});
		}

		function validateStep1() {
			const dni = $('#SolicitorDni').val();
			const name = $('#SolicitorName').val();
			const type = $('#SolicitorType').val();
			const cip = $('#SolicitorCip').val();

			if (!dni || !name) {
				Swal.fire('Atención', 'Debe buscar y seleccionar un solicitante.', 'warning');
				return false;
			}

			// PERSISTENCIA: Guardamos en nuestro "cerebro" global
			contractData.solicitor.dni = dni;
			contractData.solicitor.name = name;
			contractData.solicitor.type = type;
			contractData.solicitor.cip = cip;

			return true;
		}

		async function nextStep(n, validationFn) {
			if (validationFn && !validationFn()) {
				return;
			}
			loadStep(n);
		}

		//PASO
		//NUMERO
		//2

		$(document).on('change', '#BurialTime', function() {
			contractData.deceased.burialTime = $(this).val();
		});

		function filterDeceasedOptions() {
			// 1. Obtenemos el tipo de solicitante que guardamos en el Paso 1
			const solType = contractData.solicitor.type; // "Titular" o "Familiar"
			const $deceasedSelect = $('#DeceasedType');
			const $alert = $('#alertRestriction');

			if (!$deceasedSelect.length) return;

			if (solType === "Titular") {
				// --- ESCENARIO A: EL TITULAR FIRMA ---
				// El fallecido obligatoriamente debe ser un Beneficiario (Familiar)
				$deceasedSelect.find('option[value="Titular"]').attr('disabled', true).hide();
				$deceasedSelect.val("Beneficiario"); // Forzamos la selección a familiar

				$alert.removeClass('d-none').addClass('animate__animated animate__shakeX');

				// Ejecutamos el cambio para que se limpie el DNI y se active la lupa de búsqueda de familiares
				handleDeceasedTypeChange();
			}
			else {
				$deceasedSelect.find('option[value="Titular"]').attr('disabled', false).show();
				$deceasedSelect.val(""); // Dejamos que el usuario elija

				$alert.addClass('d-none');
			}
		}

		function openSearchBeneficiaries() {
			searchTarget = 'Deceased'; // Marcamos que el destino es el fallecido

			$.ajax({
				url: urls.searchBeneficiariesModal, // Tu nueva vista parcial
				type: 'GET',
				success: function (html) {
					// Inyectamos el HTML en el contenedor del modal
					$('#ajaxTargetSearch').html(html);

					// Mostramos el overlay con efecto
					$('#modalOverlaySearch').css('display', 'flex').hide().fadeIn(300);

					// Cargamos los datos automáticamente al abrir
					executeBeneficiarySearch();
				},
				error: function() {
					alert("Error al cargar el buscador de beneficiarios.");
				}
			});
