		function selectBeneficiary(item) {
			const $dniInput = $('#DeceasedDni');
			const $errorMsg = $('#deceasedDniError');

			// 1. Validamos integridad del DNI
			const hasValidDni = item.dni && item.dni.toString().trim().length >= 8;

			if (hasValidDni) {
				$dniInput.val(item.dni).prop('readonly', true).addClass('bg-light').removeClass('border-danger text-danger');
