		function handleDeceasedTypeChange() {
			const type = $('#DeceasedType').val();
			const $btnLupa = $('#btnLupaDeceased');
			const $dniInput = $('#DeceasedDni');
			const $nameInput = $('#DeceasedName');

			// Si es Titular y viene de Familiar/3roPolicial, ya está autocompletado y bloqueado
			const isAutoFilled = (contractData.solicitor.type === "Familiar" || contractData.solicitor.type === "TerceroPolicial");

			if (type === "Titular") {
				if (isAutoFilled) {
					$btnLupa.fadeOut(200); // No necesita buscar, ya se trajo del Paso 1
