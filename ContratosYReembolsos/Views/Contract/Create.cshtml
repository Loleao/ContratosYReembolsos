		function filterDeceasedOptions() {
			const solType = contractData.solicitor.type; // Capturado en Paso 1
			const $select = $('#DeceasedType');
			const $alert = $('#alertRestriction');
			const $msg = $('#txtRestrictionMsg');

			if (!$select.length) return;

			// Resetear opciones
			$select.find('option').prop('disabled', false).show();
			$alert.addClass('d-none');

			if (solType === "Titular") {
				// REGLA: Si solicita Titular, fallece un Beneficiario
				$select.find('option[value="Titular"], option[value="Tercero"]').prop('disabled', true).hide();
				$select.val("Beneficiario");
				$msg.text("Usted es el Titular Solicitante, seleccione al familiar beneficiario fallecido.");
				$alert.removeClass('d-none');
			}
			else if (solType === "Familiar" || solType === "TerceroPolicial") {
				// REGLA: Si solicita Familiar o 3ro Policial, fallece el Titular (Autocompletar)
				$select.find('option[value="Beneficiario"], option[value="Tercero"]').prop('disabled', true).hide();
				$select.val("Titular");
				$msg.text("Se han cargado automáticamente los datos del Titular afiliado.");
				$alert.removeClass('d-none');

				// Autocompletar datos del Titular que vinculamos en el Paso 1
				autoCompleteDeceasedWithAffiliate();
			}
			else if (solType === "Tercero") {
				// REGLA: Si solicita un Tercero Civil, fallece un Tercero (Manual)
				$select.find('option[value="Titular"], option[value="Beneficiario"]').prop('disabled', true).hide();
				$select.val("Tercero");
				$msg.text("Modo Tercero: Ingrese los datos del fallecido manualmente.");
				$alert.removeClass('d-none');
			}

			// Disparar el cambio visual de inputs (lupas, readonlies)
			handleDeceasedTypeChange();
		}

