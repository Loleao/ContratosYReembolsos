		async function changePavilion() {
			const pavId = $('#cboPavilion').val();
			const selectedType = $('input[name="BurialType"]:checked').val();

			if (!pavId) {
				$('#nicheMapsContainer').addClass('d-none');
				return;
			}

			$('#nicheLoader').removeClass('d-none');
			$('#nicheMapsContainer').addClass('d-none');

			try {
				const resp = await fetch(`${urls.getSpaceMap}?structureId=${pavId}`);
				const spaces = await resp.json();

				// Dimensiones dinámicas
				const dynamicRows = [...new Set(spaces.map(s => s.rowLetter.toUpperCase()))].sort();
				const dynamicCols = [...new Set(spaces.map(s => parseInt(s.columnNumber)))].sort((a, b) => a - b);

				const $col1 = $('#colCara1');
				const $col2 = $('#colCara2');

				if (selectedType === "Tumba" || selectedType === "MAUSOLEO") {
					$col1.show();
					$col2.addClass('d-none');
					renderGrid('gridCara1', dynamicRows, dynamicCols, spaces, selectedType);
				} else {
					$col1.show();
					$col2.removeClass('d-none'); // Se mostrará debajo de la otra por ser col-md-12

					const middleIndex = Math.ceil(dynamicCols.length / 2);
					const colsCara1 = dynamicCols.slice(0, middleIndex);
					const colsCara2 = dynamicCols.slice(middleIndex);

					renderGrid('gridCara1', dynamicRows, colsCara1, spaces, selectedType);
					renderGrid('gridCara2', dynamicRows, colsCara2, spaces, selectedType);
				}

				$('#nicheLoader').addClass('d-none');
				$('#nicheMapsContainer').removeClass('d-none');

			} catch (e) {
				console.error(e);
				$('#nicheLoader').addClass('d-none');
			}
		}

		async function loadNicheData(cemId) {
			try {
				const resp = await fetch(`${urls.getNicheMap}/${cemId}`);
				const niches = await resp.json();

				console.log("Nichos cargados:", niches);

				if (!niches || niches.length === 0) {
					console.warn("No hay nichos para este cementerio.");
					return;
				}

				const rows = ['A', 'B', 'C', 'D', 'E'];

				// Cara 1: Renderiza columnas del 1 al 5
				renderGrid('gridCara1', rows, [1, 2, 3, 4, 5], niches);

				// Cara 2: Renderiza columnas del 6 al 10
				renderGrid('gridCara2', rows, [6, 7, 8, 9, 10], niches);

			} catch (error) {
				console.error("Error al cargar mapa de nichos:", error);
			}
		}

		function renderGrid(containerId, rows, cols, allSpaces, type) {
			const $container = $('#' + containerId);
			if (!$container.length) return;
			$container.empty();

			const $mapBody = $('<div class="d-flex flex-column gap-2" style="min-width: max-content; padding: 10px;"></div>');

			// --- 1. CABECERA DE NÚMEROS ---
			const $headerRow = $('<div class="d-flex align-items-center mb-1"></div>');
			$headerRow.append('<div style="width: 53px;"></div>');
			const $numContainer = $('<div class="d-flex flex-nowrap gap-1"></div>');
			cols.forEach(c => {
				$numContainer.append(`<div class="text-center fw-bold text-muted x-small" style="width: 34px;">${c}</div>`);
			});
			$headerRow.append($numContainer);
			$mapBody.append($headerRow);

			// --- 2. FILAS DE NICHOS ---
			rows.forEach(r => {
				const $rowDiv = $('<div class="d-flex align-items-center"></div>');
				$rowDiv.append(`<div class="fw-bold text-muted border-end pe-3 me-2 text-center" style="width: 45px; font-size: 13px;">${r}</div>`);

				const $spacesContainer = $('<div class="d-flex flex-nowrap gap-1"></div>');

				cols.forEach(c => {
					const space = allSpaces.find(s =>
						s.rowLetter.toString().trim().toUpperCase() === r.toUpperCase() &&
						parseInt(s.columnNumber) === parseInt(c)
					);

					if (space) {
						let statusClass = "st-otro"; // Por defecto gris (Mantenimiento / Bloqueado)
						let isSelectable = false;

						// Normalizar status para matchear con el Enum.ToString().ToLower()
						const currentStatus = (space.status || "").toLowerCase();

						if (currentStatus === "disponible") {
							statusClass = "st-disponible";
							isSelectable = true;
						} else if (currentStatus === "ocupado") {
							statusClass = "st-ocupado";
						} else if (currentStatus === "reservado") {
							statusClass = "st-reservado";
						} else if (currentStatus === "bloqueado") {
							statusClass = "st-otro"; // Podrías crear .st-bloqueado en CSS si gustas
						}

						$spacesContainer.append(`
							<div class="space-item-modal ${statusClass}"
								 onclick="${isSelectable ? `confirmNicheSelection(${space.id}, '', '${r}', ${c})` : `Swal.fire('No disponible', 'El espacio está ${currentStatus}.', 'warning')`}"
								 title="Fila ${r} - Col ${c} (${currentStatus.toUpperCase()})">
								${c}
							</div>
						`);
					} else {
						$spacesContainer.append('<div style="width: 34px; height: 34px; background: #f1f5f9; border-radius: 6px; opacity: 0.3;"></div>');
					}
				});

				$rowDiv.append($spacesContainer);
				$mapBody.append($rowDiv);
			});

			$container.append($mapBody);
		}

		function confirmNicheSelection(id, dummy, row, col) {
			const pavilionId = $('#cboPavilion').val();
			const pavilionName = $('#cboPavilion option:selected').text();
			const type = $('input[name="BurialType"]:checked').val(); // 'Pabellon', 'Tumba' o 'Columbario'

			contractData.deceased.intermentSpaceId = parseInt(id);
			contractData.deceased.structureId = parseInt(pavilionId);
			contractData.deceased.burialDetail = `${pavilionName} - Fila ${row} - Nro ${col} (${type})`;

			// --- MAPEO DE IDs CORRECTO ---
			const SERVICIO_SEPULTURA_AUTO = {
				'Pabellon': 3,    // <--- CORREGIDO A ID 3
				'Tumba': 5,
				'Columbario': 34
			};

			const nombres = {
				'Pabellon': 'Derecho de Nicho',
				'Tumba': 'Derecho de Tumba',
				'Columbario': 'Derecho de Columbario'
			};

			const idServicio = SERVICIO_SEPULTURA_AUTO[type];

			if (idServicio) {
				// 1. Limpiar previos (usamos los IDs reales para el filtro)
				const idsSepultura = [3, 5, 34];
				contractData.serviceItems = contractData.serviceItems.filter(s => !idsSepultura.includes(s.id));

				// 2. Insertar OBJETO con nombre temporal para evitar 'undefined'
				contractData.serviceItems.push({
					id: idServicio,
					name: nombres[type],
					category: 'Servicios',
					price: 0
				});
			}

			$('#txtNicheSelected').text(contractData.deceased.burialDetail);
			$('#selectedNicheDisplay').removeClass('d-none');
			closeSearchModal();
		}

		function validateStep2() {
			const d = contractData.deceased;
			const type = $('#DeceasedType').val();

			// 1. Captura de datos desde la UI
			d.dni = $('#DeceasedDni').val();
			d.name = $('#DeceasedName').val();
			d.deathDate = $('#DeathDate').val();
			d.burialDate = $('#BurialDate').val();
			d.burialTime = $('#BurialTime').val();
			d.inei = $('#DeathDist').val();

			// Captura de Velatorio
			const wakeVal = $('#WakePlace').val();
			const wakeText = $('#WakePlace option:selected').text();
			const customAddr = $('#WakeAddressCustom').val() ? $('#WakeAddressCustom').val().trim() : '';

			// Sincronizamos el WakeId (null si es el "999" o si es Particular "")
			d.wakeId = (wakeVal && wakeVal !== "999" && wakeVal !== "") ? parseInt(wakeVal) : null;

			// Determinamos si la opción actual requiere dirección obligatoria (Otro o Particular)
			const requiereDireccionManual = wakeVal === "999" || wakeText.toUpperCase().includes("PARTICULAR") || wakeText.toUpperCase().includes("DOMICILIO");

			if (requiereDireccionManual) {
				// Validamos que realmente haya escrito una dirección
				if (!customAddr || customAddr.length < 5) {
					Swal.fire('Dirección Requerida', 'Por favor, ingrese la dirección exacta del velatorio externo.', 'warning');
					$('#WakeAddressCustom').focus();
					return false;
				}

				// Persistencia para el resumen visual (Paso 4) y la Entidad C#
				d.wakeName = `${wakeText}: ${customAddr}`;
				d.customWakeAddress = customAddr; // <--- PERSISTENCIA CRÍTICA PARA EL BACKEND
			} else {
				// Si es un velatorio interno propio de la base de datos
				d.wakeName = wakeText;
				d.customWakeAddress = null; // No hace falta dirección manual, ya está en la BD
			}

			// 2. Validaciones de Selección
			if (!type) {
				Swal.fire('Atención', 'Debe seleccionar la condición del fallecido.', 'warning');
				return false;
			}

			if (!d.dni || d.dni.length < 8) {
				Swal.fire('DNI Requerido', 'Debe ingresar un DNI de 8 dígitos para el fallecido.', 'warning');
				$('#DeceasedDni').addClass('border-danger').focus();
				return false;
			}

			if (!d.name || d.name.trim().length < 5) {
				Swal.fire('Atención', 'Debe seleccionar o registrar el nombre completo del difunto.', 'warning');
				return false;
			}

			// 3. Validaciones de Fechas
			if (!d.deathDate) {
				Swal.fire('Fecha Requerida', 'Debe indicar la fecha de fallecimiento.', 'warning');
				return false;
			}

			if (!d.burialDate || !d.burialTime) {
				Swal.fire('Programación Requerida', 'Debe indicar la fecha y hora programada para el sepelio.', 'warning');
				return false;
			}

			// 4. Validación de Ubicación (Ubigeo)
			if (!d.inei) {
				Swal.fire('Ubicación Requerida', 'Debe seleccionar el Departamento, Provincia y Distrito de fallecimiento.', 'warning');
				return false;
			}

			// 5. Validación de Cementerio y Mapa (Si es interno)
			if (!d.cemeteryId) {
				Swal.fire('Cementerio Requerido', 'Debe buscar y seleccionar un cementerio de destino.', 'warning');
				return false;
			}

			const isInternalCemetery = !$('#sectionSpecificLocation').hasClass('d-none');
			if (isInternalCemetery && !d.intermentSpaceId) {
				Swal.fire('Lugar en Mapa', 'Ha seleccionado un cementerio administrado. Debe elegir el pabellón/nicho en el mapa.', 'error');
				return false;
			}

			// 6. Limpieza de datos de estructura si es cementerio externo
			if (!isInternalCemetery) {
				d.intermentSpaceId = null;
				d.structureId = null;
				d.burialDetail = "Cementerio Externo / Provincia";
			}

			// 7. Preparación de datos para el Resumen (Paso 4)
			d.ubigeoFull = `${$('#DeathDept').val()} - ${$('#DeathProv option:selected').text()} - ${$('#DeathDist option:selected').text()}`;
			d.type = type;

			console.log("Paso 2 validado y persistido correctamente:", d);
			return true;
		}

		//AHORA PASO 3

		let currentServiceId = null;

		// --- FUNCIONES PRINCIPALES ---

		async function renderCatalog(category) {
			const container = document.getElementById('catalogContainer');
			const agencySection = document.getElementById('agreementAgencySection');

			if (!contractData.branchId) {
				container.innerHTML = '<div class="alert alert-warning border-dashed">Seleccione una sede en el paso anterior.</div>';
				return;
			}

			// 1. UI: Activar pestaña
			document.querySelectorAll('#pills-tab .nav-link').forEach(btn => {
				btn.classList.toggle('active', btn.innerText.trim().includes(category));
			});

			// 2. Control Agencia
			if (category === 'Convenio') {
				agencySection.classList.remove('d-none');
				if (!contractData.agencyId) {
					container.innerHTML = `<div class="text-center py-5 w-100"><p class="text-muted">Seleccione una Agencia arriba.</p></div>`;
					return;
				}
			} else {
				agencySection.classList.add('d-none');
			}

			container.innerHTML = '<div class="text-center py-5 w-100"><div class="spinner-border text-primary"></div></div>';

			let url = "";
			if (category === 'Inventario') url = `@Url.Action("GetInventoryStock", "Contract")?branchId=${contractData.branchId}`;
			else if (category === 'Movilidad') url = `@Url.Action("GetAvailableVehicleTypesByBranch", "Contract")?branchId=${contractData.branchId}`;
			else if (category === 'Servicios') url = `@Url.Action("GetFuneralServices", "Contract")`;
			else if (category === 'Convenio') url = `@Url.Action("GetFuneralServices", "Contract")?agencyId=${contractData.agencyId}`;

			try {
				const response = await fetch(url);
				if (!response.ok) throw new Error("Error en servidor");

				const data = await response.json(); // <-- AHORA DATA ESTÁ DEFINIDO CORRECTAMENTE

				// --- LÓGICA DE SINCRONIZACIÓN MEJORADA ---
				if (category === 'Servicios' && contractData.serviceItems.length > 0) {
					contractData.serviceItems.forEach((itemEnCarrito, index) => {
						// Buscamos el servicio real por ID en la data que acaba de llegar
						const servicioReal = data.find(d => d.id === itemEnCarrito.id);
						if (servicioReal) {
							// PISAMOS el objeto temporal con la data real de la BD
							contractData.serviceItems[index] = servicioReal;
						}
					});
					// Refrescamos el ticket de la derecha para quitar el "Cargando..."
					updateSelectionUI();
				}
				// ------------------------------------------

				container.innerHTML = data.length ? '' : '<p class="text-center py-5 w-100 text-muted small">No hay elementos disponibles.</p>';

				if (category !== 'Movilidad') {
					const grouped = data.reduce((acc, item) => {
						const catName = item.category || "Otros";
						acc[catName] = acc[catName] || [];
						acc[catName].push(item);
						return acc;
					}, {});

					for (const catName in grouped) {
						const icon = category === 'Inventario' ? 'fa-box-archive' : (category === 'Convenio' ? 'fa-handshake' : 'fa-bell-concierge');
						container.innerHTML += `<div class="col-12 mt-3 mb-2"><h6 class="text-uppercase fw-bold text-muted small border-bottom pb-2"><i class="fa-solid ${icon} me-2"></i>${catName}</h6></div>`;

						grouped[catName].forEach(item => {
							let selectionType = category === 'Servicios' ? 'Servicios-Internos' : (category === 'Convenio' ? 'Servicios-Convenio' : category);
							container.innerHTML += createProductCard(item, selectionType);
						});
					}
				} else {
					data.forEach(item => {
						container.innerHTML += createProductCard(item, 'Movilidad');
					});
				}
			} catch (error) {
				console.error("Error:", error);
				container.innerHTML = '<div class="alert alert-danger">Error al cargar el catálogo.</div>';
			}
		}

		function createProductCard(item, type) {
			let isSelected = false;

			if (type === 'Inventario') isSelected = contractData.stockItems.some(x => x.id === item.id);
			else if (type === 'Movilidad') isSelected = contractData.mobilityItems.includes(item.id);
			else if (type === 'Servicios-Internos') isSelected = contractData.serviceItems.some(x => x.id === item.id);
			else if (type === 'Servicios-Convenio') isSelected = contractData.agreementServiceItems.some(x => x.id === item.id);

			const itemData = JSON.stringify(item).replace(/"/g, '&quot;');
			const detail = item.price ? `S/ ${item.price.toFixed(2)}` : (item.stock ? `Stock: ${item.stock}` : 'Servicio');

			// Color de borde dinámico si es convenio
			const activeClass = type === 'Servicios-Convenio' ? 'border-success bg-success-subtle' : 'border-primary bg-primary-subtle';

			return `
				<div class="col-md-6 mb-2">
					<div class="card h-100 border-2 ${isSelected ? activeClass + ' shadow-sm' : 'border-light'}"
						 onclick="handleSelection('${type}', ${itemData})" style="cursor:pointer; transition: all 0.2s;">
						<div class="card-body p-2 px-3">
							<div class="d-flex justify-content-between align-items-center">
								<div>
									<p class="fw-bold mb-0 small" style="font-size: 0.75rem;">${item.name}</p>
									<span class="text-muted" style="font-size:0.65rem">${detail}</span>
								</div>
								${isSelected ? `<i class="fa-solid fa-circle-check ${type === 'Servicios-Convenio' ? 'text-success' : 'text-primary'}"></i>` : ''}
							</div>
						</div>
					</div>
				</div>`;
		}

		function handleSelection(type, item) {
			const idsObligatorios = [3, 5, 34];
			if (type === 'Servicios-Internos' && idsObligatorios.includes(item.id)) {
				Swal.fire({
					toast: true,
					position: 'top-end',
					icon: 'info',
					title: 'Este servicio es obligatorio para la ubicación elegida',
					showConfirmButton: false,
					timer: 2500
				});
				return; // Bloquea la deselección manual
			}

			if (type === 'Inventario') {
				const idx = contractData.stockItems.findIndex(x => x.id === item.id);
				if (idx === -1) {
					// Regla: Solo un ataúd
					if (item.category === 'Ataúdes' || item.name.toUpperCase().includes('ATAUD')) {
						contractData.stockItems = contractData.stockItems.filter(x => !x.name.toUpperCase().includes('ATAUD'));
					}
					contractData.stockItems.push(item);
				} else {
					contractData.stockItems.splice(idx, 1);
				}
			}
			else if (type === 'Movilidad') {
				const idx = contractData.mobilityItems.indexOf(item.id);
				if (idx === -1) contractData.mobilityItems.push(item.id);
				else contractData.mobilityItems.splice(idx, 1);
			}
			else if (type === 'Servicios-Internos') {
				const idx = contractData.serviceItems.findIndex(x => x.id === item.id);
				if (idx === -1) contractData.serviceItems.push(item);
				else contractData.serviceItems.splice(idx, 1);
			}
			else if (type === 'Servicios-Convenio') {
				const idx = contractData.agreementServiceItems.findIndex(x => x.id === item.id);
				if (idx === -1) contractData.agreementServiceItems.push(item);
				else contractData.agreementServiceItems.splice(idx, 1);
			}

			// Refrescar UI del catálogo para mostrar el check
			// Mapeamos de vuelta al nombre de la pestaña
			let tabToRefresh = type;
			if (type === 'Servicios-Internos') tabToRefresh = 'Servicios';
			if (type === 'Servicios-Convenio') tabToRefresh = 'Convenio';

			renderCatalog(tabToRefresh);
			updateSelectionUI();
		}

		function updateSelectionUI() {
			const cartContent = document.getElementById('cartContent');
			const emptyMsg = document.getElementById('emptyCartMsg');
			const totalBadge = document.getElementById('totalItemsBadge');

			cartContent.innerHTML = '';
			const total = contractData.stockItems.length +
						  contractData.mobilityItems.length +
						  contractData.serviceItems.length +
						  contractData.agreementServiceItems.length;

			totalBadge.innerText = total;
			emptyMsg.style.display = total > 0 ? 'none' : 'block';

			// 1. Bienes de Inventario
			if (contractData.stockItems.length > 0) {
				renderGroupHeader(cartContent, "Bienes de Inventario", "text-primary");
				contractData.stockItems.forEach(i => {
					cartContent.innerHTML += createCartTicket(i.name, i.category, 'bg-primary', `handleSelection('Inventario', ${JSON.stringify(i).replace(/"/g, '&quot;')})`, 'fa-box');
				});
			}

			// 2. Movilidad
			if (contractData.mobilityItems.length > 0) {
				renderGroupHeader(cartContent, "Logística y Transporte", "text-dark");
				contractData.mobilityItems.forEach(id => {
					cartContent.innerHTML += createCartTicket("Transporte Programado", "Vehículo", 'bg-dark', `handleSelection('Movilidad', {id:${id}})`, 'fa-car-side');
				});
			}

			// 3. Servicios FONAFUN (Internos)
			if (contractData.serviceItems.length > 0) {
				renderGroupHeader(cartContent, "Servicios Propios", "text-info");
				contractData.serviceItems.forEach(s => {
					cartContent.innerHTML += createCartTicket(s.name, "Servicio Interno", 'bg-info text-dark', `handleSelection('Servicios-Internos', ${JSON.stringify(s).replace(/"/g, '&quot;')})`, 'fa-bell-concierge');
				});
			}

			// 4. Servicios CONVENIO (Externos)
			if (contractData.agreementServiceItems.length > 0) {
				renderGroupHeader(cartContent, "Servicios por Convenio", "text-success");
				contractData.agreementServiceItems.forEach(s => {
					cartContent.innerHTML += createCartTicket(s.name, "Vía Convenio", 'bg-success text-white', `handleSelection('Servicios-Convenio', ${JSON.stringify(s).replace(/"/g, '&quot;')})`, 'fa-handshake');
				});
			}
		}

		async function toggleAgreementSection() {
			const isChecked = document.getElementById('chkUseAgreement').checked;
			contractData.useAgreement = isChecked;

			const tabConvenio = document.getElementById('li-tab-convenio');
			const selectAgency = document.getElementById('selAgreementAgency');

			if (isChecked) {
				tabConvenio.classList.remove('d-none');

				// Cargar agencias solo si el select está vacío
				if (selectAgency.options.length <= 1) {
					await loadAgencies();
				}
			} else {
				tabConvenio.classList.add('d-none');
				contractData.agencyId = null;
				contractData.agreementServiceItems = [];
				selectAgency.value = "";
				renderCatalog('Inventario');
			}
			updateSelectionUI();
		}

		async function loadAgencies() {
			const select = document.getElementById('selAgreementAgency');
			if (!contractData.branchId) return;

			try {
				const response = await fetch(`@Url.Action("GetAgencies", "Contract")?branchId=${contractData.branchId}`);
				const agencies = await response.json();

				// Limpiar opciones previas manteniendo la primera
				select.innerHTML = '<option value="">-- Seleccione una agencia --</option>';

				agencies.forEach(agency => {
					const option = document.createElement('option');
					option.value = agency.id;
					option.textContent = agency.name;
					select.appendChild(option);
				});
			} catch (error) {
				console.error("Error cargando agencias:", error);
			}
		}

		// Función que debe llamarse en el onchange del select de agencias
		function onAgencyChange() {
			const select = document.getElementById('selAgreementAgency');
			contractData.agencyId = select.value;
			renderCatalog('Convenio'); // Refrescar para mostrar los productos de esa agencia
		}

		function validateStep3() { // Cambiado de validateStep4 a validateStep3
			const tieneAtaud = contractData.stockItems.some(item =>
				item.category === 'Ataúdes' || item.name.toUpperCase().includes('ATAUD')
			);

			if (!tieneAtaud) {
				Swal.fire({
					title: 'Atención',
					text: 'Es obligatorio seleccionar un ataúd para continuar con el contrato.',
					icon: 'warning',
					confirmButtonColor: '#004a99'
				});
				return false;
			}
			return true;
		}

		// --- FUNCIONES AUXILIARES (Sin cambios significativos) ---

		function renderGroupHeader(container, title, colorClass) {
			container.innerHTML += `<div class="${colorClass} fw-bold mb-2 mt-3" style="font-size: 0.65rem; letter-spacing: 1px; text-transform: uppercase;">${title}</div>`;
		}

		function createCartTicket(title, subtitle, colorClass, removeAction, icon) {
			const isDark = colorClass.includes('bg-primary') || colorClass.includes('bg-dark') || colorClass.includes('bg-success');
			const textColor = isDark ? 'text-white' : 'text-dark';

			return `
				<div class="card border-0 shadow-sm mb-2 animate__animated animate__fadeInRight" style="border-radius: 10px; overflow: hidden;">
					<div class="d-flex align-items-center ${colorClass} ${textColor} p-2">
						<div class="rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center me-2" style="width: 30px; height: 30px;">
							<i class="fa-solid ${icon} fw-bold" style="font-size: 0.8rem;"></i>
						</div>
						<div class="flex-grow-1 overflow-hidden">
							<div class="fw-bold text-truncate" style="font-size: 0.75rem; line-height: 1;">${title}</div>
							<small class="opacity-75" style="font-size: 0.65rem;">${subtitle}</small>
						</div>
						<button class="btn btn-sm ${textColor} p-0 ms-2" onclick="${removeAction}">
							<i class="fa-solid fa-circle-xmark opacity-75"></i>
						</button>
					</div>
				</div>`;
		}

		//PASO
		//NUMERO
		//4

		async function renderSummary() {
			// 1. Prefijo (Consistente con tu lógica)
			$('#resContractPreview').text("Cargando...");
			try {
				const resp = await fetch(`${urls.getPrefix}?branchId=${contractData.branchId}`);
				const data = await resp.json();
				const year = new Date().getFullYear();
				$('#resContractPreview').text(`${data.prefix}${year}-XXXXX`);
			} catch (e) { $('#resContractPreview').text("---"); }

			// 2. Datos de Personas
			$('#resSolicitorName').text(contractData.solicitor.name);
			$('#resSolicitorDni').text(`DNI: ${contractData.solicitor.dni}`);
			$('#resDeceasedName').text(contractData.deceased.name);
			$('#resDeceasedDni').text(`DNI: ${contractData.deceased.dni}`);

			// 3. Logística
			const d = contractData.deceased;
			$('#resBurialDateTime').text(`${d.burialDate} ${d.burialTime}`);
			$('#resWakePlace').text(d.wakeName || "Particular / Domicilio");
			$('#resCemetery').text(d.cemeteryName);

			if (d.burialDetail) {
				$('#resNicheRow').removeClass('d-none').show();
				$('#resNicheDetail').text(d.burialDetail);
			}

			// 4. Tabla de Servicios (Mapeo de tus nuevas categorías)
			const $container = $('#resServicesTable');
			$container.empty();

			// Bienes (Ataúdes, etc)
			if (contractData.stockItems.length > 0) {
				$container.append(createSummarySectionHeader("Bienes e Inventario", "fa-box", "text-primary"));
				contractData.stockItems.forEach(i => {
					$container.append(createSummaryRow(i.name, i.category, 'primary', 'fa-box', "Entregado"));
				});
			}

			// Servicios Internos
			if (contractData.serviceItems.length > 0) {
				$container.append(createSummarySectionHeader("Servicios Propios", "fa-bell-concierge", "text-info"));
				contractData.serviceItems.forEach(s => {
					$container.append(createSummaryRow(s.name, "Servicio FONAFUN", 'info', 'fa-check', "Incluido"));
				});
			}

			// Servicios Convenio
			if (contractData.agreementServiceItems.length > 0) {
				$container.append(createSummarySectionHeader("Servicios por Convenio", "fa-handshake", "text-success"));
				contractData.agreementServiceItems.forEach(s => {
					$container.append(createSummaryRow(s.name, "Vía Agencia Externa", 'success', 'fa-users-gear', "Convenio"));
				});
			}

			// Movilidad
			if (contractData.mobilityItems.length > 0) {
				$container.append(createSummarySectionHeader("Logística de Transporte", "fa-car-side", "text-dark"));
				contractData.mobilityItems.forEach(id => {
					 $container.append(createSummaryRow("Unidad de Traslado", "Programación Logística", 'dark', 'fa-clock', "Pendiente"));
				});
			}
		}

		function createSummarySectionHeader(title, icon, textColor) {
			return `
				<div class="mt-4 mb-2 d-flex align-items-center">
					<div class="border-bottom flex-grow-1"></div>
					<span class="mx-3 fw-bold small ${textColor} text-uppercase" style="letter-spacing: 1px;">
						<i class="fa-solid ${icon} me-2"></i>${title}
					</span>
					<div class="border-bottom flex-grow-1"></div>
				</div>`;
		}

		// Función auxiliar para las filas (Ajustada para que se vea más como tabla)
		function createSummaryRow(title, subtitle, color, icon, tag) {
			return `
				<div class="d-flex justify-content-between align-items-center py-2 px-3 mb-1 bg-white border rounded-3 shadow-sm animate__animated animate__fadeInUp">
					<div class="d-flex align-items-center">
						<div class="text-${color} me-3" style="width: 25px; text-align: center;">
							<i class="fa-solid ${icon} fs-5"></i>
						</div>
						<div>
							<span class="fw-bold d-block text-dark small" style="line-height: 1.2;">${title}</span>
							<small class="text-muted" style="font-size: 0.65rem;">${subtitle}</small>
						</div>
					</div>
					<span class="badge bg-${color}-subtle text-${color} border border-${color} rounded-pill" style="font-size: 0.6rem; padding: 0.4em 0.8em;">
						${tag.toUpperCase()}
					</span>
				</div>`;
		}

		async function saveFinalContract() {
			const result = await Swal.fire({
				title: '¿Confirmar Registro?',
				text: "Se generará el contrato legal y se actualizará el inventario.",
				icon: 'question',
				showCancelButton: true,
				confirmButtonText: 'Sí, Registrar',
				cancelButtonText: 'Revisar',
				confirmButtonColor: '#004a99'
			});

			if (result.isConfirmed) {
				Swal.fire({
					title: 'Procesando...',
					allowOutsideClick: false,
					didOpen: () => { Swal.showLoading(); }
				});

				// Mapeo corregido según tu ContractController y ContractService
				// const payload = {
				// 	branchId: parseInt(contractData.branchId),
				// 	agencyId: contractData.useAgreement ? parseInt(contractData.agencyId || 0) : null,
				// 	solicitor: contractData.solicitor,
				// 	deceased: contractData.deceased,
				// 	affiliate: contractData.affiliate,
				// 	stockItems: contractData.stockItems.map(i => i.id),
				// 	serviceItems: contractData.serviceItems.map(i => i.id),
				// 	externalServiceItems: contractData.agreementServiceItems.map(i => i.id),
				// 	mobilityItems: contractData.mobilityItems, // Ya es lista de IDs
				// 	useAgreement: contractData.useAgreement
				// };

				const payload = {
					branchId: parseInt(contractData.branchId),
					agencyId: contractData.useAgreement ? parseInt(contractData.agencyId || 0) : null,
					useAgreement: contractData.useAgreement,

					solicitor: {
						Dni: contractData.solicitor.dni,
						Name: contractData.solicitor.name,
						Type: contractData.solicitor.type,
						Cip: contractData.solicitor.cip || ''
					},

					affiliate: {
						Dni: contractData.affiliate.dni,
						FullName: contractData.affiliate.name,
						Cip: contractData.affiliate.cip || ''
					},

					deceased: {
						Dni: contractData.deceased.dni,
						Name: contractData.deceased.name,
						DeathDate: contractData.deceased.deathDate,
						BurialDate: contractData.deceased.burialDate,
						BurialTime: contractData.deceased.burialTime,
						Inei: contractData.deceased.inei,
						WakeId: contractData.deceased.wakeId,
						CustomWakeAddress: contractData.deceased.customWakeAddress,
						CemeteryId: parseInt(contractData.deceased.cemeteryId),
						StructureId: contractData.deceased.structureId ? parseInt(contractData.deceased.structureId) : null,
						IntermentSpaceId: contractData.deceased.intermentSpaceId ? parseInt(contractData.deceased.intermentSpaceId) : null
					},

					stockItems: contractData.stockItems.map(i => i.id),
					serviceItems: contractData.serviceItems.map(i => i.id),
					externalServiceItems: contractData.agreementServiceItems.map(i => i.id),
					mobilityItems: contractData.mobilityItems
				};

				try {
					const response = await fetch('@Url.Action("Create", "Contract")', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							// Importante para la seguridad en .NET
							'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
						},
						body: JSON.stringify(payload)
					});

					const data = await response.json();

					if (data.success) {
						Swal.fire('¡Éxito!', 'Contrato registrado: ' + data.contractNumber, 'success')
							.then(() => {
								window.location.href = '@Url.Action("Index", "Contract")';
							});
					} else {
						Swal.fire('Error', data.message || 'Error interno del servidor', 'error');
					}
				} catch (error) {
					console.error("Error en la petición:", error);
					Swal.fire('Error', 'No se pudo establecer conexión con el servidor.', 'error');
				}
			}
		}

	</script>
}