		function validateDatesInline() {
			const deathVal = $('#DeathDate').val();
			const burialVal = $('#BurialDate').val();
			const $errorDiv = $('#dateErrorMessage');
			const $errorText = $('#dateErrorText');
			const today = new Date().toISOString().split('T')[0];

			$errorDiv.addClass('d-none');
			$('#DeathDate, #BurialDate').removeClass('is-invalid');

			if (!deathVal) return true;

			// 1. No puede fallecer en el futuro
			if (deathVal > today) {
				showDateError("La fecha de fallecimiento no puede ser una fecha futura.");
				$('#DeathDate').addClass('is-invalid');
				return false;
			}

			if (burialVal) {
				// 2. El entierro no puede ser antes que la muerte
				if (burialVal < deathVal) {
					showDateError("La fecha de sepelio no puede ser anterior al fallecimiento.");
					$('#BurialDate').addClass('is-invalid');
					return false;
				}

				// 3. Persistencia inmediata en el objeto global
				contractData.deceased.deathDate = deathVal;
				contractData.deceased.burialDate = burialVal;
			}

			return true;
		}

