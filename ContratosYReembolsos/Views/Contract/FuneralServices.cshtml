@using ContratosYReembolsos.Models.Entities.Contracts
@using Microsoft.AspNetCore.Authorization
@model IEnumerable<FuneralService>
@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Catálogo de Servicios Funerarios";
}

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Contratos</a></li>
                    <li class="breadcrumb-item active fw-bold text-primary">Servicios Funerarios</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0 text-dark">
                <i class="fa-solid fa-hand-holding-heart me-2 text-success"></i>Catálogo de Servicios
            </h2>
        </div>
        @if ((await AuthorizationService.AuthorizeAsync(User, "Permissions.CatalogoServicios.Crear")).Succeeded)
        {
            <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm" onclick="openCreateModal()">
                <i class="fa-solid fa-plus-circle me-1"></i> Nuevo Servicio
            </button>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table id="tblServices" class="table table-hover align-middle">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase">
                            <th class="ps-3">Nombre del Servicio</th>
                            <th>Descripción</th>
                            <th class="text-center">Precio Sugerido</th>
                            <th class="text-center">Sede Interna</th>
                            <th class="text-center">Agencia Convenio</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-dark">@item.Name</td>
                                <td class="text-muted small">@item.Description</td>
                                <td class="text-center fw-bold text-success">S/ @item.Price.ToString("N2")</td>

                                <td class="text-center">
                                    <span class="badge rounded-pill border px-3 @(item.IsActiveInternal ? "bg-info-subtle text-info border-info" : "bg-danger-subtle text-danger border-danger")">
                                        <i class="fa-solid @(item.IsActiveInternal ? "fa-circle-check" : "fa-circle-xmark") me-1"></i>
                                        @(item.IsActiveInternal ? "Activo" : "Inactivo")
                                    </span>
                                </td>

                                <td class="text-center">
                                    <span class="badge rounded-pill border px-3 @(item.IsActiveExternal ? "bg-success-subtle text-success border-success" : "bg-danger-subtle text-danger border-danger")">
                                        <i class="fa-solid @(item.IsActiveExternal ? "fa-circle-check" : "fa-circle-xmark") me-1"></i>
                                        @(item.IsActiveExternal ? "Activo" : "Inactivo")
                                    </span>
                                </td>

                                <td class="text-end pe-3">
                                    @if ((await AuthorizationService.AuthorizeAsync(User, "Permissions.CatalogoServicios.Editar")).Succeeded)
                                    {
                                        <button class="btn btn-sm btn-white border shadow-sm rounded-circle" style="width:32px; height:32px; p-0" onclick="openEditModal(@item.Id)" title="Editar Parámetros">
                                            <i class="fa-solid fa-pen-to-square text-primary"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* Contenedor para el Modal Dinámico *@
<div id="modalContainer"></div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tblServices').DataTable({
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                pageLength: 10,
                // Configuramos orden predeterminado por el nombre del servicio
                order: [[0, "asc"]]
            });
        });

        async function openCreateModal() {
            await loadServiceModal(0);
        }

        async function openEditModal(id) {
            await loadServiceModal(id);
        }

        async function loadServiceModal(id) {
            Swal.fire({ title: 'Cargando formulario...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });

            try {
                const response = await fetch(`@Url.Action("GetFuneralServiceForm", "Contract")?id=${id}`);

                if (response.status === 403 || response.status === 401) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Acceso Denegado',
                        text: 'No tienes los permisos necesarios para realizar esta acción.',
                        confirmButtonColor: '#004a99'
                    });
                    return;
                }

                if (!response.ok) throw new Error("Error en la respuesta del servidor");

                const html = await response.text();

                if (html.includes("navbar") || html.includes("sidebar")) {
                     Swal.fire('Sesión Expirada', 'Por favor, vuelve a iniciar sesión.', 'info').then(() => location.reload());
                     return;
                }

                document.getElementById('modalContainer').innerHTML = html;
                Swal.close();

                const modalElement = document.getElementById('modalFuneralServiceContainer');
                if (modalElement) {
                    const modal = new bootstrap.Modal(modalElement);
                    modal.show();
                } else {
                    throw new Error("No se encontró el contenedor del modal en el PartialView");
                }

            } catch (e) {
                console.error(e);
                Swal.fire('Error', 'Hubo un problema al conectar con el servidor', 'error');
            }
        }

        $(document).on('submit', '#formFuneralService', async function (e) {
            e.preventDefault();
            const $btn = $(this).find('button[type="submit"]');
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Guardando...');

            try {
                const res = await fetch('@Url.Action("SaveFuneralService", "Contract")', {
                    method: 'POST',
                    body: new FormData(this)
                });
                const result = await res.json();

                if (result.success) {
                    Swal.fire('¡Éxito!', result.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Error', result.message, 'error');
                    $btn.prop('disabled', false).text('GUARDAR');
                }
            } catch (e) {
                Swal.fire('Error', 'Error de red al intentar guardar.', 'error');
                $btn.prop('disabled', false).text('GUARDAR');
            }
        });
    </script>
}