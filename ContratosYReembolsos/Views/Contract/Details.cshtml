@model ContratosYReembolsos.Models.ViewModels.Contracts.ContractDetailsViewModel

@{
    ViewData["Title"] = "Expediente Digital " + Model.Data.ContractNumber;
    var statusClass = Model.Data.Status == "ACTIVO" ? "success" : (Model.Data.Status == "REUBICADO" ? "info" : "secondary");
}

<div class="container-fluid animate__animated animate__fadeIn py-4">
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="card-body p-4 d-flex justify-content-between align-items-center bg-white">
            <div class="d-flex align-items-center">
                <div class="bg-primary text-white rounded-4 p-3 me-4 shadow-sm">
                    <i class="fa-solid fa-file-contract fa-2x"></i>
                </div>
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1 x-small fw-bold text-uppercase tracking-wider">
                            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Contratos</a></li>
                            <li class="breadcrumb-item active text-primary">Expediente Digital</li>
                        </ol>
                    </nav>
                    <h2 class="fw-bold mb-0 text-dark">Contrato <span class="text-primary">@Model.Data.ContractNumber</span></h2>
                    <div class="d-flex align-items-center mt-1">
                        <span class="badge bg-@statusClass-subtle text-@statusClass border border-@statusClass rounded-pill px-3 py-1 me-3">
                            <i class="fa-solid fa-circle-dot me-1"></i> @Model.Data.Status
                        </span>
                        <span class="text-muted small"><i class="fa-regular fa-calendar-check me-1"></i> Registrado el @Model.Data.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">
                    <i class="fa-solid fa-chevron-left me-2"></i> Volver
                </a>
                <button onclick="window.open('@Url.Action("PrintContract", new { id = Model.Data.Id })', '_blank')" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">
                    <i class="fa-solid fa-file-pdf me-2"></i> Imprimir PDF
                </button>
            </div>
        </div>
    </div>

    <ul class="nav nav-pills nav-fill mb-4 p-1 bg-white rounded-pill shadow-sm border" id="contractTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active rounded-pill fw-bold" data-bs-toggle="pill" data-bs-target="#info-general">
                <i class="fa-solid fa-circle-info me-2"></i>Información General
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold" data-bs-toggle="pill" data-bs-target="#historial">
                <i class="fa-solid fa-clock-rotate-left me-2"></i>Historial de Movimientos
                @if (Model.MovementHistory.Any())
                {
                    <span class="badge bg-primary ms-2">@Model.MovementHistory.Count</span>
                }
            </button>
        </li>
    </ul>

    <div class="tab-content" id="contractTabContent">
        <div class="tab-pane fade show active" id="info-general" role="tabpanel">
            <div class="row g-4">
                <div class="col-md-8">

                    <div class="card border-0 shadow-sm rounded-4 mb-4">
                        <div class="card-header bg-white border-0 py-3 px-4">
                            <h5 class="fw-bold mb-0 text-dark small text-uppercase tracking-wider"><i class="fa-solid fa-user-group me-2 text-primary"></i>Datos de Identidad y Vínculo</h5>
                        </div>
                        <div class="card-body p-4 pt-0">
                            <div class="row g-3">
                                <div class="col-md-4 border-end">
                                    <div class="p-3 bg-primary bg-opacity-10 rounded-4 border border-primary border-opacity-10 h-100">
                                        <label class="x-small fw-bold text-primary text-uppercase d-block mb-2 opacity-75">Solicitante de Servicio</label>
                                        <h6 class="fw-bold mb-1 text-truncate">@Model.Data.SolicitorName</h6>
                                        <span class="badge bg-primary text-white mb-2">DNI @Model.Data.SolicitorDni</span>
                                        <p class="small text-muted mb-0"><i class="fa-solid fa-user-shield me-1"></i> Tipo: @Model.Data.SolicitorType</p>
                                    </div>
                                </div>

                                <div class="col-md-4 border-end">
                                    <div class="p-3 bg-success bg-opacity-10 rounded-4 border border-success border-opacity-10 h-100">
                                        <label class="x-small fw-bold text-success text-uppercase d-block mb-2 opacity-75">Afiliado Titular (Derecho)</label>
                                        <h6 class="fw-bold mb-1 text-truncate">@(string.IsNullOrEmpty(Model.Data.AffiliateFullName) ? Model.Data.SolicitorName : Model.Data.AffiliateFullName)</h6>
                                        <span class="badge bg-success text-white mb-2">DNI @(string.IsNullOrEmpty(Model.Data.AffiliateDni) ? Model.Data.SolicitorDni : Model.Data.AffiliateDni)</span>
                                        <p class="small text-muted mb-0"><i class="fa-solid fa-id-card me-1"></i> CIP: @(string.IsNullOrEmpty(Model.Data.AffiliateCIP) ? Model.Data.SolicitorCip : Model.Data.AffiliateCIP)</p>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="p-3 bg-dark bg-opacity-10 rounded-4 border border-dark border-opacity-10 h-100">
                                        <label class="x-small fw-bold text-dark text-uppercase d-block mb-2 opacity-75">Beneficiario Fallecido</label>
                                        <h6 class="fw-bold mb-1 text-truncate">@Model.Data.DeceasedName</h6>
                                        <span class="badge bg-dark text-white mb-2">DNI @Model.Data.DeceasedDni</span>
                                        <p class="small text-muted mb-0"><i class="fa-solid fa-calendar-xmark me-1"></i> Defunción: @Model.Data.DeathDate.ToString("dd/MM/yyyy")</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-4 mb-4">
                        <div class="card-header bg-white border-0 py-3 px-4">
                            <h5 class="fw-bold mb-0 text-dark small text-uppercase tracking-wider"><i class="fa-solid fa-truck-ramp-box me-2 text-primary"></i>Ubicación y Logística</h5>
                        </div>
                        <div class="card-body p-4 pt-0">
                            <div class="row g-3 mb-4">
                                <div class="col-md-4">
                                    <div class="p-3 border rounded-4 text-center bg-light">
                                        <i class="fa-regular fa-calendar-check text-primary mb-2 fs-5"></i>
                                        <label class="d-block x-small fw-bold text-muted text-uppercase mb-1">Fecha Sepelio</label>
                                        <span class="fw-bold">@Model.Data.BurialDate.ToShortDateString()</span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 border rounded-4 text-center bg-light">
                                        <i class="fa-regular fa-clock text-primary mb-2 fs-5"></i>
                                        <label class="d-block x-small fw-bold text-muted text-uppercase mb-1">Hora Programada</label>
                                        <span class="fw-bold">@Model.Data.BurialTime.ToString(@"hh\:mm")</span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 border rounded-4 text-center bg-light">
                                        <i class="fa-solid fa-house-chimney-window text-primary mb-2 fs-5"></i>
                                        <label class="d-block x-small fw-bold text-muted text-uppercase mb-1">Lugar de Velación</label>
                                        <span class="fw-bold d-block text-truncate" title="@Model.Data.WakeName">@Model.Data.WakeName</span>
                                        @if (!string.IsNullOrEmpty(Model.Data.CustomWakeAddress))
                                        {
                                            <small class="text-danger d-block text-truncate x-small fw-bold mt-1" title="@Model.Data.CustomWakeAddress">
                                                <i class="fa-solid fa-location-dot"></i> @Model.Data.CustomWakeAddress
                                            </small>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="p-4 bg-primary bg-opacity-10 rounded-4 border-dashed border-primary border-2 d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle p-3 me-4">
                                    <i class="fa-solid fa-monument fa-lg"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <label class="x-small fw-bold text-primary text-uppercase d-block mb-1">Destino Final Actual</label>
                                    <h5 class="fw-bold mb-1">@Model.Data.CemeteryName</h5>
                                    <p class="mb-0 text-dark fw-semibold"><i class="fa-solid fa-th-large me-2 opacity-50"></i>@Model.Data.FullLocation</p>
                                </div>
                                <div class="text-end">
                                    <span class="text-muted small d-block"><i class="fa-solid fa-map-location-dot me-1"></i> Ubigeo</span>
                                    <span class="badge bg-white text-primary border fw-bold">@Model.Data.UbigeoDetail</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden border-top border-4 border-primary">
                        <div class="card-body p-4">
                            <label class="x-small fw-bold text-muted text-uppercase d-block mb-3">Sedes Administrativas</label>
                            <div class="d-flex align-items-center mb-3">
                                <i class="fa-solid fa-building-shield fs-4 text-primary me-3"></i>
                                <div>
                                    <span class="small text-muted d-block">Sede Responsable</span>
                                    <span class="fw-bold">@Model.Data.BranchName</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="fa-solid fa-handshake fs-4 text-success me-3"></i>
                                <div>
                                    <span class="small text-muted d-block">Empresa Funeraria</span>
                                    <span class="fw-bold text-success">@Model.Data.AgencyName</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-white border-0 py-3 px-4 border-bottom">
                            <h5 class="fw-bold mb-0 text-dark small text-uppercase tracking-wider"><i class="fa-solid fa-clipboard-check me-2 text-primary"></i>Control de Cobertura</h5>
                        </div>
                        <div class="card-body p-3">

                            <div class="mb-4">
                                <span class="fw-bold text-muted x-small text-uppercase tracking-wider px-2 d-block mb-2">Bienes Otorgados</span>
                                @foreach (var prod in Model.Data.DetailedProducts)
                                {
                                    <div class="d-flex justify-content-between align-items-center p-2 mb-2 bg-white rounded-3 border align-middle shadow-sm animate__animated animate__fadeIn">
                                        <div class="d-flex align-items-center overflow-hidden">
                                            <i class="fa-solid fa-box text-primary mx-2"></i>
                                            <div class="overflow-hidden">
                                                <span class="fw-bold d-block text-truncate text-dark small" style="font-size:0.75rem;" title="@prod.Name">@prod.Name</span>
                                                @if (prod.Status == "Entregado")
                                                {
                                                    <small class="text-success x-small fw-bold"><i class="fa-solid fa-circle-check"></i> Entregado (@prod.DeliveryDate.ToString("dd/MM"))</small>
                                                }
                                                else
                                                {
                                                    <small class="text-warning x-small fw-bold"><i class="fa-solid fa-clock"></i> Pendiente Entrega</small>
                                                }
                                            </div>
                                        </div>
                                        <div class="text-end flex-shrink-0 ms-2">
                                            @if (prod.Status == "Pendiente")
                                            {
                                                <button type="button" class="btn btn-sm btn-success rounded-pill px-2 py-0" style="font-size:0.65rem;"
                                                        onclick="openDeliveryModal(@prod.Id, '@Html.Encode(prod.Name)')">
                                                    <i class="fa-solid fa-truck-ramp-box"></i> Entregar
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-link text-muted p-0 border-0 shadow-none me-1" title="Ver Notas"
                                                        onclick="showDeliveryNotes('@Html.Encode(prod.Name)', '@prod.DeliveryDate.ToString("dd/MM/yyyy HH:mm")', '@Html.Encode(prod.Observations)')">
                                                    <i class="fa-solid fa-comment-dots fs-5"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <div>
                                <span class="fw-bold text-muted x-small text-uppercase tracking-wider px-2 d-block mb-2">Servicios Propios FONAFUN</span>
                                @foreach (var serv in Model.Data.DetailedInternalServices)
                                {
                                    <div class="p-2 mb-2 bg-white rounded-3 border align-middle shadow-sm border-start border-4 animate__animated animate__fadeIn
                                         @(serv.Status == "Ejecutado" ? "border-success" : (serv.Status == "EnProgreso" ? "border-warning" : "border-info"))">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex align-items-center overflow-hidden">
                                                <i class="fa-solid fa-bell-concierge mx-2 @(serv.Status == "Ejecutado" ? "text-success" : (serv.Status == "EnProgreso" ? "text-warning" : "text-info"))"></i>
                                                <div class="overflow-hidden">
                                                    <span class="fw-bold d-block text-dark small text-truncate" style="font-size:0.75rem;" title="@serv.Name">@serv.Name</span>
                                                    @if (serv.Status == "Ejecutado")
                                                    {
                                                        <small class="text-success x-small fw-bold"><i class="fa-solid fa-square-check"></i> Finalizado</small>
                                                    }
                                                    else if (serv.Status == "EnProgreso")
                                                    {
                                                        <small class="text-warning x-small fw-bold animate__animated animate__pulse animate__infinite"><i class="fa-solid fa-spinner fa-spin"></i> En Curso...</small>
                                                    }
                                                    else
                                                    {
                                                        <small class="text-info x-small fw-semibold">Por iniciar</small>
                                                    }
                                                </div>
                                            </div>

                                            <div class="text-end flex-shrink-0 ms-2">
                                                @if (serv.Status == "Pendiente")
                                                {
                                                    <button type="button" class="btn btn-sm btn-info text-white rounded-pill px-2 py-0" style="font-size:0.65rem;"
                                                            onclick="processServiceAdvance(@serv.Id, '@Html.Encode(serv.Name)', 'Pendiente')">
                                                        <i class="fa-solid fa-play"></i> Iniciar
                                                    </button>
                                                }
                                                else if (serv.Status == "EnProgreso")
                                                {
                                                    <button type="button" class="btn btn-sm btn-warning text-dark rounded-pill px-2 py-0" style="font-size:0.65rem;"
                                                            onclick="processServiceAdvance(@serv.Id, '@Html.Encode(serv.Name)', 'EnProgreso')">
                                                        <i class="fa-solid fa-square-check"></i> Completar
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }

                                @foreach (var serv in Model.Data.ExternalServices)
                                {
                                    <div class="d-flex justify-content-between align-items-center p-2 mb-2 bg-light rounded-3 border-start border-4 border-success shadow-sm">
                                        <div class="d-flex align-items-center">
                                            <i class="fa-solid fa-handshake text-success mx-2"></i>
                                            <div>
                                                <span class="fw-bold d-block small text-dark" style="font-size:0.75rem;">@serv</span>
                                                <small class="text-success x-small fw-semibold">Vía Convenio</small>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="historial" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                        <div>
                            <h5 class="fw-bold text-dark mb-1">Registro de Auditoría de Movimientos</h5>
                            <p class="text-muted small mb-0">Trazabilidad técnica de cambios de ubicación y exhumaciones.</p>
                        </div>
                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="window.print()">
                            <i class="fa-solid fa-print me-1"></i> Imprimir Expediente
                        </button>
                    </div>

                    @if (Model.MovementHistory.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle custom-table-formal">
                                <thead class="bg-light text-uppercase x-small fw-bold text-secondary">
                                    <tr>
                                        <th class="text-center" style="width: 140px;">Fecha Operación</th>
                                        <th class="text-center" style="width: 160px;">Expediente</th>
                                        <th class="text-center">Tipo</th>
                                        <th>Ubicación Origen (Anterior)</th>
                                        <th>Ubicación Destino (Nueva)</th>
                                        <th class="text-end" style="width: 110px;">Costo</th>
                                        <th class="text-center" style="width: 80px;">Acta</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var move in Model.MovementHistory)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <span class="d-block fw-bold text-dark small">@move.RequestDate.Split(' ')[0]</span>
                                                <span class="text-muted x-small">@move.RequestDate.Split(' ')[1]</span>
                                            </td>
                                            <td class="text-center">
                                                <div class="badge-expediente">@move.ExhumationNumber</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @(move.MovementType == "REUBICACION" ? "bg-info" : "bg-primary") text-white x-small">
                                                    @move.MovementType
                                                </span>
                                            </td>
                                            <td>
                                                <div class="small text-muted fw-semibold">
                                                    <i class="fa-solid fa-circle-minus text-danger me-1"></i> @move.PreviousLocation
                                                </div>
                                            </td>
                                            <td>
                                                <div class="small text-dark fw-bold">
                                                    <i class="fa-solid fa-circle-plus text-success me-1"></i> @move.NewLocation
                                                </div>
                                            </td>
                                            <td class="text-end">
                                                <span class="fw-bold text-dark small">S/ @move.Cost.ToString("N2")</span>
                                            </td>
                                            <td class="text-center">
                                                <a href="@Url.Action("PrintExhumation", "Exhumation", new { id = move.ExhumationId })"
                                                   target="_blank"
                                                   class="btn btn-sm btn-outline-danger border-0 rounded-circle"
                                                   title="Ver Acta PDF"
                                                   style="width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fa-solid fa-file-pdf fs-5"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="bg-light rounded-circle p-4 d-inline-block mb-3">
                                <i class="fa-solid fa-shield-check fa-3x text-muted opacity-25"></i>
                            </div>
                            <h5 class="fw-bold text-muted">Sin Movimientos Registrados</h5>
                            <p class="text-muted small">El difunto permanece en su ubicación de inhumación original.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deliveryConfirmModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-bottom py-3">
                <h6 class="modal-title fw-bold text-primary text-uppercase" id="modalProductName">Confirmar Entrega</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                @Html.AntiForgeryToken()
                <input type="hidden" id="hdnDetailId" />
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Fecha y Hora de Entrega</label>
                    <input type="datetime-local" id="txtDeliveryDate" class="form-control rounded-pill border-2" />
                </div>
                <div class="mb-0">
                    <label class="form-label small fw-bold text-muted text-uppercase">Observaciones / Notas de Almacén</label>
                    <textarea id="txtDeliveryObservations" class="form-control rounded-4 border-2" rows="3" placeholder="Ej: Se realiza la entrega física del ataúd al contratante en perfecto estado."></textarea>
                </div>
            </div>
            <div class="modal-footer border-top bg-light py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-sm btn-primary rounded-pill px-4" onclick="submitProductDelivery()">Guardar Entrega</button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --pnp-blue: #004a99;
        --pnp-bg: #f8fafc;
    }

    .custom-table-formal {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e2e8f0 !important;
    }

        .custom-table-formal thead th {
            background-color: #f8fafc;
            padding: 15px;
            border-bottom: 2px solid #e2e8f0 !important;
        }

        .custom-table-formal tbody td {
            padding: 18px 15px;
            background-color: white;
        }

    .badge-expediente {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #cbd5e0;
        padding: 6px 12px;
        border-radius: 6px;
        font-family: 'Courier New', Courier, monospace;
        font-weight: bold;
        font-size: 0.85rem;
    }

    .x-small {
        font-size: 0.65rem;
    }

    .tracking-wider {
        letter-spacing: 1px;
    }

    .custom-table-formal tbody tr:hover td {
        background-color: #fcfcfc;
    }
</style>

<script>
    // --- LÓGICA LOGÍSTICA: BIENES ---
    function openDeliveryModal(id, encodedName) {
        const productName = $('<div/>').html(encodedName).text();
        $('#hdnDetailId').val(id);
        $('#modalProductName').text('Entrega: ' + productName);

        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        $('#txtDeliveryDate').val(now.toISOString().slice(0, 16));
        $('#txtDeliveryObservations').val('');

        const deliveryModal = new bootstrap.Modal(document.getElementById('deliveryConfirmModal'));
        deliveryModal.show();
    }

    async function submitProductDelivery() {
        const detailId = $('#hdnDetailId').val();
        const deliveryDate = $('#txtDeliveryDate').val();
        const observations = $('#txtDeliveryObservations').val().trim();

        if (!deliveryDate) {
            Swal.fire('Atención', 'Debe seleccionar una fecha y hora válidas.', 'warning');
            return;
        }

        Swal.fire({ title: 'Guardando registro...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

        try {
            const response = await fetch('@Url.Action("ConfirmProductDelivery", "Contract")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                body: JSON.stringify({
                    Id: parseInt(detailId),
                    DeliveryDate: deliveryDate,
                    Observations: observations
                })
            });

            const data = await response.json();
            if (data.success) {
                Swal.fire('¡Éxito!', data.message, 'success').then(() => { location.reload(); });
            } else {
                Swal.fire('Error', data.message, 'error');
            }
        } catch (error) {
            console.error("Error en entrega:", error);
            Swal.fire('Error', 'Falla de comunicación.', 'error');
        }
    }

    function showDeliveryNotes(name, dateStr, encodedObs) {
        const title = $('<div/>').html(name).text();
        const observations = encodedObs ? $('<div/>').html(encodedObs).text() : "Sin observaciones registradas.";

        Swal.fire({
            title: '<span class="fs-6 fw-bold text-primary text-uppercase">Auditoría de Despacho</span>',
            html: `
                <div class="text-start border p-3 rounded-4 bg-light small mt-2">
                    <p class="mb-2"><b>Elemento:</b> <span class="text-dark">${title}</span></p>
                    <p class="mb-2"><b>Fecha de Operación:</b> <span class="text-muted">${dateStr}</span></p>
                    <p class="mb-0"><b>Notas de Almacén:</b></p>
                    <div class="p-2 bg-white border rounded-3 mt-1 text-muted fs-7">"${observations}"</div>
                </div>
            `,
            icon: 'info',
            confirmButtonColor: '#004a99'
        });
    }

    // --- LÓGICA OPERATIVA: AVANCE DE SERVICIOS POR FASES ---
    async function processServiceAdvance(id, encodedName, currentStatus) {
        const serviceName = $('<div/>').html(encodedName).text();

        const config = currentStatus === "Pendiente"
            ? { title: '¿Iniciar Servicio?', text: `El servicio propio "${serviceName}" pasará a estado EN CURSO (En Progreso).`, btnText: 'Sí, Iniciar', color: '#0dcaf0' }
            : { title: '¿Finalizar Servicio?', text: `Registre las notas de conformidad final para cerrar el servicio "${serviceName}".`, btnText: 'Sí, Completar', color: '#ffc107' };

        const { value: text, isConfirmed } = await Swal.fire({
            title: config.title,
            text: config.text,
            input: 'textarea',
            inputPlaceholder: 'Escriba las observaciones o notas de conformidad aquí...',
            showCancelButton: true,
            confirmButtonText: config.btnText,
            cancelButtonText: 'Cancelar',
            confirmButtonColor: config.color,
            preConfirm: (inputValue) => {
                if (currentStatus === "EnProgreso" && (!inputValue || inputValue.trim().length < 5)) {
                    Swal.showValidationMessage('Debe ingresar una nota de conformidad válida para cerrar el servicio.');
                }
                return inputValue;
            }
        });

        if (isConfirmed) {
            Swal.fire({ title: 'Actualizando servicio...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

            try {
                const response = await fetch('@Url.Action("AdvanceServiceStatus", "Contract")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    body: JSON.stringify({ Id: id, Observations: text })
                });

                const data = await response.json();
                if (data.success) {
                    Swal.fire('¡Actualizado!', data.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            } catch (e) {
                Swal.fire('Error', 'Error de comunicación con el servidor.', 'error');
            }
        }
    }
</script>