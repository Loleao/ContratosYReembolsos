@using ContratosYReembolsos.Models.Entities.Branches
@model IEnumerable<IGrouping<string, Branch>>

@{
    ViewData["Title"] = "Selección de Sede - Contratos";
}

<div class="container py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Gestión de Contratos</h3>
            <p class="text-muted small">Seleccione una sede para administrar sus registros funerarios.</p>
        </div>
        <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
            <a href="@Url.Action("FuneralServices", "Contract")" class="btn btn-white px-4 fw-bold border-0">
                <i class="fas fa-list-check me-2"></i>Catálogo
            </a>
        </div>
    </div>

    <!-- Buscador -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="input-group bg-light rounded-pill px-3">
                <span class="input-group-text bg-transparent border-0 pe-0">
                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                </span>
                <input type="text" id="branchSearch" class="form-control bg-transparent border-0 py-2 shadow-none"
                       placeholder="Buscar sede por nombre, código o región...">
            </div>
        </div>
    </div>

    <!-- Acordeón Regional -->
    <div class="accordion border-0 shadow-none" id="accordionContracts">
        @foreach (var group in Model)
        {
            <div class="accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden region-group">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-bold py-3 px-4 bg-white" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapse-@group.Key.Replace(" ", "")">
                        <i class="fa-solid fa-map-location-dot me-3 text-primary"></i>
                        @group.Key.ToUpper()
                        <span class="badge bg-primary-subtle text-primary ms-auto me-3 rounded-pill fw-normal">@group.Count() Filiales</span>
                    </button>
                </h2>
                <div id="collapse-@group.Key.Replace(" ", "")" class="accordion-collapse collapse" data-bs-parent="#accordionContracts">
                    <div class="accordion-body p-4 bg-light bg-opacity-50">
                        <div class="row g-3">
                            @foreach (var branch in group.OrderBy(b => b.Name))
                            {
                                <div class="col-xl-4 col-md-6 branch-item" data-search="@branch.Name @branch.Code @group.Key">
                                    <div class="card border-0 shadow-sm rounded-4 hover-lift h-100">
                                        <div class="card-body p-3 d-flex align-items-center">
                                            <div class="flex-shrink-0 bg-primary-subtle text-primary rounded-3 p-3 me-3">
                                                <i class="fa-solid fa-file-contract fs-4"></i>
                                            </div>
                                            <div class="flex-grow-1 overflow-hidden">
                                                <h6 class="fw-bold text-dark mb-0 text-truncate">@branch.Name</h6>
                                                <small class="text-muted">Cod: @branch.Code</small>
                                            </div>
                                            <div class="ms-2">
                                                <a href="@Url.Action("Index", new { selectedBranchId = branch.Id })"
                                                   class="btn btn-sm btn-primary rounded-pill px-3 fw-bold">
                                                    Abrir
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $('#branchSearch').on('input', function() {
            let term = $(this).val().toLowerCase().trim();
            $('.region-group').each(function() {
                let $region = $(this);
                let regionMatch = false;
                $region.find('.branch-item').each(function() {
                    if ($(this).data('search').toLowerCase().includes(term)) {
                        $(this).show(); regionMatch = true;
                    } else { $(this).hide(); }
                });
                if (regionMatch) {
                    $region.show();
                    if (term.length > 1) {
                        $region.find('.accordion-collapse').addClass('show');
                        $region.find('.accordion-button').removeClass('collapsed');
                    }
                } else { $region.hide(); }
            });
        });
    </script>
}