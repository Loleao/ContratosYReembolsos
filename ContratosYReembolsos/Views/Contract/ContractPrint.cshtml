@using ContratosYReembolsos.Models.Entities.Contracts
@model Contract
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            font-size: 11px;
            color: #333;
            line-height: 1.4;
        }

        .p-4 {
            padding: 30px;
        }

        .text-primary {
            color: #004a99;
        }

        .text-danger {
            color: #dc3545;
        }

        .fw-bold {
            font-weight: bold;
        }

        .border-section {
            border: 1px solid #dee2e6;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 15px;
        }

        .title-label {
            font-weight: bold;
            color: #004a99;
            border-bottom: 1px solid #004a99;
            margin-bottom: 10px;
            text-transform: uppercase;
            font-size: 10px;
        }

        .val {
            font-weight: bold;
            color: #000;
        }

        .header-table {
            width: 100%;
            margin-bottom: 20px;
            border-collapse: collapse;
        }

        .table-services {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

            .table-services th {
                background-color: #f8f9fa;
                border: 1px solid #dee2e6;
                padding: 8px;
                text-align: left;
            }

            .table-services td {
                border: 1px solid #dee2e6;
                padding: 8px;
            }

        .row {
            display: table;
            width: 100%;
            clear: both;
        }

        .col-6 {
            display: table-cell;
            width: 50%;
            vertical-align: top;
        }

        .text-end {
            text-align: right;
        }

        .total-row {
            background-color: #004a99;
            color: white;
            font-weight: bold;
        }
    </style>
</head>
<body class="p-4">
    <table class="header-table">
        <tr>
            <td style="width: 70%">
                <h2 class="fw-bold mb-0 text-primary">FONAFUN PERÚ</h2>
                <p style="margin:0;">FONDO DE APOYO FUNERARIO - PNP</p>
                <p style="margin:0; font-size: 9px;" class="text-muted">
                    Sede de Registro: <span class="val">@Model.Branch?.Name</span><br />
                    Agencia: <span class="val">@Model.Agency?.Name</span> - @Model.Agency?.Address
                </p>
            </td>
            <td style="width: 30%; text-align: right;">
                <div style="border: 2px solid #004a99; padding: 10px; border-radius: 8px;">
                    <span class="text-danger fw-bold" style="font-size: 12px;">CONTRATO DE SERVICIO</span>
                    <h2 style="margin: 5px 0 0 0; color: #000;">@Model.ContractNumber</h2>
                </div>
            </td>
        </tr>
    </table>

    <div class="row">
        <div class="col-6" style="padding-right: 10px;">
            <div class="border-section">
                <div class="title-label">Datos del Titular / Solicitante</div>
                <div>Nombre: <span class="val">@Model.SolicitorName</span></div>
                <div>DNI: <span class="val">@Model.SolicitorDni</span></div>
                <div>Parentesco: <span class="val">@Model.SolicitorType</span></div>
            </div>
        </div>

        <div class="col-6">
            <div class="border-section">
                <div class="title-label">Datos del Fallecido</div>
                <div>Nombre: <span class="val">@Model.DeceasedName</span></div>
                <div>DNI: <span class="val">@Model.DeceasedDni</span></div>
                <div>Fecha Fallecimiento: <span class="val">@Model.DeathDate.ToShortDateString()</span></div>
            </div>
        </div>
    </div>

    <div class="border-section">
        <div class="title-label">Logística y Ubicación de Sepelio</div>
        <table style="width: 100%;">
            <tr>
                <td style="width: 33%;">Fecha Sepelio: <span class="val">@Model.BurialDate.ToShortDateString()</span></td>
                <td style="width: 33%;">Hora: <span class="val">@Model.BurialTime.ToString(@"hh\:mm")</span></td>
                <td style="width: 33%;">Ubigeo: <span class="val">@(Model.Ubigeo?.Region) - @Model.Ubigeo?.District</span></td>
            </tr>
            <tr>
                <td colspan="2">Cementerio: <span class="val">@Model.Cemetery?.Name</span></td>
                <td>Ubicación: <span class="val">@Model.IntermentStructure?.Type</span></td>
            </tr>
            @if (Model.IntermentSpace != null)
            {
                <tr>
                    <td colspan="3">Espacio Asignado: <span class="val">@Model.IntermentStructure?.Name - Fila: @Model.IntermentSpace.RowLetter Col: @Model.IntermentSpace.ColumnNumber</span></td>
                </tr>
            }
        </table>
    </div>

    <div class="border-section">
        <div class="title-label">Detalle de Suministros y Servicios</div>
        <table class="table-services">
            <thead>
                <tr>
                    <th>Descripción del Servicio / Producto</th>
                    <th>Categoría</th>
                    <th class="text-end">Estado</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <span class="val">ATAÚD @Model.CoffinVariant?.Coffin?.ModelName</span><br />
                        <small>Color: @Model.CoffinVariant?.Color | Material: @Model.CoffinVariant?.Material</small>
                    </td>
                    <td>Suministro</td>
                    <td class="text-end fw-bold">Entregado</td>
                </tr>

                @if (Model.MovilityDetails != null)
                {
                    foreach (var mov in Model.MovilityDetails)
                    {
                        <tr>
                            <td>
                                <span class="val">@mov.VehicleType?.Name</span><br />
                                <small>Servicio de movilidad logística para cortejo</small>
                            </td>
                            <td>Transporte</td>
                            <td class="text-end">Programado</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr class="total-row">
                    <td colspan="2" class="text-end" style="padding: 10px;">TOTAL PAGADO / COBERTURA:</td>
                    <td class="text-end" style="padding: 10px; font-size: 14px;">S/ @Model.TotalAmount.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div style="margin-top: 80px;">
        <table style="width: 100%; text-align: center;">
            <tr>
                <td style="width: 40%">
                    <div style="border-top: 1px solid #000; width: 80%; margin: 0 auto;"></div>
                    <p style="margin-top: 5px;"><strong>@Model.SolicitorName</strong></p>
                    <p style="margin: 0; font-size: 9px;">Firma del Solicitante</p>
                    <p style="margin: 0; font-size: 9px;">DNI: @Model.SolicitorDni</p>
                </td>
                <td style="width: 20%"></td>
                <td style="width: 40%">
                    <div style="border-top: 1px solid #000; width: 80%; margin: 0 auto;"></div>
                    <p style="margin-top: 5px;"><strong>FONAFUN PERÚ</strong></p>
                    <p style="margin: 0; font-size: 9px;">Firma Autorizada y Sello</p>
                    <p style="margin: 0; font-size: 9px;">Sede: @Model.Branch?.Name</p>
                </td>
            </tr>
        </table>
    </div>

    <div style="margin-top: 40px; text-align: center; color: #888; font-size: 8px; border-top: 1px dashed #ccc; padding-top: 10px;">
        Documento generado electrónicamente el @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss") - Código de Verificación: @Model.Id.ToString("D8")
    </div>
</body>
</html>