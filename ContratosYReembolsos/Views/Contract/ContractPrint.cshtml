@model ContratosYReembolsos.Services.DTOs.Contracts.ContractReportDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Contrato @Model.ContractNumber</title>
    <style>
        @@page {
            margin: 0.5cm;
        }

        body {
            font-family: 'Segoe UI', 'Helvetica', 'Arial', sans-serif;
            font-size: 10px;
            color: #222;
            line-height: 1.3;
            margin: 0;
            padding: 20px;
            background-color: #fff;
        }

        .header-container {
            width: 100%;
            margin-bottom: 20px;
        }

        .logo-area {
            width: 60%;
            float: left;
        }

        .contract-badge {
            width: 35%;
            float: right;
            border: 2px solid #004a99;
            border-radius: 10px;
            text-align: center;
            padding: 10px;
            background-color: #f8f9fa;
        }

        .text-institutional {
            color: #004a99;
        }

        .text-danger {
            color: #d32f2f;
        }

        .fw-bold {
            font-weight: bold;
        }

        .text-uppercase {
            text-transform: uppercase;
        }

        /* Secciones */
        .section {
            width: 100%;
            clear: both;
            margin-bottom: 12px;
            border: 1px solid #e0e0e0;
            border-radius: 5px;
            overflow: hidden;
        }

        .section-header {
            background-color: #004a99;
            color: white;
            padding: 5px 10px;
            font-weight: bold;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .section-body {
            padding: 8px 12px;
        }

        /* Columnas */
        .col-wrapper {
            width: 100%;
            clear: both;
        }

        .col-50 {
            float: left;
            width: 50%;
        }

        /* Tablas */
        .table-data {
            width: 100%;
            border-collapse: collapse;
        }

            .table-data td {
                padding: 3px 0;
                vertical-align: top;
            }

        .label {
            color: #666;
            font-size: 9px;
            width: 100px;
        }

        .val {
            font-weight: bold;
            color: #000;
        }

        .table-services {
            width: 100%;
            border-collapse: collapse;
            margin-top: 0;
        }

            .table-services th {
                background-color: #f1f4f8;
                border-bottom: 2px solid #004a99;
                padding: 6px 8px;
                text-align: left;
                font-size: 9px;
                color: #004a99;
            }

            .table-services td {
                border-bottom: 1px solid #eee;
                padding: 6px 8px;
            }

        .status-badge {
            font-size: 8px;
            padding: 2px 6px;
            border-radius: 10px;
            background: #e8f5e9;
            color: #2e7d32;
            border: 1px solid #2e7d32;
        }

        /* Firmas */
        .signature-container {
            margin-top: 50px;
            width: 100%;
            text-align: center;
        }

        .signature-box {
            width: 40%;
            display: inline-block;
            vertical-align: top;
        }

        .signature-line {
            border-top: 1px solid #000;
            margin: 0 auto 8px;
            width: 80%;
        }

        .footer {
            margin-top: 40px;
            text-align: center;
            font-size: 8px;
            color: #777;
            border-top: 1px dashed #ccc;
            padding-top: 10px;
        }

        .clearfix::after {
            content: "";
            clear: both;
            display: table;
        }
    </style>
</head>
<body>

    <div class="header-container clearfix">
        <div class="logo-area">
            <h1 class="text-institutional fw-bold" style="margin:0; font-size: 22px;">FONAFUN PERÚ</h1>
            <p class="fw-bold" style="margin:2px 0; font-size: 11px;">FONDO DE APOYO FUNERARIO - PNP</p>
            <p style="margin:5px 0 0 0; color: #555; font-size: 9px;">
                <i class="fa-solid fa-location-dot"></i> Sede: <span class="val">@Model.BranchName</span><br />
                @if (!string.IsNullOrEmpty(Model.AgencyName) && Model.AgencyName != "FONAFUN - SEDE CENTRAL")
                {
                    <span>Agencia Convenio: <span class="val">@Model.AgencyName</span> (@Model.AgencyAddress)</span>
                }
                else
                {
                    <span class="text-institutional fw-bold">ATENCIÓN POR ADMINISTRACIÓN DIRECTA</span>
                }
            </p>
        </div>
        <div class="contract-badge">
            <span class="text-danger fw-bold" style="font-size: 10px; letter-spacing: 1px;">CONTRATO DE SERVICIOS</span><br />
            <span style="font-size: 18px; font-weight: bold; color: #000;">N° @Model.ContractNumber</span><br />
            <span style="font-size: 8px; color: #666;">FECHA REGISTRO: @Model.CreatedAt</span>
        </div>
    </div>

    <div class="col-wrapper clearfix">
        <div class="col-50">
            <div class="section" style="margin-right: 10px;">
                <div class="section-header">I. Datos del Titular / Solicitante</div>
                <div class="section-body">
                    <table class="table-data">
                        <tr><td class="label">Nombres:</td><td class="val">@Model.SolicitorName</td></tr>
                        <tr><td class="label">DNI:</td><td class="val">@Model.SolicitorDni</td></tr>
                        <tr><td class="label">Parentesco:</td><td class="val">@Model.SolicitorType</td></tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-50">
            <div class="section">
                <div class="section-header">II. Datos del Beneficiario Fallecido</div>
                <div class="section-body">
                    <table class="table-data">
                        <tr><td class="label">Nombres:</td><td class="val text-uppercase">@Model.DeceasedName</td></tr>
                        <tr><td class="label">DNI:</td><td class="val">@Model.DeceasedDni</td></tr>
                        <tr><td class="label">Fallecimiento:</td><td class="val">@Model.DeathDate</td></tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="section">
        <div class="section-header">III. Itinerario y Ubicación de Sepelio</div>
        <div class="section-body">
            <table class="table-data">
                <tr>
                    <td class="label">Fecha Programada:</td>
                    <td class="val" style="width: 25%;">@Model.BurialDate</td>
                    <td class="label">Hora:</td>
                    <td class="val" style="width: 25%;">@Model.BurialTime</td>
                    <td class="label">Ubigeo:</td>
                    <td class="val">@Model.UbigeoFull</td>
                </tr>
                <tr>
                    <td class="label">Cementerio:</td>
                    <td class="val">@Model.CemeteryName</td>
                    <td class="label">Ubicación:</td>
                    <td class="val" colspan="3">@Model.BurialLocationDetail</td>
                </tr>
            </table>
        </div>
    </div>

    <div class="section">
        <div class="section-header">IV. Detalle de Beneficios Asignados (Bienes y Servicios)</div>
        <table class="table-services">
            <thead>
                <tr>
                    <th style="width: 50%;">Descripción del Beneficio</th>
                    <th style="width: 30%;">Categoría / Origen</th>
                    <th style="width: 20%; text-align: center;">Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Services)
                {
                    <tr>
                        <td><span class="val">@item.Description</span></td>
                        <td style="font-size: 8.5px; color: #555;">@item.Category</td>
                        <td style="text-align: center;">
                            <span class="status-badge">@item.Status.ToUpper()</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.UseAgreement)
    {
        <div style="background-color: #fff9c4; border: 1px solid #fbc02d; padding: 5px 10px; border-radius: 4px; font-size: 8px; margin-bottom: 10px;">
            <strong>NOTA DE CONVENIO:</strong> Los servicios marcados como "Convenio" son gestionados externamente bajo la supervisión de FONAFUN a través de la agencia <strong>@Model.AgencyName</strong>.
        </div>
    }

    <div class="signature-container clearfix" style="margin-top: 80px;">
        <div class="signature-box" style="float: left; margin-left: 5%;">
            <div class="signature-line"></div>
            <p class="fw-bold">@Model.SolicitorName</p>
            <p style="font-size: 8px; color: #555;">DNI: @Model.SolicitorDni<br />Firma del Solicitante</p>
        </div>
        <div class="signature-box" style="float: right; margin-right: 5%;">
            <div class="signature-line"></div>
            <p class="fw-bold">FONAFUN PERÚ</p>
            <p style="font-size: 8px; color: #555;">@Model.BranchName<br />Firma Autorizada y Sello</p>
        </div>
    </div>

    <div class="footer">
        Este documento es una representación impresa de un contrato electrónico generado en el sistema de gestión FONAFUN.<br />
        Generado el: @Model.CreatedAt | ID de Seguimiento: @Model.Id.ToString("D8") | <strong>Vocación de Servicio al Personal Policial</strong>
    </div>

</body>
</html>