@model ContratosYReembolsos.Services.DTOs.Contracts.ContractReportDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Contrato @Model.ContractNumber</title>
    <style>
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            font-size: 11px;
            color: #333;
            line-height: 1.4;
            margin: 0;
            padding: 30px;
        }

        .text-primary {
            color: #004a99;
        }

        .text-danger {
            color: #dc3545;
        }

        .fw-bold {
            font-weight: bold;
        }

        .header-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .border-section {
            border: 1px solid #dee2e6;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 15px;
        }

        .title-label {
            font-weight: bold;
            color: #004a99;
            border-bottom: 1px solid #004a99;
            margin-bottom: 8px;
            text-transform: uppercase;
            font-size: 10px;
        }

        .val {
            font-weight: bold;
            color: #000;
        }

        .table-services {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

            .table-services th {
                background-color: #f8f9fa;
                border: 1px solid #dee2e6;
                padding: 8px;
                text-align: left;
                font-size: 10px;
            }

            .table-services td {
                border: 1px solid #dee2e6;
                padding: 8px;
            }

        .row {
            display: block;
            width: 100%;
        }

        .col-6 {
            float: left;
            width: 48%;
        }

        .clearfix::after {
            content: "";
            clear: both;
            display: table;
        }

        .signature-box {
            margin-top: 60px;
            width: 100%;
        }

        .signature-line {
            border-top: 1px solid #000;
            width: 80%;
            margin: 0 auto 5px;
        }

        .footer-note {
            margin-top: 30px;
            text-align: center;
            color: #888;
            font-size: 8px;
            border-top: 1px dashed #ccc;
            padding-top: 10px;
        }
    </style>
</head>
<body>
    <table class="header-table">
        <tr>
            <td style="width: 65%">
                <h2 class="fw-bold mb-0 text-primary" style="margin:0;">FONAFUN PERÚ</h2>
                <p style="margin:2px 0; font-weight:bold;">FONDO DE APOYO FUNERARIO - PNP</p>
                <p style="margin:0; font-size: 9px; color: #666;">
                    Sede de Registro: <span class="val">@Model.BranchName</span><br />
                    Agencia: <span class="val">@Model.AgencyName</span> - @Model.AgencyAddress
                </p>
            </td>
            <td style="width: 35%; text-align: right;">
                <div style="border: 2px solid #004a99; padding: 10px; border-radius: 8px; text-align: center;">
                    <span class="text-danger fw-bold" style="font-size: 11px;">CONTRATO DE SERVICIO</span>
                    <h2 style="margin: 5px 0 0 0; color: #000; font-size: 20px;">@Model.ContractNumber</h2>
                </div>
            </td>
        </tr>
    </table>

    <div class="row clearfix">
        <div class="col-6" style="margin-right: 4%;">
            <div class="border-section">
                <div class="title-label">Datos del Titular / Solicitante</div>
                <div>Nombre: <span class="val">@Model.SolicitorName</span></div>
                <div>DNI: <span class="val">@Model.SolicitorDni</span></div>
                <div>Parentesco: <span class="val">@Model.SolicitorType</span></div>
            </div>
        </div>
        <div class="col-6">
            <div class="border-section">
                <div class="title-label">Datos del Fallecido</div>
                <div>Nombre: <span class="val">@Model.DeceasedName</span></div>
                <div>DNI: <span class="val">@Model.DeceasedDni</span></div>
                <div>Fecha Fallecimiento: <span class="val">@Model.DeathDate</span></div>
            </div>
        </div>
    </div>

    <div class="border-section">
        <div class="title-label">Logística y Ubicación de Sepelio</div>
        <table style="width: 100%; border-spacing: 0;">
            <tr>
                <td style="width: 33%;">Fecha Sepelio: <span class="val">@Model.BurialDate</span></td>
                <td style="width: 33%;">Hora: <span class="val">@Model.BurialTime</span></td>
                <td style="width: 33%;">Ubigeo: <span class="val">@Model.UbigeoFull</span></td>
            </tr>
            <tr>
                <td colspan="2" style="padding-top: 5px;">Cementerio: <span class="val">@Model.CemeteryName</span></td>
                <td style="padding-top: 5px;">Ubicación: <span class="val">@Model.BurialLocationDetail</span></td>
            </tr>
        </table>
    </div>

    <div class="border-section">
        <div class="title-label">Detalle de Suministros y Servicios</div>
        <table class="table-services">
            <thead>
                <tr>
                    <th>Descripción del Servicio / Producto</th>
                    <th>Categoría</th>
                    <th style="text-align: right;">Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Services)
                {
                    <tr>
                        <td><span class="val">@item.Description</span></td>
                        <td>@item.Category</td>
                        <td style="text-align: right;" class="fw-bold">@item.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <table class="signature-box">
        <tr>
            <td style="width: 45%; text-align: center;">
                <div class="signature-line"></div>
                <p style="margin: 0;"><strong>@Model.SolicitorName</strong></p>
                <p style="margin: 0; font-size: 9px;">DNI: @Model.SolicitorDni</p>
                <p style="margin: 0; font-size: 8px; color: #666;">Firma del Solicitante</p>
            </td>
            <td style="width: 10%;"></td>
            <td style="width: 45%; text-align: center;">
                <div class="signature-line"></div>
                <p style="margin: 0;"><strong>FONAFUN PERÚ</strong></p>
                <p style="margin: 0; font-size: 9px;">Sede: @Model.BranchName</p>
                <p style="margin: 0; font-size: 8px; color: #666;">Firma Autorizada y Sello</p>
            </td>
        </tr>
    </table>

    <div class="footer-note">
        Documento generado electrónicamente el @Model.CreatedAt - Código de Verificación: @Model.Id.ToString("D8")<br>
        <strong>FONAFUN - Vocación de Servicio al Personal Policial</strong>
    </div>
</body>
</html>