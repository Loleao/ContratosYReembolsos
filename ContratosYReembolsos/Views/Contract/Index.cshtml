		function validateStep2() {
			// 1. Captura de datos básicos
			const dni = $('#DeceasedDni').val();
			const deathDate = $('#DeathDate').val();
			const dept = $('#DeathDept').val();
			const prov = $('#DeathProv option:selected').text();
			const dist = $('#DeathDist option:selected').text();
			const inei = $('#DeathDist').val();
			const cemeteryId = contractData.deceased.cemeteryId;
			const spaceId = $('#IntermentSpaceId').val(); // Este viene del mapa de nichos

			// 2. Validaciones Críticas
			if (!dni) { Swal.fire('Atención', 'Debe seleccionar un difunto.', 'warning'); return false; }
			if (!deathDate) { Swal.fire('Atención', 'La fecha de fallecimiento es obligatoria.', 'warning'); return false; }
			if (!inei) { Swal.fire('Atención', 'Debe completar el lugar (Ubigeo).', 'warning'); return false; }
			if (!cemeteryId) { Swal.fire('Atención', 'Debe seleccionar un cementerio.', 'warning'); return false; }

			if (inei) {
				contractData.deceased.inei = inei;
				contractData.deceased.ubigeoFull = `${dept} - ${prov} - ${dist}`;
			}	

			// VALIDACIÓN DE INVENTARIO:
			// Si es un cementerio propio (ej: General), el spaceId es OBLIGATORIO
			if (cemeteryId === "CEM120101" && !spaceId) {
				Swal.fire('Mapa Requerido', 'Debe elegir un nicho/tumba específico del mapa para continuar.', 'error');
				return false;
			}

			// 3. PERSISTENCIA EN EL OBJETO GLOBAL
			contractData.deceased.dni = dni;
			contractData.deceased.name = $('#DeceasedName').val();
			contractData.deceased.deathDate = deathDate;
			contractData.deceased.burialDate = $('#BurialDate').val();
			contractData.deceased.burialTime = $('#BurialTime').val();
			contractData.deceased.inei = inei;
			contractData.deceased.ubigeoFull = `${$('#DeathDept').val()} - ${$('#DeathProv option:selected').text()} - ${$('#DeathDist option:selected').text()}`;
			contractData.deceased.wakeId = $('#WakePlace').val();
			contractData.deceased.wakeName = $('#WakePlace option:selected').text();
			contractData.deceased.burialType = $('input[name="BurialType"]:checked').val();

			// GUARDAMOS EL ID REAL DEL NICHO
			contractData.deceased.intermentSpaceId = spaceId ? parseInt(spaceId) : null;
			contractData.deceased.burialDetail = $('#txtNicheSelected').text();

			return true;
		}


