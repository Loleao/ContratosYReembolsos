@model IEnumerable<ContratosYReembolsos.Models.ViewModels.Contracts.ContractListViewModel>

@{
    ViewData["Title"] = "Gestión de Contratos";
}

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0">Panel de Contratos</h2>
            <p class="text-muted small">Administración central de servicios funerarios.</p>
        </div>
        <a href="@Url.Action("Create", "Contract")" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i> Nuevo Contrato
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table id="tblContracts" class="table table-hover align-middle">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase">
                            <th class="ps-3">N° Contrato</th>
                            <th>Fallecido</th>
                            <th>Sepelio (Fecha/Hora)</th>
                            <th>Sede</th>
                            <th>Estado</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <span class="fw-bold text-primary">@item.ContractNumber</span>
                                </td>
                                <td class="text-uppercase" style="font-size: 0.9rem;">
                                    @item.DeceasedName
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa-regular fa-calendar-check me-2 text-muted"></i>
                                        <span>@item.FullBurialDetail</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted">@item.BranchName</span>
                                </td>
                                <td>
                                    @{
                                        var badgeClass = item.Status == "ACTIVO" ? "bg-success-subtle text-success border-success" : "bg-secondary-subtle text-secondary border-secondary";
                                    }
                                    <span class="badge @badgeClass border rounded-pill px-3">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group shadow-sm">
                                        <button class="btn btn-sm btn-white border" onclick="printContract(@item.Id)" title="Imprimir">
                                            <i class="fa-solid fa-print text-primary"></i>
                                        </button>
                                        <button class="btn btn-sm btn-white border" onclick="viewDetails(@item.Id)" title="Ver Detalles">
                                            <i class="fa-solid fa-eye text-info"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Inicializar DataTables para tener búsqueda y paginación automática
            $('#tblContracts').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                order: [[0, 'desc']], // Ordenar por el contrato más reciente
                pageLength: 10,
                dom: '<"d-flex justify-content-between mb-3"f>rt<"d-flex justify-content-between mt-3"ip>'
            });
        });

        function printContract(id) {
            Swal.fire({
                title: 'Generando PDF',
                text: 'Espere un momento mientras se prepara el documento...',
                icon: 'info',
                showConfirmButton: false,
                timer: 1500
            });
            // Próximo paso: window.location.href = `/Contract/DownloadPdf/${id}`;
        }

        function viewDetails(id) {
            // Aquí podrías cargar un modal con toda la info del contrato
            console.log("Cargando detalles del contrato ID: " + id);
        }
    </script>
}