		async function changePavilion() {
			const pavId = $('#cboPavilion').val();
			const selectedType = $('input[name="BurialType"]:checked').val();

			if (!pavId) {
				$('#nicheMapsContainer').addClass('d-none');
				return;
			}

			$('#nicheLoader').removeClass('d-none');
			$('#nicheMapsContainer').addClass('d-none');

			try {
				const resp = await fetch(`${urls.getSpaceMap}?structureId=${pavId}`);
				const spaces = await resp.json();

				// Dimensiones dinámicas
				const dynamicRows = [...new Set(spaces.map(s => s.rowLetter.toUpperCase()))].sort();
				const dynamicCols = [...new Set(spaces.map(s => parseInt(s.columnNumber)))].sort((a, b) => a - b);

				const $col1 = $('#colCara1');
				const $col2 = $('#colCara2');

				if (selectedType === "Tumba" || selectedType === "MAUSOLEO") {
					$col1.show();
					$col2.addClass('d-none');
					renderGrid('gridCara1', dynamicRows, dynamicCols, spaces, selectedType);
				} else {
					$col1.show();
					$col2.removeClass('d-none'); // Se mostrará debajo de la otra por ser col-md-12

					const middleIndex = Math.ceil(dynamicCols.length / 2);
					const colsCara1 = dynamicCols.slice(0, middleIndex);
					const colsCara2 = dynamicCols.slice(middleIndex);

					renderGrid('gridCara1', dynamicRows, colsCara1, spaces, selectedType);
					renderGrid('gridCara2', dynamicRows, colsCara2, spaces, selectedType);
				}

				$('#nicheLoader').addClass('d-none');
				$('#nicheMapsContainer').removeClass('d-none');

			} catch (e) {
				console.error(e);
				$('#nicheLoader').addClass('d-none');
			}
		}

