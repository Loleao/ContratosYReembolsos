        function updateSelectionList() {
            const $list = $('#selectedServicesList');
            const $emptyMsg = $('#emptyCartMsg');
            const $totalDisplay = $('#totalAmountDisplay');

            // Si no existe el contenedor (porque no estamos en el paso 4), salimos
            if (!$list.length) return;

            $list.find('.selection-item').remove(); // Limpiamos items previos
            let total = 0;

            if (contractData.services.length === 0) {
                $emptyMsg.show();
            } else {
                $emptyMsg.hide();

                contractData.services.forEach(s => {
                    total += s.price || 0;

                    // Lógica para mostrar detalles extras según el LogicType
                    let detailHtml = "";
                    if (s.logicType === 'MOVILIDAD' && s.extraData?.scheduledDate) {
                        detailHtml = `<div class="text-primary" style="font-size: 0.75rem;">
                                        <i class="fa-solid fa-calendar-day me-1"></i> ${s.extraData.scheduledDate} ${s.extraData.scheduledTime}
                                      </div>`;
                    } else if (s.logicType === 'ATAUD' && s.extraData?.serialNumber) {
                        detailHtml = `<div class="text-muted" style="font-size: 0.75rem;">
                                        <i class="fa-solid fa-barcode me-1"></i> Serie: ${s.extraData.serialNumber}
                                      </div>`;
                    }

                    const item = `
                        <div class="selection-item bg-white p-2 rounded-3 mb-2 border shadow-sm animate__animated animate__fadeInRight">
                            <div class="d-flex justify-content-between align-items-start">
                                <div style="flex: 1;">
                                    <div class="fw-bold small" style="line-height: 1.1;">${s.name}</div>
                                    ${detailHtml}
                                </div>
                                <button class="btn btn-link text-danger p-0 ms-2" onclick="handleSelection(${s.serviceId})">
                                    <i class="fa-solid fa-circle-xmark"></i>
                                </button>
                            </div>
                            <div class="text-end fw-bold small mt-1">S/ ${(s.price || 0).toFixed(2)}</div>
                        </div>
                    `;
                    $list.append(item);
                });
            }

            $totalDisplay.text(`S/ ${total.toFixed(2)}`);
            contractData.totalAmount = total;
            updateCounter();
        }


