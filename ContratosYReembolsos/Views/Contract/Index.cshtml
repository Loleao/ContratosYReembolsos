        function validateStep2() {
            // 1. Captura de valores del DOM
            const deceasedDni = $('#DeceasedDni').val()?.trim();
            const deathDate = $('#DeathDate').val();
            const burialDate = $('#BurialDate').val();
            const burialTime = $('#BurialTime').val();
            const today = new Date().toISOString().split('T')[0];

            const dept = $('#DeathDept').val();
            const prov = $('#DeathProv').val();
            const inei = $('#DeathDist').val();
            const wakeId = $('#WakePlace').val();

            // 2. Validación: Identidad del Fallecido
            if (!contractData.deceased.id || deceasedDni === "") {
                alert("Debe seleccionar al fallecido usando la lupa de búsqueda.");
                return false;
            }

            // 3. Validación: Cronología de Fechas
            if (!deathDate) {
                alert("La fecha de fallecimiento es obligatoria.");
                $('#DeathDate').focus();
                return false;
            }

            if (deathDate > today) {
                alert("La fecha de fallecimiento no puede ser una fecha futura.");
                $('#DeathDate').focus();
                return false;
            }

            if (burialDate) {
                // Validar que sepelio no sea antes que fallecimiento
                if (burialDate < deathDate) {
                    alert("La fecha de sepelio no puede ser anterior a la fecha de fallecimiento.");
                    $('#BurialDate').focus();
                    return false;
                }
                // Validar hora obligatoria si hay fecha de sepelio
                if (!burialTime) {
                    alert("Por favor, ingrese la hora programada para el sepelio.");
                    $('#BurialTime').focus();
                    return false;
                }
            }

            // 4. Validación: Ubigeo y Velatorio
            if (!inei) {
                alert("Debe completar el Ubigeo (Departamento, Provincia y Distrito).");
                return false;
            }

            if (!wakeId) {
                alert("Debe seleccionar un lugar de velatorio.");
                $('#WakePlace').focus();
                return false;
            }

            // 5. Validación: Cementerio y Mapa (Lógica Específica)
            const cemeteryId = contractData.deceased.cemeteryId;
            if (!cemeteryId) {
                alert("Debe seleccionar un cementerio de destino.");
                openSearchCemetery(); // Ayudamos al usuario abriendo el buscador
                return false;
            }

            // Si es el Cementerio General, validar el mapa de nichos/tumbas
            if (cemeteryId === "CEM120101") {
                if (!contractData.deceased.burialNicheId) {
                    const type = $('input[name="BurialType"]:checked').val();
                    alert(`Para el Cementerio General, es obligatorio elegir la ubicación en el mapa (${type}).`);
                    openNicheSelector();
                    return false;
                }
            }

            // 6. PERSISTENCIA: Guardar todo en el objeto global para el Resumen Final
            contractData.deceased.deathDate = deathDate;
            contractData.deceased.burialDate = burialDate;
            contractData.deceased.burialTime = burialTime;
            contractData.deceased.inei = inei;

            // Guardamos el texto legible de la ubicación
            const distText = $('#DeathDist option:selected').text();
            const provText = $('#DeathProv option:selected').text();
            contractData.deceased.ubigeoFull = `${dept} - ${provText} - ${distText}`;

            contractData.deceased.wakeId = wakeId;
            contractData.deceased.wakeName = $('#WakePlace option:selected').text();

            // Guardamos el tipo de sepultura seleccionado
            contractData.deceased.burialType = $('input[name="BurialType"]:checked').val();

            console.log("Paso 2 completado con éxito:", contractData.deceased);
            return true; // Permite avanzar al Paso 3
        }


