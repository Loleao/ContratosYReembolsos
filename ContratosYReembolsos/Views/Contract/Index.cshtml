        function renderCatalog(category) {
            const container = $('#catalogContainer');
            if (!container.length) return;

            container.empty();

            // 1. RESALTADO DE PESTAÑAS: Buscamos todos los botones de las tabs
            // Asumiendo que tus botones tienen el texto de la categoría
            $('#pills-tab button').each(function() {
                const btnText = $(this).text().trim();
                // Si el texto del botón coincide con la categoría (ej: "Ataúdes / Urnas" contiene "Ataúdes")
                if (btnText.includes(category)) {
                    $(this).addClass('active bg-primary text-white');
                } else {
                    $(this).removeClass('active bg-primary text-white');
                }
            });

            // 2. FILTRADO DE SERVICIOS
            const filtered = availableServices.filter(s => s.categoryName === category);

            filtered.forEach(s => {
                // 3. RESALTADO DE SELECCIONADOS: Verificamos si el ID está en contractData.services
                const isSelected = contractData.services.some(x => x.serviceId === s.id);

                const badgeClass = s.currentStock > 0 ? 'bg-success' : 'bg-info';
                const badgeText = s.logicType === 'ATAUD' ? `Stock: ${s.currentStock}` : 'Servicio';

                // Aplicamos clases dinámicas: si está seleccionado, borde azul y fondo suave
                const cardClass = isSelected ? 'border-primary bg-light-subtle' : 'border-light';
                const checkIcon = isSelected ? '<i class="fa-solid fa-circle-check text-primary shadow-sm animate__animated animate__bounceIn"></i>' : '';

                container.append(`
                    <div class="col-md-4 mb-3">
                        <div class="card h-100 rounded-4 shadow-sm service-card ${cardClass}"
                             onclick="handleSelection(${s.id})"
                             style="cursor:pointer; transition: all 0.3s; border: 2px solid;">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="badge ${badgeClass} small">${badgeText}</span>
                                    ${checkIcon}
                                </div>
                                <h6 class="fw-bold mb-1 ${isSelected ? 'text-primary' : ''}">${s.name}</h6>
                                <p class="text-muted small mb-0" style="font-size: 0.75rem;">${s.description || ''}</p>
                            </div>
                        </div>
                    </div>
                `);
            });
        }

        async function handleSelection(serviceId) {
            const service = availableServices.find(s => s.id === serviceId);

            // 1. Toggle: Si ya está, lo quitamos
            const existingIndex = contractData.services.findIndex(s => s.serviceId === serviceId);
            if (existingIndex > -1) {
                contractData.services.splice(existingIndex, 1);
                renderCatalog(service.categoryName);
                updateSelectionList();
                return;
            }

            // 2. Ejecutar Gestor según LogicType
            switch (service.logicType) {
                case 'MOVILIDAD':
                    openPhysicalUnitPicker(serviceId); // Tu agenda semanal
                    break;

                case 'ATAUD':
                    // Por ahora: Regla de negocio de solo 1 ataúd
                    contractData.services = contractData.services.filter(s => s.logicType !== 'ATAUD');
                    // Aquí llamarías a tu futuro gestor de series, por ahora asignamos directo
                    addServiceToContract(service, { stockItemId: null, serialNumber: 'Pendiente selección' });
                    Swal.fire('Seleccionado', `Se ha añadido: ${service.name}`, 'success');
                    break;

                // case 'REUTILIZABLE':
                //     addServiceToContract(service);
                //     break;

                default:
                    // Lógica SIMPLE
                    addServiceToContract(service);
                    break;
            }
        }

        function addServiceToContract(service, extra = {}) {
            contractData.services.push({
                serviceId: service.id,
                name: service.name,
                price: service.price || 0,
                logicType: service.logicType,
                categoryName: service.categoryName,
                extraData: extra
            });

            renderCatalog(service.categoryName);
            updateSelectionList();
        }

        function updateCounter() {
            $('#selectedCount').text(contractData.services.length);
        }

        async function loadUnitData(serviceId, date) {
            try {
                const resp = await fetch(`${urls.getDailyAvailability}?serviceId=${serviceId}&date=${date}`);
                const data = await resp.json();
                const $body = $('#unitGridBody').empty();

                data.forEach(u => {
                    // Iniciamos la fila con la columna de la Unidad
                    let row = `<tr>
                        <td class="small fw-bold bg-light sticky-column">
                            ${u.unitName}<br>
                            <small class="text-muted text-uppercase">${u.plate}</small>
                        </td>`;

                    // Iteramos sobre cada horario de esa unidad
                    u.schedule.forEach(slot => {
                        // Definimos las clases y etiquetas DENTRO del bucle de slots
                        const isLibre = slot.isAvailable;
                        const statusClass = isLibre ? 'available text-success' : 'occupied text-danger bg-light';
                        const icon = isLibre ? '<i class="fa-solid fa-circle-check"></i>' : '<i class="fa-solid fa-ban"></i>';
                        const label = isLibre ? 'Libre' : 'Ocupado';

                        // Acción de clic solo si está disponible
                        const clickAction = isLibre
                            ? `onclick="confirmSchedule(${u.unitId}, '${u.unitName}', '${slot.time}')"`
                            : '';

                        row += `
                            <td class="time-slot ${statusClass}" ${clickAction}>
                                <div class="py-2">
                                    ${icon}<br>
                                    <span class="fw-bold">${slot.time}</span><br>
                                    <small style="font-size: 0.65rem; display: block;">${label}</small>
                                </div>
                            </td>`;
                    });

                    row += `</tr>`;
                    $body.append(row);
                });
            } catch (e) {
                console.error("Error al cargar la agenda:", e);
                $('#unitGridBody').html('<tr><td colspan="7" class="text-danger p-4">Error al cargar la disponibilidad.</td></tr>');
            }
        }

        function confirmSchedule(id, name, time) {
            // Al elegir la hora aquí, actualizamos el contractData del Paso 2 también
            contractData.deceased.burialTime = time;

            // Cerramos y devolvemos la unidad al Paso 4
            selectUnit(id, name, '', (res) => {
                // Esta es la promesa del Paso 4
                handleServiceSelectionSuccess(id, name, time);
            });
        }

        function confirmSlotSelection(time, date) {
            const service = availableServices.find(s => s.id === currentServiceId);
            if (!service) return;

            // 1. Lanzamos la alerta de confirmación PRIMERO
            Swal.fire({
                title: '¿Confirmar este horario?',
                html: `Deseas asignar <b>${service.name}</b><br>para el día <b>${date}</b> a las <b>${time}:00</b>`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#004a99',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, asignar',
                cancelButtonText: 'Cancelar',
                target: document.getElementById('modalOverlaySearch') // Para que salga sobre el modal
            }).then((result) => {
                // 2. Si el usuario confirma, recién ejecutamos los cambios
                if (result.isConfirmed) {

                    // Actualizamos datos generales del difunto
                    contractData.deceased.burialDate = date;
                    contractData.deceased.burialTime = time + ":00";

                    // Sincronizamos con los campos del Paso 2 (por si acaso)
                    if($('#BurialDate').length) $('#BurialDate').val(date);
                    if($('#BurialTime').length) $('#BurialTime').val(time);

                    // Quitamos si ya existía este servicio para no duplicar
                    contractData.services = contractData.services.filter(s => s.serviceId !== currentServiceId);

                    // Agregamos con la nueva metadata
                    addServiceToContract(service, {
                        scheduledDate: date,
                        scheduledTime: time
                    });

                    // Cerramos el modal de la agenda
                    closeSearchModal();

                    // Notificación de éxito final
                    Swal.fire({
                        title: '¡Asignado!',
                        text: 'El servicio ha sido programado con éxito.',
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    });

                    // Refrescamos la lista lateral del Paso 4
                    updateSelectionList();
                }
            });
        }

        function renderSummary() {
            const $container = $('#summaryServicesList'); // ID en tu _ContractStep5
            $container.empty();

            contractData.services.forEach(s => {
                let detalleExtra = "";
                if (s.logicType === 'MOVILIDAD') {
                    detalleExtra = `<small class="text-primary">Programado: ${s.extraData.scheduledDate} ${s.extraData.scheduledTime}</small>`;
                } else if (s.logicType === 'ATAUD') {
                    detalleExtra = `<small class="text-muted">Serie: ${s.extraData.serialNumber}</small>`;
                }

                $container.append(`
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <div>
                            <div class="fw-bold">${s.name}</div>
                            ${detalleExtra}
                        </div>
                        <div class="text-end">S/ ${s.price.toFixed(2)}</div>
                    </div>
                `);
            });
        }

        function reloadWeeklyData() {
            const fechaParaVer = $('#pickerFilterDate').val(); // Lo que el usuario quiere ver
            const fechaRealSepelio = contractData.deceased.burialDate; // Lo que se puso en el Paso 2
            const horaRealSepelio = contractData.deceased.burialTime; // Lo que se puso en el Paso 2

            loadWeeklyData(currentServiceId, fechaParaVer, horaRealSepelio, fechaRealSepelio);
        }

        function getNombreDia(i) {
            return ["Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo"][i];
        }

        // Esta función llena la tabla del modal
        async function loadWeeklyData(unitId, baseDateStr, horaReferencial, fechaRealSepelio) {
            const hoy = new Date().toISOString().split('T')[0];
            const fechaFinal = baseDateStr || hoy;
            const fechaReferenciaFinal = fechaRealSepelio || fechaFinal;

            const $body = $('#weeklyGridBody').empty();


            try {
                const horaRefLimpia = horaReferencial ? horaReferencial.substring(0, 5) : null;

                const partes = fechaFinal.split('-');
                const fechaBase = new Date(partes[0], partes[1] - 1, partes[2]);

                const diaSemana = fechaBase.getDay();
                const diferencia = (diaSemana === 0 ? -6 : 1) - diaSemana;
                const lunes = new Date(fechaBase);
                lunes.setDate(fechaBase.getDate() + diferencia);

                for(let i=0; i<7; i++) {
                    let d = new Date(lunes);
                    d.setDate(lunes.getDate() + i);
                    $(`#col-${i}`).html(`${getNombreDia(i)}<br><small class="text-muted">${d.getDate()}/${d.getMonth()+1}</small>`);
                }

                const resp = await fetch(`${urls.getWeeklyAvailability}?unitId=${unitId}&date=${fechaFinal}`);
                const occupiedSlots = await resp.json();

                const hours = ["08:00", "09:00", "10:00", "11:00", "12:00", "13:00", "14:00", "15:00", "16:00", "17:00", "18:00"];

                hours.forEach(h => {
                    let row = `<tr><td class="time-label">${h}:00</td>`;
                    for (let i = 0; i < 7; i++) {
                        let fechaCelda = new Date(lunes);
                        fechaCelda.setDate(lunes.getDate() + i);
                        const y = fechaCelda.getFullYear();
                        const m = String(fechaCelda.getMonth() + 1).padStart(2, '0');
                        const d = String(fechaCelda.getDate()).padStart(2, '0');
                        const fechaCeldaStr = `${y}-${m}-${d}`;

                        const isOccupied = occupiedSlots.some(s => s.dayIndex === i && s.time.startsWith(h));

                        // --- CAMBIO CLAVE AQUÍ ---
                        // El resaltado azul SOLO se compara contra la fechaRealSepelio (la del Paso 2)
                        const esLaFechaReal = (fechaCeldaStr === fechaReferenciaFinal);
                        const esLaHoraReal = (h === horaRefLimpia);
                        const resaltar = esLaFechaReal && esLaHoraReal;

                        // El color verde/rojo y la posibilidad de click están habilitados para TODO lo que se ve
                        // const colorClass = isOccupied ? 'slot-red' : 'slot-green';
                        // const action = isOccupied ? '' : `onclick="confirmSlotSelection('${h}', '${fechaCeldaStr}')"`;
                        const style = resaltar ? 'border: 4px solid #004a99 !important; box-shadow: inset 0 0 10px rgba(0,0,0,0.3);' : '';

                        // row += `<td class="slot ${colorClass}" style="${style}" ${action}>
                        //             ${resaltar ? '<i class="fa-solid fa-star text-white small"></i>' : ''}
                        //         </td>`;

                        const colorClass = isOccupied ? 'slot-red' : 'slot-green';
                        const action = isOccupied ? '' : `onclick="confirmSlotSelection('${h}', '${fechaCeldaStr}')"`;

                        row += `<td class="slot ${colorClass}" style="${style}" ${action}>
                                    ${resaltar ? '<i class="fa-solid fa-star text-white small"></i>' : ''}
                                </td>`;

                    }
                    row += `</tr>`;
                    $body.append(row);
                });
            } catch (e) {
                console.error("Error cargando agenda:", e);
            }
        }

        // Esta función maneja el clic en la celda verde
        function selectTimeSlot(time, dayIndex, unitId) {
            const days = ["Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo"];

            Swal.fire({
                title: 'Confirmar Horario',
                html: `Desea reservar para el día <b>${days[dayIndex]}</b> a las <b>${time}</b>`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#004a99',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, seleccionar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // 1. Guardamos la hora en el objeto global
                    contractData.deceased.burialTime = time;

                    // 2. Calculamos la fecha real basándonos en el día de la semana actual
                    const hoy = new Date();
                    const lunes = new Date(hoy.setDate(hoy.getDate() - ((hoy.getDay() + 6) % 7)));
                    const fechaSeleccionada = new Date(lunes.setDate(lunes.getDate() + dayIndex));

                    contractData.deceased.burialDate = fechaSeleccionada.toISOString().split('T')[0];

                    // 3. Cerramos el modal
                    closeSearchModal();

                    // 4. Actualizamos visualmente el Paso 4 si es necesario
                    updateCounter();
                    Swal.fire('¡Asignado!', 'El horario ha sido reservado para este contrato.', 'success');
                }
            });
        }

        function validateStep4() {
            // 1. Validación Básica: ¿Hay servicios seleccionados?
            if (contractData.services.length === 0) {
                Swal.fire({
                    title: 'Carrito vacío',
                    text: 'Debe seleccionar al menos un servicio (Ataúd, Movilidad, etc.) para continuar.',
                    icon: 'warning',
                    confirmButtonColor: '#004a99'
                });
                return false;
            }

            // 2. Validación de Reglas de Negocio Críticas
            const tieneAtaud = contractData.services.some(s => s.logicType === 'ATAUD');
            const tieneMovilidad = contractData.services.some(s => s.logicType === 'MOVILIDAD');
            const esCremacion = contractData.deceased.burialType === 'Cremacion';

            // Regla: Si no es cremación, el ataúd es obligatorio (usualmente)
            if (!tieneAtaud && !esCremacion) {
                Swal.fire({
                    title: '¿Continuar sin Ataúd?',
                    text: "No ha seleccionado un cofre para el sepelio tradicional. ¿Está seguro de continuar?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, continuar',
                    cancelButtonText: 'Elegir Ataúd',
                    confirmButtonColor: '#004a99'
                }).then((result) => {
                    if (result.isConfirmed) {
                        loadStep(5); // Forzamos el paso si el usuario confirma
                    }
                });
                return false;
            }

            // 3. Validación de Integridad de Datos (Metadata)
            // Verificamos que los servicios de movilidad tengan fecha y hora asignada
            const movilidadIncompleta = contractData.services.find(s =>
                s.logicType === 'MOVILIDAD' && (!s.extraData || !s.extraData.scheduledDate)
            );

            if (movilidadIncompleta) {
                Swal.fire({
                    title: 'Horario pendiente',
                    text: `Debe asignar un horario en la agenda para: ${movilidadIncompleta.name}`,
                    icon: 'error',
                    confirmButtonColor: '#004a99'
                });
                return false;
            }

            // 4. Preparación para el Paso 5
            // Si todo está bien, calculamos el total final antes de pasar
            const total = contractData.services.reduce((sum, s) => sum + (s.price || 0), 0);
            contractData.totalAmount = total;

            console.log("Paso 4 validado. Datos listos para resumen:", contractData);
            return true; // Permite el avance automático a loadStep(5)
        }

    </script>
}