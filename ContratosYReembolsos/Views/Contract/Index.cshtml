			// Persistencia global
			contractData.agencyId = a.id; // Guardamos solo el ID para el contrato final
			contractData.agency = { ...a }; // Mantenemos el objeto para el resumen (Paso 5)

			// Llenado de etiquetas de texto (no inputs)
			$('#txtAgencyRuc').text(a.ruc);
			$('#txtAgencyName').text(a.name);
			$('#txtAgencyAddress').text(a.address || 'Sin dirección registrada');
			$('#txtAgencyPhone').text(a.phone || 'Sin teléfono');

			// UI Toggle
			$('#agencyInfoPanel').removeClass('d-none');
			$('#noAgencySelected').addClass('d-none');

			// Actualizar Badge de Estado
			const $badge = $('#statusBadge');
			$badge.removeClass('bg-secondary-subtle text-secondary')
				  .addClass('bg-success-subtle text-success animate__animated animate__pulse');
			$badge.html('<i class="fa-solid fa-circle-check me-1"></i>Agencia Vinculada');

			closeSearchModal();

			// Notificación de éxito
			Swal.fire({
				toast: true,
				position: 'top-end',
				icon: 'success',
				title: 'Agencia seleccionada correctamente',
				showConfirmButton: false,
				timer: 2000
			});
		}

		function validateStep3() {
			if (!contractData.agencyId) {
				Swal.fire({
					title: 'Agencia Requerida',
					text: 'Debe seleccionar una empresa funeraria para continuar con el contrato.',
					icon: 'warning',
					confirmButtonColor: '#004a99'
				});
				return false;
			}
			return true;
		}

		//PASO 4

		let currentServiceId = null; // Para saber qué servicio estamos agendando

		async function initStep4() {
			const container = $('#catalogContainer');
			const type = contractData.deceased.burialType; // "Pabellon", "Tumba", etc.

			try {
				// 1. Llamar al controlador de Servicios
				const resp = await fetch(`${urls.getServicesAction}?burialType=${type}`);
				availableServices = await resp.json();

				// 2. Renderizar la primera categoría por defecto
				renderCatalog('Ataúdes');

				// 3. Actualizar el contador de la barrita azul que sale en tu imagen
				updateCounter();
			} catch (e) {
				console.error("Error cargando servicios:", e);
				container.html('<div class="alert alert-danger">No se pudo cargar el catálogo.</div>');
			}
		}

		function updateSelectionList() {
			const $list = $('#selectedServicesList');
			const $emptyMsg = $('#emptyCartMsg');
			const $totalDisplay = $('#totalAmountDisplay');

			// Si no existe el contenedor (porque no estamos en el paso 4), salimos
			if (!$list.length) return;

			$list.find('.selection-item').remove(); // Limpiamos items previos
			let total = 0;

			if (contractData.services.length === 0) {
				$emptyMsg.show();
			} else {
				$emptyMsg.hide();

				contractData.services.forEach(s => {
					total += s.price || 0;

					// Lógica para mostrar detalles extras según el LogicType
					let detailHtml = "";
					if (s.logicType === 'MOVILIDAD' && s.extraData?.scheduledDate) {
						detailHtml = `<div class="text-primary" style="font-size: 0.75rem;">
										<i class="fa-solid fa-calendar-day me-1"></i> ${s.extraData.scheduledDate} ${s.extraData.scheduledTime}
									  </div>`;
					} else if (s.logicType === 'ATAUD' && s.extraData?.serialNumber) {
						detailHtml = `<div class="text-muted" style="font-size: 0.75rem;">
										<i class="fa-solid fa-barcode me-1"></i> Serie: ${s.extraData.serialNumber}
									  </div>`;
					}

					const item = `
						<div class="selection-item bg-white p-2 rounded-3 mb-2 border shadow-sm animate__animated animate__fadeInRight">
							<div class="d-flex justify-content-between align-items-start">
								<div style="flex: 1;">
									<div class="fw-bold small" style="line-height: 1.1;">${s.name}</div>
									${detailHtml}
								</div>
								<button class="btn btn-link text-danger p-0 ms-2" onclick="handleSelection(${s.serviceId})">
									<i class="fa-solid fa-circle-xmark"></i>
								</button>
							</div>
							<div class="text-end fw-bold small mt-1">S/ ${(s.price || 0).toFixed(2)}</div>
						</div>
					`;
					$list.append(item);
				});
			}

			$totalDisplay.text(`S/ ${total.toFixed(2)}`);
			contractData.totalAmount = total;
			updateCounter();
		}


		async function openPhysicalUnitPicker(serviceId) {
			currentServiceId = serviceId;

			$.get(urls.getUnitPickerModal, function (html) {
				$('#ajaxTargetSearch').html(html);
				$('#modalOverlaySearch').fadeIn(300).css('display', 'flex');

				const fechaPaso2 = $('#BurialDate').val();
				const horaPaso2 = $('#BurialTime').val();

				setTimeout(() => {
					$('#pickerFilterDate').val(fechaPaso2);
					// Pasamos fechaPaso2 dos veces: una para la vista inicial y otra como referencia fija
					loadWeeklyData(serviceId, fechaPaso2, horaPaso2, fechaPaso2);
				}, 50);
			});
		}

		function selectUnit(id, name, plate, resolveFunc) {
			closeSearchModal();
			resolveFunc({ id, name, plate });
		}

		async function renderCatalog(category) {
			const container = document.getElementById('catalogContainer');
			const branchId = contractData.branchId;

			if (!branchId || branchId === 0) {
				container.innerHTML = '<div class="text-center py-5 w-100"><p>Seleccione una sede primero.</p></div>';
				return;
			}

			// --- CORRECCIÓN DE RESALTADO DE PESTAÑAS ---
			document.querySelectorAll('#pills-tab .nav-link').forEach(btn => {
				// Si el texto del botón contiene la categoría, activarlo
				if (btn.innerText.trim().includes(category)) {
					btn.classList.add('active');
				} else {
					btn.classList.remove('active');
				}
			});

			container.innerHTML = '<div class="text-center py-5 w-100"><div class="spinner-border text-primary"></div></div>';

			try {
				if (category === 'Ataúdes') {
					const resp = await fetch(`/Contract/GetCoffinsByBranch?branchId=${branchId}`);
					const data = await resp.json();
					renderCoffinCards(data);
				}
				else if (category === 'Movilidad') {
					const resp = await fetch(`/Contract/GetAvailableVehicleTypesByBranch?branchId=${branchId}`);
					const data = await resp.json();
					renderVehicleTypeCards(data);
				}
			} catch (error) {
				console.error("Error cargando catálogo:", error);
				container.innerHTML = '<div class="alert alert-danger">Error de conexión.</div>';
			}
		}

		function renderCoffinCards(coffins) {
			const container = document.getElementById('catalogContainer');
			container.innerHTML = coffins.length ? '' : '<p class="text-center py-5">No hay stock disponible.</p>';

			coffins.forEach(c => {
				const isSelected = contractData.coffin?.id === c.id;
				// Aseguramos que el objeto enviado tenga todas las propiedades
				const coffinJson = JSON.stringify(c).replace(/"/g, '&quot;');

				container.innerHTML += `
					<div class="col-md-6">
						<div class="card h-100 border-2 ${isSelected ? 'border-primary bg-primary-subtle shadow' : ''} shadow-sm rounded-4 item-card"
							 onclick="selectCoffin(${coffinJson})" style="cursor:pointer">
							<div class="card-body p-3">
								<div class="d-flex align-items-center">
									<i class="fa-solid fa-box-archive fa-2x text-primary me-3"></i>
									<div class="flex-grow-1">
										<h6 class="fw-bold mb-0">${c.name}</h6>
										<small class="text-success fw-bold">S/ ${(c.price || 0).toFixed(2)}</small>
									</div>
								</div>
							</div>
						</div>
					</div>`;
			});
		}

		function selectCoffin(coffin) {
			// Si ya estaba seleccionado, lo quitamos. Si no, lo asignamos.
			if (contractData.coffin?.id === coffin.id) {
				contractData.coffin = null;
				contractData.totalAmount = 0;
			} else {
				contractData.coffin = coffin;
				// CORRECCIÓN: Aseguramos que el precio se sume correctamente
				contractData.totalAmount = parseFloat(coffin.price || 0);
			}

			renderCatalog('Ataúdes');
			updateSelectionUI();
		}

		function renderVehicleTypeCards(types) {
			const container = document.getElementById('catalogContainer');
			container.innerHTML = types.length ? '' : '<p class="text-center py-5">No hay vehículos en esta sede.</p>';

			types.forEach(t => {
				// CORRECCIÓN: Referencia a la raíz
				const isSelected = contractData.requiredVehicles.includes(t.id);

				container.innerHTML += `
					<div class="col-md-6">
						<div class="card h-100 border-2 ${isSelected ? 'border-primary bg-primary-subtle shadow' : ''} shadow-sm rounded-4 item-card"
							 data-id="${t.id}" data-name="${t.name}"
							 onclick="toggleVehicleType(${t.id}, '${t.name}')" style="cursor:pointer">
							<div class="card-body p-3">
								<div class="d-flex align-items-center">
									<div class="flex-shrink-0 bg-white border rounded-circle p-2 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width:45px;height:45px">
										<i class="fa-solid ${t.icon} text-primary"></i>
									</div>
									<div class="flex-grow-1">
										<h6 class="fw-bold mb-0">${t.name}</h6>
										<small class="text-muted">Requerimiento logístico</small>
									</div>
								</div>
							</div>
						</div>
					</div>`;
			});
		}

		function toggleVehicleType(id, name) {
			const index = contractData.requiredVehicles.indexOf(id);

			if (index === -1) {
				contractData.requiredVehicles.push(id);
			} else {
				contractData.requiredVehicles.splice(index, 1);
			}

			// IMPORTANTE: Refrescar la vista para ver el resaltado
			renderCatalog('Movilidad');
			updateSelectionUI();
		}

		function updateSelectionUI() {
			const list = document.getElementById('selectedServicesList');
			const emptyMsg = document.getElementById('emptyCartMsg');
			const totalDisplay = document.getElementById('totalAmountDisplay');

			if (!list) return;
			list.innerHTML = '';
			let hasItems = false;

			// --- SECCIÓN ATAÚD ---
			if (contractData.coffin) {
				hasItems = true;
				// CORRECCIÓN: Validación de seguridad para toFixed
				const price = parseFloat(contractData.coffin.price || 0);

				list.innerHTML += `
					<div class="bg-light rounded-3 p-3 mb-2 border-start border-primary border-4">
						<div class="d-flex justify-content-between">
							<div class="fw-bold small">${contractData.coffin.name}</div>
							<button class="btn btn-sm text-danger p-0" onclick="removeCoffin()"><i class="fa-solid fa-xmark"></i></button>
						</div>
						<div class="text-primary fw-bold">S/ ${price.toFixed(2)}</div>
					</div>`;
			}

			// --- SECCIÓN MOVILIDAD ---
			contractData.requiredVehicles.forEach((id, index) => {
				hasItems = true;
				// Buscamos el nombre en el DOM si está disponible
				const card = document.querySelector(`.item-card[data-id="${id}"]`);
				const name = card ? card.getAttribute('data-name') : "Servicio Logístico";

				list.innerHTML += `
					<div class="bg-light rounded-3 p-3 mb-2 border-start border-dark border-4">
						<div class="d-flex justify-content-between align-items-center">
							<div class="fw-bold small">${name}</div>
							<button class="btn btn-sm text-danger p-0" onclick="toggleVehicleType(${id})"><i class="fa-solid fa-xmark"></i></button>
						</div>
					</div>`;
			});

			if (emptyMsg) emptyMsg.classList.toggle('d-none', hasItems);
			if (totalDisplay) totalDisplay.innerText = `S/ ${contractData.totalAmount.toFixed(2)}`;
		}

		function removeCoffin() {
			contractData.coffin = null;
			contractData.totalAmount = 0;
			renderCatalog('Ataúdes');
			updateSelectionUI();
		}

		function toggleVehicleType(id, name) {
			const index = contractData.requiredVehicles.indexOf(id);

			if (index === -1) {
				contractData.requiredVehicles.push(id);
			} else {
				contractData.requiredVehicles.splice(index, 1);
			}

			// Solo refrescamos la UI
			renderCatalog('Movilidad');
			updateSelectionUI();
		}


		function validateStep4() {
			// 1. Verificamos si hay un ataúd seleccionado (Propiedad de la raíz)
			const tieneAtaud = contractData.coffin !== null;

			// 2. Verificamos si hay vehículos seleccionados (Propiedad de la raíz)
			const tieneMovilidad = contractData.requiredVehicles.length > 0;

			// Lógica de validación: Al menos debe haber un ataúd
			if (!tieneAtaud) {
				Swal.fire({
					title: 'Selección incompleta',
					text: 'Debe seleccionar al menos un ataúd para continuar con el contrato.',
					icon: 'warning',
					confirmButtonColor: '#004a99'
				});
				return false;
			}

			// Opcional: Advertencia si no hay movilidad, pero permitimos pasar
			if (!tieneMovilidad) {
				console.log("Aviso: No se han seleccionado vehículos para este contrato.");
			}

			console.log("Paso 4 validado con éxito. Datos:", contractData);
			return true;
		}
		

		//PASO
		//NUMERO
		//5

		async function renderStep5() {
			console.log("Generando resumen final con datos:", contractData);

			// 1. Prefijo y Código de Contrato (Seguro)
			let previewPrefix = "GEN";
			try {
				const ubigeo = contractData.deceased?.ubigeoFull || "";
				if (ubigeo.includes('-')) {
					const regionText = ubigeo.split('-')[0].trim();
					const resp = await fetch(`/Contract/GetPrefix?region=${encodeURIComponent(regionText)}`);
					const data = await resp.json();
					previewPrefix = data.prefix || "GEN";
				}
			} catch (e) { console.warn("No se pudo obtener el prefijo:", e); }

			const year = new Date().getFullYear();
			$('#resContractPreview').text(`${previewPrefix}${year}-XXXXX`);

			// 2. Partes Interesadas
			$('#resSolicitorName').text(contractData.solicitor?.name || "No identificado");
			$('#resSolicitorDni').text(`DNI: ${contractData.solicitor?.dni || "---"}`);

			$('#resDeceasedName').text(contractData.deceased?.name || "No identificado");
			$('#resDeceasedDni').text(`DNI: ${contractData.deceased?.dni || "---"}`);

			// 3. Logística
			const d = contractData.deceased;
			$('#resBurialDateTime').text(`${d?.burialDate || '---'} ${d?.burialTime || ''}`);
			$('#resWakePlace').text(d?.wakeName || "Particular / Domicilio");
			$('#resCemetery').text(d?.cemeteryName || "No seleccionado");

			if (d?.burialDetail) {
				$('#resNicheRow').removeClass('d-none').show();
				$('#resNicheDetail').text(d.burialDetail);
			} else {
				$('#resNicheRow').hide();
			}

			// 4. Detalle de Servicios (Ataúd y Movilidad) - AQUÍ ESTABA EL ERROR
			const $container = $('#resServicesTable');
			$container.empty();

			// --- ATAÚD ---
			if (contractData.coffin) {
				// Forzamos que el precio sea un número para evitar el error toFixed
				const coffinPrice = parseFloat(contractData.coffin.price || 0);

				$container.append(`
					<div class="d-flex justify-content-between align-items-center py-3 border-bottom animate__animated animate__fadeIn">
						<div class="d-flex align-items-center">
							<div class="bg-primary-subtle p-2 rounded-3 me-3 text-primary">
								<i class="fa-solid fa-box-archive"></i>
							</div>
							<div>
								<span class="fw-bold d-block">${contractData.coffin.name || 'Ataúd seleccionado'}</span>
								<small class="text-muted text-uppercase" style="font-size: 10px;">Suministro Principal</small>
							</div>
						</div>
						<span class="fw-bold text-dark">S/ ${coffinPrice.toFixed(2)}</span>
					</div>
				`);
			}

			// --- MOVILIDAD ---
			if (contractData.requiredVehicles && contractData.requiredVehicles.length > 0) {
				contractData.requiredVehicles.forEach(id => {
					// Intentamos recuperar el nombre desde el atributo data-name que pusimos en el paso 4
					const card = document.querySelector(`.item-card[data-id="${id}"]`);
					const name = card ? card.getAttribute('data-name') : "Requerimiento de Movilidad";

					$container.append(`
						<div class="d-flex justify-content-between align-items-center py-3 border-bottom animate__animated animate__fadeIn">
							<div class="d-flex align-items-center">
								<div class="bg-dark-subtle p-2 rounded-3 me-3 text-dark">
									<i class="fa-solid fa-truck-moving"></i>
								</div>
								<div>
									<span class="fw-bold d-block">${name}</span>
									<small class="text-primary text-uppercase" style="font-size: 10px;">Logística para el Sepelio</small>
								</div>
							</div>
							<span class="badge bg-light text-dark border px-3 rounded-pill">Incluido</span>
						</div>
					`);
				});
			}

			// 5. Total Final (Seguro)
			const finalTotal = parseFloat(contractData.totalAmount || 0);
			$('#resTotalAmount').text(`S/ ${finalTotal.toFixed(2)}`);
		}

		async function saveFinalContract() {
			// 1. Validación de seguridad: ¿Hay servicios?
			if (contractData.services.length === 0) {
				Swal.fire('Atención', 'No puedes registrar un contrato sin servicios.', 'warning');
				return;
			}

			// 2. Confirmación con el usuario
			const result = await Swal.fire({
				title: '¿Confirmar Registro?',
				html: `Se generará un nuevo contrato oficial.<br><small class="text-muted">Esta acción descontará stock y agendará movilidades.</small>`,
				icon: 'question',
				showCancelButton: true,
				confirmButtonColor: '#004a99',
				cancelButtonColor: '#6c757d',
				confirmButtonText: 'Sí, registrar ahora',
				cancelButtonText: 'Revisar datos'
			});

			if (!result.isConfirmed) return;

			// 3. UI de carga (Bloquea la pantalla para evitar dobles clics)
			Swal.fire({
				title: 'Procesando registro...',
				text: 'Por favor, no cierre la ventana.',
				allowOutsideClick: false,
				didOpen: () => { Swal.showLoading(); }
			});

			try {
				// 4. EL ENVÍO (Asegúrate que la URL sea correcta según tu Route)
				const response = await fetch(`${urls.saveContract}`, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json'
						// Si usas Anti-Forgery Tokens en .NET, añade aquí el header:
						// 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
					},
					body: JSON.stringify(contractData)
				});

				const data = await response.json();

				if (data.success) {
					// 5. ÉXITO: Mostramos el código real generado por el Controller (Ej: JUN202600001)
					await Swal.fire({
						title: '¡Contrato Registrado!',
						html: `El código oficial es: <b class="fs-4 text-primary">${data.contractNumber}</b>`,
						icon: 'success',
						confirmButtonText: 'Ir al Listado'
					}).then((result) => {
						window.open(`${urls.downloadContract}?id=${data.id}`, '_blank');
						if (!result.isConfirmed) {
							window.location.href = '/Contract/Index';
						}
					});

					// Redirección al listado de contratos o ver detalle
					window.location.href = '/Contract/Index';
				} else {
					// ERROR DE NEGOCIO (Ej: No hay stock, error de base de datos)
					Swal.fire('Error al guardar', data.message || 'Ocurrió un error inesperado.', 'error');
				}
			} catch (error) {
				// ERROR DE RED O SERVIDOR CAÍDO
				console.error("Error en Fetch:", error);
				Swal.fire('Error de Conexión', 'No se pudo comunicar con el servidor. Intente nuevamente.', 'error');
			}
		}

	</script>
}