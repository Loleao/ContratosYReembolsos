			const name = $('#filterAgencyName').val()?.trim() || '';
			const branchId = contractData.branchId; // Obtenemos la filial del contrato actual

			const $tbody = $('#agenciesTableBody');

			// 2. Validación condicionada: Solo validamos si NO es carga inicial
			if (!isInitialLoad && !ruc && !name) {
