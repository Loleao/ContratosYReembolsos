@model IEnumerable<ContratosYReembolsos.Models.ViewModels.Contracts.ContractListViewModel>

@{
    ViewData["Title"] = "Gestión de Contratos";
}

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="d-flex align-items-center gap-3">
        @if (ViewBag.IsAdmin == true)
        {
            <a href="@Url.Action("Index", new { selectedBranchId = (int?)null })" class="btn btn-sm btn-light border rounded-circle" title="Cambiar Sede">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
        }
        <h2 class="fw-bold mb-0">Contratos: @ViewBag.BranchName</h2>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Gestión de Contratos</h2>
        <div class="d-flex gap-2">
            <a href="@Url.Action("FuneralServices", "Contract")" class="btn btn-outline-primary rounded-pill me-2">
                <i class="fas fa-list-check me-1"></i> Catálogo de Servicios
            </a>

            <a href="@Url.Action("CreateDirectInhumation", "Contract")" class="btn btn-outline-success rounded-pill">
                <i class="fa-solid fa-user-shield me-1"></i> Inhumación Directa
            </a>

            <a href="@Url.Action("Create", "Exhumation")" class="btn btn-warning rounded-pill">
                <i class="fas fa-arrows-alt-v me-1"></i> Nueva Exhumación
            </a>

            <a href="@Url.Action("Create", "Contract")" class="btn btn-success rounded-pill">
                <i class="fas fa-plus me-1"></i> Nuevo Contrato
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table id="tblContracts" class="table table-hover align-middle">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase">
                            <th class="ps-3">N° Contrato / Folio</th>
                            <th>Fallecido</th>
                            <th>Sepelio (Fecha/Hora)</th>
                            <th>Sede</th>
                            <th>Estado</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <span class="fw-bold text-primary">@item.ContractNumber</span>
                                </td>
                                <td class="text-uppercase" style="font-size: 0.9rem;">
                                    @item.DeceasedName
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa-regular fa-calendar-check me-2 text-muted"></i>
                                        <span>@item.FullBurialDetail</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted">@item.BranchName</span>
                                </td>
                                <td>
                                    @{
                                        var badgeClass = item.Status == "ACTIVO" ? "bg-success-subtle text-success border-success" : "bg-secondary-subtle text-secondary border-secondary";
                                    }
                                    <span class="badge @badgeClass border rounded-pill px-3">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group shadow-sm">
                                        @if (!item.ContractNumber.StartsWith("REG-"))
                                        {
                                            <button class="btn btn-sm btn-white border" onclick="generatePDF(@item.Id)" title="Imprimir Contrato">
                                                <i class="fa-solid fa-print text-primary"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-white border disabled" title="Regularización Directa (Sin PDF de venta comercial)">
                                                <i class="fa-solid fa-print text-muted"></i>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-white border" onclick="location.href='@Url.Action("Details", "Contract", new { id = item.Id })'" title="Ver Detalles">
                                            <i class="fa-solid fa-eye text-info"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="servicesModalContainer"></div>
<div id="modalContainer"></div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tblContracts').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                order: [[0, 'desc']],
                pageLength: 10,
                dom: '<"d-flex justify-content-between mb-3"f>rt<"d-flex justify-content-between mt-3"ip>'
            });
        });

        function generatePDF(id) {
            Swal.fire({
                title: 'Preparando documento',
                text: 'Generando el formato oficial FONAFUN...',
                icon: 'info',
                timer: 2000,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            const url = '@Url.Action("PrintContract", "Contract")' + '?id=' + id;
            window.open(url, '_blank');
        }
    </script>
}