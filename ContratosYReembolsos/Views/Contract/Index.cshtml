                console.error("Error al cargar mapa de nichos:", error);
            }
        }

        function renderGrid(containerId, rows, cols, allNiches, type) {
            const $container = $('#' + containerId);
            if (!$container.length) return;
            $container.empty();

            const isTumba = (type === "Tumba");

            // CONFIGURACIÓN DINÁMICA
            const itemClass = isTumba ? "niche-item-tumba" : "niche-item-pabellon";
            const rowHeight = isTumba ? "60px" : "40px";
            const numCols = cols.length;

            // Ajustamos la grilla del contenedor para que coincida con el número de columnas enviado
            // Esto evita que "Pabellón" intente usar 10 columnas si solo le mandamos 5
            $container.css({
                'display': 'grid',
                'grid-template-columns': `40px repeat(${numCols}, 1fr)`,
                'gap': '8px'
            });

            // 1. Cabecera (Números)
            $container.append('<div></div>');
            cols.forEach(c => {
                $container.append(`<div class="text-center fw-bold text-muted small pb-2">${c}</div>`);
            });

            // 2. Filas
            rows.forEach(r => {
                // Letra de la fila
                $container.append(`<div class="fw-bold text-muted d-flex align-items-center justify-content-center" style="height: ${rowHeight}">${r}</div>`);

                // Columnas
                cols.forEach(c => {
                    const niche = allNiches.find(n =>
                        n.row.toString().trim().toUpperCase() === r.toUpperCase() &&
                        parseInt(n.column) === parseInt(c)
                    );

                    if (niche) {
                        const isOccupied = niche.isOccupied ?? niche.IsOccupied;
                        const isReserved = niche.isBeingReserved ?? niche.IsBeingReserved;

                        let statusClass = "";
                        if (isOccupied) statusClass = "bg-ocupado";
                        else if (isReserved) statusClass = "bg-proceso";

                        $container.append(`
                            <div class="${itemClass} ${statusClass}"
                                 onclick="${isOccupied ? '' : `confirmNicheSelection(${niche.id}, '', '${r}', ${c})`}"
                                 title="${type} ${r}-${c}">
                                 ${isTumba ? '<i class="fa-solid fa-seedling opacity-50"></i>' : c}
                            </div>`);
                    } else {
                        // Espacio vacío para mantener la forma irregular si no existe en BD
                        $container.append(`<div style="height: ${rowHeight}; width: 100%;"></div>`);
                    }
                });
            });
        }

