@{
    ViewData["Title"] = "Registro de Contratos";
}

<style>
    :root {
        --pnp-blue: #004a99;
        --pnp-bg: #003366;
        --pnp-gray: #f1f4f8;
    }

    body {
        background-color: var(--pnp-bg);
        font-family: 'Segoe UI', sans-serif;
    }

    /* Contenedor Principal */
    .stepper-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        max-width: 1000px;
        margin: 50px auto;
        min-height: 600px;
    }

    /* Stepper Header (Bolitas) */
    .stepper-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 40px;
        position: relative;
    }

    .step-item {
        flex: 1;
        text-align: center;
        position: relative;
        z-index: 2;
    }

        .step-item::after {
            content: "";
            position: absolute;
            width: 100%;
            height: 2px;
            background: #e0e0e0;
            top: 20px;
            left: 50%;
            z-index: -1;
        }

        .step-item:last-child::after {
            display: none;
        }

    .step-dot {
        width: 40px;
        height: 40px;
        background: white;
        border: 2px solid #e0e0e0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 10px;
        font-weight: bold;
        color: #999;
    }

    .step-item.active .step-dot {
        border-color: var(--pnp-blue);
        color: var(--pnp-blue);
        border-width: 3px;
    }

    .step-item.completed .step-dot {
        background: #28a745;
        border-color: #28a745;
        color: white;
    }

    .step-label {
        font-size: 12px;
        font-weight: bold;
        color: #999;
        text-transform: uppercase;
    }

    /* --- ESTILO PARA NICHOS Y COLUMBARIOS (CONCRETO) --- */
    .niche-item-pabellon {
        width: 100%;
        height: 40px;
        background-color: #ffffff;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 600;
        color: #666;
        cursor: pointer;
        transition: all 0.2s;
    }

    .niche-item-pabellon:hover {
        background-color: #e9ecef;
        border-color: var(--pnp-blue);
    }

    /* --- ESTILO PARA TUMBAS (TIERRA/CÉSPED) --- */
    .niche-item-tumba {
        width: 100%;
        height: 60px; /* Más alto */
        background-color: #9ccc65;
        border: 2px solid #689f38;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        transition: all 0.2s;
    }

        .niche-item-tumba:hover {
            background-color: #8bc34a;
            transform: translateY(-2px);
        }

    /* --- ESTADOS UNIVERSALES (ESTO SÍ SE COMPARTE) --- */
    .bg-ocupado {
        background-color: #ffc7ce !important;
        border-color: #f1aeb5 !important;
        color: #a41c1c !important;
        cursor: not-allowed;
    }

    .bg-proceso {
        background-color: #cfe2ff !important;
        border-color: #9ec5fe !important;
        color: #084298 !important;
        cursor: wait;
    }

    /* Paso 4 */

    .time-slot {
        border: 1px solid #f0f0f0 !important;
        min-width: 90px;
        transition: 0.2s;
    }

        .time-slot.available:hover {
            background-color: var(--pnp-blue) !important;
            color: white !important;
            cursor: pointer;
            transform: scale(1.05);
            z-index: 5;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        .time-slot.occupied {
            cursor: not-allowed;
            opacity: 0.7;
        }

    .sticky-column {
        background-color: #f8f9fa !important;
        border-right: 2px solid #dee2e6 !important;
    }

    /* Efecto Hover para celdas disponibles */
    .slot.slot-green:hover {
        background-color: #218838 !important; /* Un verde más oscuro */
        cursor: pointer;
        transform: scale(1.1); /* Se agranda un poquito */
        z-index: 10;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        border-radius: 4px;
        transition: all 0.2s ease;
    }

    /* Evitar que las celdas rojas reaccionen */
    .slot.slot-red {
        cursor: not-allowed;
    }

    /* Estilo para la celda que ya está seleccionada (la estrella) */
    .slot[style*="border: 4px solid"] {
        animation: pulse-blue 2s infinite;
    }

    @@keyframes pulse-blue {
        0% {
            box-shadow: 0 0 0 0 rgba(0, 74, 153, 0.7);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(0, 74, 153, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(0, 74, 153, 0);
        }
    }


    /* Overlay Personalizado (Tu lógica de Legajos) */
    .custom-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(5px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 3000;
    }

    .swal2-container {
        z-index: 4000 !important;
    }

    #ajaxTargetSearch {
        width: 95%; /* Ocupa casi todo el ancho en móviles */
        max-width: 900px; /* Ancho cómodo para la tabla */
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }


</style>

<div class="container">
    <div class="stepper-card">
        <div class="stepper-header">
            <div class="step-item active" id="nav-1"><div class="step-dot">1</div><div class="step-label">Solicitante</div></div>
            <div class="step-item" id="nav-2"><div class="step-dot">2</div><div class="step-label">Difunto</div></div>
            <div class="step-item" id="nav-3"><div class="step-dot">3</div><div class="step-label">Agencia</div></div>
            <div class="step-item" id="nav-4"><div class="step-dot">4</div><div class="step-label">Servicios</div></div>
            <div class="step-item" id="nav-5"><div class="step-dot">5</div><div class="step-label">Resumen</div></div>
        </div>

        <div id="dynamic-content">
            <div class="text-center py-5">
                <i class="fa-solid fa-circle-notch fa-spin fa-2x text-primary"></i>
                <p>Cargando formulario...</p>
            </div>
        </div>
    </div>
</div>

<div id="modalOverlaySearch" class="custom-modal-overlay" onclick="handleOverlayClick(event)">
    <div id="ajaxTargetSearch"></div>
</div>

@section Scripts {
    <script>
        // 1. Configuración Global
        const urls = {
            actualStep: 0,
            step1: '@Url.Action("GetStep1", "Contract")',
            step2: '@Url.Action("GetStep2", "Contract")',
            step3: '@Url.Action("GetStep3", "Contract")',
            step4: '@Url.Action("GetStep4", "Contract")',
            step5: '@Url.Action("GetStep5", "Contract")',
            searchModal: '@Url.Action("GetSearchModal", "Contract")',
            searchAction: '@Url.Action("SearchAffiliates", "Contract")',
			searchBeneficiariesModal: '@Url.Action("GetSearchBeneficiary", "Contract")',
            searchBeneficiaries: '@Url.Action("GetBeneficiariesByAffiliate", "Contract")',
			getRegions: '@Url.Action("GetRegions", "Contract")',
			getProvinces: '@Url.Action("GetProvinces", "Contract")',
			getDistricts: '@Url.Action("GetDistricts", "Contract")',
            getWakes: '@Url.Action("GetWakes", "Contract")',
            getCemeteryModal: '@Url.Action("GetSearchCemetery", "Contract")',
            getCemeteriesAction: '@Url.Action("GetCemeteries", "Contract")',
            getAgencyModal: '@Url.Action("GetSearchAgency", "Contract")',
            getAgenciesAction: '@Url.Action("GetAgencies", "Contract")',
            getNicheSelectorModal: '@Url.Action("GetNicheSelector", "Contract")',
            getNicheMap: '@Url.Action("GetMap", "Niche")',
            getPavilions: '@Url.Action("GetPavilions", "Niche")',
            reserveNiche: '@Url.Action("Reserve", "Niche")',
            getServicesAction: '@Url.Action("GetServices", "Service")',
            getAvailableUnits: '@Url.Action("GetAvailableUnits", "Service")',
            getUnitPickerModal: '@Url.Action("GetUnitPicker", "Service")',
            getDailyAvailability: '@Url.Action("GetDailyAvailability", "Service")',
            getWeeklyAvailability: '@Url.Action("GetWeeklyAvailability", "Service")',
            saveContract: '@Url.Action("Create", "Contract")'
        };

        let contractData = {
            solicitor: { id: '', dni: '', name: '', cip: '', type: '' },
            deceased: {
                id: '', 
                dni: '', 
                name: '', 
                type: '',
                deathDate: '', 
                burialDate: '',
                burialTime: '',
                inei: '',
                ubigeoFull: '', 
                wakeId: '',
                wakeName: '',
                cemeteryId: '',
                cemeteryName: '',
                burialType: '',
                burialDetail: ''
            },
            agency: { id: '', name: '', address: '' },
            services: [],
            totalAmount: 0
        };

        let searchTarget = 'Solicitor';

        async function loadStep(n) {
            const container = document.getElementById('dynamic-content');

            container.style.opacity = '0.5';

            try {
                const resp = await fetch(urls[`step${n}`]);
                container.innerHTML = await resp.text();
                container.style.opacity = '1';

                document.querySelectorAll('.step-item').forEach((el, i) => {
                    el.classList.toggle('active', (i + 1) === n);
                    el.classList.toggle('completed', (i + 1) < n);
                });

                setTimeout(() => {
                    if (n === 1) {
                        toggleSolicitorType();
						actualStep = 1;
                    }
                    if (n === 2) {
                        if(contractData.deceased.burialTime) {
                            $('#BurialTime').val(contractData.deceased.burialTime);
                        }
                        filterDeceasedOptions();
                        loadRegions();
                        loadWakes();
						actualStep = 2;
                    }
                    if (n === 4){
						initStep4().then(() => {
                            updateSelectionList();
                        })
                    }
                }, 100);

            } catch (e) {
                console.error("Error cargando paso:", e);
                container.innerHTML = '<div class="alert alert-danger">Error al conectar con el servidor.</div>';
            }
        }

        function openSearchAffiliate(target) {
            searchTarget = target; // Guardamos si es para 'Solicitor' o 'Deceased'

            $.ajax({
                url: urls.searchModal,
                type: 'GET',
                success: function (html) {
                    $('#ajaxTargetSearch').html(html);
                    $('#modalOverlaySearch').css('display', 'flex').hide().fadeIn(300);
                }
            });
        }

        function closeSearchModal() {
            $('#modalOverlaySearch').fadeOut(300);
        }

        function handleOverlayClick(e) {
            if (e.target.id === 'modalOverlaySearch') closeSearchModal();
        }

        async function executeSearch() {
            // 1. Obtenemos los filtros básicos
            const filters = {
                dni: $('#filterDni').val(),
                cip: $('#filterCip').val(),
                name: $('#filterName').val(),
            };

            const $tbody = $('#resultsTableBody');
            $tbody.html('<tr><td colspan="4" class="text-center py-4"><i class="fas fa-spinner fa-spin"></i> Filtrando beneficiarios...</td></tr>');

            try {
                // 2. Construimos la URL con el nuevo parámetro parentDni
                const query = `dni=${filters.dni}&cip=${filters.cip}&name=${encodeURIComponent(filters.name)}&parentDni=${filters.parentDni}`;
                const response = await fetch(`${urls.searchAction}?${query}`);
                const data = await response.json();

                $tbody.empty();

                if (data.length === 0) {
                    $tbody.append('<tr><td colspan="4" class="text-center text-danger">No se encontraron beneficiarios asociados a este titular.</td></tr>');
                    return;
                }

                // 3. Renderizamos los resultados
                data.forEach(item => {
                    const tr = $(`
                        <tr style="cursor:pointer" class="align-middle">
                            <td><b>${item.dni}</b></td>
                            <td>${item.relationship || 'Familiar'}</td> <td>${item.name}</td>
                            <td class="text-end"><button class="btn btn-sm btn-primary rounded-pill">Seleccionar</button></td>
                        </tr>
                    `);
                    tr.click(() => selectAffiliate(item));
                    $tbody.append(tr);
                });
            } catch (e) {
                $tbody.html('<tr><td colspan="4" class="text-center text-danger">Error al conectar con la base de datos de beneficiarios.</td></tr>');
            }
        }

        function selectAffiliate(item) {
            if (searchTarget === 'Solicitor') {
				contractData.solicitor.id = item.id;
                contractData.solicitor.dni = item.dni;
                contractData.solicitor.name = item.name;
                contractData.solicitor.cip = item.cip;


                $('#SolicitorDni').val(item.dni);
                $('#SolicitorName').val(item.name);
                $('#SolicitorCip').val(item.cip);
            }
            else if (searchTarget === 'Deceased') {
                $('#DeceasedDni').val(item.dni);
                $('#DeceasedName').val(item.name);
                $('#DeceasedCip').val(item.cip);
            }
            closeSearchModal();
        }

        function toggleSolicitorType() {
            const select = document.getElementById('SolicitorType');
            if (!select) return;

            const type = select.value;
            contractData.solicitor.type = type; 

            const isTitular = (type === "Titular");
            const btnLupa = document.getElementById('btnLupa');
            const fields = ['SolicitorDni', 'SolicitorName', 'SolicitorCip'];

            if (btnLupa) {
                isTitular ? $(btnLupa).fadeIn(200) : $(btnLupa).fadeOut(200);
            }

            fields.forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;

                if (isTitular) {
                    el.readOnly = true;
                    el.classList.add('bg-light');
                } else {
                    el.readOnly = false;
                    el.classList.remove('bg-light');
                }
            });
        }

        function validateStep1() {
            const type = $('#SolicitorType').val();
            const dni = $('#SolicitorDni').val().trim();
            const name = $('#SolicitorName').val().trim();

            // Limpiar alertas previas si las hay
            $('.is-invalid').removeClass('is-invalid');

            if (dni === "" || dni.length < 8) {
                alert("Por favor, ingrese un DNI válido (8 dígitos).");
                $('#SolicitorDni').addClass('is-invalid').focus();
                return false;
            }

            if (name === "") {
                alert("El nombre completo es obligatorio.");
                $('#SolicitorName').addClass('is-invalid').focus();
                return false;
            }

            // Si todo está bien, permitimos avanzar
            return true;
        }

        async function nextStep(n, validationFn) {
            if (validationFn && !validationFn()) {
                return;
            }
            loadStep(n);
        }

        function filterDeceasedOptions() {
            // Leemos directamente del objeto global, no del DOM
            const solType = contractData.solicitor.type;
            const $deceasedSelect = $('#DeceasedType');

            if (!$deceasedSelect.length) return;

            if (solType === "Titular") {
                // Regla: Si el solicitante es Titular, el fallecido NO PUEDE ser Titular
                $deceasedSelect.find('option[value="Titular"]').hide();
                $deceasedSelect.val("Beneficiario"); // Forzamos selección

                $('#alertRestriction').removeClass('d-none'); // Mostramos alerta azul
                handleDeceasedTypeChange(); // Activamos la lupa
            } else {
                // Si el solicitante es familiar, el fallecido sí puede ser el Titular
                $deceasedSelect.find('option[value="Titular"]').show();
                $('#alertRestriction').addClass('d-none');
            }
        }

        document.addEventListener('DOMContentLoaded', () => loadStep(1));

        //PASO
        //NUMERO
        //2

        $(document).on('change', '#BurialTime', function() {
            contractData.deceased.burialTime = $(this).val();
        });

        function openSearchBeneficiaries() {
            searchTarget = 'Deceased'; // Marcamos que el destino es el fallecido

            $.ajax({
                url: urls.searchBeneficiariesModal, // Tu nueva vista parcial
                type: 'GET',
                success: function (html) {
                    // Inyectamos el HTML en el contenedor del modal
                    $('#ajaxTargetSearch').html(html);

                    // Mostramos el overlay con efecto
                    $('#modalOverlaySearch').css('display', 'flex').hide().fadeIn(300);

                    // Cargamos los datos automáticamente al abrir
                    executeBeneficiarySearch();
                },
                error: function() {
                    alert("Error al cargar el buscador de beneficiarios.");
                }
            });
        }

        async function executeBeneficiarySearch() {
            const $tbody = $('#resultsBeneficiaryTableBody');


            const titularId = contractData.solicitor.id; // El ID que capturamos en el Paso 1

            $tbody.html('<tr><td colspan="4" class="text-center py-4"><i class="fas fa-spinner fa-spin text-primary"></i> Buscando familiares...</td></tr>');

            if (!titularId || titularId === 0) {
                $tbody.html('<tr><td colspan="4" class="text-center text-danger">No se encontró el ID del titular. Regrese al paso 1.</td></tr>');
                return;
            }

            try {
                const query = `afiliadoId=${titularId}`;
                const response = await fetch(`${urls.searchBeneficiaries}?${query}`);

                const data = await response.json();
                $tbody.empty();

                if (data.length === 0) {
                    $tbody.html('<tr><td colspan="4" class="text-center text-muted">No existen beneficiarios registrados para este titular.</td></tr>');
                    return;
                }

                data.forEach(item => {
                    const tr = $(`
                        <tr style="cursor:pointer" class="align-middle">
                            <td><b>${item.dni}</b></td>
                            <td><span class="badge bg-info-subtle text-info border border-info-subtle px-3 rounded-pill">${item.relationship}</span></td>
                            <td class="text-uppercase">${item.name}</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-primary rounded-circle p-2">
                                    <i class="fa-solid fa-check px-1"></i>
                                </button>
                            </td>
                        </tr>
                    `);
                    // Al hacer click, ejecuta la selección
                    tr.click(() => selectBeneficiary(item));
                    $tbody.append(tr);
                });
            } catch (e) {
                $tbody.html('<tr><td colspan="4" class="text-center text-danger">Error de conexión.</td></tr>');
            }
        }

        function selectBeneficiary(item) {
            // 1. Guardamos en el objeto de datos global
            contractData.deceased.id = item.id;
            contractData.deceased.dni = item.dni;
            contractData.deceased.name = item.name;

            // 2. Llenamos los campos visibles del Paso 2
            $('#DeceasedDni').val(item.dni);
            $('#DeceasedName').val(item.name);

            // 3. Cerramos el modal
            closeSearchModal();
        }

        function handleDeceasedTypeChange() {
            const type = $('#DeceasedType').val();
            const $btnLupa = $('#btnLupaDeceased');

            if (type === "Titular") {
                $btnLupa.hide();
                // Sincronizar con datos del titular del Paso 1
                $('#DeceasedDni').val(contractData.solicitor.dni);
                $('#DeceasedName').val(contractData.solicitor.name);
                contractData.deceased.id = contractData.solicitor.id;
            }
            else if (type === "Beneficiario") {
                // Limpiar campos y mostrar la lupa para buscar familiares
                $('#DeceasedDni').val('');
                $('#DeceasedName').val('');
                $btnLupa.fadeIn();
            }
        }

        function validateDatesInline() {
            const deathVal = $('#DeathDate').val(); // Formato "YYYY-MM-DD"
            const burialVal = $('#BurialDate').val();
            const $errorDiv = $('#dateErrorMessage');
            const $errorText = $('#dateErrorText');

            // Obtenemos la fecha de hoy en formato local YYYY-MM-DD
            const today = new Date().toISOString().split('T')[0];

            $errorDiv.addClass('d-none');

            // 1. Validar que fallecimiento no sea futuro
            if (deathVal && deathVal > today) {
                $errorText.text("La fecha de fallecimiento no puede ser mayor a hoy.");
                $errorDiv.removeClass('d-none');
                return false;
            }

            // 2. Validar que sepelio no sea antes que fallecimiento
            if (deathVal && burialVal) {
                if (burialVal < deathVal) {
                    $errorText.text("La fecha de sepelio no puede ser anterior a la de fallecimiento.");
                    $errorDiv.removeClass('d-none');
                    return false;
                }
            }
            return true;
        }



        async function loadRegions() {
            const resp = await fetch(`${urls.getRegions}`);
            const data = await resp.json();
            let options = '<option value="">Seleccione...</option>';
            data.forEach(region => {
                options += `<option value="${region}">${region}</option>`;
            });
            $('#DeathDept').html(options);
        }

        async function loadProvinces() {
            const region = $('#DeathDept').val();
            const $prov = $('#DeathProv');
            const $dist = $('#DeathDist');

            if (!region) { $prov.prop('disabled', true).html('<option value="">Seleccione Dept...</option>'); return; }

            const query = `region=${encodeURIComponent(region)}`;
            const resp = await fetch(`${urls.getProvinces}?${query}`);
            const data = await resp.json();

            let options = '<option value="">Seleccione...</option>';
            data.forEach(prov => {
                options += `<option value="${prov}">${prov}</option>`;
            });

            $prov.html(options).prop('disabled', false);
            $dist.prop('disabled', true).html('<option value="">Seleccione Prov...</option>');
        }

        async function loadDistricts() {
            const region = $('#DeathDept').val();
            const province = $('#DeathProv').val();
            const $dist = $('#DeathDist');

            if (!province) { $dist.prop('disabled', true).val(''); return; }

            const query = `region=${encodeURIComponent(region)}&province=${encodeURIComponent(province)}`;
            const resp = await fetch(`${urls.getDistricts}?${query}`);

            const data = await resp.json();

            let options = '<option value="">Seleccione...</option>';
            data.forEach(d => {
                // Guardamos el INEI como valor, pero mostramos el nombre del distrito
                options += `<option value="${d.inei}">${d.distrito}</option>`;
            });

            $dist.html(options).prop('disabled', false);
        }

        async function loadWakes() {
            const $wakeSelect = $('#WakePlace');
            try {
                const resp = await fetch(`${urls.getWakes}`);
                const data = await resp.json();

                let options = '<option value="">Seleccione el local...</option>';
                data.forEach(w => {
                    options += `<option value="${w.id}">${w.name}</option>`;
                });
                $wakeSelect.html(options);
            } catch (e) {
                $wakeSelect.html('<option value="">Error al cargar locales</option>');
            }
        }

        function openSearchCemetery() {
            $.ajax({
                url: urls.getCemeteryModal,
                type: 'GET',
                success: function (html) {
                    $('#ajaxTargetSearch').html(html);
                    $('#modalOverlaySearch').css('display', 'flex').hide().fadeIn(300);

                    loadCemRegions();
                }
            });
        }

        async function loadCemRegions() {
            const resp = await fetch(urls.getRegions);
            const data = await resp.json();
            let options = '<option value="">Seleccione...</option>';
            data.forEach(r => options += `<option value="${r}">${r}</option>`);
            $('#CemFilterRegion').html(options);
        }

        async function loadCemProvinces() {
            const region = $('#CemFilterRegion').val();
            if (!region) return;
            const resp = await fetch(`${urls.getProvinces}?region=${encodeURIComponent(region)}`);
            const data = await resp.json();
            let options = '<option value="">Seleccione...</option>';
            data.forEach(p => options += `<option value="${p}">${p}</option>`);
