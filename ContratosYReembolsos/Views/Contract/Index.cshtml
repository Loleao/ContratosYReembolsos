@{
	ViewData["Title"] = "Registro de Contratos";
}

<style>
	:root {
		--pnp-blue: #004a99;
		--pnp-bg: #003366;
		--pnp-gray: #f1f4f8;
	}

	body {
		background-color: var(--pnp-bg);
		font-family: 'Segoe UI', sans-serif;
	}

	/* Contenedor Principal */
	.stepper-card {
		background: white;
		border-radius: 20px;
		padding: 40px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.2);
		/* max-width: 1000px;  <-- ELIMINA O COMENTA ESTA LÍNEA */
		width: 95%; /* Ocupa casi todo el ancho disponible */
		margin: 30px auto; /* Centrado y con menos margen superior */
		min-height: calc(100vh - 100px); /* Opcional: que casi llene el alto de la pantalla */
	}

	/* .stepper-header {
					display: flex;
					justify-content: space-between;
					margin-bottom: 40px;
					position: relative;
				} */

	.stepper-header {
		display: flex; /* Habilita flujo horizontal */
		justify-content: space-between; /* Distribuye pasos equitativamente */
		align-items: center;
		position: relative;
		margin-bottom: 50px;
		padding: 0 40px;
	}

		/* La línea gris de fondo ahora se ajusta correctamente */
		.stepper-header::before {
			content: "";
			position: absolute;
			top: 25px; /* Centrado con el dot de 50px */
			left: 60px; /* Ajuste para no sobresalir al inicio */
			right: 60px; /* Ajuste para no sobresalir al final */
			height: 3px;
			background: #e2e8f0;
			z-index: 1;
		}

	/* --- ESTILO DE LOS PASOS --- */
	.step-item {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		z-index: 2;
		position: relative;
	}

		/* Quitamos el .step-item::after porque la línea general la maneja el header::before */
		.step-item::after {
			display: none;
		}

	.step-dot {
		width: 50px;
		height: 50px;
		background: white;
		border: 2px solid #e2e8f0;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		font-size: 1.2rem;
		z-index: 5;
		margin-bottom: 10px; /* Espacio con el texto inferior */
	}

	/* Efecto cuando el paso está ACTIVO */
	.step-item.active .step-dot {
		border-color: var(--pnp-blue);
		background-color: var(--pnp-blue);
		color: white;
		transform: scale(1.1);
		box-shadow: 0 0 15px rgba(0, 74, 153, 0.3);
		border-width: 4px;
	}

	/* Efecto cuando el paso está COMPLETADO */
	.step-item.completed .step-dot {
		background-color: #10b981;
		border-color: #10b981;
		color: white;
	}

	.step-label {
		font-size: 11px;
		font-weight: bold;
		color: #94a3b8;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		transition: color 0.3s;
	}

	.step-item.active .step-label {
		color: var(--pnp-blue);
	}

	#dynamic-content {
		transition: opacity 0.3s ease-in-out, transform 0.3s ease-out;
	}

	.content-fade-out {
		opacity: 0;
		transform: translateY(10px);
	}

	.content-fade-in {
		opacity: 1;
		transform: translateY(0);
	}

	.step-dot {
		width: 50px; /* Un poco más grande para los iconos */
		height: 50px;
		background: #fff;
		border: 2px solid #e2e8f0;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		font-size: 1.2rem;
		z-index: 5;
	}

	.step-item.active .step-dot {
		border-color: var(--pnp-blue);
		color: var(--pnp-blue);
		border-width: 3px;
	}

	.step-item.completed .step-dot {
		background: #28a745;
		border-color: #28a745;
		color: white;
	}

	.step-label {
		font-size: 12px;
		font-weight: bold;
		color: #999;
		text-transform: uppercase;
	}

	/* 
	.niche-item-pabellon {
		width: 100%;
		height: 40px;
		min-width: 35px;
		background-color: #ffffff;
		border: 1px solid #dee2e6;
		border-radius: 4px;
