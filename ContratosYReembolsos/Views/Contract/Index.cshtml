			}
		}

		function renderGrid(containerId, rows, cols, allSpaces, type) {
			const $container = $('#' + containerId);
			if (!$container.length) return;
			$container.empty();

			const $mapBody = $('<div class="d-flex flex-column gap-2" style="min-width: max-content; padding: 10px;"></div>');

			// --- 1. CABECERA DE NÚMEROS ---
			const $headerRow = $('<div class="d-flex align-items-center mb-1"></div>');
			// Espacio para la letra de la fila (debe ser igual al de abajo: 45px + margen)
			$headerRow.append('<div style="width: 53px;"></div>');

			const $numContainer = $('<div class="d-flex flex-nowrap gap-1"></div>');
			cols.forEach(c => {
				// Forzamos el ancho a 34px para que coincida con .space-item-modal
				$numContainer.append(`<div class="text-center fw-bold text-muted x-small" style="width: 34px;">${c}</div>`);
			});
			$headerRow.append($numContainer);
			$mapBody.append($headerRow);

			// --- 2. FILAS DE NICHOS ---
			rows.forEach(r => {
				const $rowDiv = $('<div class="d-flex align-items-center"></div>');

				// Letra de la fila
				$rowDiv.append(`<div class="fw-bold text-muted border-end pe-3 me-2 text-center" style="width: 45px; font-size: 13px;">${r}</div>`);

				const $spacesContainer = $('<div class="d-flex flex-nowrap gap-1"></div>');

				cols.forEach(c => {
					// Buscamos el espacio que coincida con la letra y EL NÚMERO DE COLUMNA exacto
					const space = allSpaces.find(s =>
						s.rowLetter.toString().trim().toUpperCase() === r.toUpperCase() &&
						parseInt(s.columnNumber) === parseInt(c)
					);

					if (space) {
						let statusClass = "st-otro";
						let isSelectable = false;

						// Normalizar status a minúsculas para evitar errores
						const currentStatus = (space.status || "").toLowerCase();

						if (currentStatus === "disponible") {
							statusClass = "st-disponible";
							isSelectable = true;
						} else if (currentStatus === "ocupado") {
							statusClass = "st-ocupado";
						} else if (currentStatus === "reservado") {
							statusClass = "st-reservado";
						}

						$spacesContainer.append(`
							<div class="space-item-modal ${statusClass}"
								 onclick="${isSelectable ? `confirmNicheSelection(${space.id}, '', '${r}', ${c})` : 'Swal.fire(\'No disponible\', \'Este espacio no está libre.\', \'warning\')'}"
								 title="Fila ${r} - Col ${c} (${space.status})">
								${c}
							</div>
						`);
					} else {
						// Celda vacía: Mantiene el ancho de 34px para que la cuadrícula no se rompa
						$spacesContainer.append('<div style="width: 34px; height: 34px; background: #f1f5f9; border-radius: 6px; opacity: 0.3;"></div>');
					}
				});

				$rowDiv.append($spacesContainer);
				$mapBody.append($rowDiv);
			});

			$container.append($mapBody);
		}

