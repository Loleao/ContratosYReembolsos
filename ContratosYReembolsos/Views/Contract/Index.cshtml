			}).then((result) => {
				// 2. Si el usuario confirma, recién ejecutamos los cambios
				if (result.isConfirmed) {

					// Actualizamos datos generales del difunto
					contractData.deceased.burialDate = date;
					contractData.deceased.burialTime = time + ":00";

