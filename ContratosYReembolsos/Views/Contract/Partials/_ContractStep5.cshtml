<div class="animate__animated animate__fadeIn">
    <div class="mb-4 d-flex justify-content-between align-items-end border-bottom pb-3">
        <div>
            <h4 class="fw-bold text-primary mb-1">Verificación de Contrato</h4>
            <p class="text-muted mb-0"><i class="fa-solid fa-triangle-exclamation me-1 text-warning"></i> Revise los datos antes de emitir el comprobante legal.</p>
        </div>
        <div class="text-end">
            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">N° Correlativo Previsto</small>
            <span class="badge bg-primary fs-5 px-3 rounded-pill shadow-sm" id="resContractPreview">---</span>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card border-0 shadow-sm rounded-4 mb-3 border-top border-primary border-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-4 text-uppercase small text-primary"><i class="fa-solid fa-id-card-clip me-2"></i>Información Personal</h6>
                    <div class="row">
                        <div class="col-md-6 border-end">
                            <label class="text-muted small d-block">Titular / Solicitante</label>
                            <span class="fw-bold d-block h6" id="resSolicitorName">---</span>
                            <span class="badge bg-light text-dark border" id="resSolicitorDni">DNI: ---</span>
                        </div>
                        <div class="col-md-6 ps-md-4">
                            <label class="text-muted small d-block">Beneficiario / Fallecido</label>
                            <span class="fw-bold d-block h6" id="resDeceasedName">---</span>
                            <span class="badge bg-light text-dark border" id="resDeceasedDni">DNI: ---</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-3">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-4 text-uppercase small text-primary"><i class="fa-solid fa-map-location-dot me-2"></i>Itinerario de Sepelio</h6>
                    <div class="row g-4">
                        <div class="col-md-4 text-center text-md-start">
                            <label class="text-muted small d-block mb-1">Programación</label>
                            <span class="d-block fw-bold small text-primary"><i class="fa-regular fa-calendar-check me-1"></i> <span id="resBurialDateTime">---</span></span>
                        </div>
                        <div class="col-md-4 text-center text-md-start border-start border-end">
                            <label class="text-muted small d-block mb-1">Velatorio</label>
                            <span class="d-block fw-bold small"><i class="fa-solid fa-house-chimney-window me-1"></i> <span id="resWakePlace">---</span></span>
                        </div>
                        <div class="col-md-4 text-center text-md-start">
                            <label class="text-muted small d-block mb-1">Destino Final</label>
                            <span class="d-block fw-bold small"><i class="fa-solid fa-monument me-1"></i> <span id="resCemetery">---</span></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3 text-uppercase small text-primary"><i class="fa-solid fa-receipt me-2"></i>Servicios y Logística Seleccionada</h6>
                    <div id="resServicesTable">
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-5">
                <button class="btn btn-link text-muted text-decoration-none" onclick="loadStep(4)">
                    <i class="fa-solid fa-chevron-left me-1"></i> Regresar al Catálogo
                </button>
                <button class="btn btn-primary px-5 rounded-pill py-3 fw-bold shadow-lg" onclick="saveFinalContract()">
                    <i class="fa-solid fa-check-double me-2"></i> CONFIRMAR REGISTRO FINAL
                </button>
            </div>
        </div>
    </div>
</div>