<div class="animate__animated animate__fadeIn">
    <div class="mb-4">
        <h5 class="fw-bold text-primary"><i class="fa-solid fa-box-open me-2"></i> Selección de Servicios Logísticos</h5>
        <p class="text-muted small">Seleccione los elementos necesarios para el servicio funerario.</p>
    </div>

    <div class="row g-4">

        <div class="col-md-8">
            <ul class="nav nav-pills nav-fill gap-2 p-1 small bg-light rounded-pill mb-4" id="pills-tab">
                <li class="nav-item">
                    <button class="nav-link active rounded-pill" onclick="renderCatalog('Ataúdes')">Ataúdes / Urnas</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link rounded-pill" onclick="renderCatalog('Movilidad')">Movilidad</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link rounded-pill" onclick="renderCatalog('Adicionales')">Adicionales</button>
                </li>
            </ul>

            <div id="catalogContainer" class="row g-3">
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden sticky-top" style="top: 20px; z-index: 10;">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0 text-primary">
                        <i class="fa-solid fa-cart-shopping me-2"></i> Mi Selección
                    </h6>
                </div>

                <div class="card-body">
                    <div id="selectedServicesList" style="max-height: 400px; overflow-y: auto;">
                        <div class="text-center text-muted py-5 small" id="emptyCartMsg">
                            No hay servicios seleccionados.
                        </div>
                    </div>

                    <div class="border-top mt-3 pt-3">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="fw-bold small text-muted">Total Estimado:</span>
                            <span class="fw-bold text-primary h5 mb-0" id="totalAmountDisplay">S/ 0.00</span>
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary rounded-pill py-2 fw-bold" onclick="nextStep(5, validateStep4)">
                                Continuar al Resumen <i class="fa-solid fa-arrow-right ms-2"></i>
                            </button>
                            <button class="btn btn-link text-muted btn-sm" onclick="loadStep(3)">
                                Anterior
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>