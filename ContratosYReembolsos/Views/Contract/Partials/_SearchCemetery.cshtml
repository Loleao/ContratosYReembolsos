<div class="modal-content border-0 shadow-lg animate__animated animate__fadeInUp">
    <div class="modal-header bg-primary text-white py-3">
        <h5 class="modal-title fw-bold">
            <i class="fa-solid fa-place-of-worship me-2"></i> Buscar Cementerio
        </h5>
        <button type="button" class="btn-close btn-close-white" onclick="closeSearchModal()"></button>
    </div>

    <div class="modal-body p-4">
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <label class="small fw-bold text-muted">DEPARTAMENTO</label>
                <select id="CemFilterRegion" class="form-select rounded-pill" onchange="loadCemProvinces()">
                    <option value="">Seleccione...</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="small fw-bold text-muted">PROVINCIA</label>
                <select id="CemFilterProvince" class="form-select rounded-pill" onchange="loadCemDistricts()" disabled>
                    <option value="">Seleccione...</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="small fw-bold text-muted">DISTRITO</label>
                <div class="input-group">
                    <select id="CemFilterDistrict" class="form-select rounded-pill-start" disabled>
                        <option value="">Seleccione...</option>
                    </select>
                    <button class="btn btn-primary rounded-pill-end" onclick="executeCemeterySearch()">
                        <i class="fa-solid fa-search"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="table-responsive rounded-4 border shadow-sm" style="max-height: 350px;">
            <table class="table table-hover mb-0">
                <thead class="bg-light sticky-top">
                    <tr>
                        <th class="border-0">RUC</th>
                        <th class="border-0">Nombre del Cementerio</th>
                        <th class="border-0 text-end">Acción</th>
                    </tr>
                </thead>
                <tbody id="resultsCemeteryTableBody">
                    <tr><td colspan="3" class="text-center py-4 text-muted">Use los filtros para buscar un cementerio.</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>