<div class="animate__animated animate__fadeIn">
    <h4 class="text-primary fw-bold mb-4">
        <i class="fa-solid fa-file-invoice me-2"></i> Paso 2: Datos del Fallecido
    </h4>

    <div class="row g-4">
        @* Bloque de Selección de Tipo *@
        <div class="col-md-6">
            <label class="form-label fw-bold text-muted small text-uppercase">Condición del Fallecido</label>
            <div class="input-group">
                <span class="input-group-text bg-white border-2 border-end-0 rounded-start-pill text-primary">
                    <i class="fa-solid fa-id-card-clip"></i>
                </span>
                <select id="DeceasedType" class="form-select border-2 border-start-0 rounded-end-pill" onchange="handleDeceasedTypeChange()">
                    <option value="">Seleccione...</option>
                    <option value="Titular">Titular (Efectivo Policial)</option>
                    <option value="Beneficiario">Beneficiario (Familiar / Carga)</option>
                </select>
            </div>
            @* Alerta de restricción mejorada *@
            <div id="alertRestriction" class="alert alert-primary mt-2 py-2 rounded-4 d-none animate__animated animate__headShake" style="font-size: 0.85rem;">
                <i class="fa-solid fa-circle-info me-2"></i>
                Usted es el <b>Titular Solicitante</b>, seleccione al familiar fallecido.
            </div>
        </div>

        <div class="col-md-6"></div> @* Espaciador para equilibrio visual *@

        @* Bloque de Datos de Identidad *@
        <div class="col-md-3">
            <label class="form-label fw-bold text-muted small text-uppercase">DNI del Difunto</label>
            <div class="input-group shadow-sm rounded-pill overflow-hidden">
                <input type="text" id="DeceasedDni" class="form-control border-2 border-end-0 bg-light" placeholder="00000000" readonly>
                <button class="btn btn-primary px-4 border-2 border-start-0" type="button" id="btnLupaDeceased" onclick="openSearchBeneficiaries()">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
            </div>
        </div>

        <div class="col-md-9">
            <label class="form-label fw-bold text-muted small text-uppercase">Apellidos y Nombres Completos</label>
            <div class="input-group shadow-sm rounded-pill overflow-hidden">
                <span class="input-group-text bg-light border-2 border-end-0 text-muted">
                    <i class="fa-solid fa-user"></i>
                </span>
                <input type="text" id="DeceasedName" class="form-control form-control-lg border-2 border-start-0 bg-light" placeholder="Datos cargados desde el buscador..." readonly>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @* Bloque de Cronología *@
        <div class="row g-4 mt-2">
            @* Fecha Fallecimiento *@
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">
                    <i class="fa-solid fa-calendar-xmark me-1"></i> Fecha de Fallecimiento
                </label>
                <div class="input-group shadow-sm rounded-pill overflow-hidden">
                    <input type="date" id="DeathDate" class="form-control border-2 py-2"
                           onchange="validateDatesInline()">
                </div>
            </div>

            @* Fecha Sepelio *@
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">
                    <i class="fa-solid fa-calendar-check me-1"></i> Fecha de Sepelio (Programada)
                </label>
                <div class="input-group shadow-sm rounded-pill overflow-hidden">
                    <input type="date" id="BurialDate" class="form-control border-2 py-2"
                           onchange="validateDatesInline()">
                </div>
            </div>

            @* Hora Sepelio *@
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">
                    <i class="fa-solid fa-clock me-1"></i> Hora del Sepelio
                </label>
                <div class="input-group shadow-sm rounded-pill overflow-hidden">
                    <span class="input-group-text bg-white border-2 border-end-0">
                        <i class="fa-solid fa-clock text-primary"></i>
                    </span>
                    <select id="BurialTime" class="form-select border-2 border-start-0 py-2" style="cursor: pointer;">
                        <option value="">Seleccione hora...</option>
                        <optgroup label="Mañana">
                            <option value="08:00">08:00 AM</option>
                            <option value="09:00">09:00 AM</option>
                            <option value="10:00">10:00 AM</option>
                            <option value="11:00">11:00 AM</option>
                        </optgroup>
                        <optgroup label="Tarde">
                            <option value="12:00">12:00 PM</option>
                            <option value="13:00">01:00 PM</option>
                            <option value="14:00">02:00 PM</option>
                            <option value="15:00">03:00 PM</option>
                            <option value="16:00">04:00 PM</option>
                            <option value="17:00">05:00 PM</option>
                            <option value="18:00">06:00 PM</option>
                        </optgroup>
                        <optgroup label="Noche (Casos Especiales)">
                            <option value="19:00">07:00 PM</option>
                            <option value="20:00">08:00 PM</option>
                        </optgroup>
                    </select>
                </div>
            </div>
        </div>

        @* Mensaje de error dinámico mejorado *@
        <div id="dateErrorMessage" class="alert alert-danger py-2 px-3 rounded-4 mt-3 d-none animate__animated animate__shakeX" style="font-size: 0.85rem;">
            <i class="fa-solid fa-circle-exclamation me-2"></i>
            <span id="dateErrorText"></span>
        </div>

        <div class="col-md-12">
            <hr class="text-muted opacity-25 my-4">
            <h6 class="text-primary fw-bold mb-3">
                <i class="fa-solid fa-location-dot me-2"></i> LUGAR DEL FALLECIMIENTO
            </h6>
            <div class="row g-3">
                @* Departamento *@
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase">Departamento</label>
                    <div class="input-group shadow-sm rounded-pill overflow-hidden">
                        <span class="input-group-text bg-white border-2 border-end-0"><i class="fa-solid fa-map text-primary opacity-50"></i></span>
                        <select id="DeathDept" class="form-select border-2 border-start-0 py-2" onchange="loadProvinces()">
                            <option value="">Seleccione...</option>
                        </select>
                    </div>
                </div>

                @* Provincia *@
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase">Provincia</label>
                    <div class="input-group shadow-sm rounded-pill overflow-hidden">
                        <span class="input-group-text bg-white border-2 border-end-0"><i class="fa-solid fa-map-location-dot text-primary opacity-50"></i></span>
                        <select id="DeathProv" class="form-select border-2 border-start-0 py-2" onchange="loadDistricts()" disabled>
                            <option value="">Seleccione Dept...</option>
                        </select>
                    </div>
                </div>

                @* Distrito *@
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase">Distrito</label>
                    <div class="input-group shadow-sm rounded-pill overflow-hidden">
                        <span class="input-group-text bg-white border-2 border-end-0"><i class="fa-solid fa-location-crosshairs text-primary opacity-50"></i></span>
                        <select id="DeathDist" class="form-select border-2 border-start-0 py-2" disabled>
                            <option value="">Seleccione Prov...</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-12 mt-4 d-none" id="sectionWakePlace">
            <label class="form-label fw-bold text-muted small text-uppercase">Lugar de Velatorio</label>
            <div class="input-group">
                <span class="input-group-text bg-white border-2 border-end-0 rounded-start-pill text-primary">
                    <i class="fa-solid fa-house-chimney-window"></i>
                </span>
                <select id="WakePlace" class="form-select form-select-lg border-2 border-start-0 rounded-end-pill">
                    <option value="">Cargando locales...</option>
                </select>
            </div>
        </div>

        <div class="col-md-12 mt-3">
            <label class="form-label fw-bold small text-muted text-uppercase">Tipo de Sepultura</label>
            <div class="d-flex gap-3">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="BurialType" id="typePabellon" value="Pabellon" checked onchange="resetNicheSelection()">
                    <label class="form-check-label" for="typePabellon text-primary">En Pabellón</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="BurialType" id="typeCremacion" value="Columbario" onchange="resetNicheSelection()">
                    <label class="form-check-label" for="typeCremacion text-info">Cremación (Columbario)</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="BurialType" id="typeTumba" value="Tumba" onchange="resetNicheSelection()">
                    <label class="form-check-label fw-bold" for="typeTumba">En Tierra (Tumbas)</label>
                </div>
            </div>
        </div>


        <div class="col-md-12 mt-4">
            <label class="form-label fw-bold text-muted small text-uppercase">Cementerio de Destino</label>
            <div class="input-group shadow-sm rounded-pill overflow-hidden">
                <span class="input-group-text bg-white border-2 border-end-0 text-primary">
                    <i class="fa-solid fa-monument"></i>
                </span>
                <input type="text" id="CemeteryName" class="form-control border-2 border-start-0 bg-light" readonly placeholder="Seleccione un cementerio...">
                <button class="btn btn-primary px-4 border-2 border-start-0" type="button" onclick="openSearchCemetery()">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
            </div>
        </div>

        <div id="sectionSpecificLocation" class="col-md-12 mt-3 d-none animate__animated animate__fadeIn">
            <div class="card border-primary border-opacity-25 bg-primary bg-opacity-10 rounded-4">
                <div class="card-body p-3 text-center">
                    <h6 class="fw-bold text-primary mb-2">UBICACIÓN EN CEMENTERIO GENERAL</h6>
                    <div id="selectedNicheDisplay" class="mb-3 d-none">
                        <span class="badge bg-primary fs-6 rounded-pill px-3 py-2">
                            <i class="fa-solid fa-location-dot me-2"></i>
                            <span id="txtNicheSelected">Ninguno</span>
                        </span>
                    </div>
                    <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm" onclick="openNicheSelector()">
                        <i class="fa-solid fa-th me-2"></i> Elegir Lugar en el Mapa
                    </button>
                    <input type="hidden" id="BurialNicheId">
                </div>
            </div>
        </div>


    </div>

    <div class="d-flex justify-content-between mt-5">
        <button type="button" class="btn btn-outline-secondary rounded-pill px-5" onclick="loadStep(1)">
            <i class="fa-solid fa-arrow-left me-2"></i> Atrás
        </button>
        <button type="button" class="btn btn-primary rounded-pill px-5 shadow" onclick="nextStep(3, validateStep2)">
            Siguiente <i class="fa-solid fa-arrow-right ms-2"></i>
        </button>
    </div>
</div>