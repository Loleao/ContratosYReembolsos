<div class="animate__animated animate__fadeIn">
    <h5 class="fw-bold mb-4 text-primary"><i class="fa-solid fa-file-invoice-dollar me-2"></i>Paso 3: Ficha de Resumen de Regularización</h5>
    <div class="row g-4">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-dark text-white py-3"><h6 class="mb-0 fw-bold small text-uppercase"><i class="fa-solid fa-user-shield me-2"></i>Responsable del Trámite</h6></div>
                <div class="card-body p-3 bg-light bg-opacity-20">
                    <div class="row"><div class="col-6"><small class="text-muted d-block">Apellidos y Nombres</small><b id="resSolicitorName" class="text-dark">---</b></div><div class="col-3"><small class="text-muted d-block">DNI</small><span id="resSolicitorDni" class="font-monospace">---</span></div><div class="col-3"><small class="text-muted d-block">Tipo</small><span id="resSolicitorType" class="badge bg-secondary">---</span></div></div>
                </div>
            </div>
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white py-3"><h6 class="mb-0 fw-bold small text-uppercase"><i class="fa-solid fa-user-plus me-2"></i>Datos del Cuerpo Ingresado</h6></div>
                <div class="card-body p-3 bg-light bg-opacity-20">
                    <div class="row mb-3"><div class="col-8"><small class="text-muted d-block">Fallecido</small><h5 id="resDeceasedName" class="fw-bold text-primary mb-0">---</h5></div><div class="col-4"><small class="text-muted d-block">DNI Difunto</small><b id="resDeceasedDni" class="font-monospace">---</b></div></div>
                    <div class="row"><div class="col-6"><small class="text-muted d-block">Fecha Sepelio Sede</small><span id="resBurialDate" class="fw-bold">---</span></div></div>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 border-start border-5 border-success">
                <div class="card-body p-4">
                    <small class="text-muted d-block fw-bold text-uppercase x-small mb-1">Destino Físico Final</small>
                    <h5 id="resCemetery" class="fw-bold text-success mb-1">---</h5>
                    <p id="resLocation" class="font-monospace text-dark fw-bold mb-0">---</p>
                </div>
            </div>
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-light bg-opacity-50">
                <label class="form-label x-small fw-bold text-muted text-uppercase">Notas Consolidadas</label>
                <p id="resObservations" class="small italic text-muted mb-0" style="font-size:0.75rem;">---</p>
            </div>
        </div>
    </div>
</div>