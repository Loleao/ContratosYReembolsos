<div class="modal-content border-0 shadow-lg animate__animated animate__zoomIn">
    <div class="modal-header bg-dark text-white">
        <h5 class="modal-title fw-bold"><i class="fa-solid fa-map me-2"></i> SELECTOR DE UBICACIÓN</h5>
        <button type="button" class="btn-close btn-close-white" onclick="closeSearchModal()"></button>
    </div>
    <div class="modal-body p-4 bg-light">
        <div class="row justify-content-center mb-4">
            <div class="col-md-6">
                <label class="small fw-bold text-muted text-center d-block mb-2">SELECCIONE EL PABELLÓN</label>
                <select id="cboPavilion" class="form-select rounded-pill border-primary shadow-sm" onchange="changePavilion()">
                    <option value="">Cargando pabellones...</option>
                </select>
            </div>
        </div>

        <div id="nicheMapsContainer" class="d-none">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="bg-white p-3 rounded-4 shadow-sm border">
                        <h6 class="text-center fw-bold text-muted mb-3">CARA 1 (FRONTAL)</h6>
                        <div class="niche-grid" id="gridCara1"></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="bg-white p-3 rounded-4 shadow-sm border">
                        <h6 class="text-center fw-bold text-muted mb-3">CARA 2 (POSTERIOR)</h6>
                        <div class="niche-grid" id="gridCara2"></div>
                    </div>
                </div>
            </div>
        </div>

        <div id="nicheLoader" class="text-center py-5 d-none">
            <i class="fas fa-spinner fa-spin fa-2x text-primary"></i>
            <p>Cargando mapa del pabellón...</p>
        </div>
    </div>
</div>