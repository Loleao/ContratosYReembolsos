@model ContratosYReembolsos.Models.Entities.Inventory.ProductCategory
@{
    ViewData["Title"] = "Subcategorías - " + Model.Name;
}

<div class="container-fluid py-4 animate__animated animate__fadeIn">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-white p-2 rounded-pill shadow-sm border px-4">
            <li class="breadcrumb-item"><a href="@Url.Action("Categories")" class="text-decoration-none">Categorías</a></li>
            <li class="breadcrumb-item active fw-bold text-primary">@Model.Name</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold m-0">Familias en <span class="text-primary">@Model.Name</span></h4>
            <p class="text-muted small mb-0">Detalle de subcategorías habilitadas para esta línea.</p>
        </div>
        <button class="btn btn-dark rounded-pill px-4 shadow-sm" onclick="openSubcategoryModal(0)">
            <i class="fa-solid fa-plus me-1"></i> Nueva Subcategoría
        </button>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Nombre de Subcategoría</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in Model.SubCategories.OrderBy(x => x.Name))
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">@sub.Name</td>
                            <td class="text-center">
                                @if (sub.ShowInContracts)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3">Activo</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-light text-muted border px-3">Inactivo</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary rounded-circle"
                                        onclick="openSubcategoryModal(@sub.Id)">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        async function openSubcategoryModal(id) {
            Swal.fire({ title: 'Cargando...', didOpen: () => { Swal.showLoading() } });
            try {
                // Enviamos el categoryId actual para que el formulario sepa a quién pertenece
                const response = await fetch(`@Url.Action("GetSubcategoryForm")?categoryId=@Model.Id&id=${id}`);
                const html = await response.text();
                document.getElementById('modalContainer').innerHTML = html;
                Swal.close();
                new bootstrap.Modal(document.getElementById('modalSubcategoryContainer')).show();
            } catch (e) { Swal.fire('Error', 'No se pudo cargar el formulario', 'error'); }
        }

        $(document).on('submit', '#formSubcategorySave', async function(e) {
            e.preventDefault();
            const $btn = $(this).find('button[type="submit"]');
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

            const resp = await fetch('@Url.Action("SaveSubcategory")', {
                method: 'POST',
                body: new FormData(this)
            });
            const res = await resp.json();
            if(res.success) {
                Swal.fire('Guardado', res.message, 'success').then(() => location.reload());
            } else {
                Swal.fire('Error', res.message, 'error');
                $btn.prop('disabled', false).text('Guardar');
            }
        });
    </script>
}