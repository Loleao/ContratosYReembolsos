@model IEnumerable<ContratosYReembolsos.Models.ProductSubcategory>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold m-0">Subcategorías</h3>
            <p class="text-muted small">Gestión granular de familias de productos por línea de negocio.</p>
        </div>
        <button class="btn btn-primary shadow-sm rounded-pill px-4" onclick="openSubcategoryModal(0)">
            <i class="fa-solid fa-plus me-2"></i>Nueva Subcategoría
        </button>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Subcategoría</th>
                        <th>Categoría Padre</th>
                        <th class="text-center">Estado Contratos</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@item.Name</span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border fw-normal px-3 py-2">
                                    <i class="fa-solid fa-layer-group me-1 text-primary"></i>
                                    @item.Category?.Name
                                </span>
                            </td>
                            <td class="text-center">
                                @if (item.ShowInContracts)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3">
                                        <i class="fa-solid fa-check me-1"></i>Habilitado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary-subtle px-3">
                                        <i class="fa-solid fa-ban me-1"></i>Deshabilitado
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                        onclick="openSubcategoryModal(@item.Id)">
                                    <i class="fa-solid fa-pen-to-square me-1"></i>Editar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        async function openSubcategoryModal(id) {
            const response = await fetch(`@Url.Action("GetCreateSubcategory")?id=${id}`);
            document.getElementById('modalContainer').innerHTML = await response.text();
            new bootstrap.Modal(document.getElementById('modalSubcategoryContainer')).show();
        }

        $(document).on('submit', '#formSubcategorySave', async function(e) {
            e.preventDefault();
            const $btn = $(this).find('button[type="submit"]');
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

            try {
                const response = await fetch('@Url.Action("SaveSubcategory")', {
                    method: 'POST',
                    body: new FormData(this)
                });
                const res = await response.json();
                if(res.success) {
                    location.reload();
                } else {
                    Swal.fire('Error', res.message, 'error');
                    $btn.prop('disabled', false).text('Guardar Subcategoría');
                }
            } catch (err) {
                Swal.fire('Error', 'Error de conexión.', 'error');
                $btn.prop('disabled', false).text('Guardar Subcategoría');
            }
        });
    </script>
}