        function validateDecimalRules(formId) {
            let isValid = true;
            $(`#${formId} tr`).each(function() {
                const $qtyInput = $(this).find('input[type="number"]');
                const step = $qtyInput.attr('step');
                const val = parseFloat($qtyInput.val());

                if (step === "1" && val % 1 !== 0) {
                    const prodName = $(this).find('select option:selected').text();
                    Swal.fire('Cantidad Inválida', `El producto "${prodName}" se mide en UNIDADES y no acepta decimales.`, 'error');
                    isValid = false;
                    return false;
                }
            });
            return isValid;
        }

