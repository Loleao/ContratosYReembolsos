@using ContratosYReembolsos.Models.Entities.Branches
@using Microsoft.AspNetCore.Authorization
@model IEnumerable<IGrouping<string, Branch>>
@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Gestión de Inventarios - Sedes";
}

<style>
    .select2-container--bootstrap-5 .select2-selection {
        height: 38px !important;
        display: flex !important;
        align-items: center !important;
    }

    .branch-card-inventory {
        transition: all 0.3s ease;
        border: 1px solid #e2e8f0;
        border-radius: 15px;
        background: white;
    }

        .branch-card-inventory:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
            border-color: #004a99;
        }

    .icon-box-inventory {
        width: 50px;
        height: 50px;
        background: #e0eefe;
        color: #004a99;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .search-pill {
        background: #f1f4f8;
        border-radius: 50px;
        padding: 12px 25px;
        border: 1px solid transparent;
        width: 100%;
        transition: 0.3s;
    }

        .search-pill:focus {
            outline: none;
            background: white;
            border-color: #004a99;
            box-shadow: 0 0 0 4px rgba(0, 74, 153, 0.1);
        }
</style>

<div class="container py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Supervisión de Inventarios</h3>
            <p class="text-muted small mb-0">Suministros y recursos logísticos <span class="text-primary fw-bold">FONAFUN</span>.</p>
        </div>

        <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
            @* Solo mostrar Ingreso si tiene el Claim Permissions.Inventario.Ingreso *@
            @if ((await AuthorizationService.AuthorizeAsync(User, "Permissions.Inventario.Ingreso")).Succeeded)
            {
                <button class="btn btn-success px-4 fw-bold border-0" onclick="openEntryModal()">
                    <i class="fa-solid fa-plus-circle me-2"></i>Ingreso Central
                </button>
            }

            @* Solo mostrar Transferencia si tiene el Claim Permissions.Inventario.Transferencia *@
            @if ((await AuthorizationService.AuthorizeAsync(User, "Permissions.Inventario.Transferencia")).Succeeded)
            {
                <button class="btn btn-warning px-4 fw-bold text-dark border-0" onclick="openTransferModal()">
                    <i class="fa-solid fa-truck-fast me-2"></i>Transferir a Sede
                </button>
            }
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="top: 17px; left: 25px;"></i>
                <input type="text" id="inventoryBranchSearch" class="search-pill ps-5"
                       placeholder="Buscar filial por nombre, código o departamento...">
            </div>
        </div>
    </div>

    <div class="accordion border-0 shadow-none" id="accordionInventory">
        @foreach (var group in Model)
        {
            <div class="accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden region-group">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-bold py-3 px-4 bg-white text-dark" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapse-@group.Key.Replace(" ", "")">
                        <div class="d-flex align-items-center w-100">
                            <i class="fa-solid fa-map-location-dot me-3 text-primary fs-5"></i>
                            <span>@group.Key.ToUpper()</span>
                            <span class="badge bg-light text-primary border ms-auto me-3 rounded-pill fw-bold">@group.Count() Filiales</span>
                        </div>
                    </button>
                </h2>
                <div id="collapse-@group.Key.Replace(" ", "")" class="accordion-collapse collapse" data-bs-parent="#accordionInventory">
                    <div class="accordion-body p-4 bg-light bg-opacity-50">
                        <div class="row g-3">
                            @foreach (var branch in group)
                            {
                                <div class="col-xl-4 col-md-6 branch-item" data-search="@branch.Name @branch.Code @group.Key">
                                    <div class="card branch-card-inventory shadow-sm h-100">
                                        <div class="card-body p-3">
                                            <div class="d-flex align-items-start mb-3">
                                                <div class="icon-box-inventory me-3 flex-shrink-0">
                                                    <i class="fa-solid fa-warehouse fs-4"></i>
                                                </div>
                                                <div class="overflow-hidden">
                                                    <div class="d-flex align-items-center gap-2 mb-1">
                                                        <span class="badge bg-dark text-white" style="font-size: 0.65rem;">@branch.Code</span>
                                                    </div>
                                                    <h6 class="fw-bold text-dark mb-1 text-truncate">@branch.Name</h6>
                                                    <small class="text-muted text-truncate d-block" style="font-size: 0.75rem;">
                                                        <i class="fa-solid fa-location-dot me-1 text-danger opacity-75"></i>
                                                        @branch.Address
                                                    </small>
                                                </div>
                                            </div>
                                            <div class="d-grid">
                                                <a asp-action="Inventory" asp-route-branchId="@branch.Id"
                                                   class="btn btn-sm btn-primary rounded-pill fw-bold py-2 shadow-sm">
                                                    Gestionar Stock <i class="fa-solid fa-chevron-right ms-1"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div id="emptySearch" class="text-center py-5 d-none animate__animated animate__fadeIn">
        <i class="fa-solid fa-box-open fa-3x text-muted opacity-25 mb-3"></i>
        <h5 class="fw-bold text-dark">No se encontraron sedes</h5>
        <p class="text-muted">Intente con otro nombre de filial o región.</p>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        // --- MOTOR DE BÚSQUEDA INTELIGENTE ---
        $('#inventoryBranchSearch').on('input', function() {
            let term = $(this).val().toLowerCase().trim();
            let totalMatch = 0;

            $('.region-group').each(function() {
                let $region = $(this);
                let regionMatch = false;

                $region.find('.branch-item').each(function() {
                    if ($(this).data('search').toLowerCase().includes(term)) {
                        $(this).show();
                        regionMatch = true;
                        totalMatch++;
                    } else {
                        $(this).hide();
                    }
                });

                if (regionMatch) {
                    $region.show();
                    if (term.length > 1) {
                        $region.find('.accordion-collapse').addClass('show');
                        $region.find('.accordion-button').removeClass('collapsed');
                    }
                } else {
                    $region.hide();
                }
            });

            if (totalMatch === 0 && term.length > 0) $('#emptySearch').removeClass('d-none');
            else $('#emptySearch').addClass('d-none');
        });

        function expandAll() {
            $('.accordion-collapse').addClass('show');
            $('.accordion-button').removeClass('collapsed');
        }



        // 1. VARIABLES Y MAPEOS
        let globalStockProducts = [];
        let availableStock = [];
        let entryRowIndex = 0;
        let transferRowIndex = 0;

        const unitMap = { 0: "UND", 1: "LTS", 2: "MTS", 3: "KGS", 4: "GLN" };
        let productUnitRegistry = {};

        // 2. CARGA DE DATOS
        async function preloadProductData() {
            try {
                const res = await fetch('@Url.Action("GetProductData", "Inventory")');
                const data = await res.json();
                globalStockProducts = data.stock;
                globalAssetProducts = data.assets;

                // Mapear unidades para consulta rápida
                data.stock.forEach(p => productUnitRegistry[p.id] = p.unit);
            } catch (e) {
                console.error("Error cargando catálogos:", e);
            }
        }

        document.addEventListener("DOMContentLoaded", preloadProductData);

        // 3. BLOQUEO FÍSICO DE TECLAS PARA ENTEROS
        $(document).on('keydown', 'input[data-type="int"]', function (e) {
            // Bloquear punto (190, 110) y coma (188)
            if (e.key === '.' || e.key === ',' || e.keyCode === 190 || e.keyCode === 110 || e.keyCode === 188) {
                e.preventDefault();
            }
        });

        $(document).on('input', 'input[name$=".Quantity"]', function () {
            const $input = $(this);
            if ($input.attr('data-type') === "int") {
                let val = $input.val();
                if (val.includes('.') || val.includes(',')) {
                    $input.val(val.replace(/[^0-9]/g, ''));
                }
            }
        });

        // 4. LÓGICA DE REGLAS DINÁMICAS (CORREGIDA)
        function applyQuantityRules(idx, productId, isTransfer = false) {
            const inputId = isTransfer ? `#qty-transfer-${idx}` : `#quantity-${idx}`;
            const labelId = isTransfer ? `#max-label-${idx}` : `#unit-label-${idx}`;
            const $input = $(inputId);
            const $label = $(labelId);

            let unitType = productUnitRegistry[productId];
            if (unitType === undefined && isTransfer) {
                const found = availableStock.find(s => s.productId == productId);
                unitType = found ? found.unit : 0;
            }

            if (unitType === 0 || unitType === undefined) {
                // --- MODO ENTERO (UND) ---
                // Sincronizamos min y step para evitar el error de aproximación
                $input.attr('step', '1').attr('min', '1').attr('data-type', 'int');

                let val = parseFloat($input.val());
                if (isNaN(val) || val < 1) {
                    $input.val(1);
                } else if (val % 1 !== 0) {
                    $input.val(Math.floor(val));
                }
            } else {
                // --- MODO DECIMAL (LTS, MTS...) ---
                $input.attr('step', '0.01').attr('min', '0.01').attr('data-type', 'decimal');
            }

            const unitName = unitMap[unitType] || "UND";
            if (isTransfer) {
                const currentText = $label.text().split(' ')[1] || "-";
                $label.text(`/ ${currentText} ${unitName}`);
            } else {
                $label.text(unitName);
            }
        }

        // 5. INGRESO CENTRAL
        async function openEntryModal() {
            const res = await fetch('@Url.Action("GetStockEntry", "Inventory")');
            document.getElementById('modalContainer').innerHTML = await res.text();
            entryRowIndex = 0;
            addNewEntryRow();
            new bootstrap.Modal(document.getElementById('modalStockEntryContainer')).show();
        }

        function addNewEntryRow() {
            const idx = entryRowIndex;
            const stockOptions = globalStockProducts.map(p => `<option value="${p.id}">${p.name}</option>`).join('');

            const html = `
                <tr id="row-entry-${idx}" class="animate__animated animate__fadeIn">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 38px; border: 1px solid #dee2e6;">
                                <i class="fa-solid fa-box text-muted"></i>
                            </div>
                            <div style="flex-grow: 1; min-width: 0;"> @* min-width evita que el texto largo empuje la tabla *@
                                <select name="Items[${idx}].ProductId" class="form-select select-product-entry" data-idx="${idx}" required>
                                    <option value="">-- Seleccione Producto --</option>
                                    ${stockOptions}
                                </select>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="input-group input-group-sm">
                            <input type="number" name="Items[${idx}].Quantity" id="quantity-${idx}"
                                   class="form-control text-center fw-bold" value="1" min="0.01" step="0.01" required />
                            <span class="input-group-text x-small bg-light" id="unit-label-${idx}">-</span>
                        </div>
                    </td>
                    <td class="text-center">
                        <button type="button" onclick="removeEntryRow(${idx})" class="btn btn-link text-danger p-0">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>`;

            $('#bulkEntryTableBody').append(html);

            $(`#row-entry-${idx} .select-product-entry`).select2({
                theme: 'bootstrap-5',
                dropdownParent: $('#modalStockEntryContainer'),
                width: '100%'
            });

            entryRowIndex++;
        }

        $(document).on('change', '.select-product-entry', function() {
            applyQuantityRules($(this).data('idx'), $(this).val(), false);
        });

        function toggleRowType(idx, isAsset) {
            const assetBool = isAsset === 'true';
            const $qtyInput = $(`#quantity-${idx}`);
            const $serial = $(`#serial-${idx}`);
            const $stockWrapper = $(`#wrapper-stock-${idx}`);
            const $assetWrapper = $(`#wrapper-asset-${idx}`);

            $stockWrapper.toggle(!assetBool);
            $assetWrapper.toggle(assetBool);

            if (assetBool) {
                $qtyInput.val(1).prop('readonly', true).addClass('bg-light text-muted').attr('data-type', 'int').attr('step', '1').attr('min', '1');
                $serial.prop('disabled', false).removeClass('bg-light').addClass('border-warning').prop('required', true);
                $stockWrapper.find('select').prop('disabled', true);
                $assetWrapper.find('select').prop('disabled', false).prop('required', true);
                $(`#unit-label-${idx}`).text('UND');
            } else {
                $qtyInput.prop('readonly', false).removeClass('bg-light text-muted');
                $serial.prop('disabled', true).addClass('bg-light').removeClass('border-warning').val('').prop('required', false);
                $stockWrapper.find('select').prop('disabled', false).prop('required', true);
                $assetWrapper.find('select').prop('disabled', true);
                applyQuantityRules(idx, $stockWrapper.find('select').val(), false);
            }
        }

        // 6. TRASLADOS
        async function openTransferModal() {
            const res = await fetch('@Url.Action("GetProductTransfer", "Inventory")');
            document.getElementById('modalContainer').innerHTML = await res.text();
            transferRowIndex = 0;
            const originId = $('#select-origin-branch').val();
            if (originId) onOriginBranchChange(originId);
            new bootstrap.Modal(document.getElementById('modalTransferContainer')).show();
        }

        async function onOriginBranchChange(branchId) {
            if (!branchId) return;
            $('#btn-add-row').prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
            try {
                const res = await fetch(`@Url.Action("GetAvailableItemsByBranch", "Inventory")?branchId=${branchId}`);
                const data = await res.json();
                availableStock = data.stock;
                availableAssets = data.assets;
                $('#transferTableBody').empty();
                transferRowIndex = 0;
                $('#btn-add-row').prop('disabled', false).html('<i class="fa-solid fa-plus me-1"></i> Agregar');
                addTransferRow();
            } catch (e) { console.error(e); }
        }

        function addTransferRow() {
            const idx = transferRowIndex;
            const stockOptions = availableStock.map(s => `<option value="${s.productId}" data-max="${s.quantity}">${s.name}</option>`).join('');

            const html = `
                <tr id="row-transfer-${idx}" class="animate__animated animate__fadeIn">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="bg-light rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width: 35px; height: 38px; border: 1px solid #dee2e6;">
                                <i class="fa-solid fa-truck-moving text-muted"></i>
                            </div>
                            <div style="flex-grow: 1; min-width: 0;">
                                <select name="Items[${idx}].ProductId" class="form-select form-select-sm select-product-transfer shadow-sm" data-idx="${idx}" required>
                                    <option value="">-- Seleccione Producto --</option>
                                    ${stockOptions}
                                </select>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="input-group input-group-sm">
                            <input type="number" name="Items[${idx}].Quantity" id="qty-transfer-${idx}"
                                   class="form-control text-center fw-bold" value="1" min="0.01" step="0.01" required />
                            <span class="input-group-text x-small bg-white" id="max-label-${idx}">/ -</span>
                        </div>
                    </td>
                    <td class="text-center">
                        <button type="button" onclick="removeTransferRow(${idx})" class="btn btn-link text-danger p-0">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>`;

            $('#transferTableBody').append(html);

            // Inicializar Select2 con el ancho al 100% del contenedor flexible
            $(`#row-transfer-${idx} .select-product-transfer`).select2({
                theme: 'bootstrap-5',
                dropdownParent: $('#modalTransferContainer'),
                width: '100%'
            });

            transferRowIndex++;
        }

        $(document).on('change', '.select-product-transfer', function() {
            const idx = $(this).data('idx');
            updateMaxQty(idx, this);
            applyQuantityRules(idx, $(this).val(), true);
        });

        function toggleTransferRowType(idx, isAsset) {
            const assetBool = isAsset === 'true';
            const $stockWrapper = $(`#wrapper-t-stock-${idx}`);
            const $assetWrapper = $(`#wrapper-t-asset-${idx}`);
            const $stockSelect = $stockWrapper.find('select');
            const $assetSelect = $assetWrapper.find('select');
            const $qty = $(`#qty-transfer-${idx}`);

            // Alternar visibilidad
            $stockWrapper.toggle(!assetBool);
            $assetWrapper.toggle(assetBool);

            if (assetBool) {
                // --- MODO ACTIVO ---
                // Deshabilitamos Stock para que no interfiera en la validación ni en el envío
                $stockSelect.prop('disabled', true).prop('required', false);

                // Habilitamos Activo
                $assetSelect.prop('disabled', false).prop('required', true);

                // Reglas de cantidad para activos (siempre 1)
                $qty.val(1).prop('readonly', true).attr('data-type', 'int').attr('step', '1').attr('min', '1');
                $(`#max-label-${idx}`).text('/ 1 UND');
            } else {
                // --- MODO MERCADERÍA ---
                // Habilitamos Stock
                $stockSelect.prop('disabled', false).prop('required', true);

                // Deshabilitamos Activo
                $assetSelect.prop('disabled', true).prop('required', false);

                // Restauramos cantidad
                $qty.prop('readonly', false);

                // Disparamos el cambio para actualizar reglas de unidad y max cantidad
                updateMaxQty(idx, $stockSelect);
                applyQuantityRules(idx, $stockSelect.val(), true);
            }
        }

        // 7. SUBMITS Y HELPERS
        $(document).on('submit', '#formBulkEntry', async function (e) {
            e.preventDefault();
            if (!validateDecimalRules('bulkEntryTableBody')) return;
            const $btn = $(this).find('button[type="submit"]');
            $btn.prop('disabled', true).html('Guardando...');
            try {
                const res = await fetch('@Url.Action("ProcessBulkEntry", "Inventory")', { method: 'POST', body: new FormData(this) });
                const result = await res.json();
                if (result.success) Swal.fire('Éxito', result.message, 'success').then(() => location.reload());
                else { Swal.fire('Error', result.message, 'error'); $btn.prop('disabled', false).text('CONFIRMAR'); }
            } catch (e) { $btn.prop('disabled', false).text('CONFIRMAR'); }
        });

        // 7.5 SUBMIT DE TRASLADOS (Faltante en tu código)
        $(document).on('submit', '#formProductTransfer', async function (e) {
            e.preventDefault();

            // Validar reglas de decimales antes de procesar
            if (!validateDecimalRules('transferTableBody')) return;

            const $btn = $(this).find('button[type="submit"]');
            const originBranchId = $('#select-origin-branch').val();
            const targetBranchId = $('select[name="TargetBranchId"]').val();

            if (originBranchId === targetBranchId) {
                return Swal.fire('Atención', 'La sede de origen y destino no pueden ser la misma.', 'warning');
            }

            // 1. Recolectar Items de la tabla dinámica
            let items = [];
            $('#transferTableBody tr').each(function () {
                const rowId = $(this).attr('id').replace('row-transfer-', '');
                const isAsset = $(this).find(`select[name*="IsAsset"]`).val() === 'true';

                const $stockSelect = $(this).find(`select[name*="ProductId"]`);
                const $assetSelect = $(this).find(`select[name*="FixedAssetId"]`);

                let pIdRaw = null;
                let faIdRaw = null;

                if (isAsset) {
                    faIdRaw = $assetSelect.val();
                    // Obtenemos el ProductId real desde el data-attribute del option seleccionado
                    pIdRaw = $assetSelect.find(':selected').data('productid');
                } else {
                    pIdRaw = $stockSelect.val();
                }

                // Importante: Usar parseFloat para capturar los decimales correctamente
                const item = {
                    isAsset: isAsset,
                    quantity: parseFloat($(this).find(`input[id="qty-transfer-${rowId}"]`).val()) || 0,
                    productId: pIdRaw ? parseInt(pIdRaw) : null,
                    fixedAssetId: isAsset && faIdRaw ? parseInt(faIdRaw) : null
                };

                if ((isAsset && !item.fixedAssetId) || (!isAsset && !item.productId)) return;
                items.push(item);
            });

            if (items.length === 0) {
                return Swal.fire('Atención', 'Debe agregar al menos un producto válido al traslado.', 'warning');
            }

            // 2. Preparar el objeto final para el Controller (JSON)
            const payload = {
                internalControlNumber: $('input[name="InternalControlNumber"]').val(),
                originBranchId: parseInt(originBranchId),
                targetBranchId: parseInt(targetBranchId),
                observation: $('textarea[name="Observation"]').val(),
                items: items
            };

            // 3. Enviar al Servidor vía POST JSON
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Procesando...');

            try {
                const response = await fetch('@Url.Action("ProcessTransfer", "Inventory")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        title: '¡Traslado Iniciado!',
                        text: result.message,
                        icon: 'success',
                        timer: 2500,
                        showConfirmButton: false
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error', result.message, 'error');
                    $btn.prop('disabled', false).html('<i class="fa-solid fa-truck-ramp-box me-2"></i>INICIAR TRASLADO');
                }
            } catch (error) {
                console.error(error);
                Swal.fire('Error', 'No se pudo conectar con el servidor.', 'error');
                $btn.prop('disabled', false).html('<i class="fa-solid fa-truck-ramp-box me-2"></i>INICIAR TRASLADO');
            }
        });

        function updateMaxQty(idx, select) {
            const max = $(select).find(':selected').data('max') || '-';
            $(`#max-label-${idx}`).text('/ ' + max);
            $(`#qty-transfer-${idx}`).attr('max', max);
        }

        function validateDecimalRules(tbodyId) {
            let isValid = true;
            $(`#${tbodyId} tr`).each(function() {
                const $qty = $(this).find('input[type="number"]');
                if ($qty.attr('step') === "1" && parseFloat($qty.val()) % 1 !== 0) {
                    Swal.fire('Atención', 'Este producto solo acepta unidades enteras.', 'warning');
                    isValid = false; return false;
                }
            });
            return isValid;
        }

        function removeEntryRow(idx) { $(`#row-entry-${idx}`).remove(); }

        function removeTransferRow(idx) { $(`#row-transfer-${idx}`).remove(); }
    </script>
}