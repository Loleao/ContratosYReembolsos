@model IEnumerable<ContratosYReembolsos.Models.Branch>

<div class="container py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark">Supervisión de Sedes</h3>
            <p class="text-muted small">Gestión global de recursos <span class="text-primary fw-bold">FONAFUN</span>.</p>
        </div>
        <div class="btn-group shadow-sm rounded-pill overflow-hidden">
            <button class="btn btn-success px-4 fw-bold" onclick="openEntryModal()">
                <i class="fa-solid fa-plus me-2"></i>Ingreso Central
            </button>
            <button class="btn btn-warning px-4 fw-bold text-dark" onclick="openTransferModal()">
                <i class="fa-solid fa-truck-fast me-2"></i>Transferir a Sede
            </button>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var branch in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-card border-top border-primary border-4 rounded-4">
                    <div class="card-body p-4 text-center">
                        <div class="bg-primary-subtle p-3 rounded-circle d-inline-block mb-3">
                            <i class="fa-solid fa-hotel text-primary fa-2xl"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">@branch.Name</h5>
                        <p class="small text-muted mb-4"><i class="fa-solid fa-map-pin me-2 text-danger"></i>@branch.Address</p>
                        <div class="d-grid gap-2">
                            <a asp-action="Inventory" asp-route-branchId="@branch.Id" class="btn btn-primary rounded-pill fw-bold">
                                <i class="fa-solid fa-warehouse me-2"></i>Gestionar Sede
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div id="modalContainer"></div>

