@using ContratosYReembolsos.Models.ViewModels
@model AssetDashboardViewModel

<div class="container-fluid py-4 animate__animated animate__fadeIn">
    @* Switch de Navegación *@
    <div class="text-center mb-4">
        <div class="btn-group p-1 bg-white border rounded-pill shadow-sm">
            <a asp-action="InventoryDashboard" class="btn btn-white rounded-pill px-4 fw-bold text-muted">Suministros</a>
            <a asp-action="AssetDashboard" class="btn btn-primary rounded-pill px-4 fw-bold">Activos Fijos</a>
        </div>
    </div>

    @* Filtros *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3 text-center">
            <form id="filterForm" method="get" class="d-flex justify-content-center gap-3 align-items-center">
                <select name="branchId" class="form-select border-2 rounded-pill shadow-none" style="max-width: 300px;" onchange="this.form.submit()">
                    <option value="">🌎 Distribución Global de Activos</option>
                    @foreach (var s in Model.Sedes)
                    {
                        <option value="@s.Id" selected="@(Model.SelectedBranchId == s.Id)">🏢 @s.Name</option>
                    }
                </select>
            </form>
        </div>
    </div>

    <div class="row">
        @* Gráfico de Estados *@
        <div class="col-md-5 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h6 class="fw-bold mb-4 text-uppercase text-muted small">Estado de la Flota</h6>
                    <div style="max-height: 280px;">
                        <canvas id="chartPieAssets"></canvas>
                    </div>
                </div>
            </div>
        </div>

        @* Tabla de Resumen *@
        <div class="col-md-7 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-primary text-white x-small text-uppercase">
                            <tr>
                                <th class="ps-4 py-3">Tipo de Activo</th>
                                <th class="text-center">Total</th>
                                <th class="text-center">Disp.</th>
                                <th class="text-center">Asig.</th>
                                <th class="text-center pe-4">Otros</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ResumenActivos)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold small">@item.ProductName</td>
                                    <td class="text-center">@item.Total</td>
                                    <td class="text-center text-success fw-bold">@item.Disponibles</td>
                                    <td class="text-center text-primary fw-bold">@item.Asignados</td>
                                    <td class="text-center text-muted pe-4">@item.EnMantenimiento</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const ctxPie = document.getElementById('chartPieAssets').getContext('2d');
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Model.EstadosLabelsJson),
                    datasets: [{
                        data: @Html.Raw(Model.EstadosValoresJson),
                        backgroundColor: ['#198754', '#0d6efd', '#ffc107', '#dc3545', '#6c757d'],
                        borderWidth: 0,
                        hoverOffset: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                    },
                    cutout: '70%'
                }
            });
        });
    </script>
}