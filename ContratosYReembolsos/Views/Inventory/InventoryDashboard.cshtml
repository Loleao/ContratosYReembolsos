@using ContratosYReembolsos.Models.ViewModels
@model InventoryDashboardViewModel

<div class="container-fluid py-4 animate__animated animate__fadeIn">
    @* Switch de Navegación *@
    <div class="text-center mb-4">
        <div class="btn-group p-1 bg-white border rounded-pill shadow-sm">
            <a asp-action="InventoryDashboard" class="btn btn-primary rounded-pill px-4 fw-bold">Suministros</a>
            <a asp-action="AssetDashboard" class="btn btn-white rounded-pill px-4 fw-bold text-muted">Activos Fijos</a>
        </div>
    </div>

    @* Filtros Inteligentes *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form id="filterForm" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label x-small fw-bold text-muted ps-2 text-uppercase">Periodo</label>
                    <div class="btn-group w-100 p-1 bg-light rounded-pill border">
                        @foreach (var p in new[] { "daily", "weekly", "monthly", "yearly" })
                        {
                            <input type="radio" class="btn-check" name="period" id="p_@p" value="@p" @(Model.SelectedPeriod == p ? "checked" : "") onchange="updateDateType(); this.form.submit()">
                            <label class="btn btn-outline-primary border-0 rounded-pill x-small fw-bold" for="p_@p">@p.Substring(0, 3).ToUpper()</label>
                        }
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label x-small fw-bold text-muted ps-2 text-uppercase">Fecha / Rango</label>
                    <div id="dateInputContainer"></div>
                </div>

                <div class="col-md-3">
                    <label class="form-label x-small fw-bold text-muted ps-2 text-uppercase">Sede</label>
                    <select name="branchId" class="form-select border-2 rounded-pill shadow-none" onchange="this.form.submit()">
                        <option value="">🌎 Global</option>
                        @foreach (var s in Model.Sedes)
                        {
                            <option value="@s.Id" selected="@(Model.SelectedBranchId == s.Id)">🏢 @s.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label x-small fw-bold text-muted ps-2 text-uppercase">Producto</label>
                    <select name="productId" class="form-select border-2 rounded-pill shadow-none" onchange="this.form.submit()">
                        <option value="">📦 Todos los productos</option>
                        @foreach (var p in Model.Productos)
                        {
                            <option value="@p.Id" selected="@(Model.SelectedProductId == p.Id)">@p.Name</option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    @* Gráfico *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold m-0"><i class="fa-solid fa-chart-line me-2 text-primary"></i>Flujo de Suministros</h6>
                <div class="d-flex gap-2">
                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">+ @Model.TotalIngreso Ingresos</span>
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3">- @Model.TotalConsumo Consumos</span>
                </div>
            </div>
            <div style="height: 320px;"><canvas id="chartInv"></canvas></div>
        </div>
    </div>

    @* Tabla Simplificada *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white x-small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Artículo / SKU</th>
                        <th class="text-center">Stock Inicial</th>
                        <th class="text-center text-success">Total Ingresos (+)</th>
                        <th class="text-center text-danger bg-light">Total Consumo (-)</th>
                        <th class="text-center pe-4">Stock Final</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.DetalleMovimientos.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted small italic">No hay movimientos registrados.</td></tr>
                    }
                    @foreach (var item in Model.DetalleMovimientos)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold small">@item.ProductName</div>
                                <div class="x-small text-muted">@item.Sku</div>
                            </td>
                            <td class="text-center small">@item.StockInicial</td>
                            <td class="text-center small text-success fw-bold">+@item.TotalIngresos</td>
                            <td class="text-center fw-bold text-danger bg-light">-@item.TotalConsumo</td>
                            <td class="text-center pe-4 fw-bold fs-6">@item.StockFinal</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function updateDateType() {
            const period = document.querySelector('input[name="period"]:checked').value;
            const container = document.getElementById('dateInputContainer');
            const val = "@Model.DateValue";

            let html = '';
            if (period === 'daily') html = `<input type="date" name="date" value="${val}" class="form-control border-2 rounded-pill shadow-none" onchange="this.form.submit()">`;
            else if (period === 'weekly') html = `<input type="week" name="date" value="${val}" class="form-control border-2 rounded-pill shadow-none" onchange="this.form.submit()">`;
            else if (period === 'monthly') html = `<input type="month" name="date" value="${val}" class="form-control border-2 rounded-pill shadow-none" onchange="this.form.submit()">`;
            else {
                const year = val.substring(0,4);
                html = `<select name="date" class="form-select border-2 rounded-pill shadow-none" onchange="this.form.submit()">`;
                for(let i=2024; i<=2030; i++) html += `<option value="${i}" ${i==year?'selected':''}>${i}</option>`;
                html += `</select>`;
            }
            container.innerHTML = html;
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateDateType();
            new Chart(document.getElementById('chartInv'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(Model.GraficoLabelsJson),
                    datasets: [
                        { label: 'Ingresos', data: @Html.Raw(Model.ValoresIngresoJson), borderColor: '#198754', tension: 0.4, fill: true, backgroundColor: 'rgba(25, 135, 84, 0.05)' },
                        { label: 'Consumos', data: @Html.Raw(Model.ValoresConsumoJson), borderColor: '#dc3545', tension: 0.4, fill: true, backgroundColor: 'rgba(220, 53, 69, 0.05)' }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });
        });
    </script>
}