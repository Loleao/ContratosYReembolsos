@using ContratosYReembolsos.Models.ViewModels
@model List<LineaConsumoViewModel>

<div class="container-fluid py-4 animate__animated animate__fadeIn">

    @* --- PANEL DE FILTROS --- *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form id="filterForm" method="get" class="row g-3 align-items-center">
                <div class="col-md-3">
                    <div class="btn-group w-100 p-1 bg-light rounded-pill border">
                        @foreach (var p in new[] { "daily", "weekly", "monthly", "yearly" })
                        {
                            <input type="radio" class="btn-check" name="period" id="p_@p" value="@p" @(ViewBag.Period == p ? "checked" : "") onchange="this.form.submit()">
                            <label class="btn btn-outline-primary border-0 rounded-pill x-small fw-bold" for="p_@p">
                                @(p == "daily" ? "Día" : p == "weekly" ? "Semana" : p == "monthly" ? "Mes" : "Año")
                            </label>
                        }
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="branchId" class="form-select border-2 rounded-pill shadow-none" onchange="this.form.submit()">
                        <option value="">🌎 Consumo Global</option>
                        @foreach (var s in ViewBag.Sedes)
                        {
                            <option value="@s.Id" selected="@(ViewBag.SelectedBranch == s.Id)">🏢 @s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" name="date" value="@ViewBag.RefDate" class="form-control border-2 rounded-pill shadow-none" onchange="this.form.submit()" />
                </div>
            </form>
        </div>
    </div>

    @* --- GRÁFICO --- *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold m-0 text-dark"><i class="fa-solid fa-chart-area text-primary me-2"></i>Curva de Consumo</h5>
            <span class="badge bg-danger-subtle text-danger rounded-pill px-3">
                Total Salidas: @ViewBag.SumaTotalConsumo unidades
            </span>
        </div>
        <div class="card-body p-4">
            <div style="height: 350px;">
                <canvas id="chartConsumo"></canvas>
            </div>
        </div>
    </div>

    @* --- TABLA --- *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white text-uppercase x-small">
                    <tr>
                        <th class="ps-4 py-3">Articulo</th>
                        <th class="text-center">S. Inicial</th>
                        <th class="text-center">Ingresos (+)</th>
                        <th class="text-center bg-primary-subtle text-primary">Consumo (-)</th>
                        <th class="text-center">Stock Final</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold small">@item.ProductName</div>
                                <div class="x-small text-muted">@item.Sku</div>
                            </td>
                            <td class="text-center small">@item.StockInicial</td>
                            <td class="text-center small text-success">
                                @(item.TotalCompras + (item.TotalTraslados > 0 ? item.TotalTraslados : 0))
                            </td>
                            <td class="text-center fw-bold text-danger bg-light">@item.TotalConsumo</td>
                            <td class="text-center pe-4 fw-bold fs-6">@item.StockFinal</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('chartConsumo').getContext('2d');
        const gradient = ctx.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(13, 110, 253, 0.4)');
        gradient.addColorStop(1, 'rgba(13, 110, 253, 0.0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(ViewBag.GraficoLabels),
                datasets: [{
                    data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GraficoValoresArray)),
                    borderColor: '#0d6efd',
                    backgroundColor: gradient,
                    fill: true,
                    tension: 0.3,
                    pointRadius: 4,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#0d6efd'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f1f1f1' } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}