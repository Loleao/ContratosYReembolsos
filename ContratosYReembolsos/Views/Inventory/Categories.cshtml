@using ContratosYReembolsos.Models.Entities.Inventory
@model IEnumerable<ProductCategory>
@{
    ViewData["Title"] = "Gestión de Categorías";
}

<div class="container-fluid py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold m-0"><i class="fa-solid fa-tags me-2 text-primary"></i>Categorías de Inventario</h4>
            <p class="text-muted small mb-0">Administre las líneas de negocio y familias de productos.</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" onclick="openCategoryModal(0)">
            <i class="fa-solid fa-plus me-1"></i> Nueva Categoría
        </button>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4" style="width: 80px;">ID</th>
                        <th>Nombre de Categoría</th>
                        <th class="text-center">Subcategorías</th>
                        <th class="text-center">Estado Contratos</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted small">#@item.Id</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary-light p-2 rounded-3 text-primary me-3">
                                        <i class="fa-solid fa-folder-tree"></i>
                                    </div>
                                    <span class="fw-bold text-dark">@item.Name</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-primary border rounded-pill px-3">
                                    @item.SubCategories?.Count familias
                                </span>
                            </td>
                            <td class="text-center">
                                @if (item.ShowInContracts)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3">Visible</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-light text-muted border px-3">Oculto</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-primary rounded-circle me-2"
                                            onclick="openCategoryModal(@item.Id)" title="Editar">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <a href="@Url.Action("Subcategories", "Inventory", new { id = item.Id })"
                                       class="btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm">
                                        Gestionar familias <i class="fa-solid fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        async function openCategoryModal(id) {
            Swal.fire({ title: 'Cargando...', didOpen: () => { Swal.showLoading() } });
            try {
                // Cambiado a GetCategoryForm para ser genérico
                const response = await fetch(`@Url.Action("GetCategoryForm")?id=${id}`);
                const html = await response.text();
                document.getElementById('modalContainer').innerHTML = html;
                Swal.close();
                new bootstrap.Modal(document.getElementById('modalCategoryContainer')).show();
            } catch (e) { Swal.fire('Error', 'No se pudo cargar el formulario', 'error'); }
        }

        $(document).on('submit', '#formCategorySave', async function(e) {
            e.preventDefault();
            const $btn = $(this).find('button[type="submit"]');
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

            try {
                const response = await fetch('@Url.Action("SaveCategory")', {
                    method: 'POST',
                    body: new FormData(this)
                });
                const res = await response.json();
                if(res.success) {
                    Swal.fire('¡Éxito!', res.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Error', res.message, 'error');
                    $btn.prop('disabled', false).text('Guardar Categoría');
                }
            } catch (err) {
                Swal.fire('Error', 'Ocurrió un error inesperado.', 'error');
                $btn.prop('disabled', false).text('Guardar Categoría');
            }
        });
    </script>
}