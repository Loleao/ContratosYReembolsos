@model IEnumerable<ContratosYReembolsos.Models.FixedAsset>

<div id="assets-display-container">

    <div class="row g-4 grid-mode">
        @foreach (var asset in Model)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="inventory-card p-3 border-top border-primary border-4 shadow-sm">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-3">
                            <i class="fa-solid fa-barcode text-primary"></i>
                        </div>
                        <span class="badge @(asset.Status == "Available" ? "bg-success" : "bg-warning") x-small">
                            @asset.Status
                        </span>
                    </div>
                    <h6 class="fw-bold mb-1 text-truncate">@asset.Product.Name</h6>
                    <code class="d-block mb-3 text-primary fw-bold">@asset.PatrimonialCode</code>

                    <div class="pt-2 border-top d-flex justify-content-between align-items-center">
                        @* <span class="x-small text-muted"><i class="fa-solid fa-calendar me-1"></i> @asset.AcquisitionDate.ToShortDateString()</span> *@
                        <button class="btn btn-link btn-sm p-0 text-primary" title="Ver detalles">
                            <i class="fa-solid fa-circle-info"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 table-mode d-none">
        <div class="table-responsive">
            <table class="table align-middle table-hover mb-0">
                <thead class="bg-light x-small fw-bold text-muted">
                    <tr>
                        <th class="ps-4">CÓD. PATRIMONIAL</th>
                        <th>ACTIVO / MODELO</th>
                        <th>FECHA ACQUISICIÓN</th>
                        <th>ESTADO</th>
                        <th class="text-end pe-4">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asset in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <code class="fw-bold text-primary">@asset.PatrimonialCode</code>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@asset.Product.Name</div>
                                <div class="x-small text-muted">SKU: @asset.Product.Sku</div>
                            </td>
                           @*  <td class="small text-muted">
                                @asset.AcquisitionDate.ToString("dd/MM/yyyy")
                            </td> *@
                            <td>
                                @if (asset.Status == "Available")
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Disponible</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3">@asset.Status</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <button class="btn btn-light btn-sm rounded-circle me-1" title="Editar">
                                        <i class="fa-solid fa-pen p-1 text-muted"></i>
                                    </button>
                                    <button class="btn btn-light btn-sm rounded-circle" title="Historial">
                                        <i class="fa-solid fa-clock-rotate-left p-1 text-muted"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>