@model IEnumerable<ContratosYReembolsos.Models.ProductTransfer>

<div class="card border-0 shadow-sm rounded-4 animate__animated animate__fadeIn">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="bg-light">
                <tr class="x-small text-muted text-uppercase">
                    <th class="ps-4">Guía / Origen</th>
                    <th>Estado</th>
                    <th>Fecha Envío</th>
                    <th>Detalle de Productos</th>
                    <th class="text-end pe-4">Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-inbox fa-3x mb-3 opacity-25"></i>
                            <p>No hay transferencias pendientes por recibir.</p>
                        </td>
                    </tr>
                }
                @foreach (var t in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-primary">@t.InternalControlNumber</div>
                            <div class="x-small text-muted">
                                <i class="fa-solid fa-location-dot me-1"></i>Desde: @t.OriginBranch.Name
                            </div>
                        </td>
                        <td>
                            <span class="badge rounded-pill bg-warning text-dark x-small px-3">
                                <i class="fa-solid fa-truck me-1"></i> EN TRÁNSITO
                            </span>
                        </td>
                        <td class="small text-muted">@t.SentAt.ToString("g")</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var det in t.Details)
                                {
                                    <span class="badge bg-white text-dark border me-1 x-small fw-normal">
                                        <strong class="text-primary">@det.Quantity</strong> @det.Product.Name
                                        @if (det.FixedAssetId != null)
                                        {
                                            <i class="fa-solid fa-tag ms-1 text-muted" title="Activo Fijo"></i>
                                        }
                                    </span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(t.Observation))
                            {
                                <div class="x-small text-muted mt-1 italic">
                                    <i class="fa-solid fa-comment-dots me-1"></i>Obs: @t.Observation
                                </div>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                <button onclick="showReceiveModal(@t.Id, '@t.InternalControlNumber')"
                                        class="btn btn-success btn-sm px-3 fw-bold border-0">
                                    <i class="fa-solid fa-check me-1"></i> Recibir
                                </button>

                                <button onclick="confirmCancelTransfer(@t.Id, '@t.InternalControlNumber')"
                                        class="btn btn-outline-danger btn-sm px-3 border-0 bg-white">
                                    <i class="fa-solid fa-ban"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>