@using ContratosYReembolsos.Models.Entities.Inventory
@model (List<ProductStock> Stock, List<FixedAsset> Assets)

@{
    ViewData["Title"] = "Gestión de Sede - " + ViewBag.BranchName;
}

<style>
    /* Estilos para el modo tabla y grid */
    .inventory-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        background: #fff;
        position: relative;
    }

        .inventory-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

    .stock-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 5px 12px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.85rem;
        background: #212529;
        color: #fff;
    }

    .unit-tag {
        font-size: 0.7rem;
        text-transform: uppercase;
        opacity: 0.8;
        margin-left: 4px;
    }

    .btn-toggle-group {
        background: #f1f3f5;
        padding: 4px;
        border-radius: 50px;
        display: inline-flex;
    }

        .btn-toggle-group .btn {
            border-radius: 50px;
            padding: 8px 20px;
            font-weight: 600;
            border: none;
            color: #6c757d;
        }

            .btn-toggle-group .btn.active {
                background: #fff;
                color: #0d6efd;
                box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small">
                    <li class="breadcrumb-item"><a asp-action="BranchSelection" class="text-decoration-none text-muted">Sedes</a></li>
                    <li class="breadcrumb-item active fw-bold text-primary">@ViewBag.BranchName</li>
                </ol>
            </nav>
            <h3 class="fw-bold mb-0 text-dark">
                <i class="fa-solid fa-warehouse me-2 text-primary"></i>Panel de Inventario
            </h3>
        </div>

        <div class="d-flex gap-2">
            <div class="btn-group btn-group-sm p-1 bg-light rounded-pill border shadow-sm me-2">
                <button class="btn btn-white rounded-pill px-3" id="view-grid-btn" onclick="toggleDisplayMode('grid')">
                    <i class="fa-solid fa-grip"></i>
                </button>
                <button class="btn btn-white rounded-pill px-3 active shadow-sm" id="view-list-btn" onclick="toggleDisplayMode('list')">
                    <i class="fa-solid fa-list"></i>
                </button>
            </div>
            <button class="btn btn-outline-primary rounded-pill px-4 fw-bold shadow-sm" onclick="openMinStockModal()">
                <i class="fa-solid fa-bell-concierge me-1"></i> Ajustar Alertas
            </button>
            <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm" onclick="openEntryModal()">
                <i class="fa-solid fa-plus-circle me-1"></i> Nuevo Ingreso
            </button>
        </div>
    </div>

    @* --- NAVEGACIÓN DE PESTAÑAS (TABS) --- *@
    <div class="text-center mb-4">
        <div class="btn-toggle-group shadow-sm">
            <button id="btnStock" class="btn active" onclick="switchView('stock')">
                <i class="fa-solid fa-boxes-stacked me-2"></i>Stock Consumible
            </button>
            <button id="btnAssets" class="btn" onclick="switchView('assets')">
                <i class="fa-solid fa-laptop-medical me-2"></i>Activos Fijos
            </button>
            <button id="btnPending" class="btn position-relative" onclick="switchView('pending')">
                <i class="fa-solid fa-truck-ramp-box me-2"></i>Transferencias
                @if (ViewBag.TotalPendientes > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                        @ViewBag.TotalPendientes
                    </span>
                }
            </button>
            <button id="btnKardex" class="btn" onclick="switchView('kardex')">
                <i class="fa-solid fa-clipboard-list me-2"></i>Kardex
            </button>
        </div>
    </div>

    @* Contenedor Dinámico *@
    <div id="inventoryContent" class="position-relative min-vh-50">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    </div>
</div>

<div id="modalContainer"></div>


@section Scripts {
    <script>
        const branchId = '@ViewBag.BranchId';
        const urls = {
            stock: '@Url.Action("GetStockView", "Inventory")',
            assets: '@Url.Action("GetAssetsView", "Inventory")',
            pending: '@Url.Action("GetPendingView", "Inventory")',
            kardex: '@Url.Action("GetKardexView", "Inventory")',
        };

        // 1. CARGA INICIAL Y PERSISTENCIA
        document.addEventListener("DOMContentLoaded", () => {
            if (!localStorage.getItem('inventory-view-mode')) {
                localStorage.setItem('inventory-view-mode', 'list');
            }
            switchView('stock');
        });

        // 2. CAMBIO DE PESTAÑAS (Stock, Assets, etc.)
        async function switchView(view) {
            const container = document.getElementById('inventoryContent');

            document.querySelectorAll('.btn-toggle-group .btn').forEach(b => b.classList.remove('active'));
            const idBtn = 'btn' + view.charAt(0).toUpperCase() + view.slice(1);
            if(document.getElementById(idBtn)) document.getElementById(idBtn).classList.add('active');

            container.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>';

            try {
                const response = await fetch(`${urls[view]}?branchId=${branchId}`);
                if (!response.ok) throw new Error();
                container.innerHTML = await response.text();

                const savedMode = localStorage.getItem('inventory-view-mode') || 'list';
                applyDisplayMode(savedMode);

            } catch (e) {
                container.innerHTML = '<div class="alert alert-danger rounded-4 mt-3"><i class="fa-solid fa-circle-exclamation me-2"></i>Error al cargar la vista.</div>';
            }
        }

        // 3. CAMBIO DE MODO VISUAL (Grid vs List)
        function toggleDisplayMode(mode) {
            localStorage.setItem('inventory-view-mode', mode);
            applyDisplayMode(mode);
        }

        function applyDisplayMode(mode) {
            const gridBtn = document.getElementById('view-grid-btn');
            const listBtn = document.getElementById('view-list-btn');

            if (mode === 'list') {
                gridBtn.classList.remove('active', 'shadow-sm');
                listBtn.classList.add('active', 'shadow-sm');
                $('.grid-mode').addClass('d-none');
                $('.table-mode').removeClass('d-none');
            } else {
                listBtn.classList.remove('active', 'shadow-sm');
                gridBtn.classList.add('active', 'shadow-sm');
                $('.table-mode').addClass('d-none');
                $('.grid-mode').removeClass('d-none');
            }
        }

        // 4. LÓGICA DE RECEPCIÓN DE TRANSFERENCIAS (LO QUE TE FALTABA)
        async function showReceiveModal(id, code) {
            const { value: text, isConfirmed } = await Swal.fire({
                title: 'Confirmar Recepción',
                text: `¿Está seguro de recibir la transferencia ${code}? Los productos se sumarán al stock de esta sede.`,
                input: 'textarea',
                inputPlaceholder: 'Ingrese una observación de recepción (opcional)...',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, recibir todo',
                cancelButtonText: 'Cancelar',
                customClass: {
                    confirmButton: 'rounded-pill px-4',
                    cancelButton: 'rounded-pill px-4'
                }
            });

            if (isConfirmed) {
                processReceipt(id, text);
            }
        }

        async function processReceipt(id, observation) {
            Swal.fire({
                title: 'Procesando recepción...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            try {
                const formData = new FormData();
                formData.append('transferId', id);
                formData.append('receptionObservation', observation || "");

                const response = await fetch('@Url.Action("ConfirmTransferReceipt", "Inventory")', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        title: '¡Recibido!',
                        text: result.message,
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => {
                        // 1. ACTUALIZAR EL BADGE DE NOTIFICACIONES MANUALMENTE
                        const $badge = $('#btnPending .badge');
                        if ($badge.length > 0) {
                            let count = parseInt($badge.text().trim()) || 0;
                            count--;

                            if (count <= 0) {
                                $badge.remove(); // Si llega a 0, eliminamos el círculo rojo
                            } else {
                                $badge.text(count); // Si aún quedan, bajamos el número
                            }
                        }

                        // 2. REDIRECCIONAR A LA VISTA DE STOCK
                        switchView('stock');
                    });
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'No se pudo conectar con el servidor', 'error');
            }
        }

        // 5. OTROS MODALES
        async function openEntryModal() {
            const res = await fetch('@Url.Action("GetStockEntry", "Inventory")');
            document.getElementById('modalContainer').innerHTML = await res.text();
            entryRowIndex = 0;
            addNewEntryRow();
            new bootstrap.Modal(document.getElementById('modalStockEntryContainer')).show();
        }

        async function openMinStockModal() {
            try {
                const res = await fetch(`@Url.Action("GetMinStockSettings", "Inventory")?branchId=${branchId}`);
                document.getElementById('modalContainer').innerHTML = await res.text();
                new bootstrap.Modal(document.getElementById('modalMinStockContainer')).show();
            } catch (e) {
                Swal.fire('Error', 'No se pudo cargar la configuración', 'error');
            }
        }

        //STOCKS MINIMOS

        $(document).on('submit', '#formSaveMinStocks', async function (e) {
            e.preventDefault();
            const $btn = $(this).find('button[type="submit"]');
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

            try {
                const response = await fetch('@Url.Action("UpdateMinimumStocks", "Inventory")', {
                    method: 'POST',
                    body: new FormData(this)
                });
                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Configuración actualizada',
                        text: result.message,
                        showConfirmButton: false,
                        timer: 1500
                    }).then(() => {
                        location.reload(); // Recargamos para refrescar los estados de las tarjetas
                    });
                } else {
                    Swal.fire('Error', result.message, 'error');
                    $btn.prop('disabled', false).text('Guardar Configuración');
                }
            } catch (error) {
                Swal.fire('Error', 'Error de comunicación', 'error');
                $btn.prop('disabled', false).text('Guardar Configuración');
            }
        });

        function confirmCancelTransfer(id, controlNumber) {
            Swal.fire({
                title: '¿Anular Transferencia?',
                text: `Se cancelará la guía ${controlNumber} y el stock regresará a la sede de origen.`,
                icon: 'warning',
                input: 'textarea',
                inputLabel: 'Motivo de anulación',
                inputPlaceholder: 'Escriba el motivo aquí...',
                inputAttributes: { 'aria-label': 'Escriba el motivo aquí' },
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, anular',
                cancelButtonText: 'Cerrar',
                preConfirm: (reason) => {
                    if (!reason) {
                        Swal.showValidationMessage('El motivo es obligatorio para la auditoría');
                    }
                    return reason;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    cancelTransfer(id, result.value);
                }
            });
        }

        function cancelTransfer(id, reason) {
            $.post('@Url.Action("CancelTransfer", "Inventory")', { id: id, reason: reason }, function(response) {
                if (response.success) {
                    Swal.fire('Anulada', response.message, 'success').then(() => {
                        location.reload(); // O recargar el componente de la tabla
                    });
                } else {
                    Swal.fire('Error', response.message, 'error');
                }
            });
        }

    </script>
}