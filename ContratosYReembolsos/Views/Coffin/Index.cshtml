@{
    ViewData["Title"] = "Logística Nacional";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1"><i class="fa-solid fa-boxes-stacked text-primary me-2"></i>Logística FONAFUN</h4>
            <p class="text-muted small mb-0">Control central de inventarios y movimientos nacionales.</p>
        </div>

        <div class="bg-white p-1 rounded-pill shadow-sm border d-flex">
            <button id="btnFiliales" class="btn btn-primary rounded-pill px-4 fw-bold active" onclick="switchView('filiales')">
                <i class="fa-solid fa-building-shield me-2"></i>Sedes
            </button>
            <button id="btnCatalogo" class="btn btn-light rounded-pill px-4 fw-bold text-muted" onclick="switchView('catalogo')">
                <i class="fa-solid fa-book me-2"></i>Catálogo
            </button>
            <button id="btnTransfers" class="btn btn-light rounded-pill px-4 fw-bold text-muted" onclick="switchView('transferencias')">
                <i class="fa-solid fa-truck-fast me-2"></i>Traslados
            </button>
        </div>

        <button class="btn btn-dark rounded-pill px-4 shadow-sm" onclick="openTransferModal()">
            <i class="fa-solid fa-plus me-2"></i>Nueva Transferencia
        </button>
    </div>

    <div id="mainViewContainer" class="position-relative" style="min-height: 400px;">
        <div class="text-center py-5 mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Cargando módulos...</p>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        // 1. URLs dinámicas (Limpias y sin errores de comillas)
        const urls = {
            getSubsidiaryStockModal: '@Url.Action("GetFilialesGrid", "Coffin")',
            getTransfersModal: '@Url.Action("GetTransfersGrid", "Coffin")',
            getCreateTransferStockModal: '@Url.Action("GetCreateTransferStock", "Coffin")',
            executeTransfer: '@Url.Action("TransferFromGeneral", "Coffin")',
            getCatalogModal: '@Url.Action("GetCatalog", "Coffin")',
            getCreateCoffinModal: '@Url.Action("GetCreateCoffin", "Coffin")'
        };

        // 2. Carga inicial al cargar el DOM
        document.addEventListener("DOMContentLoaded", () => {
            switchView('filiales');
        });

        // 3. Función principal de navegación
        async function switchView(viewName, code = '', name = '', page = 1) {
            const container = document.getElementById('mainViewContainer');
            const btns = {
                filiales: document.getElementById('btnFiliales'),
                catalogo: document.getElementById('btnCatalogo'),
                transferencias: document.getElementById('btnTransfers')
            };

            // Resetear estilos de botones
            Object.values(btns).forEach(btn => {
                if(btn) btn.className = "btn btn-light rounded-pill px-4 fw-bold text-muted";
            });

            // Activar botón seleccionado
            if (btns[viewName]) {
                btns[viewName].className = "btn btn-primary rounded-pill px-4 fw-bold shadow-sm";
            }

            try {
                let url;
                if (viewName === 'filiales') {
                    url = `${urls.getSubsidiaryStockModal}?searchCode=${encodeURIComponent(code)}&searchName=${encodeURIComponent(name)}&page=${page}`;
                } else if (viewName === 'catalogo') {
                    url = urls.getCatalogModal;
                } else {
                    url = urls.getTransfersModal;
                }

                const response = await fetch(url);
                if (!response.ok) throw new Error("Status: " + response.status);

                const html = await response.text();
                container.innerHTML = html;
            } catch (error) {
                console.error("Fetch Error:", error);
                container.innerHTML = '<div class="alert alert-danger">Error al cargar datos.</div>';
            }
        }

        // 4. Abrir modal para nuevo Coffin o nueva Variante
        async function openCreateCoffinModal(existingModelName = '') {
            try {
                const url = `${urls.getCreateCoffinModal}?modelName=${encodeURIComponent(existingModelName)}`;
                const response = await fetch(url);
                const html = await response.text();

                const container = document.getElementById('modalContainer');
                container.innerHTML = html;

                // Bloquear nombre si ya existe
                if (existingModelName !== '') {
                    const input = container.querySelector('input[name="ModelName"]');
                    if (input) {
                        input.readOnly = true;
                        input.classList.add('bg-light');
                    }
                }

                new bootstrap.Modal(document.getElementById('createCoffinModal')).show();
            } catch (error) {
                Swal.fire('Error', 'No se pudo abrir el formulario.', 'error');
            }
        }

        // 5. Guardar el formulario del modal vía AJAX
        async function saveNewCoffin() {
            const form = document.getElementById('formCreateCoffin');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const formData = new FormData(form);
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            try {
                const response = await fetch('@Url.Action("Create", "Coffin")', {
                    method: 'POST',
                    headers: { "RequestVerificationToken": token },
                    body: formData
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        Swal.fire('¡Éxito!', result.message, 'success').then(() => {
                            const modalEl = document.getElementById('createCoffinModal');
                            bootstrap.Modal.getInstance(modalEl).hide();
                            switchView('catalogo');
                        });
                    } else {
                        Swal.fire('Error', result.message, 'error');
                    }
                } else {
                    Swal.fire('Error', 'Error en el servidor', 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Fallo de conexión.', 'error');
            }
        }

        // 6. Otras funciones de apoyo
        async function openTransferModal() {
            try {
                const response = await fetch(urls.getCreateTransferStockModal);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;
                new bootstrap.Modal(container.querySelector('.modal')).show();
            } catch (error) {
                Swal.fire('Error', 'No se pudo cargar el traslado.', 'error');
            }
        }

        async function deleteVariant(id) {
            const result = await Swal.fire({
                title: '¿Eliminar variante?',
                text: "Esta acción no se puede deshacer si no hay stock.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, borrar',
                cancelButtonText: 'Cancelar'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`@Url.Action("DeleteVariant", "Coffin")/${id}`, { method: 'POST' });
                    const data = await response.json();
                    if (data.success) {
                        Swal.fire('Eliminado', data.message, 'success');
                        switchView('catalogo');
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (e) { console.error(e); }
            }
        }

        async function deleteCoffin(id, name) {
            const result = await Swal.fire({
                title: `¿Borrar ${name}?`,
                text: "Se eliminarán el modelo y TODAS sus variantes. Esta acción es definitiva.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Eliminar Todo',
                cancelButtonText: 'Cancelar'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`@Url.Action("DeleteCoffin", "Coffin")/${id}`, { method: 'POST' });
                    const data = await response.json();
                    if (data.success) {
                        Swal.fire('Eliminado', data.message, 'success');
                        switchView('catalogo');
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (e) { console.error(e); }
            }
        }
    </script>
}