@{
    ViewData["Title"] = "Logística Nacional";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1"><i class="fa-solid fa-boxes-stacked text-primary me-2"></i>Logística FONAFUN</h4>
            <p class="text-muted small mb-0">Control central de inventarios y movimientos nacionales.</p>
        </div>

        <div class="bg-white p-1 rounded-pill shadow-sm border d-flex">
            <button id="btnFiliales" class="btn btn-primary rounded-pill px-4 fw-bold active" onclick="switchView('filiales')">
                <i class="fa-solid fa-building-shield me-2"></i>Sedes
            </button>
            <button id="btnTransfers" class="btn btn-light rounded-pill px-4 fw-bold text-muted" onclick="switchView('transferencias')">
                <i class="fa-solid fa-truck-fast me-2"></i>Traslados
            </button>
        </div>

        <button class="btn btn-dark rounded-pill px-4 shadow-sm" onclick="openTransferModal()">
            <i class="fa-solid fa-plus me-2"></i>Nueva Transferencia
        </button>
    </div>

    <div id="mainViewContainer" class="position-relative" style="min-height: 400px;">
        <div class="text-center py-5 mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Cargando módulos...</p>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        // URLs dinámicas
        const urls = {
            getSubsidiaryStockModal: '@Url.Action("GetFilialesGrid", "Coffin")',
            getTransfersModal: '@Url.Action("GetTransfersGrid", "Coffin")',
            getCreateTransferStockModal: '@Url.Action("GetCreateTransferStock", "Coffin")',
            executeTransfer: '@Url.Action("TransferFromGeneral", "Coffin")'
        };

        document.addEventListener("DOMContentLoaded", () => switchView('filiales'));

        // Función de Filtrado (Ahora global para evitar errores de definición)
        function applyFilters() {
            const code = document.getElementById('filterCode')?.value || '';
            const name = document.getElementById('filterName')?.value || '';
            switchView('filiales', code, name, 1);
        }

        async function switchView(viewName, code = '', name = '', page = 1) {
            const container = document.getElementById('mainViewContainer');
            const btnF = document.getElementById('btnFiliales');
            const btnT = document.getElementById('btnTransfers');

            // Toggle de clases para los botones
            if(viewName === 'filiales') {
                btnF.className = "btn btn-primary rounded-pill px-4 fw-bold shadow-sm";
                btnT.className = "btn btn-light rounded-pill px-4 fw-bold text-muted";
            } else {
                btnT.className = "btn btn-primary rounded-pill px-4 fw-bold shadow-sm";
                btnF.className = "btn btn-light rounded-pill px-4 fw-bold text-muted";
            }

            try {
                // USANDO TUS URLS EXACTAS
                const url = viewName === 'filiales'
                    ? `${urls.getSubsidiaryStockModal}?searchCode=${encodeURIComponent(code)}&searchName=${encodeURIComponent(name)}&page=${page}`
                    : urls.getTransfersModal;

                const response = await fetch(url);
                if (!response.ok) throw new Error("Status: " + response.status);

                const html = await response.text();
                container.innerHTML = html;
            } catch (error) {
                console.error("Fetch Error:", error);
                container.innerHTML = '<div class="alert alert-danger">Error al cargar datos. Revisa la consola (F12).</div>';
            }
        }

        // Abrir Modal de Nueva Transferencia
        async function openTransferModal() {
            try {
                const response = await fetch(urls.getCreateTransferStockModal);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;
                new bootstrap.Modal(container.querySelector('.modal')).show();
            } catch (error) {
                Swal.fire('Error', 'No se pudo cargar el formulario.', 'error');
            }
        }

        async function executeTransfer() {
            // Capturamos los datos del modal
            const variantId = document.getElementById('transferVariantId').value;
            const targetId = document.getElementById('targetSubsidiaryId').value;
            const qty = document.getElementById('transferQuantity').value;
            const ref = document.getElementById('transferReference').value;

            // Validación de frontend
            if (!variantId || !targetId || !qty || !ref) {
                Swal.fire('Atención', 'Complete todos los campos obligatorios.', 'warning');
                return;
            }

            // Validación de stock local en el cliente
            const selectedOpt = document.querySelector('#transferVariantId option:checked');
            const max = parseInt(selectedOpt.dataset.max);
            if (parseInt(qty) > max) {
                Swal.fire('Error', `Solo hay ${max} unidades disponibles.`, 'error');
                return;
            }

            try {
                const url = `${urls.executeTransfer}?variantId=${variantId}&targetSubsidiaryId=${targetId}&quantity=${qty}&reference=${ref}`;
                const response = await fetch(url, { method: 'POST' });
                const result = await response.json();

                if (result.success) {
                    Swal.fire('¡Despachado!', result.message, 'success').then(() => {
                        // Cerramos modal y refrescamos la pestaña de Traslados
                        bootstrap.Modal.getInstance(document.getElementById('transferModal')).hide();
                        switchView('transferencias');
                    });
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Fallo de conexión.', 'error');
            }
        }

        function applyFilters() {
            const code = document.getElementById('filterCode')?.value || '';
            const name = document.getElementById('filterName')?.value || '';
            // Reiniciamos a la página 1 al filtrar
            switchView('filiales', code, name, 1);
        }
    </script>
}