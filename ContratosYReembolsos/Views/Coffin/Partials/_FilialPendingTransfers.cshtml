@model IEnumerable<ContratosYReembolsos.Models.CoffinTransfer>

<div class="animate__animated animate__fadeIn">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fa-solid fa-circle-check fa-3x text-success opacity-25 mb-3"></i>
                    <p class="text-muted">No hay envíos pendientes para esta sede.</p>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-primary text-white">
                        <tr class="small">
                            <th class="ps-4">PRODUCTO</th>
                            <th>CANTIDAD</th>
                            <th>ORIGEN</th>
                            <th>GUÍA / REF</th>
                            <th class="text-center">GESTIÓN</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@t.CoffinVariant.Coffin.ModelName</div>
                                    <div class="small text-muted">@t.CoffinVariant.Color</div>
                                </td>
                                <td><span class="badge bg-dark rounded-pill">@t.Quantity</span></td>
                                <td class="small">Central (070000)</td>
                                <td class="text-muted small">@t.GuiaRemision</td>
                                <td class="text-center">
                                    <button class="btn btn-success btn-sm rounded-pill px-3 fw-bold" onclick="confirmReceipt(@t.Id)">
                                        Confirmar Llegada
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>