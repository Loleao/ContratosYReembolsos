@model IEnumerable<ContratosYReembolsos.Models.External.Subsidiary>

<div class="animate__animated animate__fadeIn">
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <label class="form-label x-small fw-bold text-muted mb-1">CÓDIGO</label>
                    <input type="text" id="filterCode" class="form-control form-control-sm border-0 bg-light"
                           placeholder="Ej: 070000" value="@ViewBag.SearchCode">
                </div>
                <div class="col-md-5">
                    <label class="form-label x-small fw-bold text-muted mb-1">NOMBRE DE SEDE</label>
                    <input type="text" id="filterName" class="form-control form-control-sm border-0 bg-light"
                           placeholder="Buscar..." value="@ViewBag.SearchName">
                </div>
                <div class="col-md-3 mt-4">
                    <button class="btn btn-primary btn-sm w-100 rounded-pill shadow-sm" onclick="applyFilters()">
                        <i class="fa-solid fa-magnifying-glass me-1"></i> Filtrar Sedes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var filial in Model)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 subsidiary-card">
                    <div class="card-body p-4 text-center">
                        <div class="icon-box mb-3 mx-auto" style="width: 45px; height: 45px; background: #f8f9fa; display: flex; align-items: center; justify-content: center; border-radius: 12px;">
                            <i class="fa-solid fa-warehouse text-primary"></i>
                        </div>
                        <h6 class="fw-bold mb-1 text-truncate">@filial.Name</h6>
                        <p class="text-muted mb-4" style="font-size: 11px;">ID: @filial.Id</p>
                        <a href="@Url.Action("Inventory", "Coffin", new { id = filial.Id })" class="btn btn-dark btn-sm w-100 rounded-pill py-2">
                            Abrir Almacén <i class="fa-solid fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                @* Botón Anterior *@
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link rounded-start-pill px-3" href="javascript:void(0)"
                       onclick="switchView('filiales', '@ViewBag.SearchCode', '@ViewBag.SearchName', @(ViewBag.CurrentPage - 1))">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>

                @* Números *@
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" href="javascript:void(0)"
                           onclick="switchView('filiales', '@ViewBag.SearchCode', '@ViewBag.SearchName', @i)">@i</a>
                    </li>
                }

                @* Botón Siguiente *@
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link rounded-end-pill px-3" href="javascript:void(0)"
                       onclick="switchView('filiales', '@ViewBag.SearchCode', '@ViewBag.SearchName', @(ViewBag.CurrentPage + 1))">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<script>
    function applyFilters() {
        const code = document.getElementById('filterCode').value;
        const name = document.getElementById('filterName').value;
        // Reiniciamos a la página 1 al filtrar
        switchView('filiales', code, name, 1);
    }
</script>