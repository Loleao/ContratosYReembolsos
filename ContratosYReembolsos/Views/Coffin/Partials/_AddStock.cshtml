<div class="modal fade" id="entryModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="fa-solid fa-truck-loading me-2"></i>Ingreso de Cargamento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <p class="small text-muted mb-0 text-uppercase fw-bold">Sede de recepción</p>
                    <p class="fw-bold text-primary">@ViewBag.BranchName</p>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="fw-bold small">LISTA DE PRODUCTOS</label>
                    <button type="button" class="btn btn-outline-dark btn-sm rounded-pill" onclick="addRow()">
                        <i class="fa-solid fa-plus me-1"></i> Agregar fila
                    </button>
                </div>

                <table class="table table-sm align-middle">
                    <thead class="bg-light x-small">
                        <tr>
                            <th style="width: 45%;">Ataúd / Variante</th>
                            <th style="width: 15%;">Cant.</th>
                            <th style="width: 35%;">Ref. (Guía/Factura)</th>
                            <th style="width: 5%;"></th>
                        </tr>
                    </thead>
                    <tbody id="tbodyIngreso">
                        @* Aquí se insertan las filas *@
                    </tbody>
                </table>

                @* Plantilla oculta para el selector de variantes *@
                <select id="catalogSource" class="d-none">
                    <option value="">-- Seleccionar --</option>
                    @foreach (var v in ViewBag.Variants)
                    {
                        <option value="@v.Id">@v.DisplayName</option>
                    }
                </select>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold" onclick="saveBulkEntry()">
                    Confirmar Carga <i class="fa-solid fa-save ms-1"></i>
                </button>
            </div>
        </div>
    </div>
</div>