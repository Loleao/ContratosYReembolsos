@model IEnumerable<ContratosYReembolsos.Models.Coffin>

<div class="animate__animated animate__fadeIn">
    @* Encabezado del Catálogo *@
    <div class="card border-0 shadow-sm rounded-4 mb-4 bg-dark text-white">
        <div class="card-body p-4 d-flex justify-content-between align-items-center">
            <div>
                <h5 class="fw-bold mb-1">Catálogo de Variantes</h5>
                <p class="small mb-0 opacity-75">Define aquí los modelos base que FONAFUN ofrece a nivel nacional.</p>
            </div>
            <button class="btn btn-primary rounded-pill px-4 shadow" onclick="openCreateCoffinModal()">
                <i class="fa-solid fa-plus me-1"></i> Nuevo Modelo / Variante
            </button>
        </div>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="fa-solid fa-folder-open fa-3x text-muted mb-3"></i>
                <p class="text-muted">No hay modelos registrados en el catálogo.</p>
            </div>
        }
        else
        {
            @foreach (var coffin in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 position-relative">
                        @* BOTÓN PARA ELIMINAR EL COFFIN COMPLETO *@
                        <button class="btn btn-sm text-danger position-absolute top-0 end-0 m-3 opacity-50 hover-opacity-100"
                                onclick="deleteCoffin(@coffin.Id, '@coffin.ModelName')"
                                title="Eliminar modelo completo">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>

                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3 pe-4">
                                <h6 class="fw-bold text-primary mb-0 text-uppercase">@coffin.ModelName</h6>
                                <span class="badge bg-light text-dark border">@coffin.Variants.Count Variantes</span>
                            </div>

                            <div class="list-group list-group-flush mb-3">
                                @foreach (var variant in coffin.Variants)
                                {
                                    <div class="list-group-item px-0 py-2 border-0 d-flex justify-content-between align-items-center">
                                        <div class="small">
                                            <i class="fa-solid fa-circle text-muted me-2" style="font-size: 8px;"></i>
                                            @variant.Color | @variant.Material | <span class="fw-bold">@variant.Size</span>
                                        </div>
                                        <button class="btn btn-outline-danger btn-sm rounded-pill py-0 px-2"
                                                onclick="deleteVariant(@variant.Id)"
                                                style="font-size: 10px;">
                                            Eliminar
                                        </button>
                                    </div>
                                }
                            </div>

                            <div class="mt-auto">
                                <button class="btn btn-light btn-sm w-100 rounded-pill text-muted small border-dashed"
                                        onclick="openCreateCoffinModal('@coffin.ModelName')">
                                    <i class="fa-solid fa-plus me-1"></i> Agregar otra variante
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .hover-opacity-100:hover {
        opacity: 1 !important;
    }

    .border-dashed {
        border: 1px dashed #dee2e6;
    }
</style>