<div class="modal fade" id="transferModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="fa-solid fa-truck-fast me-2"></i>Nueva Transferencia Masiva</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label x-small fw-bold text-primary">FILIAL DESTINO</label>
                        <select id="targetBranchId" class="form-select border-2 shadow-sm">
                            <option value="">-- Seleccione Sede Destino --</option>
                            @foreach (var f in ViewBag.Subsidiaries)
                            {
                                <option value="@f.Id">@f.Name (Cód: @f.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label x-small fw-bold text-primary">GUÍA DE REMISIÓN</label>
                        <input type="text" id="bulkTransferReference" class="form-control border-2" placeholder="G001-000XXX">
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="fw-bold small">PRODUCTOS A DESPACHAR (ALMACÉN CENTRAL)</label>
                    <button type="button" class="btn btn-outline-dark btn-sm rounded-pill" onclick="addTransferRow()">
                        <i class="fa-solid fa-plus me-1"></i> Añadir Ataúd
                    </button>
                </div>

                <table class="table table-sm align-middle">
                    <thead class="bg-light x-small">
                        <tr>
                            <th style="width: 60%;">Modelo / Variante</th>
                            <th style="width: 30%;">Cantidad</th>
                            <th style="width: 10%;"></th>
                        </tr>
                    </thead>
                    <tbody id="tbodyTransferencia">
                        @* Filas dinámicas *@
                    </tbody>
                </table>

                @* Fuente de datos oculta para el JS *@
                <select id="transferCatalogSource" class="d-none">
                    <option value="">-- Seleccionar --</option>
                    @foreach (var p in ViewBag.Products)
                    {
                        <option value="@p.VariantId" data-max="@p.StockDisponible">
                            @p.DisplayName (Stock: @p.StockDisponible)
                        </option>
                    }
                </select>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold" onclick="executeBulkTransfer()">
                    Confirmar Envío <i class="fa-solid fa-paper-plane ms-1"></i>
                </button>
            </div>
        </div>
    </div>
</div>