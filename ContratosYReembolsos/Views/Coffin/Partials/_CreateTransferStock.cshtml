<div class="modal fade" id="transferModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-truck-ramp-box me-2"></i>Módulo de Transferencia Central</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label x-small fw-bold text-muted text-uppercase small">Origen</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-building-circle-check text-success"></i></span>
                            <input type="text" class="form-control bg-light border-start-0 fw-bold" value="ALMACÉN GENERAL (070000)" readonly>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label x-small fw-bold text-primary small">ATAÚD A ENVIAR (Variante/Color)</label>
                        <select id="transferVariantId" class="form-select border-2 shadow-sm">
                            <option value="">-- Seleccione Modelo y Color --</option>
                            @foreach (var p in ViewBag.Products)
                            {
                                @* Usamos VariantId y DisplayName definidos en el Controller *@
                                <option value="@p.VariantId" data-max="@p.StockDisponible">
                                    @p.DisplayName (Disp: @p.StockDisponible)
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label x-small fw-bold text-primary small">FILIAL DESTINO</label>
                        <select id="targetSubsidiaryId" class="form-select border-2 shadow-sm">
                            <option value="">-- Seleccione Sede Destino --</option>
                            @foreach (var f in ViewBag.Subsidiaries)
                            {
                                <option value="@f.Id">@f.Name (@f.Id)</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label x-small fw-bold small">CANTIDAD</label>
                        <div class="input-group">
                            <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('transferQuantity').stepDown()">-</button>
                            <input type="number" id="transferQuantity" class="form-control text-center fw-bold" value="1" min="1">
                            <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('transferQuantity').stepUp()">+</button>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <label class="form-label x-small fw-bold small">DOCUMENTO DE REFERENCIA</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-file-invoice"></i></span>
                            <input type="text" id="transferReference" class="form-control" placeholder="Ej: Guía de Remisión G001-002">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light rounded-bottom-4">
                <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary rounded-pill px-5 fw-bold shadow" onclick="executeTransfer()">
                    Procesar Envío <i class="fa-solid fa-paper-plane ms-2"></i>
                </button>
            </div>
        </div>
    </div>
</div>