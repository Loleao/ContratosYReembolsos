@{
    ViewData["Title"] = "Gestión de Sede - " + ViewBag.SubsidiaryName;
}

<style>
    .coffin-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        position: relative;
    }

        .coffin-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

    .stock-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 6px 14px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.8rem;
        z-index: 10;
        background-color: #000 !important;
        color: #fff !important;
    }

    .img-container {
        height: 160px;
        background-color: #f8f9fa;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .variant-color-tag {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6c757d;
    }

    .x-small {
        font-size: 0.7rem;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index")">Sedes</a></li>
                    <li class="breadcrumb-item active">@ViewBag.SubsidiaryName</li>
                </ol>
            </nav>
            <h4 class="fw-bold mb-0"><i class="fa-solid fa-warehouse me-2 text-primary"></i>@ViewBag.SubsidiaryName</h4>
        </div>

        <div class="d-flex gap-3">
            <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm" onclick="openEntryModal(null)">
                <i class="fa-solid fa-plus-circle me-1"></i> Nuevo Ingreso
            </button>

            <div class="bg-white p-1 rounded-pill shadow-sm border d-flex">
                <button id="btnStock" class="btn btn-primary rounded-pill px-4 fw-bold" onclick="switchFilialView('stock')">
                    <i class="fa-solid fa-boxes-stacked me-2"></i>Stock Actual
                </button>
                <button id="btnPending" class="btn btn-light rounded-pill px-4 fw-bold text-muted" onclick="switchFilialView('pendientes')">
                    <i class="fa-solid fa-truck-ramp-box me-2"></i>Por Recibir
                </button>
            </div>
        </div>
    </div>

    <div id="filialViewContainer" class="position-relative" style="min-height: 400px;">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        const filialId = '@ViewBag.SubsidiaryId';
        const filialUrls = {
            stock: '@Url.Action("GetFilialStock", "Coffin")',
            pendientes: '@Url.Action("GetFilialPendingTransfers", "Coffin")',
            getAddStockModal: '@Url.Action("GetAddStock", "Coffin")',
            registerEntry: '@Url.Action("RegisterStockEntry", "Coffin")',
            confirmReceipt: '@Url.Action("ConfirmReceipt", "Coffin")'
        };

        document.addEventListener("DOMContentLoaded", () => switchFilialView('stock'));

        async function switchFilialView(view) {
            const container = document.getElementById('filialViewContainer');
            const btnS = document.getElementById('btnStock');
            const btnP = document.getElementById('btnPending');

            if(view === 'stock') {
                btnS.className = "btn btn-primary rounded-pill px-4 fw-bold shadow-sm";
                btnP.className = "btn btn-light rounded-pill px-4 fw-bold text-muted";
            } else {
                btnP.className = "btn btn-primary rounded-pill px-4 fw-bold shadow-sm";
                btnS.className = "btn btn-light rounded-pill px-4 fw-bold text-muted";
            }

            try {
                const url = view === 'stock' ? `${filialUrls.stock}?id=${filialId}` : `${filialUrls.pendientes}?id=${filialId}`;
                const response = await fetch(url);
                container.innerHTML = await response.text();
            } catch (e) {
                container.innerHTML = '<div class="alert alert-danger">Error al cargar la vista.</div>';
            }
        }

        async function openEntryModal() {
            const url = `${filialUrls.getAddStockModal}?branchId=${filialId}`;
            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error("Error en el servidor");

                const html = await response.text();
                document.getElementById('modalContainer').innerHTML = html;

                const modal = new bootstrap.Modal(document.getElementById('entryModal'));
                modal.show();

                // Agregar la primera fila automáticamente
                addRow();
            } catch (error) {
                console.error(error);
                Swal.fire('Error', 'No se pudo cargar el formulario.', 'error');
            }
        }

        // 2. Función para añadir filas a la tabla
        function addRow() {
            const tbody = document.getElementById('tbodyIngreso');
            const options = document.getElementById('catalogSource').innerHTML;
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td><select class="form-select form-select-sm variant-id border-2" required>${options}</select></td>
                <td><input type="number" class="form-control form-control-sm variant-qty border-2 text-center" value="1" min="1"></td>
                <td><input type="text" class="form-control form-control-sm variant-ref border-2" placeholder="Guía..."></td>
                <td><button class="btn btn-link text-danger btn-sm p-0" onclick="this.closest('tr').remove()"><i class="fa-solid fa-trash"></i></button></td>
            `;
            tbody.appendChild(tr);
        }

        async function saveBulkEntry() {
            const items = [];
            const rows = document.querySelectorAll('#tbodyIngreso tr');

            rows.forEach(tr => {
                const vId = tr.querySelector('.variant-id').value;
                const vQty = tr.querySelector('.variant-qty').value;
                const vRef = tr.querySelector('.variant-ref').value;

                if (vId && parseInt(vQty) > 0) {
                    items.push({
                        VariantId: parseInt(vId),
                        Quantity: parseInt(vQty),
                        Reference: vRef
                    });
                }
            });

            if (items.length === 0) {
                Swal.fire('Atención', 'Agregue al menos un producto válido.', 'warning');
                return;
            }

            // CREAMOS EL OBJETO QUE COINCIDE CON BulkEntryRequest
            const payload = {
                BranchId: parseInt(filialId),
                Items: items
            };

            try {
                const response = await fetch('@Url.Action("RegisterBulkEntry", "Coffin")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                        // Si usas tokens de seguridad, agrégalo aquí
                    },
                    body: JSON.stringify(payload)
                });

                // Verificamos si la respuesta es OK antes de intentar leer el JSON
                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(errorText || "Error 400 Bad Request");
                }

                const result = await response.json();

                if (result.success) {
                    Swal.fire('¡Éxito!', result.message, 'success').then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (e) {
                console.error("Detalle del error:", e);
                Swal.fire('Error', 'El servidor rechazó los datos. Revisa que todos los campos estén llenos.', 'error');
            }
        }

        async function saveEntry() {
            const variantId = document.querySelector('[name="VariantId"]').value;
            const qty = document.querySelector('[name="Quantity"]').value;
            const ref = document.querySelector('[name="Reference"]').value;

            if (!variantId || !qty || !ref) {
                Swal.fire('Atención', 'Complete todos los campos obligatorios.', 'warning');
                return;
            }

            const params = new URLSearchParams();
            params.append('branchId', filialId);
            params.append('variantId', variantId);
            params.append('quantity', qty);
            params.append('reference', ref);

            try {
                const response = await fetch(filialUrls.registerEntry, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        // Si usas [ValidateAntiForgeryToken] en el POST, necesitas enviar el token aquí
                    },
                    body: params
                });

                const data = await response.json();
                if (data.success) {
                    Swal.fire('¡Éxito!', data.message, 'success').then(() => {
                        const modalEl = document.querySelector('.modal');
                        bootstrap.Modal.getInstance(modalEl).hide();
                        switchFilialView('stock');
                    });
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Fallo de comunicación.', 'error');
            }
        }

        async function confirmReceipt(transferId) {
            const { value: obs } = await Swal.fire({
                title: '¿Confirmar Recepción?',
                text: "Verifica que la cantidad física coincida con la guía antes de confirmar.",
                icon: 'question',
                input: 'text',
                inputLabel: 'Observaciones / Estado del producto',
                inputPlaceholder: 'Ej: Todo conforme / Caja dañada...',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                confirmButtonText: 'Sí, recibir en almacén',
                cancelButtonText: 'Cancelar'
            });

            if (obs !== undefined) {
                try {
                    const url = `${filialUrls.confirmReceipt}?transferId=${transferId}&observations=${encodeURIComponent(obs)}`;
                    const response = await fetch(url, { method: 'POST' });
                    const result = await response.json();

                    if (result.success) {
                        Swal.fire('¡Éxito!', result.message, 'success')
                            .then(() => switchFilialView('pendientes')); // Recarga la pestaña de pendientes
                    } else {
                        Swal.fire('Error', result.message, 'error');
                    }
                } catch (e) {
                    Swal.fire('Error', 'Fallo de conexión al procesar la recepción.', 'error');
                }
            }
        }
    </script>
}