@model ContratosYReembolsos.Models.ViewModels.CoffinCreateViewModel

<div class="container-fluid">
    <div class="mb-4">
        <a href="@Url.Action("Index")" class="text-decoration-none small text-muted">
            <i class="fa-solid fa-arrow-left me-1"></i> Volver al catálogo
        </a>
        <h4 class="fw-bold mt-2">Registrar Nuevo Modelo y Variante Inicial</h4>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="form-card">
                <form asp-action="Create" enctype="multipart/form-data" method="post">
                    <div class="row g-3">
                        <div class="col-12">
                            <h6 class="text-primary fw-bold mb-3">Información General del Modelo</h6>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="ModelName" class="form-label small fw-bold">Nombre del Modelo</label>
                            <input asp-for="ModelName" class="form-control form-control-lg" placeholder="Ej: Imperial Presidencial" />
                        </div>

                        <div class="col-12 mt-4">
                            <h6 class="text-primary fw-bold mb-3">Especificaciones de la Variante Inicial</h6>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Material" class="form-label small fw-bold">Material</label>
                            <select asp-for="Material" class="form-select">
                                <option value="Madera">Madera</option>
                                <option value="Metal">Metal</option>
                                <option value="MDF">MDF</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Size" class="form-label small fw-bold">Tamaño</label>
                            <select asp-for="Size" class="form-select">
                                <option value="Adulto">Adulto</option>
                                <option value="Párvulo">Párvulo</option>
                                <option value="Extra Grande (XL)">Extra Grande (XL)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Color" class="form-label small fw-bold">Color Inicial</label>
                            <input asp-for="Color" class="form-control" placeholder="Ej: Blanco" />
                        </div>

                        <div class="col-md-6 mt-3">
                            <label asp-for="InitialStock" class="form-label small fw-bold">Stock Inicial (En Central 070000)</label>
                            <input asp-for="InitialStock" class="form-control" type="number" />
                        </div>
                        <div class="col-md-6 mt-3">
                            <label asp-for="MinimumStock" class="form-label small fw-bold">Alerta Stock Mínimo</label>
                            <input asp-for="MinimumStock" class="form-control" type="number" />
                        </div>

                        <div class="col-12 mt-4">
                            <label class="form-label small fw-bold text-primary">Fotografía de la Variante</label>
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="img-preview" id="previewContainer">
                                        <i class="fa-solid fa-camera fa-2x text-muted" id="iconPreview"></i>
                                        <img src="" id="imgActualPreview" style="display:none;" />
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <input type="file" name="imageFile" id="imageInput" class="form-control" accept="image/*" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-5 text-end">
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm">
                                <i class="fa-solid fa-save me-2"></i> Crear Modelo y Variante
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>