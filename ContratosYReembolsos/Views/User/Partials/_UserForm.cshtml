@using ContratosYReembolsos.Models.ViewModels.Users
@model RegisterUserViewModel

@* Nota: No usamos Layout ni @section Scripts en una parcial *@

<form id="userForm" asp-controller="User" asp-action="SaveUser" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    @* Resumen de errores general *@
    <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small mb-3"></div>

    <div class="row g-3">
        @* Username (El login tipo pespejo) *@
        <div class="col-md-6">
            <label class="form-label fw-bold small"><i class="fa-solid fa-user-tag me-1"></i>Nombre de Usuario</label>
            <input asp-for="UserName" class="form-control rounded-3" placeholder="Ej: pespejo"
                   readonly="@(!string.IsNullOrEmpty(Model.Id))" />
            <span asp-validation-for="UserName" class="text-danger small"></span>
            @if (!string.IsNullOrEmpty(Model.Id))
            {
                <div class="form-text x-small text-muted">El nombre de usuario no es editable.</div>
            }
        </div>

        @* DNI *@
        <div class="col-md-6">
            <label class="form-label fw-bold small"><i class="fa-solid fa-id-card me-1"></i>Número de DNI</label>
            <input asp-for="DNI" class="form-control rounded-3" placeholder="8 dígitos" maxlength="8" />
            <span asp-validation-for="DNI" class="text-danger small"></span>
        </div>

        @* Nombre Completo *@
        <div class="col-md-12">
            <label class="form-label fw-bold small"><i class="fa-solid fa-signature me-1"></i>Nombre Completo</label>
            <input asp-for="FullName" class="form-control rounded-3" placeholder="Nombres y Apellidos" />
            <span asp-validation-for="FullName" class="text-danger small"></span>
        </div>

        @* Email *@
        <div class="col-md-12">
            <label class="form-label fw-bold small"><i class="fa-solid fa-envelope me-1"></i>Correo Institucional</label>
            <input asp-for="Email" class="form-control rounded-3" placeholder="ejemplo@fonafun.com" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        @* Filial *@
        <div class="col-md-12">
            <label class="form-label fw-bold text-primary small"><i class="fa-solid fa-building-flag me-1"></i>Filial Asignada</label>
            <select asp-for="BranchId" class="form-select border-primary" asp-items="Model.Branches">
                <option value="">-- ACCESO GLOBAL (Sede Central) --</option>
            </select>
            <div class="form-text text-muted" style="font-size: 11px;">Restringe el acceso del usuario a esta sede.</div>
        </div>

        @* SECCIÓN DE CONTRASEÑA - Solo obligatoria si es CREACIÓN *@
        <div class="col-12 mt-3 mb-1">
            <div class="d-flex align-items-center">
                <hr class="flex-grow-1">
                <span class="px-2 small text-muted fw-bold text-uppercase">Seguridad</span>
                <hr class="flex-grow-1">
            </div>
            @if (!string.IsNullOrEmpty(Model.Id))
            {
                <div class="alert alert-info py-1 px-2 x-small mb-2" style="font-size: 0.7rem;">
                    <i class="fa-solid fa-circle-info me-1"></i> Deje en blanco para mantener la contraseña actual.
                </div>
            }
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold small"><i class="fa-solid fa-key me-1"></i>Contraseña</label>
            <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="Mín. 6 caracteres" />
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold small"><i class="fa-solid fa-check-double me-1"></i>Confirmar</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control rounded-3" placeholder="Repita la clave" />
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>
    </div>

    <div class="d-flex justify-content-end mt-4 pt-3 border-top">
        <button type="button" class="btn btn-light rounded-pill px-4 me-2 fw-bold small" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow fw-bold">
            <i class="fa-solid fa-save me-1"></i> @(string.IsNullOrEmpty(Model.Id) ? "Registrar" : "Guardar Cambios")
        </button>
    </div>
</form>