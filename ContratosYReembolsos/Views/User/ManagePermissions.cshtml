@using ContratosYReembolsos.Models.ViewModels.Users
@model ManageUserPermissionsViewModel

<div class="container py-4">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-dark text-white p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-1">Configuración de Accesos</h4>
                    <p class="mb-0 opacity-75">Usuario: <strong>@Model.FullName</strong> | DNI: @Model.DNI</p>
                </div>
                <i class="fa-solid fa-user-shield fa-2x opacity-50"></i>
            </div>
        </div>

        <form asp-action="ManagePermissions" method="post">
            <input type="hidden" asp-for="UserId" />
            <div class="card-body p-4 bg-light">

                @* Agrupamos por la propiedad Group *@
                @{
                    var groups = Model.Claims.GroupBy(c => c.Group);
                }

                @foreach (var group in groups)
                {
                    <div class="mb-4">
                        <h6 class="text-uppercase text-primary fw-bold mb-3 border-bottom pb-2">
                            <i class="fa-solid fa-layer-group me-2"></i>Módulo @group.Key
                        </h6>
                        <div class="row g-3">
                            @for (int i = 0; i < Model.Claims.Count; i++)
                            {
                                if (Model.Claims[i].Group == group.Key)
                                {
                                    <div class="col-md-6 col-lg-4">
                                        <div class="card h-100 border-0 shadow-sm rounded-3">
                                            <div class="card-body d-flex align-items-center">
                                                <div class="form-check form-switch me-3">
                                                    <input type="hidden" asp-for="@Model.Claims[i].Value" />
                                                    <input type="checkbox" asp-for="@Model.Claims[i].IsSelected"
                                                           class="form-check-input border-2" style="cursor:pointer; width: 2.5em; height: 1.25em;">
                                                </div>
                                                <div>
                                                    <label class="fw-bold d-block mb-0">@Model.Claims[i].DisplayName</label>
                                                    <span class="x-small text-muted">@Model.Claims[i].Value</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="card-footer bg-white p-4 d-flex justify-content-end gap-2 border-top">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Volver</a>
                <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow">
                    Guardar Permisos <i class="fa-solid fa-save ms-2"></i>
                </button>
            </div>
        </form>
    </div>
</div>