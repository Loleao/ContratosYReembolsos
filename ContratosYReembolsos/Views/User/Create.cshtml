@using ContratosYReembolsos.Models.ViewModels.Users
@model RegisterUserViewModel

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h4 class="fw-bold mb-0 text-primary">
                        <i class="fa-solid fa-user-shield me-2"></i>Nuevo Trabajador FONAFUN
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @* Resumen de errores general *@
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small mb-3"></div>

                        <div class="row g-3">
                            @* DNI *@
                            <div class="col-md-6">
                                <label class="form-label fw-bold small"><i class="fa-solid fa-id-card me-1"></i>DNI (Usuario)</label>
                                <input asp-for="DNI" class="form-control rounded-3" placeholder="8 dígitos" maxlength="8" />
                                <span asp-validation-for="DNI" class="text-danger small"></span>
                            </div>

                            @* Nombre *@
                            <div class="col-md-6">
                                <label class="form-label fw-bold small"><i class="fa-solid fa-signature me-1"></i>Nombre Completo</label>
                                <input asp-for="FullName" class="form-control rounded-3" placeholder="Nombres y Apellidos" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            @* Email *@
                            <div class="col-md-12">
                                <label class="form-label fw-bold small"><i class="fa-solid fa-envelope me-1"></i>Correo Institucional</label>
                                <input asp-for="Email" class="form-control rounded-3" placeholder="ejemplo@fonafun.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            @* Filial *@
                            <div class="col-md-12">
                                <label class="form-label fw-bold text-primary small"><i class="fa-solid fa-building-flag me-1"></i>Filial Asignada</label>
                                <select asp-for="BranchId" class="form-select border-primary" asp-items="Model.Branches">
                                    <option value="">-- ACCESO GLOBAL (Sede Central) --</option>
                                </select>
                                <div class="form-text text-muted" style="font-size: 11px;">Restringe el acceso del usuario a esta sede.</div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small"><i class="fa-solid fa-key me-1"></i>Contraseña</label>
                                <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="Mín. 6 caracteres" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            @* Confirm Password (EL QUE FALTABA) *@
                            <div class="col-md-6">
                                <label class="form-label fw-bold small"><i class="fa-solid fa-check-double me-1"></i>Confirmar Contraseña</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control rounded-3" placeholder="Repita la clave" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 me-2 text-uppercase fw-bold small">Cancelar</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 shadow">
                                <i class="fa-solid fa-save me-1"></i> Registrar Trabajador
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}